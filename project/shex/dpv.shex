# metamodel_version: 1.11.0
# version: 2.3
BASE <https://github.com/lmodel/dpv/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX linkml: <https://w3id.org/linkml/>


<String> xsd:string

<Integer> xsd:integer

<Boolean> xsd:boolean

<Float> xsd:float

<Double> xsd:double

<Decimal> xsd:decimal

<Time> xsd:time

<Date> xsd:date

<Datetime> xsd:dateTime

<DateOrDatetime> linkml:DateOrDatetime

<Uriorcurie> IRI

<Curie> xsd:string

<Uri> IRI

<Ncname> xsd:string

<Objectidentifier> IRI

<Nodeidentifier> NONLITERAL

<Jsonpointer> xsd:string

<Jsonpath> xsd:string

<Sparqlpath> xsd:string

<AcademicResearch> CLOSED {
    (  $<AcademicResearch_tes> (  &<ResearchAndDevelopment_tes> ;
          rdf:type [ <ResearchAndDevelopment> ] ? ;
          &<Purpose_tes> ;
          rdf:type [ <Purpose> ] ?
