    {
      "name": "ContextuallyAnonymisedData",
      "definition_uri": "https://w3id.org/lmodel/dpv/ContextuallyAnonymisedData",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "personal-data-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Data that can be considered as being fully anonymised within the context\nbut in actuality is not fully anonymised and is still personal data as\nit can be de-anonymised outside that context",
      "comments": [
        "To distinguish between partially anonymised data that can be effectively\ntreated as anonymised data (e.g. in processing) within a context (e.g.\nan organisation), the concept ContextuallyAnonymisedData should be used\ninstead of AnonymisedData. Transfer of this data outside of the context\nshould consider that it is not fully anonymised and that it is still\npersonal data"
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Contextually Anonymised Data"
      ],
      "mappings": [
        "dpv:ContextuallyAnonymisedData",
        "dpv:ContextuallyAnonymisedData"
      ],
      "exact_mappings": [
        "dpv_upstream:ContextuallyAnonymisedData",
        "dpv_owl:ContextuallyAnonymisedData"
      ],
      "is_a": "PseudonymisedData",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/ContextuallyAnonymisedData",
      "@type": "ClassDefinition"
    },
