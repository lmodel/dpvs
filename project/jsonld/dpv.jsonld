    {
      "name": "DataController",
      "definition_uri": "https://w3id.org/lmodel/dpv/DataController",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "entities-legalrole-classes",
          "@type": "Annotation"
        }
      ],
      "description": "The individual or organisation that decides (or controls) the purpose(s)\nof processing personal data.",
      "comments": [
        "The terms 'Controller', 'Data Controller', and 'PII Controller' refer to\nthe same concept"
      ],
      "in_subset": [
        "entities_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Data Controller"
      ],
