      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "contract-types-classes",
          "@type": "Annotation"
        }
      ],
      "description": "A contract where the terms and conditions are determined by one or more\nof the parties, and the other parties have negligible or no ability to\nnegotiate the terms and conditions",
      "comments": [
        "Such a contract results in the unempowered parties being in a \"take it\nor leave it\" position as they can only accept or reject the contract.\nStandard form contracts are also known as \"Adhesion contract\" or\n\"Boilerplate contract\""
      ],
      "in_subset": [
        "legal_basis_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
