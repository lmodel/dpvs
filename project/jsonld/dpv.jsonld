    {
      "name": "SpecialCategoryPersonalData",
      "definition_uri": "https://w3id.org/lmodel/dpv/SpecialCategoryPersonalData",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "personal-data-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Sensitive Personal Data whose use requires specific additional legal\npermission or justification",
      "comments": [
        "The term 'special category' is based on GDPR Art.9, but should not be\nconsidered as exclusive to it. DPV considers all Special Categories to\nalso be Sensitive, but whose use is either prohibited or regulated and\ntherefore requires additional legal basis for justification that is\nseparate from that for general personal data."
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Special Category Personal Data"
      ],
      "mappings": [
        "dpv:SpecialCategoryPersonalData",
