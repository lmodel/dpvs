  "classes": [
    {
      "name": "AcceptableRule",
      "definition_uri": "https://w3id.org/lmodel/dpv/AcceptableRule",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "rules-classes",
          "@type": "Annotation"
        }
      ],
      "description": "A rule that is acceptable where it is either desirable if it occurs or\nit is not unacceptable if it does",
      "comments": [
        "Acceptable is a subjective concept that enables distinguishing with\n\"unacceptable\". By itself it does not signal any permission or\nobligation - for which further specific concepts are defined"
      ],
      "in_subset": [
        "common_subset"
      ],
