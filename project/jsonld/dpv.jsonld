        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/RiskMitigationMeasure",
      "@type": "ClassDefinition"
    },
    {
      "name": "SecurityAssessment",
      "definition_uri": "https://w3id.org/lmodel/dpv/SecurityAssessment",
      "annotations": [
