      ],
      "exact_mappings": [
        "dpv_upstream:ConsentStatusInvalidForProcessing",
        "dpv_owl:ConsentStatusInvalidForProcessing"
      ],
      "is_a": "ConsentStatus",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/ConsentStatusInvalidForProcessing",
      "@type": "ClassDefinition"
    },
    {
      "name": "ConsentStatusValidForProcessing",
      "definition_uri": "https://w3id.org/lmodel/dpv/ConsentStatusValidForProcessing",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "consent-status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "States of consent that can be used as valid justifications for\nprocessing data",
      "comments": [
        "Practically, given consent is the only valid state for processing"
      ],
      "in_subset": [
        "consent_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Consent Status Valid for Processing"
      ],
      "mappings": [
        "dpv:ConsentStatusValidForProcessing",
        "dpv:ConsentStatusValidForProcessing"
      ],
      "exact_mappings": [
        "dpv_upstream:ConsentStatusValidForProcessing",
        "dpv_owl:ConsentStatusValidForProcessing"
      ],
      "is_a": "ConsentStatus",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/ConsentStatusValidForProcessing",
      "@type": "ClassDefinition"
    },
    {
      "name": "ConsentUnknown",
      "definition_uri": "https://w3id.org/lmodel/dpv/ConsentUnknown",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "consent-status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "State where information about consent is not available or is unknown",
      "comments": [
        "Consent states can be unknown, for example, when information is not\navailable, or cannot be trusted, or is known to be inaccurate"
      ],
      "in_subset": [
        "consent_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Consent Unknown"
      ],
      "mappings": [
        "dpv:ConsentUnknown",
