    {
      "name": "Purpose",
      "definition_uri": "https://w3id.org/lmodel/dpv/Purpose",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "purposes-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Purpose or (broader) Goal associated with data or technology",
      "comments": [
        "The purpose or goal here is intended to sufficiently describe the\nintention or objective of why the data or technology is being used, and\nshould be broader than mere technical descriptions of achieving a\ncapability. For example, \"Analyse Data\" is an abstract purpose with no\nindication of what the analyses is for as compared to a purpose such as\n\"Marketing\" or \"Service Provision\" which provide clarity and\ncomprehension of the 'purpose' and can be enhanced with additional\ndescriptions. Such modelling is in line with regulatory requirements\nregarding the specificity of purposes, for example in GDPR"
      ],
      "in_subset": [
        "processing_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Purpose"
      ],
      "mappings": [
        "dpv:Purpose",
        "dpv:Purpose"
      ],
      "exact_mappings": [
        "dpv_upstream:Purpose",
        "dpv_owl:Purpose"
      ],
      "related_mappings": [
        "usage_policy:AnyPurpose"
      ],
      "is_a": "DpvThing",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/Purpose",
      "@type": "ClassDefinition"
    },
