    {
      "name": "ReuseCompatibility",
      "definition_uri": "https://w3id.org/lmodel/dpv/ReuseCompatibility",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Status indicating whether the specified context is compatible with\nanother earlier context",
      "comments": [
        "Compatibility refers to whether two contexts, such as dpv:Process\ninstances, are compatible with each other based on a criteria which is\nnot defined by the concept. This criteria can be based on requirements\nfrom law, such as GDPR's purpose compatibility or can be based on\nprivacy norms such as contextual integrity. To express such\ninterpretations, further concepts should be expanded from this base\nconcept"
      ],
      "in_subset": [
        "common_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
