    {
      "name": "RiskLevel",
      "definition_uri": "https://w3id.org/lmodel/dpv/RiskLevel",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "risk-classes",
          "@type": "Annotation"
        }
      ],
      "description": "The magnitude of a risk expressed as an indication to aid in its\nmanagement",
      "comments": [
        "Risk Levels can be defined as a combination of different\ncharacteristics. For example, ISO 31073:2022 defines it as a combination\nof consequences and their likelihood. Another example would be the Risk\nMatrix where Risk Level is defined as a combination of Likelihood and\nSeverity associated with the Risk."
      ],
      "in_subset": [
        "risk_notice_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Risk Level"
      ],
      "mappings": [
        "dpv:RiskLevel",
        "dpv:RiskLevel"
      ],
      "exact_mappings": [
        "dpv_upstream:RiskLevel",
        "dpv_owl:RiskLevel"
      ],
      "is_a": "DpvThing",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/RiskLevel",
      "@type": "ClassDefinition"
    },
    {
      "name": "RiskMitigationMeasure",
      "definition_uri": "https://w3id.org/lmodel/dpv/RiskMitigationMeasure",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "risk-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Measures intended to mitigate, minimise, or prevent risk.",
      "in_subset": [
