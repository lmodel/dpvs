    {
      "name": "NegotiatedContract",
      "definition_uri": "https://w3id.org/lmodel/dpv/NegotiatedContract",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "contract-types-classes",
          "@type": "Annotation"
        }
      ],
      "description": "A contract where the terms and conditions are determined with all\nparties having the ability to negotiate the terms and conditions",
      "comments": [
        "Negotiation here refers to the opportunity for a party on their own\ninitiative to modify or dictate terms and conditions within a contract.\nIf the party is provided a set of options to choose from or in other\nways is dictated which terms and conditions can be present in the\ncontract, neither of these should be considered a negotiation"
      ],
      "in_subset": [
        "legal_basis_subset"
      ],
