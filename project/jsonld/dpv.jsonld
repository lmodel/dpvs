    {
      "name": "HumanInvolved",
      "definition_uri": "https://w3id.org/lmodel/dpv/HumanInvolved",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "processing-context-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Humans are involved in the specified context",
      "comments": [
        "This concept only indicates that humans are involved. For specific\ninvolvement, see specialised concepts e.g. involved for input,\noversight."
      ],
      "in_subset": [
        "processing_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Human involved"
      ],
      "mappings": [
        "dpv:HumanInvolved",
