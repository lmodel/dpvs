      "definition_uri": "https://w3id.org/lmodel/dpv/InverseJurisdiction",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "jurisdiction-classes",
          "@type": "Annotation"
        }
      ],
      "description": "An inverse jurisdiction for a specific jurisdiction is the set of all\nother jurisdictions that are not part of the specific jurisdiction",
      "comments": [
        "Inverse Jurisdictions are helpful when asserting and checking rules that\ninvolve a concept representing jurisdictions outside of a given\njurisdiction. An inverse jurisdiction of an inverse jurisdiction should\ngive back the same original jurisdiction but this is undefined and\nstrongly dissuaded as it could lead to recursive definitions in some\nuse-cases"
      ],
      "in_subset": [
        "legal_basis_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
