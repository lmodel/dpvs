      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "processing-context-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Level of automation corresponding to Level 6 in ISO/IEC 22989:2022 where\nthe automation in system is capable of modifying its operation domain or\nits goals without external intervention, control or oversight",
      "comments": [
        "Though Autonomous, such operations can still be associated with\ndpv:HumanInvolved e.g. for inputs, oversight or verification"
      ],
      "in_subset": [
        "processing_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
