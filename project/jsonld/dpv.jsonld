    {
      "name": "IdentifyingPersonalData",
      "definition_uri": "https://w3id.org/lmodel/dpv/IdentifyingPersonalData",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "personal-data-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Personal Data that explicitly and by itself is sufficient to identify a\nperson",
      "comments": [
        "DPV does not use PII ('Personally Identifiable Information') as it has\nvarying and conflicting definitions across sources. Instead the concept\n'identifying personal data' is intended to provide a clear\ncategorisation of its interpretation. Where multiple data categories can\nbe combined to create an 'identifying' category e.g. fingerprinting,\nthis concept represents the combined category."
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Identifying Personal Data"
      ],
      "mappings": [
        "dpv:IdentifyingPersonalData",
        "dpv:IdentifyingPersonalData"
      ],
