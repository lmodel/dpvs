    {
      "name": "Applicability",
      "definition_uri": "https://w3id.org/lmodel/dpv/Applicability",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "context-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Concept provided to represent indication of cases where the information\nor context is not applicable (N/A) or not available or this is not known\nor determined yet. If the information is applicable and available, this\nconcept should not be used.",
      "comments": [
        "These concepts are useful in closed-world interpretations, for example\nin forms where a field must have a value to explicitly denote it is not\napplicable or the information is not available yet."
      ],
      "in_subset": [
        "common_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
