        "dpv_upstream:Anonymisation",
        "dpv_owl:Anonymisation"
      ],
      "is_a": "Deidentification",
      "mixins": [
        "TechnicalMeasure"
      ],
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/Anonymisation",
      "@type": "ClassDefinition"
    },
    {
      "name": "AnonymisedData",
      "definition_uri": "https://w3id.org/lmodel/dpv/AnonymisedData",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "personal-data-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Personal Data that has been (fully and completely) anonymised so that it\nis no longer considered Personal Data",
      "comments": [
        "It is advised to carefully consider indicating data is fully or\ncompletely anonymised by determining whether the data by itself or in\ncombination with other data can identify a person. Failing this\ncondition, the data should be denoted as PseudonymisedData. To indicate\ndata is anonymised only for a specified entity (e.g. within an\norganisation), the concept ContextuallyAnonymisedData (as subclass of\nPseudonymisedData) should be used instead of AnonymisedData."
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Anonymised Data"
      ],
      "mappings": [
        "dpv:AnonymisedData",
        "dpv:AnonymisedData"
      ],
      "exact_mappings": [
        "dpv_upstream:AnonymisedData",
        "dpv_owl:AnonymisedData"
      ],
      "is_a": "NonPersonalData",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/AnonymisedData",
      "@type": "ClassDefinition"
    },
