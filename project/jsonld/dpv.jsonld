    {
      "name": "PermissionManagement",
      "definition_uri": "https://w3id.org/lmodel/dpv/PermissionManagement",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "organisational-measures-classes",
          "@type": "Annotation"
        },
        {
          "tag": "dct_source",
          "value": "DGA 12.n",
          "@type": "Annotation"
        }
      ],
      "description": "Methods to obtain, provide, modify, and withdraw permissions along with\nmaintaining a record of permissions, retrieving records, and processing\nchanges in permission states",
      "comments": [
        "Permission is a broader concept than '(Informed) Consent' as consent\nwhen used as a legal basis has specific requirements to be valid. For\nmanagement of consent, see the concept dpv:ConsentManagement"
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
