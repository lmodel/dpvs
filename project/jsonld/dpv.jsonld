    {
      "name": "HumanInvolvement",
      "definition_uri": "https://w3id.org/lmodel/dpv/HumanInvolvement",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "processing-context-classes",
          "@type": "Annotation"
        }
      ],
      "description": "The involvement of humans in specified context",
      "comments": [
        "Human Involvement here broadly refers to any involvement by a human in\nthe context of carrying out processing. This may include verification of\noutcomes, providing input data for making decisions, or overseeing\nactivities. To indicate whether humans are involved or not, see relevant\nconcepts of dpv:HumanInvolved and dpv:HumanNotInvolved. The term 'Human\nin the loop' and its varieties are absent from DPV due to their\ncontradictory and non-compatible use across different sources."
      ],
      "in_subset": [
        "processing_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Human Involvement"
      ],
      "mappings": [
        "dpv:HumanInvolvement",
        "dpv:HumanInvolvement"
      ],
      "exact_mappings": [
        "dpv_upstream:HumanInvolvement",
        "dpv_owl:HumanInvolvement"
      ],
      "is_a": "EntityInvolvement",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/HumanInvolvement",
      "@type": "ClassDefinition"
    },
    {
      "name": "HumanInvolvementForControl",
      "definition_uri": "https://w3id.org/lmodel/dpv/HumanInvolvementForControl",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "processing-context-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Human involvement for the purposes of exercising control over the\nspecified operations in context",
      "comments": [
        "Control is a broad term that can be applied to various stages and\noperations. It maps to None, Assistive, and Partial automation models."
      ],
      "in_subset": [
        "processing_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Human Involvement for control"
      ],
      "mappings": [
        "dpv:HumanInvolvementForControl",
        "dpv:HumanInvolvementForControl"
      ],
      "exact_mappings": [
        "dpv_upstream:HumanInvolvementForControl",
        "dpv_owl:HumanInvolvementForControl"
      ],
      "is_a": "HumanInvolvement",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/HumanInvolvementForControl",
      "@type": "ClassDefinition"
    },
    {
      "name": "HumanInvolvementForDecision",
      "definition_uri": "https://w3id.org/lmodel/dpv/HumanInvolvementForDecision",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "processing-context-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Human involvement for the purposes of exercising decisions over the\nspecified operations in context",
      "comments": [
        "Decisions are about exercising control over the operation, and are\ndistinct from input (data or parameters)."
      ],
      "in_subset": [
        "processing_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
