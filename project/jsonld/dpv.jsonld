    {
      "name": "AuditConditionallyApproved",
      "definition_uri": "https://w3id.org/lmodel/dpv/AuditConditionallyApproved",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "State of being conditionally approved through the audit",
      "comments": [
        "A \"conditional approval\" is intended to reflect states where the audit\nhas identified further changes which must be implemented before\nconsidering the audit has been 'passed', without requiring another audit\nto validate them. This is distinct from the case where an audit has\nstate 'rejected', which means changes must be made and submitted for\nreview. The requirements of a 'conditional acceptance' are expected to\nbe minor or not significant enough to warrant another audit to review\nthem."
      ],
      "in_subset": [
        "common_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Audit Conditionally Approved"
      ],
      "mappings": [
        "dpv:AuditConditionallyApproved",
        "dpv:AuditConditionallyApproved"
      ],
      "exact_mappings": [
        "dpv_upstream:AuditConditionallyApproved",
        "dpv_owl:AuditConditionallyApproved"
      ],
