        "dpv_owl:DataController",
        "iso29100:PIIController"
      ],
      "related_mappings": [
        "common_domain_model:Counterparty",
        "iso22989:AIProvider",
        "iso27001:Organization",
        "nist_ai_rmf:AiActor",
        "oscal:ResponsibleParty"
      ],
      "is_a": "LegalEntity",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/DataController",
      "@type": "ClassDefinition"
    },
    {
      "name": "DataExporter",
      "definition_uri": "https://w3id.org/lmodel/dpv/DataExporter",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "entities-legalrole-classes",
          "@type": "Annotation"
        }
      ],
      "description": "An entity that 'exports' data where exporting is considered a form of\ndata transfer",
      "comments": [
        "The term 'Data Exporter' is used by the EU-EDPB as the entity that\ntransfer data across borders. While the EDPB refers to the\njurisdictional border of EU, the term within DPV can be used to denote\nany 'export' or transfer or transmission of data and is thus a broader\nconcept than the EDPB's definition."
      ],
      "in_subset": [
        "entities_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Data Exporter"
      ],
      "mappings": [
        "dpv:DataExporter",
        "dpv:DataExporter"
      ],
      "exact_mappings": [
        "dpv_upstream:DataExporter",
        "dpv_owl:DataExporter"
      ],
      "is_a": "LegalEntity",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/DataExporter",
      "@type": "ClassDefinition"
    },
    {
      "name": "DataImporter",
      "definition_uri": "https://w3id.org/lmodel/dpv/DataImporter",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "entities-legalrole-classes",
          "@type": "Annotation"
        }
      ],
      "description": "An entity that 'imports' data where importing is considered a form of\ndata transfer",
      "comments": [
        "The term 'Data Importer' is used by the EU-EDPB as the entity that\nreceives transferred data across borders. While the EDPB refers to the\njurisdictional border of EU, the term within DPV can be used to denote\nany 'import' or reception of transfer or transmission of data and is\nthus a broader concept than the EDPB's definition."
      ],
      "in_subset": [
        "entities_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Data Importer"
      ],
      "mappings": [
        "dpv:DataImporter",
        "dpv:DataImporter"
      ],
      "exact_mappings": [
        "dpv_upstream:DataImporter",
        "dpv_owl:DataImporter"
      ],
      "is_a": "DpvRecipient",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/DataImporter",
      "@type": "ClassDefinition"
    },
    {
      "name": "DataProcessor",
      "definition_uri": "https://w3id.org/lmodel/dpv/DataProcessor",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "entities-legalrole-classes",
          "@type": "Annotation"
