    {
      "name": "LegalCompliance",
      "definition_uri": "https://w3id.org/lmodel/dpv/LegalCompliance",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "purposes-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Purposes associated with carrying out data processing to fulfill a legal\nor statutory obligation",
      "comments": [
        "This purpose only refers to processing that is additionally required in\norder to fulfill the obligations and requirements associated with a law.\nFor example, the use of consent would have its own separate purposes,\nwith this purpose addressing a legal requirement for maintaining consent\nrecord (along with RecordManagement). This purpose will typically be\nused with Legal Obligation as the legal basis."
      ],
      "in_subset": [
        "processing_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
