      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/UncategorisedData",
      "@type": "ClassDefinition"
    },
    {
      "name": "UnstructuredData",
      "definition_uri": "https://w3id.org/lmodel/dpv/UnstructuredData",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "personal-data-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Data that is without a predefined data model or is not organised in a\npre-defined manner",
      "comments": [
        "This concept is relevant to application of privacy/data protection\nregulations like GDPR as unstructured data may contain PII/personal data\nand it is useful to flag such data with unknown or incomplete modelling\ninformation for audits. It is also useful to flag data for potential\nquality issues"
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
