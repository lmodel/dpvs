          "value": "personal-data-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Data whose categorisation is not known e.g. whether it is personal or\nnon-personal data",
      "comments": [
        "This concept is intended for indicating that a legally relevant\ncategorisation of data has not been made - specifically regarding\nwhether it is personal data or not, but it can also be extended for\nother categorisations such as sensitive data or domain-specific\nconfidential data"
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Uncategorised Data"
      ],
      "mappings": [
