      "name": "Anonymisation",
      "definition_uri": "https://w3id.org/lmodel/dpv/Anonymisation",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "technical-measures-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Anonymisation is the process by which data is irreversibly altered in\nsuch a way that a data subject can no longer be identified directly or\nindirectly, either by the entity holding the data alone or in\ncollaboration with other entities and information sources",
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Anonymisation"
      ],
