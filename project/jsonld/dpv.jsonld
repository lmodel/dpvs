    {
      "name": "NotAvailable",
      "definition_uri": "https://w3id.org/lmodel/dpv/NotAvailable",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "context-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Concept indicating the information or context is applicable but\ninformation is not yet available",
      "comments": [
        "This concept is useful when describing situations where information is\nrequired but is not available (yet). For example, if in a form a field\nasks about whether a process X was completed, and it is correct to\ninterpret that process X is applicable and must be completed, but the\ninformation is not yet available as to whether this was done - then\nNotAvailable is useful to represent this."
      ],
      "in_subset": [
        "common_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
