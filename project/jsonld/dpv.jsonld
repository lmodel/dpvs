    {
      "name": "RenewedConsentGiven",
      "definition_uri": "https://w3id.org/lmodel/dpv/RenewedConsentGiven",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "consent-status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "The state where a previously given consent has been 'renewed' or\n'refreshed' or 'reaffirmed' to form a new instance of given consent",
      "comments": [
        "An example of this state is when a previously given consent has expired,\nand the individual is presented a notice regarding continuing associated\nprocessing operations - to which they agree. This state can be useful to\nkeep track of 'reconfirmed' or 'refreshed' consent within consent\nrecords, assist notices and contextual agents to create better\nconsenting dialogues, and assist with specific legal obligations related\nto subsequent consenting"
      ],
      "in_subset": [
        "consent_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Renewed Consent Given"
      ],
