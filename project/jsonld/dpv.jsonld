      "class_uri": "https://w3id.org/lmodel/dpv/PermissionManagement",
      "@type": "ClassDefinition"
    },
    {
      "name": "PersonalData",
      "definition_uri": "https://w3id.org/lmodel/dpv/PersonalData",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "personal-data-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Data directly or indirectly associated or related to an individual",
      "comments": [
        "This definition of personal data encompasses the concepts used in GDPR\nArt.4-1 for 'personal data' and ISO/IEC 2700 for 'personally\nidentifiable information (PII)'."
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Personal Data"
      ],
      "mappings": [
        "dpv:PersonalData",
        "dpv:PersonalData"
      ],
      "exact_mappings": [
        "dpv_upstream:PersonalData",
        "dpv_owl:PersonalData"
      ],
      "close_mappings": [
        "iso29100:PersonallyIdentifiableInformation"
      ],
      "related_mappings": [
        "usage_policy:AnyData"
      ],
      "narrow_mappings": [
        "iso27001:Asset"
      ],
      "is_a": "DpvData",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/PersonalData",
      "@type": "ClassDefinition"
    },
    {
      "name": "PersonalDataAudit",
      "definition_uri": "https://w3id.org/lmodel/dpv/PersonalDataAudit",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "organisational-measures-classes",
          "@type": "Annotation"
        }
      ],
      "description": "An audit that systematically examines the existence and use of personal\ndata along with its associated resources (e.g. where it is stored) and\nflows (e.g. where it originates and with whom it is being shared)",
      "comments": [
        "This concept is the same as \"Data Mapping\" and \"Data Flow Mapping\nExercise\" used by the Information Commissioner's Office as \"to document\nthe data that flows in, around, and out of information processing\nsystems or services\""
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Personal Data Audit"
      ],
      "mappings": [
        "dpv:PersonalDataAudit",
        "dpv:PersonalDataAudit"
      ],
      "exact_mappings": [
        "dpv_upstream:PersonalDataAudit",
        "dpv_owl:PersonalDataAudit"
      ],
      "is_a": "InformationAudit",
