    {
      "name": "RiskConcept",
      "definition_uri": "https://w3id.org/lmodel/dpv/RiskConcept",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "risk-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Parent concept for combining concepts associated with risk assessment\nsuch as actual and potential Risk, Risk Source, Consequences, and\nImpacts",
      "comments": [
        "RiskConcept is a generic concept used for creation of specific\ntaxonomies in the RISK extension to provide guidance on how a concept\ncan potentially be a risk, risk source, consequence, and impact. It is\nnot intended to be used directly and is only created for organisation of\nconcepts in DPV vocabularies"
      ],
      "in_subset": [
        "risk_notice_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
