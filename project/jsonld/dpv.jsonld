      "name": "DpvThing",
      "definition_uri": "https://w3id.org/lmodel/dpv/DpvThing",
      "description": "Abstract base class for every DPV entity. Provides a uniform ``id``\nidentifier slot. Does NOT enumerate DPV properties: the upstream OWL\ndeclares no ``rdfs:domain`` triples, so any DPV property is semantically\napplicable to any DPV class (open-world). Generators that need a\nclosed-world property list per class should consume the W3C DPV OWL\nrelease directly rather than this LinkML projection.",
      "in_subset": [
        "common_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
