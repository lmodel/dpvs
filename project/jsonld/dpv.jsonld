    {
      "name": "HumanOversight",
      "definition_uri": "https://w3id.org/lmodel/dpv/HumanOversight",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "organisational-measures-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Procedures related to implementing and ensuring human oversight, which\nincludes ability for humans to oversee, understand, control, and reverse\nprocesses, and to have sufficient monitoring capability to detect and\naddress anomalies, dysfunctions, or unexpected performance",
      "comments": [
        "DPV also provides a taxonomy for 'Entity Involvement' including specific\nforms of 'Human Involvement' which allow expressing the roles of humans\nin specific capacities such as oversight, controls, and whether they\nhave the ability to do something or don't. The Human Oversight as an\norganisational measure represents the overall plans and procedures for\nimplementation of such human involvement"
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Human Oversight"
      ],
