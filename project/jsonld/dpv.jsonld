    {
      "name": "SensitivePersonalData",
      "definition_uri": "https://w3id.org/lmodel/dpv/SensitivePersonalData",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "personal-data-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Personal data that is considered 'sensitive' in terms of privacy and/or\nimpact, and therefore requires additional considerations and/or\nprotection",
      "comments": [
        "Sensitivity' is a matter of context, and may be defined within legal\nframeworks. For GDPR, Special categories of personal data are considered\na subset of sensitive data. To illustrate the difference between the\ntwo, consider the situation where Location data is collected, and which\nis considered 'sensitive' but not 'special'. As a probable rule,\nsensitive data require additional considerations whereas special\ncategory data requires additional legal basis / justifications."
      ],
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Sensitive Personal Data"
      ],
      "mappings": [
        "dpv:SensitivePersonalData",
        "dpv:SensitivePersonalData"
      ],
      "exact_mappings": [
        "dpv_upstream:SensitivePersonalData",
        "dpv_owl:SensitivePersonalData"
      ],
      "is_a": "PersonalData",
      "mixins": [
        "SensitiveData"
      ],
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/SensitivePersonalData",
      "@type": "ClassDefinition"
    },
