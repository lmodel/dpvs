      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "processing-context-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Human involvement for the purposes of having oversight over the\nspecified context regarding its operations, inputs, or outputs",
      "comments": [
        "Oversight by itself does not indicate the ability to intervene or\ncontrol the operations."
      ],
      "in_subset": [
