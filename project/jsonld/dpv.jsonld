    {
      "name": "Pseudonymisation",
      "definition_uri": "https://w3id.org/lmodel/dpv/Pseudonymisation",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "technical-measures-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Pseudonymisation means the processing of personal data in such a manner\nthat the personal data can no longer be attributed to a specific data\nsubject without the use of additional information, provided that such\nadditional information is kept separately and is subject to technical\nand organisational measures to ensure that the personal data are not\nattributed to an identified or identifiable natural person;",
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Pseudonymisation"
      ],
      "mappings": [
        "dpv:Pseudonymisation",
        "dpv:Pseudonymisation"
      ],
      "exact_mappings": [
        "dpv_upstream:Pseudonymisation",
        "dpv_owl:Pseudonymisation"
      ],
      "is_a": "Deidentification",
      "mixins": [
        "TechnicalMeasure"
      ],
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/Pseudonymisation",
      "@type": "ClassDefinition"
    },
    {
      "name": "PseudonymisedData",
      "definition_uri": "https://w3id.org/lmodel/dpv/PseudonymisedData",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "personal-data-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Pseudonymised Data is data that has gone a partial or incomplete\nanonymisation process by replacing the identifiable information with\nartificial identifiers or 'pseudonyms', and is still considered as\npersonal data",
      "in_subset": [
        "personal_data_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Pseudonymised Data"
      ],
      "mappings": [
        "dpv:PseudonymisedData",
        "dpv:PseudonymisedData"
      ],
      "exact_mappings": [
        "dpv_upstream:PseudonymisedData",
        "dpv_owl:PseudonymisedData"
      ],
      "is_a": "PersonalData",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/PseudonymisedData",
      "@type": "ClassDefinition"
    },
