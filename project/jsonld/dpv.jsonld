      "class_uri": "https://w3id.org/lmodel/dpv/ConsentInvalidated",
      "@type": "ClassDefinition"
    },
    {
      "name": "ConsentRefused",
      "definition_uri": "https://w3id.org/lmodel/dpv/ConsentRefused",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "consent-status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "The state where consent has been refused",
      "comments": [
        "An example of this state is when the individual clicks on a 'disagree'\nor 'reject' or 'refuse' button, or leaves a checkbox unticked"
      ],
      "in_subset": [
        "consent_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Consent Refused"
      ],
      "mappings": [
        "dpv:ConsentRefused",
        "dpv:ConsentRefused"
      ],
      "exact_mappings": [
        "dpv_upstream:ConsentRefused",
        "dpv_owl:ConsentRefused"
      ],
      "is_a": "ConsentStatusInvalidForProcessing",
      "mixins": [
        "ConsentStatus"
      ],
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/ConsentRefused",
      "@type": "ClassDefinition"
    },
    {
      "name": "ConsentRequestDeferred",
      "definition_uri": "https://w3id.org/lmodel/dpv/ConsentRequestDeferred",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "consent-status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "State where a request for consent has been deferred without a decision",
      "comments": [
        "An example of this state is when the individual closes or dismisses a\nnotice without making a decision. This state is intended for making the\ndistinction between a notice being provided (as a consent request) and\nthe individual interacting with the notice without making a decision -\nwhere the 'ignoring of a notice' is taken as consent being neither given\nnor refused"
      ],
      "in_subset": [
        "consent_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Consent Request Deferred"
      ],
      "mappings": [
        "dpv:ConsentRequestDeferred",
        "dpv:ConsentRequestDeferred"
      ],
      "exact_mappings": [
        "dpv_upstream:ConsentRequestDeferred",
        "dpv_owl:ConsentRequestDeferred"
      ],
      "is_a": "ConsentStatusInvalidForProcessing",
      "mixins": [
        "ConsentStatus"
      ],
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/ConsentRequestDeferred",
      "@type": "ClassDefinition"
    },
    {
      "name": "ConsentRequested",
      "definition_uri": "https://w3id.org/lmodel/dpv/ConsentRequested",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "consent-status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "State where a request for consent has been made and is awaiting a\ndecision",
      "comments": [
        "An example of this state is when a notice has been presented to the\nindividual but they have not made a decision"
      ],
      "in_subset": [
        "consent_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Consent Requested"
      ],
      "mappings": [
        "dpv:ConsentRequested",
        "dpv:ConsentRequested"
      ],
      "exact_mappings": [
        "dpv_upstream:ConsentRequested",
        "dpv_owl:ConsentRequested"
      ],
      "is_a": "ConsentStatusInvalidForProcessing",
      "mixins": [
        "ConsentStatus"
      ],
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/ConsentRequested",
      "@type": "ClassDefinition"
    },
    {
      "name": "ConsentRevoked",
      "definition_uri": "https://w3id.org/lmodel/dpv/ConsentRevoked",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "consent-status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "The state where the consent is revoked by an entity other than the data\nsubject and which prevents it from being further used as a valid state",
      "comments": [
        "An example of this state is when a Data Controller stops utilising\npreviously obtaining consent, such as when that service no longer exists"
      ],
      "in_subset": [
        "consent_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Consent Revoked"
      ],
      "mappings": [
        "dpv:ConsentRevoked",
        "dpv:ConsentRevoked"
      ],
      "exact_mappings": [
        "dpv_upstream:ConsentRevoked",
        "dpv_owl:ConsentRevoked"
      ],
      "is_a": "ConsentStatusInvalidForProcessing",
      "mixins": [
        "ConsentStatus"
      ],
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/ConsentRevoked",
      "@type": "ClassDefinition"
    },
    {
      "name": "ConsentStatus",
      "definition_uri": "https://w3id.org/lmodel/dpv/ConsentStatus",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "consent-status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "The state or status of 'consent' that provides information reflecting\nits operational status and validity for processing data",
      "comments": [
        "States are useful as information artefacts to implement them in\ncontrolling processing, and to reflect the process and flow of obtaining\nand maintaining consent. For example, a database table that stores\nconsent states for specific processing and can be queried to obtain them\nin an efficient manner. States are also useful in investigations to\ndetermine the use and validity of consenting practices"
      ],
      "in_subset": [
        "consent_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Consent Status"
      ],
      "mappings": [
        "dpv:ConsentStatus",
        "dpv:ConsentStatus"
      ],
      "exact_mappings": [
        "dpv_upstream:ConsentStatus",
        "dpv_owl:ConsentStatus"
      ],
      "is_a": "Status",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/ConsentStatus",
      "@type": "ClassDefinition"
    },
    {
      "name": "ConsentStatusInvalidForProcessing",
      "definition_uri": "https://w3id.org/lmodel/dpv/ConsentStatusInvalidForProcessing",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "consent-status-classes",
          "@type": "Annotation"
        }
      ],
      "description": "States of consent that cannot be used as valid justifications for\nprocessing data",
      "comments": [
        "This identifies the stages associated with consent that should not be\nused to process data"
      ],
      "in_subset": [
        "consent_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Consent Status Invalid for Processing"
      ],
      "mappings": [
        "dpv:ConsentStatusInvalidForProcessing",
