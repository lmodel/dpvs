    {
      "name": "is_outside_of_location",
      "definition_uri": "https://w3id.org/lmodel/dpv/is_outside_of_location",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "jurisdiction-properties",
          "@type": "Annotation"
        }
      ],
      "description": "Indicates the interpretation where the location being referenced is\noutside of the indicated concept",
      "comments": [
        "This property is helpful for cases where a distinction needs to be made\nbetween inside/outside of a concept, and the area outside of that\nconcept is to be referenced. For example, using Home with\ndpv:hasLocation means inside the Home, and using this property along\nwith Home means outside of Home - such as the yard or porch"
      ],
      "in_subset": [
        "legal_basis_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
