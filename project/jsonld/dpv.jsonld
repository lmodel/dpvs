    {
      "name": "UnknownApplicability",
      "definition_uri": "https://w3id.org/lmodel/dpv/UnknownApplicability",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "context-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Concept indicating information or context availability is unknown i.e.\nit is not known if the information exists or is applicable and therefore\nstatements about its availability cannot be made (yet)",
      "comments": [
        "This concept is useful when describing situations where it cannot be\nstated whether the context applies or whether the information is not\navailable yet. For example, if a form field asks about whether a process\nX was completed and it is not yet known whether X applies or not and\ntherefore it is also unclear whether X was completed or not. Using\nUnknownApplicability is a signal that the applicability of X should be\nassessed, and if applicable, then information about X should be\nidentified and used here."
      ],
      "in_subset": [
        "common_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Unknown Applicability"
      ],
      "mappings": [
        "dpv:UnknownApplicability",
        "dpv:UnknownApplicability"
      ],
      "exact_mappings": [
        "dpv_upstream:UnknownApplicability",
        "dpv_owl:UnknownApplicability"
      ],
      "is_a": "Applicability",
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/UnknownApplicability",
      "@type": "ClassDefinition"
    },
