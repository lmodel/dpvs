    {
      "name": "Child",
      "definition_uri": "https://w3id.org/lmodel/dpv/Child",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "entities-datasubject-classes",
          "@type": "Annotation"
        }
      ],
      "description": "A 'child' is a natural legal person who is below a certain legal age\ndepending on the legal jurisdiction.",
      "comments": [
        "The legality of age defining a child varies by jurisdiction. In\naddition, 'child' is distinct from a 'minor'. For example, the legal age\nfor consumption of alcohol can be 21, which makes a person of age 20 a\n'minor' in this context. In other cases, 'minor' and 'child' are used\ninterchangeably to refer to a person below some legally defined age."
      ],
      "in_subset": [
        "entities_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/dpv",
      "aliases": [
        "Child"
      ],
      "mappings": [
        "dpv:Child",
        "dpv:Child"
      ],
      "exact_mappings": [
        "dpv_upstream:Child",
        "dpv_owl:Child"
      ],
      "is_a": "VulnerableHuman",
      "mixins": [
        "HumanSubject"
      ],
      "slots": [
        "id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/dpv/Child",
      "@type": "ClassDefinition"
    },
