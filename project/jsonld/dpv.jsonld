      "name": "FullAutomation",
      "definition_uri": "https://w3id.org/lmodel/dpv/FullAutomation",
      "annotations": [
        {
          "tag": "skos_in_scheme",
          "value": "processing-context-classes",
          "@type": "Annotation"
        }
      ],
      "description": "Level of automation corresponding to Level 5 in ISO/IEC 22989:2022 where\nthe automation in system is capable of performing all its tasks\nregardless of the conditions without human involvement",
      "comments": [
        "Though Fully Automated such operations can still be associated with\ndpv:HumanInvolved e.g. for inputs, oversight or verification"
      ],
      "in_subset": [
        "processing_subset"
