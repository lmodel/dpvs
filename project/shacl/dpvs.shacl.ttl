            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path dpvs:id ] ;
    sh:targetClass dpvs:Anonymisation .

dpvs:Anonymise a sh:NodeShape ;
    rdfs:comment """to irreversibly alter personal data in such a way that an unique data
