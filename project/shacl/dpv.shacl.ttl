dpv:AIGovernance a sh:NodeShape ;
    rdfs:comment """Procedures related to governance of AI, including its procurement,
development, deployment, and assessments""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description """Stable identifier for the instance. Typically a CURIE or IRI naming the
RDF subject this LinkML instance corresponds to.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path dpv:id ] ;
    sh:targetClass dpv:AIGovernance .

