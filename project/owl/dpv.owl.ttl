dpv:Display a owl:Class ;
    rdfs:label "Display" ;
    rdfs:subClassOf dpv:Disclose,
        dpv:Processing ;
    skos:altLabel "Display" ;
    skos:definition "to present or show data" ;
    skos:exactMatch dpv:Display,
        dpv_upstream:Display,
        dpv_owl:Display ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.20" ;
    dpv:skos_in_scheme "processing-classes" .

dpv:DisputeManagement a owl:Class ;
    rdfs:label "DisputeManagement" ;
    rdfs:subClassOf dpv:OrganisationGovernance,
        dpv:Purpose ;
    skos:altLabel "Dispute Management" ;
    skos:definition """Purposes associated with activities that manage disputes by natural
persons, private bodies, or public authorities relevant to organisation""" ;
    skos:exactMatch dpv:DisputeManagement,
        dpv_upstream:DisputeManagement,
        dpv_owl:DisputeManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Disseminate a owl:Class ;
    rdfs:label "Disseminate" ;
    rdfs:subClassOf dpv:Disclose,
        dpv:Processing ;
    skos:altLabel "Disseminate" ;
    skos:definition "to spread data throughout" ;
    skos:exactMatch dpv:Disseminate,
        dpv_upstream:Disseminate,
        dpv_owl:Disseminate ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:DistributedSystemSecurity a owl:Class ;
    rdfs:label "DistributedSystemSecurity" ;
    rdfs:subClassOf dpv:SecurityMethod,
        dpv:TechnicalMeasure ;
    skos:altLabel "Distributed System Security" ;
    skos:definition "Security implementations provided using or over a distributed system" ;
    skos:exactMatch dpv:DistributedSystemSecurity,
        dpv_upstream:DistributedSystemSecurity,
        dpv_owl:DistributedSystemSecurity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
