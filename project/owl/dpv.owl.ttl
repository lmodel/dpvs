agreement, such as for entering into a contract""" ;
    skos:exactMatch dpv:EstablishContractualAgreement,
        dpv_upstream:EstablishContractualAgreement,
        dpv_owl:EstablishContractualAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:EvaluationOfIndividuals a owl:Class ;
    rdfs:label "EvaluationOfIndividuals" ;
    rdfs:subClassOf dpv:EvaluationScoring ;
    skos:altLabel "Evaluation of Individuals" ;
    skos:definition "Processing that involves evaluation of individuals" ;
    skos:exactMatch dpv:EvaluationOfIndividuals,
        dpv_upstream:EvaluationOfIndividuals,
        dpv_owl:EvaluationOfIndividuals ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:Expected a owl:Class ;
    rdfs:label "Expected" ;
    rdfs:subClassOf dpv:ExpectationStatus ;
    skos:altLabel "Expected" ;
    skos:definition "Status indicating the specified context was expected" ;
    skos:exactMatch dpv:Expected,
        dpv_upstream:Expected,
        dpv_owl:Expected ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ExplicitlyExpressedConsent a owl:Class ;
    rdfs:label "ExplicitlyExpressedConsent" ;
    rdfs:subClassOf dpv:ExpressedConsent,
        dpv:LegalBasis ;
    skos:altLabel "Explicitly Expressed Consent" ;
    skos:definition """Consent that is expressed through an explicit action solely conveying a
consenting decision""" ;
    skos:exactMatch dpv:ExplicitlyExpressedConsent,
        dpv_upstream:ExplicitlyExpressedConsent,
        dpv_owl:ExplicitlyExpressedConsent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Explicitly expressed consent is a more specific form of Expressed
consent where the action taken must 'explicitly' relate to only the
consent decision. Expressed consent where the consenting is part of
other matters therefore cannot satisfy the requirements of explicitly
expressed consent. An example of explicit action expressing the
consenting decision is a button on a web form where the form only
relates to consent, or it is accompanied with suitable text that
reiterates what the consenting decision is about""" ;
    dpv:skos_in_scheme "consent-types-classes" .

dpv:Export a owl:Class ;
    rdfs:label "Export" ;
    rdfs:subClassOf dpv:Disclose,
        dpv:Processing ;
    skos:altLabel "Export" ;
    skos:definition "to provide a copy of data from one system to another" ;
    skos:exactMatch dpv:Export,
        dpv_upstream:Export,
        dpv_owl:Export ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.20" ;
    dpv:skos_in_scheme "processing-classes" .

dpv:FRIA a owl:Class ;
    rdfs:label "FRIA" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RightsImpactAssessment ;
    skos:altLabel "Fundamental Rights Impact Assessment (FRIA)" ;
    skos:definition """Impact assessment which assesses the potential and actual impact on
fundamental rights occurring due to processing activities""" ;
    skos:exactMatch dpv:FRIA,
        dpv_upstream:FRIA,
        dpv_owl:FRIA ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The fundamental rights and freedoms may be those defined in law or other
norms, and may be bound to a jurisdiction - for example see EU Charter
of Fundamental Rights""" ;
    dpv:dct_source "AI Act Art.27" ;
    dpv:skos_in_scheme "risk-classes" .

