    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:EntityNotInvolved a owl:Class ;
    rdfs:label "EntityNotInvolved" ;
    rdfs:subClassOf dpv:EntityInvolvementStatus ;
    skos:altLabel "Entity Not Involved" ;
