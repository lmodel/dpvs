    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:PrivacyByDesign a owl:Class ;
    rdfs:label "PrivacyByDesign" ;
    rdfs:subClassOf dpv:GuidelinesPrinciple,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Privacy by Design" ;
    skos:definition """Practices regarding incorporating data protection and privacy in the
