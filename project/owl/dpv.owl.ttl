dpv:HumanInvolved a owl:Class ;
    rdfs:label "HumanInvolved" ;
    rdfs:subClassOf dpv:HumanInvolvement ;
    skos:altLabel "Human involved" ;
    skos:definition "Humans are involved in the specified context" ;
    skos:exactMatch dpv:HumanInvolved,
        dpv_upstream:HumanInvolved,
        dpv_owl:HumanInvolved ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept only indicates that humans are involved. For specific
involvement, see specialised concepts e.g. involved for input,
oversight.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:HumanInvolvementForControl a owl:Class ;
    rdfs:label "HumanInvolvementForControl" ;
    rdfs:subClassOf dpv:HumanInvolvement ;
    skos:altLabel "Human Involvement for control" ;
    skos:definition """Human involvement for the purposes of exercising control over the
specified operations in context""" ;
    skos:exactMatch dpv:HumanInvolvementForControl,
        dpv_upstream:HumanInvolvementForControl,
        dpv_owl:HumanInvolvementForControl ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Control is a broad term that can be applied to various stages and
operations. It maps to None, Assistive, and Partial automation models.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:HumanInvolvementForDecision a owl:Class ;
    rdfs:label "HumanInvolvementForDecision" ;
    rdfs:subClassOf dpv:HumanInvolvement ;
    skos:altLabel "Human Involvement for decision" ;
    skos:definition """Human involvement for the purposes of exercising decisions over the
specified operations in context""" ;
    skos:exactMatch dpv:HumanInvolvementForDecision,
        dpv_upstream:HumanInvolvementForDecision,
        dpv_owl:HumanInvolvementForDecision ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Decisions are about exercising control over the operation, and are
distinct from input (data or parameters).""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:HumanInvolvementForInput a owl:Class ;
    rdfs:label "HumanInvolvementForInput" ;
    rdfs:subClassOf dpv:HumanInvolvement ;
    skos:altLabel "Human Involvement for Input" ;
    skos:definition """Human involvement for the purposes of providing inputs to the specified
context""" ;
    skos:exactMatch dpv:HumanInvolvementForInput,
        dpv_upstream:HumanInvolvementForInput,
        dpv_owl:HumanInvolvementForInput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Inputs can be in the form of data or other resources." ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:HumanInvolvementForIntervention a owl:Class ;
    rdfs:label "HumanInvolvementForIntervention" ;
    rdfs:subClassOf dpv:HumanInvolvement ;
    skos:altLabel "Human Involvement for intervention" ;
    skos:definition """Human involvement for the purposes of exercising interventions over the
specified operations in context""" ;
    skos:exactMatch dpv:HumanInvolvementForIntervention,
        dpv_upstream:HumanInvolvementForIntervention,
        dpv_owl:HumanInvolvementForIntervention ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Intervention indicates the ability to intervene in operations, which can
be at various stages. It maps to Conditional and High automation models.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:HumanInvolvementForOversight a owl:Class ;
    rdfs:label "HumanInvolvementForOversight" ;
    rdfs:subClassOf dpv:HumanInvolvement ;
    skos:altLabel "Human Involvement for Oversight" ;
    skos:definition """Human involvement for the purposes of having oversight over the
specified context regarding its operations, inputs, or outputs""" ;
    skos:exactMatch dpv:HumanInvolvementForOversight,
        dpv_upstream:HumanInvolvementForOversight,
        dpv_owl:HumanInvolvementForOversight ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Oversight by itself does not indicate the ability to intervene or
control the operations.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:HumanInvolvementForVerification a owl:Class ;
    rdfs:label "HumanInvolvementForVerification" ;
    rdfs:subClassOf dpv:HumanInvolvement ;
    skos:altLabel "Human Involvement for Verification" ;
    skos:definition """Human involvement for the purposes of verification of specified context
to ensure its operations, inputs, or outputs are correct or are
acceptable.""" ;
    skos:exactMatch dpv:HumanInvolvementForVerification,
        dpv_upstream:HumanInvolvementForVerification,
        dpv_owl:HumanInvolvementForVerification ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Verification by itself does not imply ability to Control, Intervene, or
having Oversight.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:HumanNotInvolved a owl:Class ;
    rdfs:label "HumanNotInvolved" ;
    rdfs:subClassOf dpv:HumanInvolvement ;
    skos:altLabel "Human not involved" ;
    skos:definition "Humans are not involved in the specified context" ;
    skos:exactMatch dpv:HumanNotInvolved,
        dpv_upstream:HumanNotInvolved,
        dpv_owl:HumanNotInvolved ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This maps to Autonomous and Full Automation models if no humans are
involved.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:HumanOversight a owl:Class ;
    rdfs:label "HumanOversight" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Human Oversight" ;
    skos:definition """Procedures related to implementing and ensuring human oversight, which
includes ability for humans to oversee, understand, control, and reverse
processes, and to have sufficient monitoring capability to detect and
address anomalies, dysfunctions, or unexpected performance""" ;
    skos:exactMatch dpv:HumanOversight,
        dpv_upstream:HumanOversight,
        dpv_owl:HumanOversight ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """DPV also provides a taxonomy for 'Entity Involvement' including specific
forms of 'Human Involvement' which allow expressing the roles of humans
in specific capacities such as oversight, controls, and whether they
have the ability to do something or don't. The Human Oversight as an
organisational measure represents the overall plans and procedures for
implementation of such human involvement""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:IPRManagement a owl:Class ;
    rdfs:label "IPRManagement" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RightsManagement ;
    skos:altLabel "Intellectual Property Rights Management" ;
    skos:definition """Management of Intellectual Property Rights with a view to identify and
safeguard and enforce them""" ;
    skos:exactMatch dpv:IPRManagement,
        dpv_upstream:IPRManagement,
        dpv_owl:IPRManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 3.1.c" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:IdentifyingPersonalData a owl:Class ;
    rdfs:label "IdentifyingPersonalData" ;
    rdfs:subClassOf dpv:PersonalData ;
    skos:altLabel "Identifying Personal Data" ;
    skos:definition """Personal Data that explicitly and by itself is sufficient to identify a
person""" ;
    skos:exactMatch dpv:IdentifyingPersonalData,
        dpv_upstream:IdentifyingPersonalData,
        dpv_owl:IdentifyingPersonalData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """DPV does not use PII ('Personally Identifiable Information') as it has
varying and conflicting definitions across sources. Instead the concept
'identifying personal data' is intended to provide a clear
categorisation of its interpretation. Where multiple data categories can
be combined to create an 'identifying' category e.g. fingerprinting,
this concept represents the combined category.""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:IdentityAuthentication a owl:Class ;
    rdfs:label "IdentityAuthentication" ;
    rdfs:subClassOf dpv:EnforceSecurity,
        dpv:Purpose ;
    skos:altLabel "Identity Authentication" ;
    skos:definition """Purposes associated with performing authentication based on identity as
a form of security""" ;
    skos:exactMatch dpv:IdentityAuthentication,
        dpv_upstream:IdentityAuthentication,
        dpv_owl:IdentityAuthentication ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:IdentityManagementMethod a owl:Class ;
    rdfs:label "IdentityManagementMethod" ;
    rdfs:subClassOf dpv:AuthorisationProcedure,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Identity Management Method" ;
    skos:definition "Management of identity and identity-based processes" ;
    skos:exactMatch dpv:IdentityManagementMethod,
        dpv_upstream:IdentityManagementMethod,
        dpv_owl:IdentityManagementMethod ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:IdentityVerification a owl:Class ;
    rdfs:label "IdentityVerification" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:Verification ;
    skos:altLabel "Identity Verification" ;
    skos:definition """Purposes associated with verifying or authenticating identity as a form
of security""" ;
    skos:exactMatch dpv:IdentityVerification,
        dpv_upstream:IdentityVerification,
        dpv_owl:IdentityVerification ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Immigrant a owl:Class ;
    rdfs:label "Immigrant" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Immigrant" ;
    skos:definition "Humans that are immigrants (for a jurisdiction)" ;
    skos:exactMatch dpv:Immigrant,
        dpv_upstream:Immigrant,
        dpv_owl:Immigrant ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:Impact a owl:Class ;
    rdfs:label "Impact" ;
    rdfs:subClassOf dpv:Consequence ;
    skos:altLabel "Impact" ;
    skos:definition """The impact(s) possible or arising as a consequence from specified
context""" ;
    skos:exactMatch dpv:Impact,
        dpv_upstream:Impact,
        dpv_owl:Impact ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Impact is a stronger notion of consequence in terms of influence,
change, or effect on something e.g. for impact assessments""" ;
    dpv:skos_in_scheme "risk-classes" .

dpv:ImpliedConsent a owl:Class ;
    rdfs:label "ImpliedConsent" ;
    rdfs:subClassOf dpv:InformedConsent,
        dpv:LegalBasis ;
    skos:altLabel "Implied Consent" ;
    skos:definition """Consent that is implied indirectly through an action not associated
solely with conveying a consenting decision""" ;
    skos:exactMatch dpv:ImpliedConsent,
        dpv_upstream:ImpliedConsent,
        dpv_owl:ImpliedConsent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Implied consent is expected to also be Informed Consent. An example is a
CCTV notice outside a monitored area that informs the individuals that
by walking in they would be consenting to the use of camera for
surveillance.""" ;
    dpv:skos_in_scheme "consent-types-classes" .

dpv:ImproveExistingProductsAndServices a owl:Class ;
    rdfs:label "ImproveExistingProductsAndServices" ;
    rdfs:subClassOf dpv:OptimisationForController,
        dpv:Purpose ;
    skos:altLabel "Improve Existing Products and Services" ;
    skos:definition "Purposes associated with improving existing products and services" ;
    skos:exactMatch dpv:ImproveExistingProductsAndServices,
        dpv_upstream:ImproveExistingProductsAndServices,
        dpv_owl:ImproveExistingProductsAndServices ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ImproveHealthcare a owl:Class ;
    rdfs:label "ImproveHealthcare" ;
    rdfs:subClassOf dpv:PublicBenefit,
        dpv:Purpose ;
    skos:altLabel "Improve Healthcare" ;
    skos:definition """Purposes associated with improving healthcare systems such as for
personalised treatments and curing chronic diseases""" ;
    skos:exactMatch dpv:ImproveHealthcare,
        dpv_upstream:ImproveHealthcare,
        dpv_owl:ImproveHealthcare ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.16" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ImproveInternalCRMProcesses a owl:Class ;
    rdfs:label "ImproveInternalCRMProcesses" ;
    rdfs:subClassOf dpv:CustomerRelationshipManagement,
        dpv:OptimisationForController,
        dpv:Purpose ;
    skos:altLabel "Improve Internal CRM Processes" ;
    skos:definition """Purposes associated with improving customer-relationship management
(CRM) processes""" ;
    skos:exactMatch dpv:ImproveInternalCRMProcesses,
        dpv_upstream:ImproveInternalCRMProcesses,
        dpv_owl:ImproveInternalCRMProcesses ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ImprovePublicServices a owl:Class ;
    rdfs:label "ImprovePublicServices" ;
    rdfs:subClassOf dpv:PublicBenefit,
        dpv:Purpose ;
    skos:altLabel "Improve Public Services" ;
    skos:definition """Purposes associated with improving the provision of public services,
such as public safety, education or law enforcement""" ;
    skos:exactMatch dpv:ImprovePublicServices,
        dpv_upstream:ImprovePublicServices,
        dpv_owl:ImprovePublicServices ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.16" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ImproveTransportMobility a owl:Class ;
    rdfs:label "ImproveTransportMobility" ;
    rdfs:subClassOf dpv:PublicBenefit,
        dpv:Purpose ;
    skos:altLabel "Improve Transport and Mobility" ;
    skos:definition """Purposes associated with improving traffic, public transport systems or
costs for drivers""" ;
    skos:exactMatch dpv:ImproveTransportMobility,
        dpv_upstream:ImproveTransportMobility,
        dpv_owl:ImproveTransportMobility ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.16" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:IncidentManagementProcedures a owl:Class ;
    rdfs:label "IncidentManagementProcedures" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Incident Management Procedures" ;
    skos:definition "Procedures related to management of incidents" ;
    skos:exactMatch dpv:IncidentManagementProcedures,
        dpv_upstream:IncidentManagementProcedures,
        dpv_owl:IncidentManagementProcedures ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch iso42001:AIIncident,
        nist_csf_v2:CSFFunction ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:IncidentReportingCommunication a owl:Class ;
    rdfs:label "IncidentReportingCommunication" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Incident Reporting Communication" ;
    skos:definition "Procedures related to management of incident reporting" ;
    skos:exactMatch dpv:IncidentReportingCommunication,
        dpv_upstream:IncidentReportingCommunication,
        dpv_owl:IncidentReportingCommunication ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:IncorrectData a owl:Class ;
    rdfs:label "IncorrectData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Incorrect Data" ;
    skos:definition """Data that is known to be incorrect or inconsistent with some
requirements""" ;
    skos:exactMatch dpv:IncorrectData,
        dpv_upstream:IncorrectData,
        dpv_owl:IncorrectData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:IncreaseServiceRobustness a owl:Class ;
    rdfs:label "IncreaseServiceRobustness" ;
    rdfs:subClassOf dpv:OptimisationForController,
        dpv:Purpose ;
    skos:altLabel "Increase Service Robustness" ;
    skos:definition "Purposes associated with improving robustness and resilience of services" ;
    skos:exactMatch dpv:IncreaseServiceRobustness,
        dpv_upstream:IncreaseServiceRobustness,
        dpv_owl:IncreaseServiceRobustness ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:IndeterminateDuration a owl:Class ;
    rdfs:label "IndeterminateDuration" ;
    rdfs:subClassOf dpv:DpvDuration ;
    skos:altLabel "Indeterminate Duration" ;
    skos:definition "Duration that is indeterminate or cannot be determined" ;
    skos:exactMatch dpv:IndeterminateDuration,
        dpv_upstream:IndeterminateDuration,
        dpv_owl:IndeterminateDuration ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Indeterminate means (exact or otherwise) information about the duration
cannot be determined, which is distinct from 'EndlessDuration' where it
is known (or decided) that the duration is open-ended or without an end.""" ;
    dpv:skos_in_scheme "context-classes" .

dpv:IndustryConsortium a owl:Class ;
    rdfs:label "IndustryConsortium" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "Industry Consortium" ;
    skos:definition "A consortium established and comprising on industry organisations" ;
    skos:exactMatch dpv:IndustryConsortium,
        dpv_upstream:IndustryConsortium,
        dpv_owl:IndustryConsortium ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:Infer a owl:Class ;
    rdfs:label "Infer" ;
    rdfs:subClassOf dpv:Derive,
        dpv:Processing ;
    skos:altLabel "Infer" ;
    skos:definition "to infer data from existing data" ;
    skos:exactMatch dpv:Infer,
        dpv_upstream:Infer,
        dpv_owl:Infer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Infer indicates data that is derived without it being present or
obtainable from existing data. For data that is presented, and is
'extracted' or 'obtained' from existing data, see Derive.""" ;
    dpv:skos_in_scheme "processing-classes" .

dpv:InferredPersonalData a owl:Class ;
    rdfs:label "InferredPersonalData" ;
    rdfs:subClassOf dpv:DerivedPersonalData,
        dpv:InferredData ;
    skos:altLabel "Inferred Personal Data" ;
    skos:definition "Personal Data that is obtained through inference from other data" ;
    skos:exactMatch dpv:InferredPersonalData,
        dpv_upstream:InferredPersonalData,
        dpv_owl:InferredPersonalData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Inferred Data is derived data generated from existing data, but which
did not originally exist within it, e.g. inferring demographics from
browsing history.""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:InformationFlowControl a owl:Class ;
    rdfs:label "InformationFlowControl" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Information Flow Control" ;
    skos:definition "Use of measures to control information flows" ;
    skos:exactMatch dpv:InformationFlowControl,
        dpv_upstream:InformationFlowControl,
        dpv_owl:InformationFlowControl ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:InformationSecurityPolicy a owl:Class ;
    rdfs:label "InformationSecurityPolicy" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:Policy ;
    skos:altLabel "Information Security Policy" ;
    skos:definition "Policy regarding security of information" ;
    skos:exactMatch dpv:InformationSecurityPolicy,
        dpv_upstream:InformationSecurityPolicy,
        dpv_owl:InformationSecurityPolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:InnovativeUseOfExistingTechnology a owl:Class ;
    rdfs:label "InnovativeUseOfExistingTechnology" ;
    rdfs:subClassOf dpv:InnovativeUseOfTechnology ;
    skos:altLabel "Innovative Use of Existing Technologies" ;
    skos:definition "Involvement of existing technologies used in an innovative manner" ;
    skos:exactMatch dpv:InnovativeUseOfExistingTechnology,
        dpv_upstream:InnovativeUseOfExistingTechnology,
        dpv_owl:InnovativeUseOfExistingTechnology ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:InnovativeUseOfNewTechnologies a owl:Class ;
    rdfs:label "InnovativeUseOfNewTechnologies" ;
    rdfs:subClassOf dpv:InnovativeUseOfTechnology ;
    skos:altLabel "Innovative Use of New Technologies" ;
    skos:definition "Involvement of a new (innovative) technologies" ;
    skos:exactMatch dpv:InnovativeUseOfNewTechnologies,
        dpv_upstream:InnovativeUseOfNewTechnologies,
        dpv_owl:InnovativeUseOfNewTechnologies ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "New technologies are by definition considered innovative" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:IntellectualPropertyData a owl:Class ;
    rdfs:label "IntellectualPropertyData" ;
    rdfs:subClassOf dpv:ConfidentialData ;
    skos:altLabel "Intellectual Property Data" ;
    skos:definition "Data protected by Intellectual Property rights and regulations" ;
    skos:exactMatch dpv:IntellectualPropertyData,
        dpv_upstream:IntellectualPropertyData,
        dpv_owl:IntellectualPropertyData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:narrowMatch gists:IntellectualProperty ;
    dpv:dct_source "DGA 5.10" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:InternalResourceOptimisation a owl:Class ;
    rdfs:label "InternalResourceOptimisation" ;
    rdfs:subClassOf dpv:OptimisationForController,
        dpv:Purpose ;
    skos:altLabel "Internal Resource Optimisation" ;
    skos:definition """Purposes associated with optimisation of internal resource availability
and usage for organisation""" ;
    skos:exactMatch dpv:InternalResourceOptimisation,
        dpv_upstream:InternalResourceOptimisation,
        dpv_owl:InternalResourceOptimisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:InternationalOrganisation a owl:Class ;
    rdfs:label "InternationalOrganisation" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "International Organisation" ;
    skos:definition """An organisation and its subordinate bodies governed by public
international law, or any other body which is set up by, or on the basis
of, an agreement between two or more countries""" ;
    skos:exactMatch dpv:InternationalOrganisation,
        dpv_upstream:InternationalOrganisation,
        dpv_owl:InternationalOrganisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:IntrusionDetectionSystem a owl:Class ;
    rdfs:label "IntrusionDetectionSystem" ;
    rdfs:subClassOf dpv:SecurityMethod,
        dpv:TechnicalMeasure ;
    skos:altLabel "Intrusion Detection System" ;
    skos:definition """Use of measures to detect intrusions and other unauthorised attempts to
gain access to a system""" ;
    skos:exactMatch dpv:IntrusionDetectionSystem,
        dpv_upstream:IntrusionDetectionSystem,
        dpv_owl:IntrusionDetectionSystem ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:InverseJurisdiction a owl:Class ;
    rdfs:label "InverseJurisdiction" ;
    rdfs:subClassOf dpv:DpvJurisdiction ;
    skos:altLabel "Inverse Jurisdiction" ;
    skos:definition """An inverse jurisdiction for a specific jurisdiction is the set of all
other jurisdictions that are not part of the specific jurisdiction""" ;
    skos:exactMatch dpv:InverseJurisdiction,
        dpv_upstream:InverseJurisdiction,
        dpv_owl:InverseJurisdiction ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Inverse Jurisdictions are helpful when asserting and checking rules that
involve a concept representing jurisdictions outside of a given
jurisdiction. An inverse jurisdiction of an inverse jurisdiction should
give back the same original jurisdiction but this is undefined and
strongly dissuaded as it could lead to recursive definitions in some
use-cases""" ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:JITNotice a owl:Class ;
    rdfs:label "JITNotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Just-in-time Notice" ;
    skos:definition """A notice that is provided "just in time" when collecting information or
performing an activity""" ;
    skos:exactMatch dpv:JITNotice,
        dpv_upstream:JITNotice,
        dpv_owl:JITNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes" .

dpv:JobApplicant a owl:Class ;
    rdfs:label "JobApplicant" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Job Applicant" ;
    skos:definition "Humans that apply for jobs or employments" ;
    skos:exactMatch dpv:JobApplicant,
        dpv_upstream:JobApplicant,
        dpv_owl:JobApplicant ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:JointDataControllers a owl:Class ;
    rdfs:label "JointDataControllers" ;
    rdfs:subClassOf dpv:DataController ;
    skos:altLabel "Joint Data Controllers" ;
    skos:definition """A group of Data Controllers that jointly determine the purposes and
means of processing""" ;
    skos:exactMatch dpv:JointDataControllers,
        dpv_upstream:JointDataControllers,
        dpv_owl:JointDataControllers ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """While Joint Data Controllers operate together, they are made up of
individually distinct legal entities. To indicate the membership of this
group, hasDataController should be used to denote each Data Controller.
The concept of Joint Data Controllers also allows specifying a single
group as the 'Controller' and to specify role and responsibilities
within that group for each entity using DPV's concepts (e.g.
isImplementedByEntity)""" ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:JointDataControllersAgreement a owl:Class ;
    rdfs:label "JointDataControllersAgreement" ;
    rdfs:subClassOf dpv:DataControllerContract,
        dpv:LegalBasis,
        dpv:LegalMeasure ;
    skos:altLabel "Joint Data Controllers Agreement" ;
    skos:definition """An agreement outlining conditions, criteria, obligations,
responsibilities, and specifics for carrying out processing of data
between Controllers within a Joint Controllers relationship""" ;
    skos:exactMatch dpv:JointDataControllersAgreement,
        dpv_upstream:JointDataControllersAgreement,
        dpv_owl:JointDataControllersAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:JudicialOrganisation a owl:Class ;
    rdfs:label "JudicialOrganisation" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "Judicial Organisation" ;
    skos:definition """An organisation involved in interpreting and applying the law, resolving
disputes, and administering justice as part of the judicial system""" ;
    skos:exactMatch dpv:JudicialOrganisation,
        dpv_upstream:JudicialOrganisation,
        dpv_owl:JudicialOrganisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:Justification a owl:Class ;
    rdfs:label "Justification" ;
    rdfs:subClassOf dpv:Context ;
    skos:altLabel "Justification" ;
    skos:definition """A form of documentation providing reasons, explanations, or
justifications""" ;
    skos:exactMatch dpv:Justification,
        dpv_upstream:Justification,
        dpv_owl:Justification ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:LargeDataVolume a owl:Class ;
    rdfs:label "LargeDataVolume" ;
    rdfs:subClassOf dpv:DataVolume ;
    skos:altLabel "Large Data Volume" ;
    skos:definition "Data volume that is considered large within the context" ;
    skos:exactMatch dpv:LargeDataVolume,
        dpv_upstream:LargeDataVolume,
        dpv_owl:LargeDataVolume ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:LargeScaleOfDataSubjects a owl:Class ;
    rdfs:label "LargeScaleOfDataSubjects" ;
    rdfs:subClassOf dpv:DataSubjectScale ;
    skos:altLabel "Large Scale Of Data Subjects" ;
    skos:definition "Scale of data subjects considered large within the context" ;
    skos:exactMatch dpv:LargeScaleOfDataSubjects,
        dpv_upstream:LargeScaleOfDataSubjects,
        dpv_owl:LargeScaleOfDataSubjects ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:LargeScaleProcessing a owl:Class ;
    rdfs:label "LargeScaleProcessing" ;
    rdfs:subClassOf dpv:ProcessingScale ;
    skos:altLabel "Large Scale Processing" ;
    skos:definition """Processing that takes place at large scales (as specified by some
criteria)""" ;
    skos:exactMatch dpv:LargeScaleProcessing,
        dpv_upstream:LargeScaleProcessing,
        dpv_owl:LargeScaleProcessing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The exact definition of what constitutes "large scale" depends on use of
jurisdictional, domain-specific, or other forms of externally defined
criteria. Where possible, this should be reflected by extending this
term with the appropriate context.""" ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:LawEnforcementOrganisation a owl:Class ;
    rdfs:label "LawEnforcementOrganisation" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "Law Enforcement Organisation" ;
    skos:definition """An organisation that is an agency responsible for enforcing laws,
maintaining public order, and ensuring public safety""" ;
    skos:exactMatch dpv:LawEnforcementOrganisation,
        dpv_upstream:LawEnforcementOrganisation,
        dpv_owl:LawEnforcementOrganisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:Lawful a owl:Class ;
    rdfs:label "Lawful" ;
    rdfs:subClassOf dpv:Lawfulness ;
    skos:altLabel "Lawful" ;
    skos:definition "State of being lawful or legally compliant" ;
    skos:exactMatch dpv:Lawful,
        dpv_upstream:Lawful,
        dpv_owl:Lawful ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:LawfulnessUnknown a owl:Class ;
    rdfs:label "LawfulnessUnknown" ;
    rdfs:subClassOf dpv:Lawfulness ;
    skos:altLabel "Lawfulness Unknown" ;
    skos:definition "State of the lawfulness not being known" ;
    skos:exactMatch dpv:LawfulnessUnknown,
        dpv_upstream:LawfulnessUnknown,
        dpv_owl:LawfulnessUnknown ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:LayeredNotice a owl:Class ;
    rdfs:label "LayeredNotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Layered Notice" ;
    skos:definition "A notice that contains layered elements" ;
    skos:exactMatch dpv:LayeredNotice,
        dpv_upstream:LayeredNotice,
        dpv_owl:LayeredNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes" .

dpv:LegalAgent a owl:Class ;
    rdfs:label "LegalAgent" ;
    rdfs:subClassOf dpv:DpvAgent,
        dpv:LegalEntity ;
    skos:altLabel "Legal Agent" ;
    skos:definition """A Legal Agent is a Legal Entity that is authorised to act on behalf of
another entity""" ;
    skos:exactMatch dpv:LegalAgent,
        dpv_upstream:LegalAgent,
        dpv_owl:LegalAgent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Legal agents may be human or non-human (e.g. an organisation), but they
must be 'legal persons' i.e. recognised by law as such. The agency and
the mechanisms through which it is given, acquired, or expressed is
governed by relevant jurisdictional frameworks e.g. power of attorney""" ;
    dpv:skos_in_scheme "entities-classes" .

dpv:LegalCompliance a owl:Class ;
    rdfs:label "LegalCompliance" ;
    rdfs:subClassOf dpv:FulfilmentOfObligation,
        dpv:Purpose ;
    skos:altLabel "Legal Compliance" ;
    skos:definition """Purposes associated with carrying out data processing to fulfill a legal
or statutory obligation""" ;
    skos:exactMatch dpv:LegalCompliance,
        dpv_upstream:LegalCompliance,
        dpv_owl:LegalCompliance ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This purpose only refers to processing that is additionally required in
order to fulfill the obligations and requirements associated with a law.
For example, the use of consent would have its own separate purposes,
with this purpose addressing a legal requirement for maintaining consent
record (along with RecordManagement). This purpose will typically be
used with Legal Obligation as the legal basis.""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:LegalComplianceAssessment a owl:Class ;
    rdfs:label "LegalComplianceAssessment" ;
    rdfs:subClassOf dpv:ComplianceAssessment,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Legal Compliance Assessment" ;
    skos:definition "Assessment regarding legal compliance" ;
    skos:exactMatch dpv:LegalComplianceAssessment,
        dpv_upstream:LegalComplianceAssessment,
        dpv_owl:LegalComplianceAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:LegalComplianceAudit a owl:Class ;
    rdfs:label "LegalComplianceAudit" ;
    rdfs:subClassOf dpv:Audit,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Legal Compliance Audit" ;
    skos:definition """An audit that systematically examines the state of legal compliance by
reviewing policies and procedures related to obligations and compliance
requirements for specific laws and regulations""" ;
    skos:exactMatch dpv:LegalComplianceAudit,
        dpv_upstream:LegalComplianceAudit,
        dpv_owl:LegalComplianceAudit ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:LegalObligationCompleted a owl:Class ;
    rdfs:label "LegalObligationCompleted" ;
    rdfs:subClassOf dpv:LegalObligationStatus ;
    skos:altLabel "Legal ObligationCompleted" ;
    skos:definition "Status where the legal obligation has been completed" ;
    skos:exactMatch dpv:LegalObligationCompleted,
        dpv_upstream:LegalObligationCompleted,
        dpv_owl:LegalObligationCompleted ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:LegalObligationOngoing a owl:Class ;
    rdfs:label "LegalObligationOngoing" ;
    rdfs:subClassOf dpv:LegalObligationStatus ;
    skos:altLabel "Legal ObligationOngoing" ;
    skos:definition "Status where the legal obligation is being fulfilled" ;
    skos:exactMatch dpv:LegalObligationOngoing,
        dpv_upstream:LegalObligationOngoing,
        dpv_owl:LegalObligationOngoing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:LegalObligationPending a owl:Class ;
    rdfs:label "LegalObligationPending" ;
    rdfs:subClassOf dpv:LegalObligationStatus ;
    skos:altLabel "Legal ObligationPending" ;
    skos:definition "Status where the legal obligation has not been started" ;
    skos:exactMatch dpv:LegalObligationPending,
        dpv_upstream:LegalObligationPending,
        dpv_owl:LegalObligationPending ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:LegitimateInterestAssessment a owl:Class ;
    rdfs:label "LegitimateInterestAssessment" ;
    rdfs:subClassOf dpv:Assessment,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Legitimate Interest Assessment" ;
    skos:definition """Indicates an assessment regarding the use of legitimate interest as a
lawful basis by the data controller""" ;
    skos:exactMatch dpv:LegitimateInterestAssessment,
        dpv_upstream:LegitimateInterestAssessment,
        dpv_owl:LegitimateInterestAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:LegitimateInterestInformed a owl:Class ;
    rdfs:label "LegitimateInterestInformed" ;
    rdfs:subClassOf dpv:LegitimateInterestStatus ;
    skos:altLabel "Legitimate InterestInformed" ;
    skos:definition """Status where the Legitimate Interest was informed to the data subject or
other relevant entities""" ;
    skos:exactMatch dpv:LegitimateInterestInformed,
        dpv_upstream:LegitimateInterestInformed,
        dpv_owl:LegitimateInterestInformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:LegitimateInterestNotObjected a owl:Class ;
    rdfs:label "LegitimateInterestNotObjected" ;
    rdfs:subClassOf dpv:LegitimateInterestStatus ;
    skos:altLabel "Legitimate InterestNotObjected" ;
    skos:definition "Status where the use of Legitimate Interest was not objected to" ;
    skos:exactMatch dpv:LegitimateInterestNotObjected,
        dpv_upstream:LegitimateInterestNotObjected,
        dpv_owl:LegitimateInterestNotObjected ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:LegitimateInterestObjected a owl:Class ;
    rdfs:label "LegitimateInterestObjected" ;
    rdfs:subClassOf dpv:LegitimateInterestStatus ;
    skos:altLabel "Legitimate InterestObjected" ;
    skos:definition "Status where the use of Legitimate Interest was objected to" ;
    skos:exactMatch dpv:LegitimateInterestObjected,
        dpv_upstream:LegitimateInterestObjected,
        dpv_owl:LegitimateInterestObjected ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:LegitimateInterestOfController a owl:Class ;
    rdfs:label "LegitimateInterestOfController" ;
    rdfs:subClassOf dpv:LegalBasis,
        dpv:LegitimateInterest ;
    skos:altLabel "Legitimate Interest of Controller" ;
    skos:definition """Legitimate Interests of a Data Controller in conducting specified
activities""" ;
    skos:exactMatch dpv:LegitimateInterestOfController,
        dpv_upstream:LegitimateInterestOfController,
        dpv_owl:LegitimateInterestOfController ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:LegitimateInterestOfDataSubject a owl:Class ;
    rdfs:label "LegitimateInterestOfDataSubject" ;
    rdfs:subClassOf dpv:LegalBasis,
        dpv:LegitimateInterest ;
    skos:altLabel "Legitimate Interest of Data Subject" ;
    skos:definition """Legitimate Interests of the Data Subject in conducting specified
activities""" ;
    skos:exactMatch dpv:LegitimateInterestOfDataSubject,
        dpv_upstream:LegitimateInterestOfDataSubject,
        dpv_owl:LegitimateInterestOfDataSubject ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:LegitimateInterestOfThirdParty a owl:Class ;
    rdfs:label "LegitimateInterestOfThirdParty" ;
    rdfs:subClassOf dpv:LegalBasis,
        dpv:LegitimateInterest ;
    skos:altLabel "Legitimate Interest of Third Party" ;
    skos:definition "Legitimate Interests of a Third Party in conducting specified activities" ;
    skos:exactMatch dpv:LegitimateInterestOfThirdParty,
        dpv_upstream:LegitimateInterestOfThirdParty,
        dpv_owl:LegitimateInterestOfThirdParty ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:LegitimateInterestUninformed a owl:Class ;
    rdfs:label "LegitimateInterestUninformed" ;
    rdfs:subClassOf dpv:LegitimateInterestStatus ;
    skos:altLabel "Legitimate InterestUninformed" ;
    skos:definition """Status where the Legitimate Interest was not informed to the data
