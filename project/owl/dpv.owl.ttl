dpv:DisasterRecoveryProcedures a owl:Class ;
    rdfs:label "DisasterRecoveryProcedures" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Disaster Recovery Procedures" ;
    skos:definition "Procedures related to management of disasters and recovery" ;
    skos:exactMatch dpv:DisasterRecoveryProcedures,
