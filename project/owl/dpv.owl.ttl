    skos:altLabel "has service consumer" ;
    skos:definition "Indicates the entity that consumes or receives the associated service" ;
    skos:exactMatch dpv_upstream:hasServiceConsumer,
        dpv_owl:hasServiceConsumer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-legalrole-properties" .

dpv:has_service_provider a owl:DatatypeProperty ;
    rdfs:label "has_service_provider" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "has service provider" ;
    skos:definition "Indicates the entity that provides the associated service" ;
    skos:exactMatch dpv_upstream:hasServiceProvider,
        dpv_owl:hasServiceProvider ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-legalrole-properties" .

dpv:has_severity a owl:DatatypeProperty ;
    rdfs:label "has_severity" ;
    skos:altLabel "has severity" ;
    skos:definition "Indicates the severity associated with a concept" ;
    skos:exactMatch dpv_upstream:hasSeverity,
        dpv_owl:hasSeverity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-properties" .

dpv:has_storage_condition a owl:DatatypeProperty ;
    rdfs:label "has_storage_condition" ;
    rdfs:subPropertyOf dpv:has_processing_condition ;
    skos:altLabel "has storage condition" ;
    skos:definition "Indicates information about storage condition" ;
    skos:exactMatch dpv_upstream:hasStorageCondition,
        dpv_owl:hasStorageCondition ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-properties" .

dpv:has_subsidiary a owl:DatatypeProperty ;
    rdfs:label "has_subsidiary" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "has subsidiary" ;
    skos:definition "Indicates this entity has the specified entity as its subsidiary" ;
    skos:exactMatch dpv_upstream:hasSubsidiary,
        dpv_owl:hasSubsidiary ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-properties" .

dpv:has_technical_measure a owl:DatatypeProperty ;
    rdfs:label "has_technical_measure" ;
    rdfs:subPropertyOf dpv:has_technical_organisational_measure ;
    skos:altLabel "has technical measure" ;
    skos:definition "Indicates use or applicability of Technical measure" ;
    skos:exactMatch dpv_upstream:hasTechnicalMeasure,
        dpv_owl:hasTechnicalMeasure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "TOM-properties" .

dpv:has_third_country a owl:DatatypeProperty ;
    rdfs:label "has_third_country" ;
    rdfs:subPropertyOf dpv:has_country ;
    skos:altLabel "has third country" ;
    skos:definition "Indicates applicability or relevance of a 'third country'" ;
    skos:exactMatch dpv_upstream:hasThirdCountry,
        dpv_owl:hasThirdCountry ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-properties" .

dpv:has_third_party a owl:DatatypeProperty ;
    rdfs:label "has_third_party" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "has third party" ;
    skos:definition "Indicates association with Third Party" ;
    skos:exactMatch dpv_upstream:hasThirdParty,
        dpv_owl:hasThirdParty ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-legalrole-properties" .

dpv:has_uncategorised_data a owl:DatatypeProperty ;
    rdfs:label "has_uncategorised_data" ;
    rdfs:subPropertyOf dpv:has_data ;
    skos:altLabel "has uncategorised data" ;
    skos:definition "Indicates association with the specified uncategorised data" ;
    skos:exactMatch dpv_upstream:hasUncategorisedData,
        dpv_owl:hasUncategorisedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-properties" .

dpv:has_unstructured_data a owl:DatatypeProperty ;
    rdfs:label "has_unstructured_data" ;
    rdfs:subPropertyOf dpv:has_data ;
    skos:altLabel "has unstructured data" ;
    skos:definition "Indicates association with the specified unstructured data" ;
    skos:exactMatch dpv_upstream:hasUnstructuredData,
        dpv_owl:hasUnstructuredData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-properties" .

dpv:is_after a owl:DatatypeProperty ;
    rdfs:label "is_after" ;
    skos:altLabel "is after" ;
    skos:definition "Indicates the specified concepts is 'after' this concept in some context" ;
    skos:exactMatch dpv_upstream:isAfter,
        dpv_owl:isAfter ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Also used for specifying a RightExerciseActivity occurs before another
RightExerciseActivity""" ;
    dpv:skos_in_scheme "context-properties, rights-properties" .

dpv:is_applicable_for a owl:DatatypeProperty ;
    rdfs:label "is_applicable_for" ;
    skos:altLabel "is applicable for" ;
    skos:definition "Indicates the concept or information is applicable for specified context" ;
    skos:exactMatch dpv_upstream:isApplicableFor,
        dpv_owl:isApplicableFor ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-properties" .

dpv:is_authority_for a owl:DatatypeProperty ;
    rdfs:label "is_authority_for" ;
    skos:altLabel "is authority for" ;
    skos:definition "Indicates area, scope, or applicability of an Authority" ;
    skos:exactMatch dpv_upstream:isAuthorityFor,
        dpv_owl:isAuthorityFor ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-authority-properties" .

dpv:is_before a owl:DatatypeProperty ;
    rdfs:label "is_before" ;
    skos:altLabel "is before" ;
    skos:definition """Indicates the specified concepts is 'before' this concept in some
context""" ;
    skos:exactMatch dpv_upstream:isBefore,
        dpv_owl:isBefore ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Also used for specifying a RightExerciseActivity occurs before another
RightExerciseActivity""" ;
    dpv:skos_in_scheme "context-properties, rights-properties" .

dpv:is_determined_by_entity a owl:DatatypeProperty ;
    rdfs:label "is_determined_by_entity" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "is determined by entity" ;
    skos:definition "Indicates the context is determined by the specified entity" ;
    skos:exactMatch dpv_upstream:isDeterminedByEntity,
        dpv_owl:isDeterminedByEntity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-properties" .

dpv:is_during a owl:DatatypeProperty ;
    rdfs:label "is_during" ;
    skos:altLabel "is during" ;
    skos:definition """Indicates the specified concepts occur 'during' this concept in some
context""" ;
    skos:exactMatch dpv_upstream:isDuring,
        dpv_owl:isDuring ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-properties" .

dpv:is_exercised_at a owl:DatatypeProperty ;
    rdfs:label "is_exercised_at" ;
    skos:altLabel "is exercised at" ;
    skos:definition "Indicates context or information about exercising a right" ;
    skos:exactMatch dpv_upstream:isExercisedAt,
        dpv_owl:isExercisedAt ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rights-properties" .

dpv:is_implemented_by_entity a owl:DatatypeProperty ;
    rdfs:label "is_implemented_by_entity" ;
    skos:altLabel "is implemented by entity" ;
    skos:definition "Indicates implementation details such as entities or agents" ;
    skos:exactMatch dpv_upstream:isImplementedByEntity,
        dpv_owl:isImplementedByEntity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Also used to indicate the Entity that implements or performs a Right
Exercise Activity""",
        """The use of 'entity' is inclusive of entities (e.g. Data Processor) as
well as 'agent' (e.g. DPO). For indicating technological implementation,
the property isImplementedByTechnology should be used.""" ;
    dpv:skos_in_scheme "processing-context-properties, rights-properties" .

dpv:is_implemented_using_technology a owl:DatatypeProperty ;
    rdfs:label "is_implemented_using_technology" ;
    skos:altLabel "is implemented using technology" ;
    skos:definition "Indicates implementation details such as technologies or processes" ;
    skos:exactMatch dpv_upstream:isImplementedUsingTechnology,
        dpv_owl:isImplementedUsingTechnology ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The term 'technology' is inclusive of technologies, processes, and
methods.""" ;
    dpv:skos_in_scheme "processing-context-properties" .

dpv:is_indicated_at_time a owl:DatatypeProperty ;
    rdfs:label "is_indicated_at_time" ;
    skos:altLabel "is indicated at time" ;
    skos:definition """Specifies the temporal information for when the entity has indicated the
specific context""" ;
    skos:exactMatch dpv_upstream:isIndicatedAtTime,
        dpv_owl:isIndicatedAtTime ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-properties" .

dpv:is_indicated_by a owl:DatatypeProperty ;
    rdfs:label "is_indicated_by" ;
    skos:altLabel "is indicated by" ;
    skos:definition "Specifies entity who indicates the specific context" ;
    skos:exactMatch dpv_upstream:isIndicatedBy,
        dpv_owl:isIndicatedBy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-properties" .

dpv:is_mitigated_by_measure a owl:DatatypeProperty ;
    rdfs:label "is_mitigated_by_measure" ;
    rdfs:subPropertyOf dpv:has_technical_organisational_measure ;
    skos:altLabel "is mitigated by measure" ;
    skos:definition "Indicate a risk is mitigated by specified measure" ;
    skos:exactMatch dpv_upstream:isMitigatedByMeasure,
        dpv_owl:isMitigatedByMeasure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-properties" .

dpv:is_not_applicable_for a owl:DatatypeProperty ;
    rdfs:label "is_not_applicable_for" ;
    skos:altLabel "is not applicable for" ;
    skos:definition """Indicates the concept or information is not applicable for specified
context""" ;
    skos:exactMatch dpv_upstream:isNotApplicableFor,
        dpv_owl:isNotApplicableFor ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-properties" .

dpv:is_organisational_unit_of a owl:DatatypeProperty ;
    rdfs:label "is_organisational_unit_of" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "is organisational unit of" ;
    skos:definition "Indicates this entity is an organisational unit of the specified entity" ;
    skos:exactMatch dpv_upstream:isOrganisationalUnitOf,
        dpv_owl:isOrganisationalUnitOf ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-properties" .

dpv:is_outside_of_location a owl:DatatypeProperty ;
    rdfs:label "is_outside_of_location" ;
    rdfs:subPropertyOf dpv:has_location ;
    skos:altLabel "is outside of location" ;
    skos:definition """Indicates the interpretation where the location being referenced is
outside of the indicated concept""" ;
    skos:exactMatch dpv_upstream:isOutsideOfLocation,
        dpv_owl:isOutsideOfLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This property is helpful for cases where a distinction needs to be made
between inside/outside of a concept, and the area outside of that
concept is to be referenced. For example, using Home with
dpv:hasLocation means inside the Home, and using this property along
with Home means outside of Home - such as the yard or porch""" ;
    dpv:skos_in_scheme "jurisdiction-properties" .

dpv:is_policy_for a owl:DatatypeProperty ;
    rdfs:label "is_policy_for" ;
    skos:altLabel "is policy for" ;
    skos:definition "Indicates the context or application of policy" ;
    skos:exactMatch dpv_upstream:isPolicyFor,
        dpv_owl:isPolicyFor ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "TOM-properties" .

dpv:is_representative_for a owl:DatatypeProperty ;
    rdfs:label "is_representative_for" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "is representative for" ;
    skos:definition "Indicates the entity is a representative for specified entity" ;
    skos:exactMatch dpv_upstream:isRepresentativeFor,
        dpv_owl:isRepresentativeFor ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-properties" .

dpv:is_residual_risk_of a owl:DatatypeProperty ;
    rdfs:label "is_residual_risk_of" ;
    skos:altLabel "is residual risk of" ;
    skos:definition """Indicates this risk is the remaining or residual risk from applying
mitigation measures or treatments to specified risk""" ;
    skos:exactMatch dpv_upstream:isResidualRiskOf,
        dpv_owl:isResidualRiskOf ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-properties" .

dpv:is_subsidiary_of a owl:DatatypeProperty ;
    rdfs:label "is_subsidiary_of" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "is subsidiary of" ;
    skos:definition "Indicates this entity is the subsidiary of the specified entity" ;
    skos:exactMatch dpv_upstream:isSubsidiaryOf,
        dpv_owl:isSubsidiaryOf ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-properties" .

dpv:mitigates_risk a owl:DatatypeProperty ;
    rdfs:label "mitigates_risk" ;
    skos:altLabel "mitigates risk" ;
    skos:definition "Indicates risks mitigated by this concept" ;
    skos:exactMatch dpv_upstream:mitigatesRisk,
        dpv_owl:mitigatesRisk ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-properties" .

dpv:supports_compliance_with a owl:DatatypeProperty ;
    rdfs:label "supports_compliance_with" ;
    skos:altLabel "supports Compliance With" ;
    skos:definition """Indicate the measure is required for meeting specified requirement or
satisfying specified condition/constraint""" ;
    skos:exactMatch dpv_upstream:supportsComplianceWith,
        dpv_owl:supportsComplianceWith ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "TOM-properties" .

<https://w3id.org/lmodel/dpv.owl.ttl> a owl:Ontology ;
    rdfs:label "dpv" ;
    dcterms:license "CC-BY-4.0" ;
    dcterms:title "Data Privacy Vocabulary (DPV)" ;
    pav:version "2.3" ;
    rdfs:seeAlso <https://w3c.github.io/dpv/>,
        <https://w3id.org/dpv> ;
    skos:definition """Top-level LinkML schema for the W3C Data Privacy Vocabulary (DPV)
version 2.3. Re-exports the aggregate `dpv_core` schema which contains
every class and slot of the upstream OWL release. Per-module schemas
(under `./modules/`) are available as standalone subset schemas; they
are intentionally NOT imported here to avoid duplicate class
declarations during `gen-project` (each shared class would otherwise
arrive with two conflicting `from_schema` URIs).""" ;
    dpv:dpv_modules """tom, consent, consent_controls, consent_status, consent_types, context,
contract, contract_clause, contract_control, contract_status,
contract_types, entities, entities_authority, entities_datasubject,
entities_legalrole, entities_organisation, jurisdiction, legal_basis,
legal_basis_status, legal_measures, notice, organisational_measures,
personal_data, physical_measures, process, processing,
processing_context, processing_scale, purposes, rights, risk, rules,
status, technical_measures""" .

dpv:AIGovernance a owl:Class ;
    rdfs:label "AIGovernance" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "AI Governance" ;
    skos:closeMatch iso42001:AIManagementSystem ;
    skos:definition """Procedures related to governance of AI, including its procurement,
development, deployment, and assessments""" ;
    skos:exactMatch dpv:AIGovernance,
        dpv_upstream:AIGovernance,
        dpv_owl:AIGovernance ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch iso22989:AILifecycleProcess,
        nist_ai_rmf:Function,
        nist_csf_v2:CSFFunction ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:AILiteracy a owl:Class ;
    rdfs:label "AILiteracy" ;
    rdfs:subClassOf dpv:DigitalLiteracy,
        dpv:OrganisationalMeasure ;
    skos:altLabel "AI Literacy" ;
    skos:definition """Providing skills, knowledge, and understanding to enable reading,
writing, analysing, reasoning, and communicating regarding AI""" ;
    skos:exactMatch dpv:AILiteracy,
        dpv_upstream:AILiteracy,
        dpv_owl:AILiteracy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch iso42001:AIReferenceControl ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:AINotice a owl:Class ;
    rdfs:label "AINotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "AI Notice" ;
    skos:definition """A notice providing information regarding the particulars of an AI system
such as its intended purpose and proper use""" ;
    skos:exactMatch dpv:AINotice,
        dpv_upstream:AINotice,
        dpv_owl:AINotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch iso42001:AISystem ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:AcademicResearch a owl:Class ;
    rdfs:label "AcademicResearch" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ResearchAndDevelopment ;
    skos:altLabel "Academic Research" ;
    skos:definition """Purposes associated with conducting or assisting with research conducted
in an academic context e.g. within universities""" ;
    skos:exactMatch dpv:AcademicResearch,
        dpv_upstream:AcademicResearch,
        dpv_owl:AcademicResearch ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpu:Education ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:AcademicScientificOrganisation a owl:Class ;
    rdfs:label "AcademicScientificOrganisation" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "Academic or Scientific Organisation" ;
    skos:definition """Organisations related to academia or scientific pursuits e.g.
Universities, Schools, Research Bodies""" ;
    skos:exactMatch dpv:AcademicScientificOrganisation,
        dpv_upstream:AcademicScientificOrganisation,
        dpv_owl:AcademicScientificOrganisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:AcceptContract a owl:Class ;
    rdfs:label "AcceptContract" ;
    rdfs:subClassOf dpv:ContractControl ;
    skos:altLabel "Accept Contract" ;
    skos:definition "Control for accepting a contract" ;
    skos:exactMatch dpv:AcceptContract,
        dpv_upstream:AcceptContract,
        dpv_owl:AcceptContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-control-classes" .

dpv:AcceptableUsePolicy a owl:Class ;
    rdfs:label "AcceptableUsePolicy" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:Policy ;
    skos:altLabel "Acceptable Use Policy" ;
    skos:definition """Acceptable Use Policy (AUP) refers to conditions, contexts, or uses
which are considered acceptable with the implication that those not
covered by such a policy are to be considered unacceptable""" ;
    skos:exactMatch dpv:AcceptableUsePolicy,
        dpv_upstream:AcceptableUsePolicy,
        dpv_owl:AcceptableUsePolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:Access a owl:Class ;
    rdfs:label "Access" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Use ;
    skos:altLabel "Access" ;
    skos:definition "to access data" ;
    skos:exactMatch dpv:Access,
        dpv_upstream:Access,
        dpv_owl:Access ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:AccountManagement a owl:Class ;
    rdfs:label "AccountManagement" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Account Management" ;
    skos:definition """Account Management refers to purposes associated with account
management, such as to create, provide, maintain, and manage accounts""" ;
    skos:exactMatch dpv:AccountManagement,
        dpv_upstream:AccountManagement,
        dpv_owl:AccountManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Acquire a owl:Class ;
    rdfs:label "Acquire" ;
    rdfs:subClassOf dpv:Obtain,
        dpv:Processing ;
    skos:altLabel "Acquire" ;
    skos:definition "to come into possession or control of the data" ;
    skos:exactMatch dpv:Acquire,
        dpv_upstream:Acquire,
        dpv_owl:Acquire ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:ActiveRight a owl:Class ;
    rdfs:label "ActiveRight" ;
    rdfs:subClassOf dpv:Right ;
    skos:altLabel "Active Right" ;
    skos:definition """The right(s) applicable, provided, or expected that need to be
(actively) exercised""" ;
    skos:exactMatch dpv:ActiveRight,
        dpv_upstream:ActiveRight,
        dpv_owl:ActiveRight ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Active rights require the entity to expressly exercise them. For
example, a Data Subject exercising their right to withdraw their
consent.""" ;
    dpv:skos_in_scheme "rights-classes" .

dpv:ActivelyInvolved a owl:Class ;
    rdfs:label "ActivelyInvolved" ;
    rdfs:subClassOf dpv:InvolvementStatus ;
    skos:altLabel "Actively Involved" ;
    skos:definition "Status indicating the specified context is 'actively' involved" ;
    skos:exactMatch dpv:ActivelyInvolved,
        dpv_upstream:ActivelyInvolved,
        dpv_owl:ActivelyInvolved ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of active involvement is a person directly using a system to
enter information""" ;
    dpv:skos_in_scheme "status-classes" .

dpv:ActivityCompleted a owl:Class ;
    rdfs:label "ActivityCompleted" ;
    rdfs:subClassOf dpv:ActivityStatus ;
    skos:altLabel "Activity Completed" ;
    skos:definition "State of an activity that has completed i.e. is fully in the past" ;
    skos:exactMatch dpv:ActivityCompleted,
        dpv_upstream:ActivityCompleted,
        dpv_owl:ActivityCompleted ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ActivityHalted a owl:Class ;
    rdfs:label "ActivityHalted" ;
    rdfs:subClassOf dpv:ActivityStatus ;
    skos:altLabel "Activity Halted" ;
    skos:definition """State of an activity that was occurring in the past, and has been halted
or paused or stopped""" ;
    skos:exactMatch dpv:ActivityHalted,
        dpv_upstream:ActivityHalted,
        dpv_owl:ActivityHalted ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ActivityMonitoring a owl:Class ;
    rdfs:label "ActivityMonitoring" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Activity Monitoring" ;
    skos:definition """Monitoring of activities including assessing whether they have been
successfully initiated and completed""" ;
    skos:exactMatch dpv:ActivityMonitoring,
        dpv_upstream:ActivityMonitoring,
        dpv_owl:ActivityMonitoring ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:ActivityNotCompleted a owl:Class ;
    rdfs:label "ActivityNotCompleted" ;
    rdfs:subClassOf dpv:ActivityStatus ;
    skos:altLabel "Activity Not Completed" ;
    skos:definition """State of an activity that could not be completed, but has reached some
end state""" ;
    skos:exactMatch dpv:ActivityNotCompleted,
        dpv_upstream:ActivityNotCompleted,
        dpv_owl:ActivityNotCompleted ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This relates to a 'Stop' state as distinct from a 'Halt' state. It makes
no comments on whether the Activity can be resumed or continued towards
completion.""" ;
    dpv:skos_in_scheme "status-classes" .

dpv:ActivityOngoing a owl:Class ;
    rdfs:label "ActivityOngoing" ;
    rdfs:subClassOf dpv:ActivityStatus ;
    skos:altLabel "Activity Ongoing" ;
    skos:definition "State of an activity occurring in continuation i.e. currently ongoing" ;
    skos:exactMatch dpv:ActivityOngoing,
        dpv_upstream:ActivityOngoing,
        dpv_owl:ActivityOngoing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ActivityPlanned a owl:Class ;
    rdfs:label "ActivityPlanned" ;
    rdfs:subClassOf dpv:ActivityStatus ;
    skos:altLabel "Activity Planned" ;
    skos:definition """State of an activity being planned with concrete plans for
implementation""" ;
    skos:exactMatch dpv:ActivityPlanned,
        dpv_upstream:ActivityPlanned,
        dpv_owl:ActivityPlanned ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ActivityProposed a owl:Class ;
    rdfs:label "ActivityProposed" ;
    rdfs:subClassOf dpv:ActivityStatus ;
    skos:altLabel "Activity Proposed" ;
    skos:definition """State of an activity being proposed without any concrete plans for
implementation""" ;
    skos:exactMatch dpv:ActivityProposed,
        dpv_upstream:ActivityProposed,
        dpv_owl:ActivityProposed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:Adapt a owl:Class ;
    rdfs:label "Adapt" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Transform ;
    skos:altLabel "Adapt" ;
    skos:definition "to modify the data, often rewritten into a new form for a new use" ;
    skos:exactMatch dpv:Adapt,
        dpv_upstream:Adapt,
        dpv_owl:Adapt ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:Adult a owl:Class ;
    rdfs:label "Adult" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Adult" ;
    skos:definition """A natural person that is not a child i.e. has attained some legally
specified age of adulthood""" ;
    skos:exactMatch dpv:Adult,
        dpv_upstream:Adult,
        dpv_owl:Adult ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:AgeVerification a owl:Class ;
    rdfs:label "AgeVerification" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:Verification ;
    skos:altLabel "Age Verification" ;
    skos:definition """Purposes associated with verifying or authenticating age or age related
information as a form of security""" ;
    skos:exactMatch dpv:AgeVerification,
        dpv_upstream:AgeVerification,
        dpv_owl:AgeVerification ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Age Verification can include verification of the exact age, e.g. being
21 years old, a date, e.g. birth date is 01 January 1969, or a
condition, e.g. age is over 21 years and the person is an adult.
Specific dedicated resources should be used to further express
information and processes associated with Age Verification, for example
the Age Verification Vocabulary https://w3id.org/age/""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Aggregate a owl:Class ;
    rdfs:label "Aggregate" ;
    rdfs:subClassOf dpv:Alter,
        dpv:Processing ;
    skos:altLabel "Aggregate" ;
    skos:definition "to aggregate data" ;
    skos:exactMatch dpv:Aggregate,
        dpv_upstream:Aggregate,
        dpv_owl:Aggregate ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpr:Aggregate ;
    dpv:skos_in_scheme "processing-classes" .

dpv:AlgorithmicLogic a owl:Class ;
    rdfs:label "AlgorithmicLogic" ;
    rdfs:subClassOf dpv:ProcessingContext ;
    skos:altLabel "Algorithmic Logic" ;
    skos:definition "The algorithmic logic applied or used" ;
    skos:exactMatch dpv:AlgorithmicLogic,
        dpv_upstream:AlgorithmicLogic,
        dpv_owl:AlgorithmicLogic ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Algorithmic Logic is intended as a broad concept for explaining the use
of algorithms and automated decisions making within Processing. To
describe the actual algorithm, see the Algorithm concept.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:Align a owl:Class ;
    rdfs:label "Align" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Transform ;
    skos:altLabel "Align" ;
    skos:definition "to adjust the data to be in relation to another data" ;
    skos:exactMatch dpv:Align,
        dpv_upstream:Align,
        dpv_owl:Align ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:AmbulanceProvider a owl:Class ;
    rdfs:label "AmbulanceProvider" ;
    rdfs:subClassOf dpv:EmergencyServiceProvider ;
    skos:altLabel "Ambulance Provider" ;
    skos:definition """An organisation that that offers transportation and medical care to
patients requiring urgent medical attention""" ;
    skos:exactMatch dpv:AmbulanceProvider,
        dpv_upstream:AmbulanceProvider,
        dpv_owl:AmbulanceProvider ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:Analyse a owl:Class ;
    rdfs:label "Analyse" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Use ;
    skos:altLabel "Analyse" ;
    skos:definition "to study or examine the data in detail" ;
    skos:exactMatch dpv:Analyse,
        dpv_upstream:Analyse,
        dpv_owl:Analyse ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpr:Analyse ;
    dpv:skos_in_scheme "processing-classes" .

dpv:Anonymisation a owl:Class ;
    rdfs:label "Anonymisation" ;
    rdfs:subClassOf dpv:Deidentification,
        dpv:TechnicalMeasure ;
    skos:altLabel "Anonymisation" ;
    skos:definition """Anonymisation is the process by which data is irreversibly altered in
such a way that a data subject can no longer be identified directly or
indirectly, either by the entity holding the data alone or in
collaboration with other entities and information sources""" ;
    skos:exactMatch dpv:Anonymisation,
        dpv_upstream:Anonymisation,
        dpv_owl:Anonymisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:Anonymise a owl:Class ;
    rdfs:label "Anonymise" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Transform ;
    skos:altLabel "Anonymise" ;
    skos:definition """to irreversibly alter personal data in such a way that an unique data
subject can no longer be identified directly or indirectly or in
combination with other data""" ;
    skos:exactMatch dpv:Anonymise,
        dpv_upstream:Anonymise,
        dpv_owl:Anonymise ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpr:Anonymise ;
    dpv:skos_in_scheme "processing-classes" .

dpv:AnonymisedData a owl:Class ;
    rdfs:label "AnonymisedData" ;
    rdfs:subClassOf dpv:NonPersonalData ;
    skos:altLabel "Anonymised Data" ;
    skos:definition """Personal Data that has been (fully and completely) anonymised so that it
is no longer considered Personal Data""" ;
    skos:exactMatch dpv:AnonymisedData,
        dpv_upstream:AnonymisedData,
        dpv_owl:AnonymisedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """It is advised to carefully consider indicating data is fully or
completely anonymised by determining whether the data by itself or in
combination with other data can identify a person. Failing this
condition, the data should be denoted as PseudonymisedData. To indicate
data is anonymised only for a specified entity (e.g. within an
organisation), the concept ContextuallyAnonymisedData (as subclass of
PseudonymisedData) should be used instead of AnonymisedData.""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:Applicant a owl:Class ;
    rdfs:label "Applicant" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Applicant" ;
    skos:definition "Humans that are applicants in some context" ;
    skos:exactMatch dpv:Applicant,
        dpv_upstream:Applicant,
        dpv_owl:Applicant ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:ApprovalProcedure a owl:Class ;
    rdfs:label "ApprovalProcedure" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Approval Procedure" ;
    skos:definition """A procedure or process for determining and managing approvals for
activities as part of governance""" ;
    skos:exactMatch dpv:ApprovalProcedure,
        dpv_upstream:ApprovalProcedure,
        dpv_owl:ApprovalProcedure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:Assess a owl:Class ;
    rdfs:label "Assess" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Use ;
    skos:altLabel "Assess" ;
    skos:definition "to assess data for some criteria" ;
    skos:exactMatch dpv:Assess,
        dpv_upstream:Assess,
        dpv_owl:Assess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:AssetManagementProcedures a owl:Class ;
    rdfs:label "AssetManagementProcedures" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Asset Management Procedures" ;
    skos:definition "Procedures related to management of assets" ;
    skos:exactMatch dpv:AssetManagementProcedures,
        dpv_upstream:AssetManagementProcedures,
        dpv_owl:AssetManagementProcedures ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:AssistiveAutomation a owl:Class ;
    rdfs:label "AssistiveAutomation" ;
    rdfs:subClassOf dpv:AutomationLevel ;
    skos:altLabel "Assistive Automation" ;
    skos:definition """Level of automation corresponding to Level 1 in ISO/IEC 22989:2022 where
automation is limited to parts of the system or a specific part of the
system in a manner that does not change the control of the human in
using/driving the system""" ;
    skos:exactMatch dpv:AssistiveAutomation,
        dpv_upstream:AssistiveAutomation,
        dpv_owl:AssistiveAutomation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Human Involvement is implied here, specifically the ability to make
decisions regarding operations, but also possibly for intervention,
oversight, and verification""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:AsylumSeeker a owl:Class ;
    rdfs:label "AsylumSeeker" ;
    rdfs:subClassOf dpv:HumanSubject,
        dpv:VulnerableHuman ;
    skos:altLabel "Asylum Seeker" ;
    skos:definition "Humans that are asylum seekers" ;
    skos:exactMatch dpv:AsylumSeeker,
        dpv_upstream:AsylumSeeker,
        dpv_owl:AsylumSeeker ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:AsymmetricCryptography a owl:Class ;
    rdfs:label "AsymmetricCryptography" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Asymmetric Cryptography" ;
    skos:definition """Use of public-key cryptography or asymmetric cryptography involving a
public and private pair of keys""" ;
    skos:exactMatch dpv:AsymmetricCryptography,
        dpv_upstream:AsymmetricCryptography,
        dpv_owl:AsymmetricCryptography ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:AsymmetricEncryption a owl:Class ;
    rdfs:label "AsymmetricEncryption" ;
    rdfs:subClassOf dpv:Encryption,
        dpv:TechnicalMeasure ;
    skos:altLabel "Asymmetric Encryption" ;
    skos:definition "Use of asymmetric cryptography to encrypt data" ;
    skos:exactMatch dpv:AsymmetricEncryption,
        dpv_upstream:AsymmetricEncryption,
        dpv_owl:AsymmetricEncryption ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:AuditApproved a owl:Class ;
    rdfs:label "AuditApproved" ;
    rdfs:subClassOf dpv:AuditStatus ;
    skos:altLabel "Audit Approved" ;
    skos:definition "State of being approved through the audit" ;
    skos:exactMatch dpv:AuditApproved,
        dpv_upstream:AuditApproved,
        dpv_owl:AuditApproved ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:AuditConditionallyApproved a owl:Class ;
    rdfs:label "AuditConditionallyApproved" ;
    rdfs:subClassOf dpv:AuditStatus ;
    skos:altLabel "Audit Conditionally Approved" ;
    skos:definition "State of being conditionally approved through the audit" ;
    skos:exactMatch dpv:AuditConditionallyApproved,
        dpv_upstream:AuditConditionallyApproved,
        dpv_owl:AuditConditionallyApproved ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """A "conditional approval" is intended to reflect states where the audit
has identified further changes which must be implemented before
considering the audit has been 'passed', without requiring another audit
to validate them. This is distinct from the case where an audit has
state 'rejected', which means changes must be made and submitted for
review. The requirements of a 'conditional acceptance' are expected to
be minor or not significant enough to warrant another audit to review
them.""" ;
    dpv:skos_in_scheme "status-classes" .

dpv:AuditNotRequired a owl:Class ;
    rdfs:label "AuditNotRequired" ;
    rdfs:subClassOf dpv:AuditStatus ;
    skos:altLabel "Audit Not Required" ;
    skos:definition "State where an audit is determined as not being required" ;
    skos:exactMatch dpv:AuditNotRequired,
        dpv_upstream:AuditNotRequired,
        dpv_owl:AuditNotRequired ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:AuditRejected a owl:Class ;
    rdfs:label "AuditRejected" ;
    rdfs:subClassOf dpv:AuditStatus ;
    skos:altLabel "Audit Rejected" ;
    skos:definition "State of not being approved or being rejected through the audit" ;
    skos:exactMatch dpv:AuditRejected,
        dpv_upstream:AuditRejected,
        dpv_owl:AuditRejected ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:AuditRequested a owl:Class ;
    rdfs:label "AuditRequested" ;
    rdfs:subClassOf dpv:AuditStatus ;
    skos:altLabel "Audit Requested" ;
    skos:definition "State of an audit being requested whose outcome is not yet known" ;
    skos:exactMatch dpv:AuditRequested,
        dpv_upstream:AuditRequested,
        dpv_owl:AuditRequested ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:AuditRequired a owl:Class ;
    rdfs:label "AuditRequired" ;
    rdfs:subClassOf dpv:AuditStatus ;
    skos:altLabel "Audit Required" ;
    skos:definition """State where an audit is determined as being required but has not been
conducted""" ;
    skos:exactMatch dpv:AuditRequired,
        dpv_upstream:AuditRequired,
        dpv_owl:AuditRequired ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:AuthorisationProtocols a owl:Class ;
    rdfs:label "AuthorisationProtocols" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Authorisation Protocols" ;
    skos:definition """Protocols involving authorisation of roles or profiles to determine
permission, rights, or privileges""" ;
    skos:exactMatch dpv:AuthorisationProtocols,
        dpv_upstream:AuthorisationProtocols,
        dpv_owl:AuthorisationProtocols ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:AuthorityInformed a owl:Class ;
    rdfs:label "AuthorityInformed" ;
    rdfs:subClassOf dpv:EntityInformed,
        dpv:EntityInformedStatus ;
    skos:altLabel "Authority Informed" ;
    skos:definition """Status indicating Authority has been informed about the specified
context""" ;
    skos:exactMatch dpv:AuthorityInformed,
        dpv_upstream:AuthorityInformed,
        dpv_owl:AuthorityInformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:AuthorityUninformed a owl:Class ;
    rdfs:label "AuthorityUninformed" ;
    rdfs:subClassOf dpv:EntityInformedStatus,
        dpv:EntityUninformed ;
    skos:altLabel "Authority Uninformed" ;
    skos:definition """Status indicating Authority is uninformed i.e. has not been informed
about the specified context""" ;
    skos:exactMatch dpv:AuthorityUninformed,
        dpv_upstream:AuthorityUninformed,
        dpv_owl:AuthorityUninformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:AutomatedDecisionMaking a owl:Class ;
    rdfs:label "AutomatedDecisionMaking" ;
    rdfs:subClassOf dpv:DecisionMaking ;
    skos:altLabel "Automated Decision Making" ;
    skos:definition "Processing that involves automated decision making" ;
    skos:exactMatch dpv:AutomatedDecisionMaking,
        dpv_upstream:AutomatedDecisionMaking,
        dpv_owl:AutomatedDecisionMaking ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Automated decision making can be defined as “the ability to make
decisions by technological means without human involvement.”
(“Guidelines on Automated individual decision-making and Profiling for
the purposes of Regulation 2016/679 (wp251rev.01)”, 2018, p. 8)""" ;
    skos:relatedMatch iso22989:Decision ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:AutomatedScoringOfIndividuals a owl:Class ;
    rdfs:label "AutomatedScoringOfIndividuals" ;
    rdfs:subClassOf dpv:ScoringOfIndividuals ;
    skos:altLabel "Automated Scoring of Individuals" ;
    skos:definition "Processing that involves automated scoring of individuals" ;
    skos:exactMatch dpv:AutomatedScoringOfIndividuals,
        dpv_upstream:AutomatedScoringOfIndividuals,
        dpv_owl:AutomatedScoringOfIndividuals ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Scoring can lead to the action being considered Decision Making if the
scoring is itself a decision - see 2023-MAR-16 opinion of Advocate
General on Case C 634/21. Therefore, the assessment of whether scoring
was automated or not is important given the legal obligations
surrounding automated decision making e.g. in GDPR""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:Autonomous a owl:Class ;
    rdfs:label "Autonomous" ;
    rdfs:subClassOf dpv:AutomationLevel ;
    skos:altLabel "Autonomous" ;
    skos:definition """Level of automation corresponding to Level 6 in ISO/IEC 22989:2022 where
the automation in system is capable of modifying its operation domain or
its goals without external intervention, control or oversight""" ;
    skos:exactMatch dpv:Autonomous,
        dpv_upstream:Autonomous,
        dpv_owl:Autonomous ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Though Autonomous, such operations can still be associated with
dpv:HumanInvolved e.g. for inputs, oversight or verification""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:B2B2CContract a owl:Class ;
    rdfs:label "B2B2CContract" ;
    rdfs:subClassOf dpv:B2BContract,
        dpv:B2CContract,
        dpv:LegalBasis ;
    skos:altLabel "Business-to-Business-to-Consumer Contract" ;
    skos:definition """A contract between two businesses who partner together to provide
services to a consumer""" ;
    skos:exactMatch dpv:B2B2CContract,
        dpv_upstream:B2B2CContract,
        dpv_owl:B2B2CContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:BackgroundChecks a owl:Class ;
    rdfs:label "BackgroundChecks" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SecurityProcedure ;
    skos:altLabel "Background Checks" ;
    skos:definition """Procedure where the background of an entity is assessed to identity
vulnerabilities and threats due to their current or intended role""" ;
    skos:exactMatch dpv:BackgroundChecks,
        dpv_upstream:BackgroundChecks,
        dpv_owl:BackgroundChecks ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:BiometricAuthentication a owl:Class ;
    rdfs:label "BiometricAuthentication" ;
    rdfs:subClassOf dpv:AuthenticationProtocols,
        dpv:TechnicalMeasure ;
    skos:altLabel "Biometric Authentication" ;
    skos:definition "Use of biometric data for authentication" ;
    skos:exactMatch dpv:BiometricAuthentication,
        dpv_upstream:BiometricAuthentication,
        dpv_owl:BiometricAuthentication ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:C2BContract a owl:Class ;
    rdfs:label "C2BContract" ;
    rdfs:subClassOf dpv:ContractByEntityType,
        dpv:LegalBasis ;
    skos:altLabel "Consumer-to-Business Contract" ;
    skos:definition """A contract between a consumer and a business where the business
purchases goods or services from the consumer""" ;
    skos:exactMatch dpv:C2BContract,
        dpv_upstream:C2BContract,
        dpv_owl:C2BContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:C2CContract a owl:Class ;
    rdfs:label "C2CContract" ;
    rdfs:subClassOf dpv:ContractByEntityType,
        dpv:LegalBasis ;
    skos:altLabel "Consumer-to-Consumer Contract" ;
    skos:definition "A contract between two consumers" ;
    skos:exactMatch dpv:C2CContract,
        dpv_upstream:C2CContract,
        dpv_owl:C2CContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:CannotChallengeProcess a owl:Class ;
    rdfs:label "CannotChallengeProcess" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Challenge Process" ;
    skos:definition """Involvement where entity cannot challenge the process of specified
context""" ;
    skos:exactMatch dpv:CannotChallengeProcess,
        dpv_upstream:CannotChallengeProcess,
        dpv_owl:CannotChallengeProcess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Challenge refers to raising questions about validity, necessity,
correctness, or other similar 'trustworthiness' attributes regarding the
process or plan or implementation""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotChallengeProcessInput a owl:Class ;
    rdfs:label "CannotChallengeProcessInput" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Challenge Process Input" ;
    skos:definition "Involvement where entity cannot challenge input of specified context" ;
    skos:exactMatch dpv:CannotChallengeProcessInput,
        dpv_upstream:CannotChallengeProcessInput,
        dpv_owl:CannotChallengeProcessInput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotChallengeProcessOutput a owl:Class ;
    rdfs:label "CannotChallengeProcessOutput" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Challenge Process Output" ;
    skos:definition """Involvement where entity cannot challenge the output of specified
context""" ;
    skos:exactMatch dpv:CannotChallengeProcessOutput,
        dpv_upstream:CannotChallengeProcessOutput,
        dpv_owl:CannotChallengeProcessOutput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Challenge refers to raising questions about validity, necessity,
correctness, or other similar 'trustworthiness' attributes regarding the
output of the process or plan or implementation (where output is
distinct from the process itself)""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotCorrectProcess a owl:Class ;
    rdfs:label "CannotCorrectProcess" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Correct Process" ;
    skos:definition "Involvement where entity cannot correct the process of specified context" ;
    skos:exactMatch dpv:CannotCorrectProcess,
        dpv_upstream:CannotCorrectProcess,
        dpv_owl:CannotCorrectProcess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotCorrectProcessInput a owl:Class ;
    rdfs:label "CannotCorrectProcessInput" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Correct Process Input" ;
    skos:definition "Involvement where entity cannot correct input of specified context" ;
    skos:exactMatch dpv:CannotCorrectProcessInput,
        dpv_upstream:CannotCorrectProcessInput,
        dpv_owl:CannotCorrectProcessInput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotCorrectProcessOutput a owl:Class ;
    rdfs:label "CannotCorrectProcessOutput" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Correct Process Output" ;
    skos:definition "Involvement where entity cannot correct the output of specified context" ;
    skos:exactMatch dpv:CannotCorrectProcessOutput,
        dpv_upstream:CannotCorrectProcessOutput,
        dpv_owl:CannotCorrectProcessOutput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotObjectToProcess a owl:Class ;
    rdfs:label "CannotObjectToProcess" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Object to Process" ;
    skos:definition "Involvement where entity cannot object to process of specified context" ;
    skos:exactMatch dpv:CannotObjectToProcess,
        dpv_upstream:CannotObjectToProcess,
        dpv_owl:CannotObjectToProcess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotOptInToProcess a owl:Class ;
    rdfs:label "CannotOptInToProcess" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Opt-in to Process" ;
    skos:definition "Involvement where entity cannot opt-in to specified context" ;
    skos:exactMatch dpv:CannotOptInToProcess,
        dpv_upstream:CannotOptInToProcess,
        dpv_owl:CannotOptInToProcess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotOptOutFromProcess a owl:Class ;
    rdfs:label "CannotOptOutFromProcess" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Opt-out from Process" ;
    skos:definition "Involvement where entity cannot opt-out from specified context" ;
    skos:exactMatch dpv:CannotOptOutFromProcess,
        dpv_upstream:CannotOptOutFromProcess,
        dpv_owl:CannotOptOutFromProcess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotReverseProcessEffects a owl:Class ;
    rdfs:label "CannotReverseProcessEffects" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Reverse Process Effects" ;
    skos:definition "Involvement where entity cannot reverse effects of specified context" ;
    skos:exactMatch dpv:CannotReverseProcessEffects,
        dpv_upstream:CannotReverseProcessEffects,
        dpv_owl:CannotReverseProcessEffects ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Effects refer to consequences and impacts arising from the process or
from the outputs of a process""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotReverseProcessInput a owl:Class ;
    rdfs:label "CannotReverseProcessInput" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Reverse Process Input" ;
    skos:definition "Involvement where entity cannot reverse input of specified context" ;
    skos:exactMatch dpv:CannotReverseProcessInput,
        dpv_upstream:CannotReverseProcessInput,
        dpv_owl:CannotReverseProcessInput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Reversion can be considered a form of correction in some instances. We
welcome inputs to further explore and define this relation between
correction and reversion concepts.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotReverseProcessOutput a owl:Class ;
    rdfs:label "CannotReverseProcessOutput" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Reverse Process Output" ;
    skos:definition "Involvement where entity cannot reverse output of specified context" ;
    skos:exactMatch dpv:CannotReverseProcessOutput,
        dpv_upstream:CannotReverseProcessOutput,
        dpv_owl:CannotReverseProcessOutput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CannotWithdrawFromProcess a owl:Class ;
    rdfs:label "CannotWithdrawFromProcess" ;
    rdfs:subClassOf dpv:EntityNonPermissiveInvolvement ;
    skos:altLabel "Cannot Withdraw from Process" ;
    skos:definition """Involvement where entity cannot withdraw a previously given assent from
specified context""" ;
    skos:exactMatch dpv:CannotWithdrawFromProcess,
        dpv_upstream:CannotWithdrawFromProcess,
        dpv_owl:CannotWithdrawFromProcess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:Certification a owl:Class ;
    rdfs:label "Certification" ;
    rdfs:subClassOf dpv:CertificationSeal,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Certification" ;
    skos:definition """Certification mechanisms, seals, and marks for the purpose of
demonstrating compliance""" ;
    skos:exactMatch dpv:Certification,
        dpv_upstream:Certification,
        dpv_owl:Certification ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ChallengingProcess a owl:Class ;
    rdfs:label "ChallengingProcess" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Challenging Process" ;
    skos:definition "Involvement where entity can challenge the process of specified context" ;
    skos:exactMatch dpv:ChallengingProcess,
        dpv_upstream:ChallengingProcess,
        dpv_owl:ChallengingProcess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Challenge refers to raising questions about validity, necessity,
correctness, or other similar 'trustworthiness' attributes regarding the
process or plan or implementation""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ChallengingProcessInput a owl:Class ;
    rdfs:label "ChallengingProcessInput" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Challenging Process Input" ;
    skos:definition "Involvement where entity can challenge input of specified context" ;
    skos:exactMatch dpv:ChallengingProcessInput,
        dpv_upstream:ChallengingProcessInput,
        dpv_owl:ChallengingProcessInput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ChallengingProcessOutput a owl:Class ;
    rdfs:label "ChallengingProcessOutput" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Challenging Process Output" ;
    skos:definition "Involvement where entity can challenge the output of specified context" ;
    skos:exactMatch dpv:ChallengingProcessOutput,
        dpv_upstream:ChallengingProcessOutput,
        dpv_owl:ChallengingProcessOutput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Challenge refers to raising questions about validity, necessity,
correctness, or other similar 'trustworthiness' attributes regarding the
output of the process or plan or implementation (where output is
distinct from the process itself)""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CharityOrganisation a owl:Class ;
    rdfs:label "CharityOrganisation" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Charity Organisation" ;
    skos:definition """A nonprofit entity dedicated to providing assistance or raising funds
for social, educational, religious, or other philanthropic purposes""" ;
    skos:exactMatch dpv:CharityOrganisation,
        dpv_upstream:CharityOrganisation,
        dpv_owl:CharityOrganisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:Child a owl:Class ;
    rdfs:label "Child" ;
    rdfs:subClassOf dpv:HumanSubject,
        dpv:VulnerableHuman ;
    skos:altLabel "Child" ;
    skos:definition """A 'child' is a natural legal person who is below a certain legal age
depending on the legal jurisdiction.""" ;
    skos:exactMatch dpv:Child,
        dpv_upstream:Child,
        dpv_owl:Child ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The legality of age defining a child varies by jurisdiction. In
addition, 'child' is distinct from a 'minor'. For example, the legal age
for consumption of alcohol can be 21, which makes a person of age 20 a
'minor' in this context. In other cases, 'minor' and 'child' are used
interchangeably to refer to a person below some legally defined age.""" ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:Citizen a owl:Class ;
    rdfs:label "Citizen" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Citizen" ;
    skos:definition "Humans that are citizens (for a jurisdiction)" ;
    skos:exactMatch dpv:Citizen,
        dpv_upstream:Citizen,
        dpv_owl:Citizen ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:City a owl:Class ;
    rdfs:label "City" ;
    rdfs:subClassOf dpv:DpvRegion ;
    skos:altLabel "City" ;
    skos:definition "A region consisting of urban population and commerce" ;
    skos:exactMatch dpv:City,
        dpv_upstream:City,
        dpv_owl:City ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:Client a owl:Class ;
    rdfs:label "Client" ;
    rdfs:subClassOf dpv:DpvCustomer,
        dpv:HumanSubject ;
    skos:altLabel "Client" ;
    skos:definition "Humans that are clients or recipients of services" ;
    skos:exactMatch dpv:Client,
        dpv_upstream:Client,
        dpv_owl:Client ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:Clinic a owl:Class ;
    rdfs:label "Clinic" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "Clinic" ;
    skos:definition """An organisation that is a smaller healthcare facility offering
outpatient medical services for diagnosis and treatment""" ;
    skos:exactMatch dpv:Clinic,
        dpv_upstream:Clinic,
        dpv_owl:Clinic ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:CloudLocation a owl:Class ;
    rdfs:label "CloudLocation" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:RemoteLocation ;
    skos:altLabel "Cloud Location" ;
    skos:definition """Location that is in the 'cloud' i.e. a logical location operated over
the internet""" ;
    skos:exactMatch dpv:CloudLocation,
        dpv_upstream:CloudLocation,
        dpv_owl:CloudLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:CodeOfConduct a owl:Class ;
    rdfs:label "CodeOfConduct" ;
    rdfs:subClassOf dpv:GuidelinesPrinciple,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Code of Conduct" ;
    skos:definition """A set of rules or procedures outlining the norms and practices for
conducting activities""" ;
    skos:exactMatch dpv:CodeOfConduct,
        dpv_upstream:CodeOfConduct,
        dpv_owl:CodeOfConduct ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:Collect a owl:Class ;
    rdfs:label "Collect" ;
    rdfs:subClassOf dpv:Obtain,
        dpv:Processing ;
    skos:altLabel "Collect" ;
    skos:definition "to gather data from someone" ;
    skos:exactMatch dpv:Collect,
        dpv_upstream:Collect,
        dpv_owl:Collect ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpr:Collect ;
    dpv:skos_in_scheme "processing-classes" .

dpv:CombatClimateChange a owl:Class ;
    rdfs:label "CombatClimateChange" ;
    rdfs:subClassOf dpv:PublicBenefit,
        dpv:Purpose ;
    skos:altLabel "Combat Climate Change" ;
    skos:definition """Purposes associated with combating the causes and consequences of
climate change, including reducing gas emissions and fighting
emergencies such as floods or wildfires""" ;
    skos:exactMatch dpv:CombatClimateChange,
        dpv_upstream:CombatClimateChange,
        dpv_owl:CombatClimateChange ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.16" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Combine a owl:Class ;
    rdfs:label "Combine" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Transform ;
    skos:altLabel "Combine" ;
    skos:definition "to join or merge data" ;
    skos:exactMatch dpv:Combine,
        dpv_upstream:Combine,
        dpv_owl:Combine ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpr:Aggregate ;
    dpv:skos_in_scheme "processing-classes" .

dpv:CommercialResearch a owl:Class ;
    rdfs:label "CommercialResearch" ;
    rdfs:subClassOf dpv:CommercialPurpose,
        dpv:Purpose,
        dpv:ResearchAndDevelopment ;
    skos:altLabel "Commercial Research" ;
    skos:definition """Purposes associated with conducting research in a commercial setting or
with intention to commercialise e.g. in a company or sponsored by a
company""" ;
    skos:exactMatch dpv:CommercialResearch,
        dpv_upstream:CommercialResearch,
        dpv_owl:CommercialResearch ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpu:Develop ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:CommerciallyConfidentialData a owl:Class ;
    rdfs:label "CommerciallyConfidentialData" ;
    rdfs:subClassOf dpv:ConfidentialData ;
    skos:altLabel "Commercially Confidential Data" ;
    skos:definition """Data that is considered confidential due to business/trade secrets,
confidentiality agreements, or company secrets""" ;
    skos:exactMatch dpv:CommerciallyConfidentialData,
        dpv_upstream:CommerciallyConfidentialData,
        dpv_owl:CommerciallyConfidentialData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 6.5(c)" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:CommunicationForCustomerCare a owl:Class ;
    rdfs:label "CommunicationForCustomerCare" ;
    rdfs:subClassOf dpv:CommunicationManagement,
        dpv:CustomerCare,
        dpv:Purpose ;
    skos:altLabel "Communication for Customer Care" ;
    skos:definition """Customer Care Communication refers to purposes associated with
communicating with customers for assisting them, resolving issues,
ensuring satisfaction, etc. in relation to services provided""" ;
    skos:exactMatch dpv:CommunicationForCustomerCare,
        dpv_upstream:CommunicationForCustomerCare,
        dpv_owl:CommunicationForCustomerCare ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:CompatibilityUnknown a owl:Class ;
    rdfs:label "CompatibilityUnknown" ;
    rdfs:subClassOf dpv:ReuseCompatibility ;
    skos:altLabel "Compatibility Unknown" ;
    skos:definition """Status indicating the compatibility of the context with an earlier
context is currently unknown""" ;
    skos:exactMatch dpv:CompatibilityUnknown,
        dpv_upstream:CompatibilityUnknown,
        dpv_owl:CompatibilityUnknown ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ComplianceIndeterminate a owl:Class ;
    rdfs:label "ComplianceIndeterminate" ;
    rdfs:subClassOf dpv:ComplianceStatus ;
    skos:altLabel "Compliance Indeterminate" ;
    skos:definition """State where the status of compliance has not been fully assessed,
evaluated, or determined""" ;
    skos:exactMatch dpv:ComplianceIndeterminate,
        dpv_upstream:ComplianceIndeterminate,
        dpv_owl:ComplianceIndeterminate ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ComplianceMonitoring a owl:Class ;
    rdfs:label "ComplianceMonitoring" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Compliance Monitoring" ;
    skos:definition "Monitoring of compliance (e.g. internal policy, regulations)" ;
    skos:exactMatch dpv:ComplianceMonitoring,
        dpv_upstream:ComplianceMonitoring,
        dpv_owl:ComplianceMonitoring ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ComplianceUnknown a owl:Class ;
    rdfs:label "ComplianceUnknown" ;
    rdfs:subClassOf dpv:ComplianceStatus ;
    skos:altLabel "Compliance Unknown" ;
    skos:definition "State where the status of compliance is unknown" ;
    skos:exactMatch dpv:ComplianceUnknown,
        dpv_upstream:ComplianceUnknown,
        dpv_owl:ComplianceUnknown ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ComplianceViolation a owl:Class ;
    rdfs:label "ComplianceViolation" ;
    rdfs:subClassOf dpv:ComplianceStatus ;
    skos:altLabel "Compliance Violation" ;
    skos:definition """State where compliance cannot be achieved due to requirements being
violated""" ;
    skos:exactMatch dpv:ComplianceViolation,
        dpv_upstream:ComplianceViolation,
        dpv_owl:ComplianceViolation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Changed from \"violation of compliance\" for consistency with other terms" ;
    dpv:skos_in_scheme "status-classes" .

dpv:Compliant a owl:Class ;
    rdfs:label "Compliant" ;
    rdfs:subClassOf dpv:ComplianceStatus ;
    skos:altLabel "Compliant" ;
    skos:definition "State of being fully compliant" ;
    skos:exactMatch dpv:Compliant,
        dpv_upstream:Compliant,
        dpv_owl:Compliant ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ConditionalAutomation a owl:Class ;
    rdfs:label "ConditionalAutomation" ;
    rdfs:subClassOf dpv:AutomationLevel ;
    skos:altLabel "Conditional Automation" ;
    skos:definition """Level of automation corresponding to Level 3 in ISO/IEC 22989:2022 where
the automation is sufficient to perform most tasks of the system with
the human present to take over where necessary""" ;
    skos:exactMatch dpv:ConditionalAutomation,
        dpv_upstream:ConditionalAutomation,
        dpv_owl:ConditionalAutomation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Human Involvement is implied here, e.g. for intervention, input,
decisions""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ConfidentialityAgreement a owl:Class ;
    rdfs:label "ConfidentialityAgreement" ;
    rdfs:subClassOf dpv:LegalAgreement,
        dpv:LegalMeasure ;
    skos:altLabel "Confidentiality Agreement" ;
    skos:definition """Agreements that enforce confidentiality for e.g. to protect business,
professional, or company secrets""" ;
    skos:exactMatch dpv:ConfidentialityAgreement,
        dpv_upstream:ConfidentialityAgreement,
        dpv_owl:ConfidentialityAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 3.1.a" ;
    dpv:skos_in_scheme "legal-measures-classes" .

dpv:ConformanceAssessment a owl:Class ;
    rdfs:label "ConformanceAssessment" ;
    rdfs:subClassOf dpv:Assessment,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Conformance Assessment" ;
    skos:definition """Assessment regarding conformance with standards or norms or guidelines
or similar instruments""" ;
    skos:exactMatch dpv:ConformanceAssessment,
        dpv_upstream:ConformanceAssessment,
        dpv_owl:ConformanceAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:Conformant a owl:Class ;
    rdfs:label "Conformant" ;
    rdfs:subClassOf dpv:ConformanceStatus ;
    skos:altLabel "Conformant" ;
    skos:definition "State of being conformant" ;
    skos:exactMatch dpv:Conformant,
        dpv_upstream:Conformant,
        dpv_owl:Conformant ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ConsentExpired a owl:Class ;
    rdfs:label "ConsentExpired" ;
    rdfs:subClassOf dpv:ConsentStatus,
        dpv:ConsentStatusInvalidForProcessing ;
    skos:altLabel "Consent Expired" ;
    skos:definition """The state where the temporal or contextual validity of consent has
'expired'""" ;
    skos:exactMatch dpv:ConsentExpired,
        dpv_upstream:ConsentExpired,
        dpv_owl:ConsentExpired ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of this state is when the obtained consent has been assigned
a duration - which has lapsed or 'expired', making it invalid to be used
further for processing data""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:ConsentGiven a owl:Class ;
    rdfs:label "ConsentGiven" ;
    rdfs:subClassOf dpv:ConsentStatus,
        dpv:ConsentStatusValidForProcessing ;
    skos:altLabel "Consent Given" ;
    skos:definition "The state where consent has been given" ;
    skos:exactMatch dpv:ConsentGiven,
        dpv_upstream:ConsentGiven,
        dpv_owl:ConsentGiven ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of this state is when the individual clicks on a button,
ticks a checkbox, verbally agrees - or any other form that communicates
their decision agreeing to the processing of data""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:ConsentInvalidated a owl:Class ;
    rdfs:label "ConsentInvalidated" ;
    rdfs:subClassOf dpv:ConsentStatus,
        dpv:ConsentStatusInvalidForProcessing ;
    skos:altLabel "Consent Invalidated" ;
    skos:definition "The state where consent has been deemed to be invalid" ;
    skos:exactMatch dpv:ConsentInvalidated,
        dpv_upstream:ConsentInvalidated,
        dpv_owl:ConsentInvalidated ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of this state is where an investigating authority or a court
finds the collected consent did not meet requirements, and 'invalidates'
both prior and future uses of it to carry out processing""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:ConsentManagement a owl:Class ;
    rdfs:label "ConsentManagement" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:PermissionManagement ;
    skos:altLabel "Consent Management" ;
    skos:definition """Methods to obtain, provide, modify, and withdraw consent along with
maintaining a record of consent, retrieving records, and processing
changes in consent states""" ;
    skos:exactMatch dpv:ConsentManagement,
        dpv_upstream:ConsentManagement,
        dpv_owl:ConsentManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 12.n" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ConsentNotice a owl:Class ;
    rdfs:label "ConsentNotice" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:PrivacyNotice ;
    skos:altLabel "Consent Notice" ;
    skos:definition "A Notice for information provision associated with Consent" ;
    skos:exactMatch dpv:ConsentNotice,
        dpv_upstream:ConsentNotice,
        dpv_owl:ConsentNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes, organisational-measures-classes" .

dpv:ConsentReceipt a owl:Class ;
    rdfs:label "ConsentReceipt" ;
    rdfs:subClassOf dpv:ConsentRecord,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Consent Receipt" ;
    skos:definition """A record of consent or consent related activities that is provided to
another entity""" ;
    skos:exactMatch dpv:ConsentReceipt,
        dpv_upstream:ConsentReceipt,
        dpv_owl:ConsentReceipt ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ConsentRefused a owl:Class ;
    rdfs:label "ConsentRefused" ;
    rdfs:subClassOf dpv:ConsentStatus,
        dpv:ConsentStatusInvalidForProcessing ;
    skos:altLabel "Consent Refused" ;
    skos:definition "The state where consent has been refused" ;
    skos:exactMatch dpv:ConsentRefused,
        dpv_upstream:ConsentRefused,
        dpv_owl:ConsentRefused ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of this state is when the individual clicks on a 'disagree'
or 'reject' or 'refuse' button, or leaves a checkbox unticked""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:ConsentRequestDeferred a owl:Class ;
    rdfs:label "ConsentRequestDeferred" ;
    rdfs:subClassOf dpv:ConsentStatus,
        dpv:ConsentStatusInvalidForProcessing ;
    skos:altLabel "Consent Request Deferred" ;
    skos:definition "State where a request for consent has been deferred without a decision" ;
    skos:exactMatch dpv:ConsentRequestDeferred,
        dpv_upstream:ConsentRequestDeferred,
        dpv_owl:ConsentRequestDeferred ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of this state is when the individual closes or dismisses a
notice without making a decision. This state is intended for making the
distinction between a notice being provided (as a consent request) and
the individual interacting with the notice without making a decision -
where the 'ignoring of a notice' is taken as consent being neither given
nor refused""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:ConsentRequested a owl:Class ;
    rdfs:label "ConsentRequested" ;
    rdfs:subClassOf dpv:ConsentStatus,
        dpv:ConsentStatusInvalidForProcessing ;
    skos:altLabel "Consent Requested" ;
    skos:definition """State where a request for consent has been made and is awaiting a
decision""" ;
    skos:exactMatch dpv:ConsentRequested,
        dpv_upstream:ConsentRequested,
        dpv_owl:ConsentRequested ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of this state is when a notice has been presented to the
individual but they have not made a decision""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:ConsentRevoked a owl:Class ;
    rdfs:label "ConsentRevoked" ;
    rdfs:subClassOf dpv:ConsentStatus,
        dpv:ConsentStatusInvalidForProcessing ;
    skos:altLabel "Consent Revoked" ;
    skos:definition """The state where the consent is revoked by an entity other than the data
subject and which prevents it from being further used as a valid state""" ;
    skos:exactMatch dpv:ConsentRevoked,
        dpv_upstream:ConsentRevoked,
        dpv_owl:ConsentRevoked ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of this state is when a Data Controller stops utilising
previously obtaining consent, such as when that service no longer exists""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:ConsentUnknown a owl:Class ;
    rdfs:label "ConsentUnknown" ;
    rdfs:subClassOf dpv:ConsentStatus,
        dpv:ConsentStatusInvalidForProcessing ;
    skos:altLabel "Consent Unknown" ;
    skos:definition "State where information about consent is not available or is unknown" ;
    skos:exactMatch dpv:ConsentUnknown,
        dpv_upstream:ConsentUnknown,
        dpv_owl:ConsentUnknown ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Consent states can be unknown, for example, when information is not
available, or cannot be trusted, or is known to be inaccurate""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:ConsentWithdrawn a owl:Class ;
    rdfs:label "ConsentWithdrawn" ;
    rdfs:subClassOf dpv:ConsentStatus,
        dpv:ConsentStatusInvalidForProcessing ;
    skos:altLabel "Consent Withdrawn" ;
    skos:definition """The state where the consent is withdrawn or revoked specifically by the
data subject and which prevents it from being further used as a valid
state""" ;
    skos:exactMatch dpv:ConsentWithdrawn,
        dpv_upstream:ConsentWithdrawn,
        dpv_owl:ConsentWithdrawn ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This state can be considered a form of 'revocation' of consent, where
the revocation can only be performed by the data subject. Therefore we
suggest using ConsentRevoked when it is a non-data-subject entity, and
ConsentWithdrawn when it is the data subject""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:ConsequenceAsSideEffect a owl:Class ;
    rdfs:label "ConsequenceAsSideEffect" ;
    rdfs:subClassOf dpv:Consequence ;
    skos:altLabel "Consequence as Side-Effect" ;
    skos:definition """The consequence(s) possible or arising as a side-effect of specified
context""" ;
    skos:exactMatch dpv:ConsequenceAsSideEffect,
        dpv_upstream:ConsequenceAsSideEffect,
        dpv_owl:ConsequenceAsSideEffect ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-classes" .

dpv:ConsequenceOfFailure a owl:Class ;
    rdfs:label "ConsequenceOfFailure" ;
    rdfs:subClassOf dpv:Consequence ;
    skos:altLabel "Consequence of Failure" ;
    skos:definition "The consequence(s) possible or arising from failure of specified context" ;
    skos:exactMatch dpv:ConsequenceOfFailure,
        dpv_upstream:ConsequenceOfFailure,
        dpv_owl:ConsequenceOfFailure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-classes" .

dpv:ConsequenceOfSuccess a owl:Class ;
    rdfs:label "ConsequenceOfSuccess" ;
    rdfs:subClassOf dpv:Consequence ;
    skos:altLabel "Consequence of Success" ;
    skos:definition "The consequence(s) possible or arising from success of specified context" ;
    skos:exactMatch dpv:ConsequenceOfSuccess,
        dpv_upstream:ConsequenceOfSuccess,
        dpv_owl:ConsequenceOfSuccess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-classes" .

dpv:ConsultationWithAuthority a owl:Class ;
    rdfs:label "ConsultationWithAuthority" ;
    rdfs:subClassOf dpv:Consultation,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Consultation with Authority" ;
    skos:definition "Consultation with an authority or authoritative entity" ;
    skos:exactMatch dpv:ConsultationWithAuthority,
        dpv_upstream:ConsultationWithAuthority,
        dpv_owl:ConsultationWithAuthority ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ConsultationWithDPO a owl:Class ;
    rdfs:label "ConsultationWithDPO" ;
    rdfs:subClassOf dpv:Consultation,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Consultation with DPO" ;
    skos:definition "Consultation with Data Protection Officer(s)" ;
    skos:exactMatch dpv:ConsultationWithDPO,
        dpv_upstream:ConsultationWithDPO,
        dpv_owl:ConsultationWithDPO ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ConsultationWithDataSubjectRepresentative a owl:Class ;
    rdfs:label "ConsultationWithDataSubjectRepresentative" ;
    rdfs:subClassOf dpv:ConsultationWithDataSubject,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Consultation with Data Subject Representative" ;
    skos:definition "Consultation with representative of data subject(s)" ;
    skos:exactMatch dpv:ConsultationWithDataSubjectRepresentative,
        dpv_upstream:ConsultationWithDataSubjectRepresentative,
        dpv_owl:ConsultationWithDataSubjectRepresentative ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ConsumerStandardFormContract a owl:Class ;
    rdfs:label "ConsumerStandardFormContract" ;
    rdfs:subClassOf dpv:LegalBasis,
        dpv:StandardFormContract ;
    skos:altLabel "Consumer Standard Form Contract" ;
    skos:definition """A contract where the terms and conditions are determined by parties in
the role of a 'consumer' - whether an entity or an individual, and the
other parties have negligible or no ability to negotiate the terms and
conditions""" ;
    skos:exactMatch dpv:ConsumerStandardFormContract,
        dpv_upstream:ConsumerStandardFormContract,
        dpv_owl:ConsumerStandardFormContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:ContextuallyAnonymisedData a owl:Class ;
    rdfs:label "ContextuallyAnonymisedData" ;
    rdfs:subClassOf dpv:PseudonymisedData ;
    skos:altLabel "Contextually Anonymised Data" ;
    skos:definition """Data that can be considered as being fully anonymised within the context
but in actuality is not fully anonymised and is still personal data as
it can be de-anonymised outside that context""" ;
    skos:exactMatch dpv:ContextuallyAnonymisedData,
        dpv_upstream:ContextuallyAnonymisedData,
        dpv_owl:ContextuallyAnonymisedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """To distinguish between partially anonymised data that can be effectively
treated as anonymised data (e.g. in processing) within a context (e.g.
an organisation), the concept ContextuallyAnonymisedData should be used
instead of AnonymisedData. Transfer of this data outside of the context
should consider that it is not fully anonymised and that it is still
personal data""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:ContinuousFrequency a owl:Class ;
    rdfs:label "ContinuousFrequency" ;
    rdfs:subClassOf dpv:Frequency ;
    skos:altLabel "Continuous Frequency" ;
    skos:definition "Frequency where occurrences are continuous" ;
    skos:exactMatch dpv:ContinuousFrequency,
        dpv_upstream:ContinuousFrequency,
        dpv_owl:ContinuousFrequency ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:ContractActive a owl:Class ;
    rdfs:label "ContractActive" ;
    rdfs:subClassOf dpv:ContractActivationStatus ;
    skos:altLabel "Contract Active" ;
    skos:definition """Status representing contract that has been fully executed and whose
terms are considered active i.e. they are applicable and are required to
be performed""" ;
    skos:exactMatch dpv:ContractActive,
        dpv_upstream:ContractActive,
        dpv_owl:ContractActive ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """A contract being active only refers to its terms now being required to
be fulfilled, while dpv:ContractBeingPerformed states that they are
being performed""" ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractAmended a owl:Class ;
    rdfs:label "ContractAmended" ;
    rdfs:subClassOf dpv:ContractPerformanceStatus ;
    skos:altLabel "Contract Amended" ;
    skos:definition """Status representing contract that has been fully executed and whose
terms have been amended through mutual agreement or other means such
that the contract is still required to be performed""" ;
    skos:exactMatch dpv:ContractAmended,
        dpv_upstream:ContractAmended,
        dpv_owl:ContractAmended ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractAmendmentClause a owl:Class ;
    rdfs:label "ContractAmendmentClause" ;
    rdfs:subClassOf dpv:ContractualClause ;
    skos:altLabel "Contract Amendment Clause" ;
    skos:definition """A provision describing how changes or modifications to the contract can
be made and the process for implementing them""" ;
    skos:exactMatch dpv:ContractAmendmentClause,
        dpv_upstream:ContractAmendmentClause,
        dpv_owl:ContractAmendmentClause ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ContractApproved a owl:Class ;
    rdfs:label "ContractApproved" ;
    rdfs:subClassOf dpv:ContractPreparationStatus ;
    skos:altLabel "Contract Approved" ;
    skos:definition """Status representing contract has been approved and can be used for
signing""" ;
    skos:exactMatch dpv:ContractApproved,
        dpv_upstream:ContractApproved,
        dpv_owl:ContractApproved ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractBeingPerformed a owl:Class ;
    rdfs:label "ContractBeingPerformed" ;
    rdfs:subClassOf dpv:ContractPerformanceStatus ;
    skos:altLabel "Contract Being Performed" ;
    skos:definition """Status representing contract that has been fully executed and whose
terms are being carried out i.e. the contract is being performed""" ;
    skos:exactMatch dpv:ContractBeingPerformed,
        dpv_upstream:ContractBeingPerformed,
        dpv_owl:ContractBeingPerformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractBreached a owl:Class ;
    rdfs:label "ContractBreached" ;
    rdfs:subClassOf dpv:ContractTerminationStatus ;
    skos:altLabel "Contract Breached" ;
    skos:definition """Status representing contract being breached where its terms are not
fulfilled or are violated with legal consequences""" ;
    skos:exactMatch dpv:ContractBreached,
        dpv_upstream:ContractBreached,
        dpv_owl:ContractBreached ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractConfidentialityClause a owl:Class ;
    rdfs:label "ContractConfidentialityClause" ;
    rdfs:subClassOf dpv:ContractualClause ;
    skos:altLabel "Contract Confidentiality Clause" ;
    skos:definition """A provision requiring parties to keep certain information confidential
and not disclose it to third parties""" ;
    skos:exactMatch dpv:ContractConfidentialityClause,
        dpv_upstream:ContractConfidentialityClause,
        dpv_owl:ContractConfidentialityClause ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ContractDefinitions a owl:Class ;
    rdfs:label "ContractDefinitions" ;
    rdfs:subClassOf dpv:ContractualClause ;
    skos:altLabel "Contract Definitions" ;
    skos:definition """A section specifying the meanings of key terms and phrases used
throughout the contract""" ;
    skos:exactMatch dpv:ContractDefinitions,
        dpv_upstream:ContractDefinitions,
        dpv_owl:ContractDefinitions ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ContractDisputeResolutionClause a owl:Class ;
    rdfs:label "ContractDisputeResolutionClause" ;
    rdfs:subClassOf dpv:ContractualClause ;
    skos:altLabel "Contract DisputeResolution Clause" ;
    skos:definition """A provision detailing the methods and procedures for resolving
disagreements or conflicts arising from the contract""" ;
    skos:exactMatch dpv:ContractDisputeResolutionClause,
        dpv_upstream:ContractDisputeResolutionClause,
        dpv_owl:ContractDisputeResolutionClause ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ContractDisputed a owl:Class ;
    rdfs:label "ContractDisputed" ;
    rdfs:subClassOf dpv:ContractTerminationStatus ;
    skos:altLabel "Contract Disputed" ;
    skos:definition """Status representing contract being disputed where one or more parties
have an issue regarding the interpretation and performance of the
contract""" ;
    skos:exactMatch dpv:ContractDisputed,
        dpv_upstream:ContractDisputed,
        dpv_owl:ContractDisputed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractDrafted a owl:Class ;
    rdfs:label "ContractDrafted" ;
    rdfs:subClassOf dpv:ContractPreparationStatus ;
    skos:altLabel "Contract Drafted" ;
    skos:definition """Status representing the drafting of contract text has been completed and
it can now be offered for signing""" ;
    skos:exactMatch dpv:ContractDrafted,
        dpv_upstream:ContractDrafted,
        dpv_owl:ContractDrafted ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractExpired a owl:Class ;
    rdfs:label "ContractExpired" ;
    rdfs:subClassOf dpv:ContractTerminationStatus ;
    skos:altLabel "Contract Expired" ;
    skos:definition """Status representing reaching the expiry defined in the contract, such as
when the stated duration or the stated obligations have been completed""" ;
    skos:exactMatch dpv:ContractExpired,
        dpv_upstream:ContractExpired,
        dpv_owl:ContractExpired ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractExtended a owl:Class ;
    rdfs:label "ContractExtended" ;
    rdfs:subClassOf dpv:ContractTerminationStatus ;
    skos:altLabel "Contract Extended" ;
    skos:definition """Status representing the duration associated with a contract being
extended through mutual agreement or by a party""" ;
    skos:exactMatch dpv:ContractExtended,
        dpv_upstream:ContractExtended,
        dpv_owl:ContractExtended ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractFulfilled a owl:Class ;
    rdfs:label "ContractFulfilled" ;
    rdfs:subClassOf dpv:ContractFulfilmentStatus ;
    skos:altLabel "Contract Fulfilled" ;
    skos:definition """Status representing contract where all its terms have been fulfilled in
a manner that does not constitute a violation or breach of the contract""" ;
    skos:exactMatch dpv:ContractFulfilled,
        dpv_upstream:ContractFulfilled,
        dpv_owl:ContractFulfilled ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractFullyExecuted a owl:Class ;
    rdfs:label "ContractFullyExecuted" ;
    rdfs:subClassOf dpv:ContractExecutionStatus ;
    skos:altLabel "Contract Fully Executed" ;
    skos:definition """Status representing contract has been fully executed i.e. it has been
signed by all parties and all other procedural aspects such as exchange
of signed contract copies have been completed""" ;
    skos:exactMatch dpv:ContractFullyExecuted,
        dpv_upstream:ContractFullyExecuted,
        dpv_owl:ContractFullyExecuted ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractFullySigned a owl:Class ;
    rdfs:label "ContractFullySigned" ;
    rdfs:subClassOf dpv:ContractExecutionStatus ;
    skos:altLabel "Contract Fully Signed" ;
    skos:definition "Status representing contract has been signed by all concerned parties" ;
    skos:exactMatch dpv:ContractFullySigned,
        dpv_upstream:ContractFullySigned,
        dpv_owl:ContractFullySigned ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractInactive a owl:Class ;
    rdfs:label "ContractInactive" ;
    rdfs:subClassOf dpv:ContractActivationStatus ;
    skos:altLabel "Contract Inactive" ;
    skos:definition """Status representing contract that has been fully executed and whose
terms are not yet active i.e. they need to be performed at a later time""" ;
    skos:exactMatch dpv:ContractInactive,
        dpv_upstream:ContractInactive,
        dpv_owl:ContractInactive ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of an inactive contract is where its terms need to be
fulfilled at a later date, at which point the contract will become
active""" ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractJurisdictionClause a owl:Class ;
    rdfs:label "ContractJurisdictionClause" ;
    rdfs:subClassOf dpv:ContractualClause ;
    skos:altLabel "Contract Jurisdiction Clause" ;
    skos:definition """A provision specifying the legal jurisdiction or court where disputes
related to the contract will be resolved""" ;
    skos:exactMatch dpv:ContractJurisdictionClause,
        dpv_upstream:ContractJurisdictionClause,
        dpv_owl:ContractJurisdictionClause ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ContractNegotiated a owl:Class ;
    rdfs:label "ContractNegotiated" ;
    rdfs:subClassOf dpv:ContractPreparationStatus ;
    skos:altLabel "Contract Negotiated" ;
    skos:definition """Status representing contract has been successfully negotiated by
involved parties""" ;
    skos:exactMatch dpv:ContractNegotiated,
        dpv_upstream:ContractNegotiated,
        dpv_owl:ContractNegotiated ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractNotFulfilled a owl:Class ;
    rdfs:label "ContractNotFulfilled" ;
    rdfs:subClassOf dpv:ContractFulfilmentStatus ;
    skos:altLabel "Contract Not Fulfilled" ;
    skos:definition """Status representing contract where none of its terms have been fulfilled
in a manner that does not constitute a violation or breach of the
contract i.e. there is still time and opportunity to complete the terms""" ;
    skos:exactMatch dpv:ContractNotFulfilled,
        dpv_upstream:ContractNotFulfilled,
        dpv_owl:ContractNotFulfilled ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractOffered a owl:Class ;
    rdfs:label "ContractOffered" ;
    rdfs:subClassOf dpv:ContractPreparationStatus ;
    skos:altLabel "Contract Offered" ;
    skos:definition """Status representing contract has been offered to a party or to parties
for reviewing and signing""" ;
    skos:exactMatch dpv:ContractOffered,
        dpv_upstream:ContractOffered,
        dpv_owl:ContractOffered ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractPartiallyFulfilled a owl:Class ;
    rdfs:label "ContractPartiallyFulfilled" ;
    rdfs:subClassOf dpv:ContractFulfilmentStatus ;
    skos:altLabel "Contract Partially Fulfilled" ;
    skos:definition """Status representing contract where some of its terms have been
fulfilled, and others are yet to be fulfilled in a manner that does not
constitute a violation or breach of the contract i.e. there is still
time and opportunity to complete the terms""" ;
    skos:exactMatch dpv:ContractPartiallyFulfilled,
        dpv_upstream:ContractPartiallyFulfilled,
        dpv_owl:ContractPartiallyFulfilled ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractPartiallySigned a owl:Class ;
    rdfs:label "ContractPartiallySigned" ;
    rdfs:subClassOf dpv:ContractExecutionStatus ;
    skos:altLabel "Contract Partially Signed" ;
    skos:definition """Status representing contract has been partially signed by parties i.e.
some parties have signed the contract and others are yet to make a
decision to sign it""" ;
    skos:exactMatch dpv:ContractPartiallySigned,
        dpv_upstream:ContractPartiallySigned,
        dpv_owl:ContractPartiallySigned ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractPerformance a owl:Class ;
    rdfs:label "ContractPerformance" ;
    rdfs:subClassOf dpv:Contract,
        dpv:LegalBasis ;
    skos:altLabel "Contract Performance" ;
    skos:definition """Fulfilment or performance of a contract involving specified processing
of data or technologies""" ;
    skos:exactMatch dpv:ContractPerformance,
        dpv_upstream:ContractPerformance,
        dpv_owl:ContractPerformance ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:ContractPreamble a owl:Class ;
    rdfs:label "ContractPreamble" ;
    rdfs:subClassOf dpv:ContractualClause ;
    skos:altLabel "Contract Preamble" ;
    skos:definition """An introductory section outlining the background, context, and purpose
of the contract""" ;
    skos:exactMatch dpv:ContractPreamble,
        dpv_upstream:ContractPreamble,
        dpv_owl:ContractPreamble ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ContractRejected a owl:Class ;
    rdfs:label "ContractRejected" ;
    rdfs:subClassOf dpv:ContractPreparationStatus ;
    skos:altLabel "Contract Rejected" ;
    skos:definition """Status representing contract has been rejected and cannot be used for
signing""" ;
    skos:exactMatch dpv:ContractRejected,
        dpv_upstream:ContractRejected,
        dpv_owl:ContractRejected ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractRenewed a owl:Class ;
    rdfs:label "ContractRenewed" ;
    rdfs:subClassOf dpv:ContractPerformanceStatus ;
    skos:altLabel "Contract Renewed" ;
    skos:definition """Status representing contract being renewed with new duration and/or
applicability where the contract has been fully executed in the past""" ;
    skos:exactMatch dpv:ContractRenewed,
        dpv_upstream:ContractRenewed,
        dpv_owl:ContractRenewed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractSignedByParty a owl:Class ;
    rdfs:label "ContractSignedByParty" ;
    rdfs:subClassOf dpv:ContractExecutionStatus ;
    skos:altLabel "Contract Signed By Party" ;
    skos:definition """Status representing contract has been signed by the indicated signing
party""" ;
    skos:exactMatch dpv:ContractSignedByParty,
        dpv_upstream:ContractSignedByParty,
        dpv_owl:ContractSignedByParty ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The signing party can be expressed using dpv:hasParty with the status
along with metadata such as a timestamp, or the status can be used to
list whether each party in the contract has signed or not e.g. it is
reviewing the contract""" ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractTemporarilySuspended a owl:Class ;
    rdfs:label "ContractTemporarilySuspended" ;
    rdfs:subClassOf dpv:ContractPerformanceStatus ;
    skos:altLabel "Contract Temporarily Suspended" ;
    skos:definition """Status representing contract that has been temporarily suspended through
mutual agreement or by some parties""" ;
    skos:exactMatch dpv:ContractTemporarilySuspended,
        dpv_upstream:ContractTemporarilySuspended,
        dpv_owl:ContractTemporarilySuspended ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractTerminated a owl:Class ;
    rdfs:label "ContractTerminated" ;
    rdfs:subClassOf dpv:ContractTerminationStatus ;
    skos:altLabel "Contract Terminated" ;
    skos:definition "Status representing contract being terminated by one or more parties" ;
    skos:exactMatch dpv:ContractTerminated,
        dpv_upstream:ContractTerminated,
        dpv_owl:ContractTerminated ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractTerminationClause a owl:Class ;
    rdfs:label "ContractTerminationClause" ;
    rdfs:subClassOf dpv:ContractualClause ;
    skos:altLabel "Contract Termination Clause" ;
    skos:definition """A provision outlining the conditions under which the contract can be
terminated before its completion, including any penalties or obligations""" ;
    skos:exactMatch dpv:ContractTerminationClause,
        dpv_upstream:ContractTerminationClause,
        dpv_owl:ContractTerminationClause ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ContractUnderNegotiation a owl:Class ;
    rdfs:label "ContractUnderNegotiation" ;
    rdfs:subClassOf dpv:ContractPreparationStatus ;
    skos:altLabel "Contract Under Negotiation" ;
    skos:definition "Status representing contract is under negotiation between parties" ;
    skos:exactMatch dpv:ContractUnderNegotiation,
        dpv_upstream:ContractUnderNegotiation,
        dpv_owl:ContractUnderNegotiation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractUnderReview a owl:Class ;
    rdfs:label "ContractUnderReview" ;
    rdfs:subClassOf dpv:ContractPreparationStatus ;
    skos:altLabel "Contract Under Review" ;
    skos:definition """Status representing contract is under review and is being considered for
signing""" ;
    skos:exactMatch dpv:ContractUnderReview,
        dpv_upstream:ContractUnderReview,
        dpv_owl:ContractUnderReview ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractViolated a owl:Class ;
    rdfs:label "ContractViolated" ;
    rdfs:subClassOf dpv:ContractFulfilmentStatus ;
    skos:altLabel "Contract Violated" ;
    skos:definition """Status representing contract where one or more terms have not been
fulfilled or have been fulfilled, where either is considered a violation
of the terms""" ;
    skos:exactMatch dpv:ContractViolated,
        dpv_upstream:ContractViolated,
        dpv_owl:ContractViolated ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractualClauseFulfilled a owl:Class ;
    rdfs:label "ContractualClauseFulfilled" ;
    rdfs:subClassOf dpv:ContractualClauseFulfilmentStatus ;
    skos:altLabel "Contractual Clause Fulfilled" ;
    skos:definition """Status indicating the terms of the contractual clause are fulfilled i.e.
they have been successfully completed without violation""" ;
    skos:exactMatch dpv:ContractualClauseFulfilled,
        dpv_upstream:ContractualClauseFulfilled,
        dpv_owl:ContractualClauseFulfilled ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ContractualClauseNotFulfilled a owl:Class ;
    rdfs:label "ContractualClauseNotFulfilled" ;
    rdfs:subClassOf dpv:ContractualClauseFulfilmentStatus ;
    skos:altLabel "Contractual Clause Unfulfilled" ;
    skos:definition """Status indicating the terms of the contractual clause have not yet been
fulfilled in a manner that does not constitute a violation i.e. there is
still an opportunity to complete them""" ;
    skos:exactMatch dpv:ContractualClauseNotFulfilled,
        dpv_upstream:ContractualClauseNotFulfilled,
        dpv_owl:ContractualClauseNotFulfilled ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ContractualClausePartiallyFulfilled a owl:Class ;
    rdfs:label "ContractualClausePartiallyFulfilled" ;
    rdfs:subClassOf dpv:ContractualClauseFulfilmentStatus ;
    skos:altLabel "Contractual Clause Partially Fulfilled" ;
    skos:definition """Status indicating some of the terms of the contractual clause have been
fulfilled, and others have not yet been fulfilled in a manner that does
not constitute a violation i.e. there is still an opportunity to
complete them""" ;
    skos:exactMatch dpv:ContractualClausePartiallyFulfilled,
        dpv_upstream:ContractualClausePartiallyFulfilled,
        dpv_owl:ContractualClausePartiallyFulfilled ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ContractualClauseViolated a owl:Class ;
    rdfs:label "ContractualClauseViolated" ;
    rdfs:subClassOf dpv:ContractualClauseFulfilmentStatus ;
    skos:altLabel "Contractual Clause Breached" ;
    skos:definition "Status indicating the terms of the contractual clause have been violated" ;
    skos:exactMatch dpv:ContractualClauseViolated,
        dpv_upstream:ContractualClauseViolated,
        dpv_owl:ContractualClauseViolated ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ControllerDataSubjectAgreement a owl:Class ;
    rdfs:label "ControllerDataSubjectAgreement" ;
    rdfs:subClassOf dpv:DataSubjectContract,
        dpv:LegalBasis,
        dpv:LegalMeasure ;
    skos:altLabel "Controller-Data Subject Agreement" ;
    skos:definition """An agreement outlining conditions, criteria, obligations,
responsibilities, and specifics for carrying out processing of data
between a Data Controller and a Data Subject""" ;
    skos:exactMatch dpv:ControllerDataSubjectAgreement,
        dpv_upstream:ControllerDataSubjectAgreement,
        dpv_owl:ControllerDataSubjectAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:ControllerInformed a owl:Class ;
    rdfs:label "ControllerInformed" ;
    rdfs:subClassOf dpv:EntityInformed,
        dpv:EntityInformedStatus ;
    skos:altLabel "Controller Informed" ;
    skos:definition """Status indicating Controller has been informed about the specified
context""" ;
    skos:exactMatch dpv:ControllerInformed,
        dpv_upstream:ControllerInformed,
        dpv_owl:ControllerInformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ControllerProcessorAgreement a owl:Class ;
    rdfs:label "ControllerProcessorAgreement" ;
    rdfs:subClassOf dpv:DataProcessorContract,
        dpv:LegalBasis,
        dpv:LegalMeasure ;
    skos:altLabel "Controller-Processor Agreement" ;
    skos:definition """An agreement outlining conditions, criteria, obligations,
responsibilities, and specifics for carrying out processing of data
between a Data Controller and a Data Processor""" ;
    skos:exactMatch dpv:ControllerProcessorAgreement,
        dpv_upstream:ControllerProcessorAgreement,
        dpv_owl:ControllerProcessorAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:ControllerUninformed a owl:Class ;
    rdfs:label "ControllerUninformed" ;
    rdfs:subClassOf dpv:EntityInformedStatus,
        dpv:EntityUninformed ;
    skos:altLabel "Controller Uninformed" ;
    skos:definition """Status indicating Controller is uninformed i.e. has not been informed
about the specified context""" ;
    skos:exactMatch dpv:ControllerUninformed,
        dpv_upstream:ControllerUninformed,
        dpv_owl:ControllerUninformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:Copy a owl:Class ;
    rdfs:label "Copy" ;
    rdfs:subClassOf dpv:Processing ;
    skos:altLabel "Copy" ;
    skos:definition "to produce an exact reproduction of the data" ;
    skos:exactMatch dpv:Copy,
        dpv_upstream:Copy,
        dpv_owl:Copy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpr:Copy ;
    dpv:skos_in_scheme "processing-classes" .

dpv:CorrectingProcess a owl:Class ;
    rdfs:label "CorrectingProcess" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Correcting Process" ;
    skos:definition "Involvement where entity can correct the process of specified context" ;
    skos:exactMatch dpv:CorrectingProcess,
        dpv_upstream:CorrectingProcess,
        dpv_owl:CorrectingProcess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Correction of process refers to the ability to change how the process
takes place""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CorrectingProcessInput a owl:Class ;
    rdfs:label "CorrectingProcessInput" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Correcting Process Input" ;
    skos:definition "Involvement where entity can correct input of specified context" ;
    skos:exactMatch dpv:CorrectingProcessInput,
        dpv_upstream:CorrectingProcessInput,
        dpv_owl:CorrectingProcessInput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CorrectingProcessOutput a owl:Class ;
    rdfs:label "CorrectingProcessOutput" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Correcting Process Output" ;
    skos:definition "Involvement where entity can correct the output of specified context" ;
    skos:exactMatch dpv:CorrectingProcessOutput,
        dpv_upstream:CorrectingProcessOutput,
        dpv_owl:CorrectingProcessOutput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Correction of outputs allows modification of the output - implying
continuation of the process. This is distinct from reversing of outputs
which revert the output back to its previous value and possibly imply
not continuing with the process""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:CounterMoneyLaundering a owl:Class ;
    rdfs:label "CounterMoneyLaundering" ;
    rdfs:subClassOf dpv:FraudPreventionAndDetection,
        dpv:Purpose ;
    skos:altLabel "Counter Money Laundering" ;
    skos:definition """Purposes associated with detection, prevention, and mitigation of
mitigate money laundering""" ;
    skos:exactMatch dpv:CounterMoneyLaundering,
        dpv_upstream:CounterMoneyLaundering,
        dpv_owl:CounterMoneyLaundering ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Counterterrorism a owl:Class ;
    rdfs:label "Counterterrorism" ;
    rdfs:subClassOf dpv:PublicBenefit,
        dpv:Purpose ;
    skos:altLabel "Counterterrorism" ;
    skos:definition """Purposes associated with activities that detect, prevent, mitigate, or
otherwise perform activities to combat or eliminate terrorism (also
referred to as anti-terrorism)""" ;
    skos:exactMatch dpv:Counterterrorism,
        dpv_upstream:Counterterrorism,
        dpv_owl:Counterterrorism ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:CredentialManagement a owl:Class ;
    rdfs:label "CredentialManagement" ;
    rdfs:subClassOf dpv:AuthorisationProcedure,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Credential Management" ;
    skos:definition "Management of credentials and their use in authorisations" ;
    skos:exactMatch dpv:CredentialManagement,
        dpv_upstream:CredentialManagement,
        dpv_owl:CredentialManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:CrossBorderTransfer a owl:Class ;
    rdfs:label "CrossBorderTransfer" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Transfer ;
    skos:altLabel "Cross-Border Transfer" ;
    skos:definition "to move data from one jurisdiction (border) to another" ;
    skos:exactMatch dpv:CrossBorderTransfer,
        dpv_upstream:CrossBorderTransfer,
        dpv_owl:CrossBorderTransfer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:CryptographicKeyManagement a owl:Class ;
    rdfs:label "CryptographicKeyManagement" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Cryptographic Key Management" ;
    skos:definition """Management of cryptographic keys, including their generation, storage,
assessment, and safekeeping""" ;
    skos:exactMatch dpv:CryptographicKeyManagement,
        dpv_upstream:CryptographicKeyManagement,
        dpv_owl:CryptographicKeyManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:CustomerClaimsManagement a owl:Class ;
    rdfs:label "CustomerClaimsManagement" ;
    rdfs:subClassOf dpv:CustomerManagement,
        dpv:Purpose ;
    skos:altLabel "Customer Claims Management" ;
    skos:definition """Customer Claims Management refers to purposes associated with managing
claims, including repayment of monies owed""" ;
    skos:exactMatch dpv:CustomerClaimsManagement,
        dpv_upstream:CustomerClaimsManagement,
        dpv_owl:CustomerClaimsManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:CustomerOrderManagement a owl:Class ;
    rdfs:label "CustomerOrderManagement" ;
    rdfs:subClassOf dpv:CustomerManagement,
        dpv:Purpose ;
    skos:altLabel "Customer Order Management" ;
    skos:definition """Customer Order Management refers to purposes associated with managing
customer orders i.e. processing of an order related to customer's
purchase of good or services""" ;
    skos:exactMatch dpv:CustomerOrderManagement,
        dpv_upstream:CustomerOrderManagement,
        dpv_owl:CustomerOrderManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:CustomerSolvencyMonitoring a owl:Class ;
    rdfs:label "CustomerSolvencyMonitoring" ;
    rdfs:subClassOf dpv:CustomerManagement,
        dpv:Purpose ;
    skos:altLabel "Customer Solvency Monitoring" ;
    skos:definition """Customer Solvency Monitoring refers to purposes associated with monitor
solvency of customers for financial diligence""" ;
    skos:exactMatch dpv:CustomerSolvencyMonitoring,
        dpv_upstream:CustomerSolvencyMonitoring,
        dpv_owl:CustomerSolvencyMonitoring ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:CybersecurityAssessment a owl:Class ;
    rdfs:label "CybersecurityAssessment" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SecurityAssessment ;
    skos:altLabel "Cybersecurity Assessment" ;
    skos:definition """Assessment of cybersecurity capabilities in terms of vulnerabilities and
effectiveness of controls""" ;
    skos:exactMatch dpv:CybersecurityAssessment,
        dpv_upstream:CybersecurityAssessment,
        dpv_owl:CybersecurityAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-classes" .

dpv:CybersecurityTraining a owl:Class ;
    rdfs:label "CybersecurityTraining" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:StaffTraining ;
    skos:altLabel "Cybersecurity Training" ;
    skos:definition "Training methods related to cybersecurity" ;
    skos:exactMatch dpv:CybersecurityTraining,
        dpv_upstream:CybersecurityTraining,
        dpv_owl:CybersecurityTraining ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DPIA a owl:Class ;
    rdfs:label "DPIA" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RightsImpactAssessment ;
    skos:altLabel "Data Protection Impact Assessment (DPIA)" ;
    skos:definition """Impact assessment determining the potential and actual impact of
processing activities on individuals or groups of individuals and taking
into account the impacts of activities on their rights and freedoms""" ;
    skos:exactMatch dpv:DPIA,
        dpv_upstream:DPIA,
        dpv_owl:DPIA ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Specific requirements and procedures for DPIA are defined in GDPR Art.35" ;
    dpv:dct_source "GDPR Art. 35" ;
    dpv:skos_in_scheme "risk-classes" .

dpv:DashboardNotice a owl:Class ;
    rdfs:label "DashboardNotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Dashboard Notice" ;
    skos:definition """A notice that is provided within a dashboard also used for other
purposes""" ;
    skos:exactMatch dpv:DashboardNotice,
        dpv_upstream:DashboardNotice,
        dpv_owl:DashboardNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes" .

dpv:DataAltruism a owl:Class ;
    rdfs:label "DataAltruism" ;
    rdfs:subClassOf dpv:PublicBenefit,
        dpv:Purpose ;
    skos:altLabel "Data Altruism" ;
    skos:definition """Purposes associated with the voluntary sharing of data for the general
interest of the public, such as healthcare or combating climate change""" ;
    skos:exactMatch dpv:DataAltruism,
        dpv_upstream:DataAltruism,
        dpv_owl:DataAltruism ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Data Altruism as a purpose should be combined with other purposes to
indicate their altruistic interpretation or application. E.g. improving
healthcare and data altruism in combination.""" ;
    dpv:dct_source "DGA 2.16" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:DataAvailabilityAssessment a owl:Class ;
    rdfs:label "DataAvailabilityAssessment" ;
    rdfs:subClassOf dpv:DataGovernance,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Availability Assessment" ;
    skos:definition """Measures associated with assessment of availability of data for specific
task(s)""" ;
    skos:exactMatch dpv:DataAvailabilityAssessment,
        dpv_upstream:DataAvailabilityAssessment,
        dpv_owl:DataAvailabilityAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataBackupProtocols a owl:Class ;
    rdfs:label "DataBackupProtocols" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Data Backup Protocols" ;
    skos:definition "Protocols or plans for backing up of data" ;
    skos:exactMatch dpv:DataBackupProtocols,
        dpv_upstream:DataBackupProtocols,
        dpv_owl:DataBackupProtocols ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:DataBreachImpactAssessment a owl:Class ;
    rdfs:label "DataBreachImpactAssessment" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RightsImpactAssessment ;
    skos:altLabel "Data Breach Impact Assessment (DBIA)" ;
    skos:definition """Impact Assessment concerning the consequences and impacts of a data
breach""" ;
    skos:exactMatch dpv:DataBreachImpactAssessment,
        dpv_upstream:DataBreachImpactAssessment,
        dpv_owl:DataBreachImpactAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Data Breach assessments can require additional non-security related
assessments such as GDPR Art.34 Rights Impact Assessment""" ;
    dpv:skos_in_scheme "risk-classes" .

dpv:DataBreachNotice a owl:Class ;
    rdfs:label "DataBreachNotice" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SecurityIncidentNotice ;
    skos:altLabel "Data Breach Notice" ;
    skos:definition """A notice providing information about data breach(es) i.e. unauthorised
transfer, access, use, or modification of data""" ;
    skos:exactMatch dpv:DataBreachNotice,
        dpv_upstream:DataBreachNotice,
        dpv_owl:DataBreachNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source " DGA 21.5 GDPR 33" ;
    dpv:skos_in_scheme "notice-classes, organisational-measures-classes" .

dpv:DataBreachNotification a owl:Class ;
    rdfs:label "DataBreachNotification" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SecurityIncidentNotification ;
    skos:altLabel "Data Breach Notification" ;
    skos:definition """Notification of information about data breach(es) i.e. unauthorised
transfer, access, use, or modification of data""" ;
    skos:exactMatch dpv:DataBreachNotification,
        dpv_upstream:DataBreachNotification,
        dpv_owl:DataBreachNotification ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source " DGA 21.5 GDPR 33" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataBreachRecord a owl:Class ;
    rdfs:label "DataBreachRecord" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RecordsOfActivities ;
    skos:altLabel "Data Breach Record" ;
    skos:closeMatch iso27001:InformationSecurityIncident,
        iso29100:PrivacyBreach ;
    skos:definition "Record of a data breach incident" ;
    skos:exactMatch dpv:DataBreachRecord,
        dpv_upstream:DataBreachRecord,
        dpv_owl:DataBreachRecord ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch ocsf:FindingInfo ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataControllerDataSource a owl:Class ;
    rdfs:label "DataControllerDataSource" ;
    rdfs:subClassOf dpv:DataSource ;
    skos:altLabel "Data Controller as Data Source" ;
    skos:definition """Data Sourced from Data Controller(s), e.g. a Controller inferring data
or generating data""" ;
    skos:exactMatch dpv:DataControllerDataSource,
        dpv_upstream:DataControllerDataSource,
        dpv_owl:DataControllerDataSource ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:DataDeletionPolicy a owl:Class ;
    rdfs:label "DataDeletionPolicy" ;
    rdfs:subClassOf dpv:DataProcessingPolicy,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Deletion Policy" ;
    skos:definition "Policy regarding deletion of data" ;
    skos:exactMatch dpv:DataDeletionPolicy,
        dpv_upstream:DataDeletionPolicy,
        dpv_owl:DataDeletionPolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Deletion and Erasure are distinct activities where deletion refers to
logical removal of data with the possibility of retrieval whereas
erasure refers to destruction of data such that it cannot be retrieved.
See dpv:DataErasurePolicy""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataErasurePolicy a owl:Class ;
    rdfs:label "DataErasurePolicy" ;
    rdfs:subClassOf dpv:DataProcessingPolicy,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Erasure Policy" ;
    skos:definition "Policy regarding erasure of data" ;
    skos:exactMatch dpv:DataErasurePolicy,
        dpv_upstream:DataErasurePolicy,
        dpv_owl:DataErasurePolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Erasure or data destruction or secure removal of data refers to
irreversible erasure of data. See dpv:DataDeletion for reversible or
logical deletion of data""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataExporter a owl:Class ;
    rdfs:label "DataExporter" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Data Exporter" ;
    skos:definition """An entity that 'exports' data where exporting is considered a form of
data transfer""" ;
    skos:exactMatch dpv:DataExporter,
        dpv_upstream:DataExporter,
        dpv_owl:DataExporter ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The term 'Data Exporter' is used by the EU-EDPB as the entity that
transfer data across borders. While the EDPB refers to the
jurisdictional border of EU, the term within DPV can be used to denote
any 'export' or transfer or transmission of data and is thus a broader
concept than the EDPB's definition.""" ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:DataHandlingClause a owl:Class ;
    rdfs:label "DataHandlingClause" ;
    rdfs:subClassOf dpv:ContractualTerms,
        dpv:LegalMeasure ;
    skos:altLabel "Data Handling Clause" ;
    skos:definition "Contractual clauses governing handling of data within or by an entity" ;
    skos:exactMatch dpv:DataHandlingClause,
        dpv_upstream:DataHandlingClause,
        dpv_owl:DataHandlingClause ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-measures-classes" .

dpv:DataImporter a owl:Class ;
    rdfs:label "DataImporter" ;
    rdfs:subClassOf dpv:DpvRecipient ;
    skos:altLabel "Data Importer" ;
    skos:definition """An entity that 'imports' data where importing is considered a form of
data transfer""" ;
    skos:exactMatch dpv:DataImporter,
        dpv_upstream:DataImporter,
        dpv_owl:DataImporter ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The term 'Data Importer' is used by the EU-EDPB as the entity that
receives transferred data across borders. While the EDPB refers to the
jurisdictional border of EU, the term within DPV can be used to denote
any 'import' or reception of transfer or transmission of data and is
thus a broader concept than the EDPB's definition.""" ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:DataInteroperabilityAssessment a owl:Class ;
    rdfs:label "DataInteroperabilityAssessment" ;
    rdfs:subClassOf dpv:Assessment,
        dpv:DataInteroperabilityManagement,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Interoperability Assessment" ;
    skos:definition "Measures associated with assessment of data interoperability" ;
    skos:exactMatch dpv:DataInteroperabilityAssessment,
        dpv_upstream:DataInteroperabilityAssessment,
        dpv_owl:DataInteroperabilityAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataInteroperabilityImprovement a owl:Class ;
    rdfs:label "DataInteroperabilityImprovement" ;
    rdfs:subClassOf dpv:DataInteroperabilityManagement,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Interoperability Improvement" ;
    skos:definition "Measures associated with improvement of data interoperability" ;
    skos:exactMatch dpv:DataInteroperabilityImprovement,
        dpv_upstream:DataInteroperabilityImprovement,
        dpv_owl:DataInteroperabilityImprovement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 12.d" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataInventoryManagement a owl:Class ;
    rdfs:label "DataInventoryManagement" ;
    rdfs:subClassOf dpv:DataGovernance,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Inventory Management" ;
    skos:definition """Measures associated with management of data inventory or a data asset
list""" ;
    skos:exactMatch dpv:DataInventoryManagement,
        dpv_upstream:DataInventoryManagement,
        dpv_owl:DataInventoryManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataJurisdictionPolicy a owl:Class ;
    rdfs:label "DataJurisdictionPolicy" ;
    rdfs:subClassOf dpv:DataProcessingPolicy,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Jurisdiction Policy" ;
    skos:definition "Policy specifying jurisdictional requirements for data processing" ;
    skos:exactMatch dpv:DataJurisdictionPolicy,
        dpv_upstream:DataJurisdictionPolicy,
        dpv_owl:DataJurisdictionPolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Jurisdictional requirements can refer to data being stored within
specific jurisdictions, or that data must be in line with jurisdictional
laws and norms""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataLiteracy a owl:Class ;
    rdfs:label "DataLiteracy" ;
    rdfs:subClassOf dpv:DigitalLiteracy,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Literacy" ;
    skos:definition """Providing skills, knowledge, and understanding to enable reading,
writing, analysing, reasoning, and communicating regarding data""" ;
    skos:exactMatch dpv:DataLiteracy,
        dpv_upstream:DataLiteracy,
        dpv_owl:DataLiteracy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataProtectionAuthority a owl:Class ;
    rdfs:label "DataProtectionAuthority" ;
    rdfs:subClassOf dpv:DpvAuthority ;
    skos:altLabel "Data Protection Authority" ;
    skos:definition """An authority tasked with overseeing legal compliance regarding privacy
and data protection laws.""" ;
    skos:exactMatch dpv:DataProtectionAuthority,
        dpv_upstream:DataProtectionAuthority,
        dpv_owl:DataProtectionAuthority ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch nist_csf_v2:ResponsibleParty,
        oscal:ResponsibleParty ;
    dpv:skos_in_scheme "entities-authority-classes" .

dpv:DataProtectionOfficer a owl:Class ;
    rdfs:label "DataProtectionOfficer" ;
    rdfs:subClassOf dpv:Representative ;
    skos:altLabel "Data Protection Officer" ;
    skos:definition """An entity within or authorised by an organisation to monitor internal
compliance, inform and advise on data protection obligations and act as
a contact point for data subjects and the supervisory authority.""" ;
    skos:exactMatch dpv:DataProtectionOfficer,
        dpv_upstream:DataProtectionOfficer,
        dpv_owl:DataProtectionOfficer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch oscal:ResponsibleRole ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:DataProtectionTraining a owl:Class ;
    rdfs:label "DataProtectionTraining" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:StaffTraining ;
    skos:altLabel "Data Protection Training" ;
    skos:definition "Training intended to increase knowledge regarding data protection" ;
    skos:exactMatch dpv:DataProtectionTraining,
        dpv_upstream:DataProtectionTraining,
        dpv_owl:DataProtectionTraining ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataPublishedByDataSubject a owl:Class ;
    rdfs:label "DataPublishedByDataSubject" ;
    rdfs:subClassOf dpv:DataSubjectDataSource ;
    skos:altLabel "Data published by Data Subject" ;
    skos:definition "Data is published by the data subject" ;
    skos:exactMatch dpv:DataPublishedByDataSubject,
        dpv_upstream:DataPublishedByDataSubject,
        dpv_owl:DataPublishedByDataSubject ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This refers to where that data was made publicly available by the data
subject. An example of this would be a social media profile that the
data subject has made publicly accessible.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:DataQualityImprovement a owl:Class ;
    rdfs:label "DataQualityImprovement" ;
    rdfs:subClassOf dpv:DataQualityManagement,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Quality Improvement" ;
    skos:definition "Measures associated with improvement of data quality" ;
    skos:exactMatch dpv:DataQualityImprovement,
        dpv_upstream:DataQualityImprovement,
        dpv_owl:DataQualityImprovement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataRedaction a owl:Class ;
    rdfs:label "DataRedaction" ;
    rdfs:subClassOf dpv:DataSanitisationTechnique,
        dpv:TechnicalMeasure ;
    skos:altLabel "Data Redaction" ;
    skos:definition "Removal of sensitive information from a data or document" ;
    skos:exactMatch dpv:DataRedaction,
        dpv_upstream:DataRedaction,
        dpv_owl:DataRedaction ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:DataRestorationPolicy a owl:Class ;
    rdfs:label "DataRestorationPolicy" ;
    rdfs:subClassOf dpv:DataProcessingPolicy,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Restoration Policy" ;
    skos:definition "Policy regarding restoration of data" ;
    skos:exactMatch dpv:DataRestorationPolicy,
        dpv_upstream:DataRestorationPolicy,
        dpv_owl:DataRestorationPolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Restoration can refer to how data is restored from a backup" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataReusePolicy a owl:Class ;
    rdfs:label "DataReusePolicy" ;
    rdfs:subClassOf dpv:DataProcessingPolicy,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Reuse Policy" ;
    skos:definition """Policy regarding reuse of data i.e. using data for purposes other than
its initial purpose""" ;
    skos:exactMatch dpv:DataReusePolicy,
        dpv_upstream:DataReusePolicy,
        dpv_owl:DataReusePolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This policy can be used to describe the procedures associated with
undertaking such reuse of data, for example to assess its legality and
the compatibility of the initial and subsequent purposes""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataSecurityManagement a owl:Class ;
    rdfs:label "DataSecurityManagement" ;
    rdfs:subClassOf dpv:DataGovernance,
        dpv:OrganisationalMeasure,
        dpv:SecurityProcedure ;
    skos:altLabel "Data Security Management" ;
    skos:closeMatch iso27001:InformationSecurityManagementSystem ;
    skos:definition "Measures associated with management of data security" ;
    skos:exactMatch dpv:DataSecurityManagement,
        dpv_upstream:DataSecurityManagement,
        dpv_owl:DataSecurityManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Examples of data security management are assessing the appropriate
security controls such as encryption, testing the implemented security
controls, and ensuring it is protected and safeguarded from unintended
actions""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataStoragePolicy a owl:Class ;
    rdfs:label "DataStoragePolicy" ;
    rdfs:subClassOf dpv:DataProcessingPolicy,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Storage Policy" ;
    skos:definition """Policy regarding storage of data, including the manner, duration,
location, and conditions for storage""" ;
    skos:exactMatch dpv:DataStoragePolicy,
        dpv_upstream:DataStoragePolicy,
        dpv_owl:DataStoragePolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataSubProcessor a owl:Class ;
    rdfs:label "DataSubProcessor" ;
    rdfs:subClassOf dpv:DataProcessor ;
    skos:altLabel "Data Sub-Processor" ;
    skos:definition "A 'sub-processor' is a processor engaged by another processor" ;
    skos:exactMatch dpv:DataSubProcessor,
        dpv_upstream:DataSubProcessor,
        dpv_owl:DataSubProcessor ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """A 'Sub-Processor' is always a 'Processor' with the distinction of not
directly being appointed by the 'Controller'""" ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:DataSubject a owl:Class ;
    rdfs:label "DataSubject" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Data Subject" ;
    skos:definition """The individual (or category of individuals) whose personal data is being
processed""" ;
    skos:exactMatch dpv:DataSubject,
        dpv_upstream:DataSubject,
        dpv_owl:DataSubject,
        iso22989:DataSubject,
        iso29100:PIIPrincipal ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:narrowMatch common_domain_model:NaturalPerson,
        gists:Person ;
    skos:note """The term 'data subject' is specific to the GDPR, but is functionally
equivalent to the term 'individual associated with data' and the ISO/IEC
term 'PII Principle'""" ;
    skos:relatedMatch iso27001:InterestedParty ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:DataSubjectInformed a owl:Class ;
    rdfs:label "DataSubjectInformed" ;
    rdfs:subClassOf dpv:EntityInformed,
        dpv:EntityInformedStatus ;
    skos:altLabel "Data Subject Informed" ;
    skos:definition """Status indicating DataSubject has been informed about the specified
context""" ;
    skos:exactMatch dpv:DataSubjectInformed,
        dpv_upstream:DataSubjectInformed,
        dpv_owl:DataSubjectInformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:DataSubjectRight a owl:Class ;
    rdfs:label "DataSubjectRight" ;
    rdfs:subClassOf dpv:Right ;
    skos:altLabel "Data Subject Right" ;
    skos:definition "The rights applicable or provided to a Data Subject" ;
    skos:exactMatch dpv:DataSubjectRight,
        dpv_upstream:DataSubjectRight,
        dpv_owl:DataSubjectRight ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Based on use of definitions, the notion of 'Data Subject Right' can be
equivalent to 'Individual Right' or 'Right of a Person'""" ;
    dpv:skos_in_scheme "rights-classes" .

dpv:DataSubjectRightsManagement a owl:Class ;
    rdfs:label "DataSubjectRightsManagement" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RightsManagement ;
    skos:altLabel "Data Subject Rights Management" ;
    skos:definition "Methods to provide, implement, and exercise data subjects' rights" ;
    skos:exactMatch dpv:DataSubjectRightsManagement,
        dpv_upstream:DataSubjectRightsManagement,
        dpv_owl:DataSubjectRightsManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept only concerns the organisational management of rights, and
does not represent the rights themselves - especially where such
'rights' are legally recognised or defined for the data subject or
individual. The concept dpv:DataSubjectRight is provided to represent
such legal rights.""" ;
    dpv:dct_source "DGA 12.m" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataSubjectUninformed a owl:Class ;
    rdfs:label "DataSubjectUninformed" ;
    rdfs:subClassOf dpv:EntityInformedStatus,
        dpv:EntityUninformed ;
    skos:altLabel "Data Subject Uninformed" ;
    skos:definition """Status indicating DataSubject is uninformed i.e. has not been informed
about the specified context""" ;
    skos:exactMatch dpv:DataSubjectUninformed,
        dpv_upstream:DataSubjectUninformed,
        dpv_owl:DataSubjectUninformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:DataSuitabilityAssessment a owl:Class ;
    rdfs:label "DataSuitabilityAssessment" ;
    rdfs:subClassOf dpv:DataQualityAssessment,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Suitability Assessment" ;
    skos:definition """Measures associated with assessment of suitability of data for specific
task(s)""" ;
    skos:exactMatch dpv:DataSuitabilityAssessment,
        dpv_upstream:DataSuitabilityAssessment,
        dpv_owl:DataSuitabilityAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataTransferImpactAssessment a owl:Class ;
    rdfs:label "DataTransferImpactAssessment" ;
    rdfs:subClassOf dpv:ImpactAssessment,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Transfer Impact Assessment" ;
    skos:definition "Impact Assessment for conducting data transfers" ;
    skos:exactMatch dpv:DataTransferImpactAssessment,
        dpv_upstream:DataTransferImpactAssessment,
        dpv_owl:DataTransferImpactAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-classes" .

dpv:DataTransferLegalBasis a owl:Class ;
    rdfs:label "DataTransferLegalBasis" ;
    rdfs:subClassOf dpv:LegalBasis ;
    skos:altLabel "Data Transfer Legal Basis" ;
    skos:definition """Specific or special categories and instances of legal basis intended for
justifying data transfers""" ;
    skos:exactMatch dpv:DataTransferLegalBasis,
        dpv_upstream:DataTransferLegalBasis,
        dpv_owl:DataTransferLegalBasis ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:DataTransferNotice a owl:Class ;
    rdfs:label "DataTransferNotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Transfer Notice" ;
    skos:definition "Notice for the legal entity for the transfer of its data" ;
    skos:exactMatch dpv:DataTransferNotice,
        dpv_upstream:DataTransferNotice,
        dpv_owl:DataTransferNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 5.9" ;
    dpv:skos_in_scheme "notice-classes, organisational-measures-classes" .

dpv:DataTransferRecord a owl:Class ;
    rdfs:label "DataTransferRecord" ;
    rdfs:subClassOf dpv:DataProcessingRecord,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Transfer Record" ;
    skos:definition "Record of data transfer activities" ;
    skos:exactMatch dpv:DataTransferRecord,
        dpv_upstream:DataTransferRecord,
        dpv_owl:DataTransferRecord ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DecentralisedLocations a owl:Class ;
    rdfs:label "DecentralisedLocations" ;
    rdfs:subClassOf dpv:LocationFixture ;
    skos:altLabel "Decentralised Locations" ;
    skos:definition """Location that is spread across multiple separate areas with no
distinction between their importance""" ;
    skos:exactMatch dpv:DecentralisedLocations,
        dpv_upstream:DecentralisedLocations,
        dpv_owl:DecentralisedLocations ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:Delete a owl:Class ;
    rdfs:label "Delete" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Remove ;
    skos:altLabel "Delete" ;
    skos:definition """to remove data in a logical fashion i.e. with the possibility of
retrieval""" ;
    skos:exactMatch dpv:Delete,
        dpv_upstream:Delete,
        dpv_owl:Delete ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:DeliveryOfGoods a owl:Class ;
    rdfs:label "DeliveryOfGoods" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RequestedServiceProvision ;
    skos:altLabel "Delivery of Goods" ;
    skos:definition """Purposes associated with delivering goods and services requested or
asked by consumer""" ;
    skos:exactMatch dpv:DeliveryOfGoods,
        dpv_upstream:DeliveryOfGoods,
        dpv_owl:DeliveryOfGoods ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpu:Delivery ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:DesignStandard a owl:Class ;
    rdfs:label "DesignStandard" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:Standard ;
    skos:altLabel "Design Standard" ;
    skos:definition "A set of rules or guidelines outlining criterias for design" ;
    skos:exactMatch dpv:DesignStandard,
        dpv_upstream:DesignStandard,
        dpv_owl:DesignStandard ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:Destruct a owl:Class ;
    rdfs:label "Destruct" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Remove ;
    skos:altLabel "Destruct" ;
    skos:definition "to process data in a way it no longer exists or cannot be repaired" ;
    skos:exactMatch dpv:Destruct,
        dpv_upstream:Destruct,
        dpv_owl:Destruct ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:DeterministicPseudonymisation a owl:Class ;
    rdfs:label "DeterministicPseudonymisation" ;
    rdfs:subClassOf dpv:Pseudonymisation,
        dpv:TechnicalMeasure ;
    skos:altLabel "Deterministic Pseudonymisation" ;
    skos:definition "Pseudonymisation achieved through a deterministic function" ;
    skos:exactMatch dpv:DeterministicPseudonymisation,
        dpv_upstream:DeterministicPseudonymisation,
        dpv_owl:DeterministicPseudonymisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:Deterrence a owl:Class ;
    rdfs:label "Deterrence" ;
    rdfs:subClassOf dpv:Rule,
        dpv:UnacceptableRule ;
    skos:altLabel "Deterrence" ;
    skos:definition "A rule describing a deterrence for performing an activity" ;
    skos:exactMatch dpv:Deterrence,
        dpv_upstream:Deterrence,
        dpv_owl:Deterrence ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Deterrences are aligned with the term SHOULD NOT in RFC2119 where
specified activities should be avoided from being carried out but are
not prohibitions""" ;
    dpv:skos_in_scheme "rules-classes" .

dpv:DeterrenceFollowed a owl:Class ;
    rdfs:label "DeterrenceFollowed" ;
    rdfs:subClassOf dpv:RuleFulfilled,
        dpv:RuleFulfilmentStatus ;
    skos:altLabel "Deterrence Followed" ;
    skos:definition """Status indicating a deterrence has been followed i.e. the activity
stated as being deterred has not been carried out""" ;
    skos:exactMatch dpv:DeterrenceFollowed,
        dpv_upstream:DeterrenceFollowed,
        dpv_owl:DeterrenceFollowed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

dpv:DeterrenceNotFollowed a owl:Class ;
    rdfs:label "DeterrenceNotFollowed" ;
    rdfs:subClassOf dpv:RuleFulfilmentStatus,
        dpv:RuleUnfulfilled ;
    skos:altLabel "Deterrence Not Followed" ;
    skos:definition """Status indicating a deterrence has not been followed i.e. the activity
stated as being deterred has been carried out""" ;
    skos:exactMatch dpv:DeterrenceNotFollowed,
        dpv_upstream:DeterrenceNotFollowed,
        dpv_owl:DeterrenceNotFollowed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

dpv:DeviceNotice a owl:Class ;
    rdfs:label "DeviceNotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Device Notice" ;
    skos:definition """A notice provided using the functionality provided by a device e.g.
using the popup or alert feature""" ;
    skos:exactMatch dpv:DeviceNotice,
        dpv_upstream:DeviceNotice,
        dpv_owl:DeviceNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes" .

dpv:DifferentialPrivacy a owl:Class ;
    rdfs:label "DifferentialPrivacy" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Differential Privacy" ;
    skos:definition """Utilisation of differential privacy where information is shared as
patterns or groups to withhold individual elements""" ;
    skos:exactMatch dpv:DifferentialPrivacy,
        dpv_upstream:DifferentialPrivacy,
        dpv_owl:DifferentialPrivacy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:DigitalRightsManagement a owl:Class ;
    rdfs:label "DigitalRightsManagement" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Digital Rights Management" ;
