dpv:PostedNotice a owl:Class ;
    rdfs:label "PostedNotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Posted Notice" ;
    skos:definition "A notice that is posted as a sign or banner" ;
    skos:exactMatch dpv:PostedNotice,
        dpv_upstream:PostedNotice,
        dpv_owl:PostedNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes" .

dpv:PrimaryImportance a owl:Class ;
    rdfs:label "PrimaryImportance" ;
    rdfs:subClassOf dpv:Importance ;
    skos:altLabel "Primary Importance" ;
    skos:definition "Indication of 'primary' or 'main' or 'core' importance" ;
    skos:exactMatch dpv:PrimaryImportance,
        dpv_upstream:PrimaryImportance,
        dpv_owl:PrimaryImportance ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:PrimaryUse a owl:Class ;
    rdfs:label "PrimaryUse" ;
    rdfs:subClassOf dpv:ReuseCompatibility ;
    skos:altLabel "Primary Use" ;
    skos:definition """Status indicating compatibility based on the use being either the
original context or something that is compatible with it""" ;
    skos:exactMatch dpv:PrimaryUse,
        dpv_upstream:PrimaryUse,
        dpv_owl:PrimaryUse ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Primary Use refers to an assessment where two contexts are found to be
compatible, e.g. if purpose is used to test compatibility, then for two
activities the second activity is said be the primary use if its purpose
is compatible with the first activity's purpose""" ;
    dpv:skos_in_scheme "status-classes" .

dpv:Principle a owl:Class ;
    rdfs:label "Principle" ;
    rdfs:subClassOf dpv:GuidelinesPrinciple,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Principle" ;
    skos:definition """A representation of values or norms that must be taken into
consideration when conducting activities""" ;
    skos:exactMatch dpv:Principle,
        dpv_upstream:Principle,
        dpv_owl:Principle ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:PrintedNotice a owl:Class ;
    rdfs:label "PrintedNotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Printed Notice" ;
    skos:definition "A notice that is provided in a printed form on or along with a device" ;
