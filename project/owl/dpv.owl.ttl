    skos:exactMatch dpv:DigitalRightsManagement,
        dpv_upstream:DigitalRightsManagement,
        dpv_owl:DigitalRightsManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:DigitalSignatures a owl:Class ;
