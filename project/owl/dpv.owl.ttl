    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:EncryptionInUse a owl:Class ;
    rdfs:label "EncryptionInUse" ;
    rdfs:subClassOf dpv:Encryption,
        dpv:TechnicalMeasure ;
    skos:altLabel "Encryption in Use" ;
    skos:definition "Encryption of data when it is being used" ;
