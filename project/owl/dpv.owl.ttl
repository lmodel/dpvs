dpv:DocumentSecurity a owl:Class ;
    rdfs:label "DocumentSecurity" ;
    rdfs:subClassOf dpv:SecurityMethod,
        dpv:TechnicalMeasure ;
    skos:altLabel "Document Security" ;
    skos:definition """Security measures enacted over documents to protect against tampering or
restrict access""" ;
    skos:exactMatch dpv:DocumentSecurity,
        dpv_upstream:DocumentSecurity,
        dpv_owl:DocumentSecurity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:Download a owl:Class ;
    rdfs:label "Download" ;
    rdfs:subClassOf dpv:Disclose,
        dpv:Processing ;
    skos:altLabel "Download" ;
    skos:definition """to provide a copy or to receive a copy of data over a network or
internet""" ;
    skos:exactMatch dpv:Download,
        dpv_upstream:Download,
        dpv_owl:Download ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source " 2.20" ;
    dpv:skos_in_scheme "processing-classes" .

dpv:DpvAgent a owl:Class ;
    rdfs:label "DpvAgent" ;
    rdfs:subClassOf dpv:DpvEntity ;
    skos:altLabel "Agent" ;
    skos:definition """An Agent is a dpv:Entity that is (a) acting on behalf of another Entity;
and (b) is authorised to do so by that Entity""" ;
    skos:exactMatch dpv:Agent,
        dpv_upstream:Agent,
        dpv_owl:Agent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """the Entity the Agent is acting on behalf of can be a human or non-human
and a legal or non-legal entity. For specific distinction, see
dpv:LegalAgent and tech:MachineAgent. The form and validity of
authorisation through which the Agent is empowered to represent and act
on behalf of the Entity is not defined or covered in this concept""" ;
    dpv:skos_in_scheme "entities-classes" .

dpv:DpvCustomer a owl:Class ;
    rdfs:label "DpvCustomer" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Customer" ;
    skos:definition "Humans that purchase goods or services" ;
    skos:exactMatch dpv:Customer,
        dpv_upstream:Customer,
        dpv_owl:Customer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """note: for B2B relations where customers are organisations, this concept
only applies for data subjects""" ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:DpvRegion a owl:Class ;
    rdfs:label "DpvRegion" ;
    rdfs:subClassOf dpv:DpvCountry ;
    skos:altLabel "Region" ;
    skos:definition "A region is an area or site that is considered a location" ;
    skos:exactMatch dpv:Region,
        dpv_upstream:Region,
        dpv_owl:Region ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:EULA a owl:Class ;
    rdfs:label "EULA" ;
    rdfs:subClassOf dpv:LegalBasis,
        dpv:LicenseAgreement ;
    skos:altLabel "End User License Agreement (EULA)" ;
    skos:definition """End User License Agreement is a contract entered into between a software
