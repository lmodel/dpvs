functions""" ;
    skos:exactMatch dpv:MemberPartnerManagement,
        dpv_upstream:MemberPartnerManagement,
        dpv_owl:MemberPartnerManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:MentallyVulnerableDataSubject a owl:Class ;
