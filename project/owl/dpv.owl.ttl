dpv:HealthcareOrganisation a owl:Class ;
    rdfs:label "HealthcareOrganisation" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "Healthcare Organisation" ;
    skos:definition """An organisation that delivers medical services, promotes health, and
