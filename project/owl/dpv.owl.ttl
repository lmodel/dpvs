@prefix common_domain_model: <https://w3id.org/lmodel/common-domain-model/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dpv: <https://github.com/lmodel/dpv/> .
@prefix dpv_owl: <https://w3id.org/dpv/owl#> .
@prefix dpv_upstream: <https://w3id.org/dpv#> .
@prefix gists: <https://w3id.org/lmodel/gists/> .
@prefix iso22989: <https://w3id.org/lmodel/iso22989/> .
@prefix iso27001: <https://w3id.org/lmodel/iso27001/> .
@prefix iso29100: <https://w3id.org/lmodel/iso29100/> .
@prefix iso42001: <https://w3id.org/lmodel/iso42001/> .
@prefix nist_ai_rmf: <https://w3id.org/lmodel/nist-ai-rmf/> .
@prefix nist_csf_v2: <https://w3id.org/lmodel/nist-csf-v2/> .
@prefix ocsf: <https://w3id.org/lmodel/ocsf/> .
@prefix oscal: <https://w3id.org/lmodel/oscal/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix svd: <https://specialprivacy.ercim.eu/vocabs/data#> .
@prefix svpr: <https://specialprivacy.ercim.eu/vocabs/processing#> .
@prefix svpu: <https://specialprivacy.ercim.eu/vocabs/purposes#> .
@prefix usage_policy: <https://specialprivacy.ercim.eu/langs/usage-policy#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dpv:AuthenticationABC a owl:Class ;
    rdfs:label "AuthenticationABC" ;
    rdfs:subClassOf dpv:CryptographicAuthentication,
        dpv:TechnicalMeasure ;
    skos:altLabel "Authentication using ABC",
        "Authentication-ABC" ;
    skos:definition """Use of Attribute Based Credentials (ABC) to perform and manage
authentication""" ;
    skos:exactMatch dpv:Authentication-ABC,
        dpv_upstream:Authentication-ABC,
        dpv_owl:Authentication-ABC ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:AuthenticationPABC a owl:Class ;
    rdfs:label "AuthenticationPABC" ;
    rdfs:subClassOf dpv:CryptographicAuthentication,
        dpv:TechnicalMeasure ;
    skos:altLabel "Authentication using PABC",
        "Authentication-PABC" ;
    skos:definition """Use of Privacy-enhancing Attribute Based Credentials (ABC) to perform
and manage authentication""" ;
    skos:exactMatch dpv:Authentication-PABC,
        dpv_upstream:Authentication-PABC,
        dpv_owl:Authentication-PABC ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:DpvConsumer a owl:Class ;
    rdfs:label "DpvConsumer" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Consumer" ;
    skos:definition "Humans that consume goods or services for direct use" ;
    skos:exactMatch dpv:Consumer,
        dpv_upstream:Consumer,
        dpv_owl:Consumer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:DpvOptional a owl:Class ;
    rdfs:label "DpvOptional" ;
    rdfs:subClassOf dpv:Necessity ;
    skos:altLabel "Optional" ;
    skos:definition "Indication of 'optional' or 'voluntary'" ;
    skos:exactMatch dpv:Optional,
        dpv_upstream:Optional,
        dpv_owl:Optional ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:DpvRecord a owl:Class ;
    rdfs:label "DpvRecord" ;
    rdfs:subClassOf dpv:Obtain,
        dpv:Processing ;
    skos:altLabel "Record" ;
    skos:definition "to make a record (especially media)" ;
    skos:exactMatch dpv:Record,
        dpv_upstream:Record,
        dpv_owl:Record ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:DpvService a owl:Class ;
    rdfs:label "DpvService" ;
    rdfs:subClassOf dpv:DpvProcess ;
    skos:altLabel "Service" ;
    skos:definition """A service is a process where one entity provides some benefit or
assistance to another entity""" ;
    skos:exactMatch dpv:Service,
        dpv_upstream:Service,
        dpv_owl:Service ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Service Provider and Service Consumer reflect the roles associated with
a service. 'Service' as a process is a distinct concept from the use of
'service' as a provision method in Tech extension""" ;
    dpv:skos_in_scheme "process-classes" .

dpv:DpvUser a owl:Class ;
    rdfs:label "DpvUser" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "User" ;
    skos:definition "Humans that use service(s)" ;
    skos:exactMatch dpv:User,
        dpv_upstream:User,
        dpv_owl:User ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:has_active_entity a owl:DatatypeProperty ;
    rdfs:label "has_active_entity" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "has active entity" ;
    skos:definition "indicates the entity is actively involved in specified context" ;
    skos:exactMatch dpv_upstream:hasActiveEntity,
        dpv_owl:hasActiveEntity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-properties" .

dpv:has_activity_status a owl:DatatypeProperty ;
    rdfs:label "has_activity_status" ;
    rdfs:subPropertyOf dpv:has_status ;
    skos:altLabel "has activity status" ;
    skos:definition "Indicates the status of activity of specified concept" ;
    skos:exactMatch dpv_upstream:hasActivityStatus,
        dpv_owl:hasActivityStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-properties" .

dpv:has_address a owl:DatatypeProperty ;
    rdfs:label "has_address" ;
    skos:altLabel "has address" ;
    skos:definition "Specifies address of a legal entity such as street address or pin code" ;
    skos:exactMatch dpv_upstream:hasAddress,
        dpv_owl:hasAddress ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-properties" .

dpv:has_algorithmic_logic a owl:DatatypeProperty ;
    rdfs:label "has_algorithmic_logic" ;
    skos:altLabel "has algorithmic logic" ;
    skos:definition """Indicates the logic used in processing such as for automated decision
making""" ;
    skos:exactMatch dpv_upstream:hasAlgorithmicLogic,
        dpv_owl:hasAlgorithmicLogic ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-properties" .

dpv:has_applicability a owl:DatatypeProperty ;
    rdfs:label "has_applicability" ;
    skos:altLabel "has applicability" ;
    skos:definition """Indicates situations where the context is not applicable, information is
not available, or this is unknown. An appropriate instance of
dpv:Applicability should be used with this relation to express the
situation""" ;
    skos:exactMatch dpv_upstream:hasApplicability,
        dpv_owl:hasApplicability ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-properties" .

dpv:has_applicable_law a owl:DatatypeProperty ;
    rdfs:label "has_applicable_law" ;
    skos:altLabel "has applicable law" ;
    skos:definition "Indicates applicability of a Law" ;
    skos:exactMatch dpv_upstream:hasApplicableLaw,
        dpv_owl:hasApplicableLaw ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-properties" .

dpv:has_audit_status a owl:DatatypeProperty ;
    rdfs:label "has_audit_status" ;
    rdfs:subPropertyOf dpv:has_status ;
    skos:altLabel "has audit status" ;
    skos:definition "Indicates the status of audit associated with specified concept" ;
    skos:exactMatch dpv_upstream:hasAuditStatus,
        dpv_owl:hasAuditStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-properties" .

dpv:has_authority a owl:DatatypeProperty ;
    rdfs:label "has_authority" ;
    skos:altLabel "has authority" ;
    skos:definition "Indicates applicability of authority for a jurisdiction" ;
    skos:exactMatch dpv_upstream:hasAuthority,
        dpv_owl:hasAuthority ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-authority-properties" .

dpv:has_automation_level a owl:DatatypeProperty ;
    rdfs:label "has_automation_level" ;
    skos:altLabel "has automation level" ;
    skos:definition """Indicates the level of automation involved in implementation of the
specified context""" ;
    skos:exactMatch dpv_upstream:hasAutomationLevel,
        dpv_owl:hasAutomationLevel ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-properties" .

dpv:has_conformance_status a owl:DatatypeProperty ;
    rdfs:label "has_conformance_status" ;
    skos:altLabel "has conformance status" ;
    skos:definition "Indicates the status of being conformant or non-conformant" ;
    skos:exactMatch dpv_upstream:hasConformanceStatus,
        dpv_owl:hasConformanceStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-properties" .

dpv:has_consent_control a owl:DatatypeProperty ;
    rdfs:label "has_consent_control" ;
    skos:altLabel "has consent control" ;
    skos:definition "Specific a control associated with consent" ;
    skos:exactMatch dpv_upstream:hasConsentControl,
        dpv_owl:hasConsentControl ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "consent-properties" .

dpv:has_consent_status a owl:DatatypeProperty ;
    rdfs:label "has_consent_status" ;
    skos:altLabel "has consent status" ;
    skos:definition "Specifies the state or status of consent" ;
    skos:exactMatch dpv_upstream:hasConsentStatus,
        dpv_owl:hasConsentStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "consent-properties" .

dpv:has_contact a owl:DatatypeProperty ;
    rdfs:label "has_contact" ;
    skos:altLabel "has contact" ;
    skos:definition "Specifies contact details of a legal entity such as phone or email" ;
    skos:exactMatch dpv_upstream:hasContact,
        dpv_owl:hasContact ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-properties" .

dpv:has_context a owl:DatatypeProperty ;
    rdfs:label "has_context" ;
    skos:altLabel "has context" ;
    skos:definition "Indicates a purpose is restricted to the specified context(s)" ;
    skos:exactMatch dpv_upstream:hasContext,
        dpv_owl:hasContext ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-properties" .

dpv:has_contract_control a owl:DatatypeProperty ;
    rdfs:label "has_contract_control" ;
    skos:altLabel "has contract control" ;
    skos:definition "Indicates the contract to be used with a contract" ;
    skos:exactMatch dpv_upstream:hasContractControl,
        dpv_owl:hasContractControl ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-properties" .

dpv:has_contractual_clause a owl:DatatypeProperty ;
    rdfs:label "has_contractual_clause" ;
    skos:altLabel "has contractual clause" ;
    skos:definition "Indicates the association or involvement of specified contractual clause" ;
    skos:exactMatch dpv_upstream:hasContractualClause,
        dpv_owl:hasContractualClause ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-properties" .

dpv:has_contractual_fulfilment_status a owl:DatatypeProperty ;
    rdfs:label "has_contractual_fulfilment_status" ;
    rdfs:subPropertyOf dpv:has_contract_status ;
    skos:altLabel "has contractual fulfilment status" ;
    skos:definition "Indicates the fulfilment status of a contract or a contractual clause" ;
    skos:exactMatch dpv_upstream:hasContractualFulfilmentStatus,
        dpv_owl:hasContractualFulfilmentStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-properties" .

dpv:has_data_exporter a owl:DatatypeProperty ;
    rdfs:label "has_data_exporter" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "has data exporter" ;
    skos:definition """Indicates inclusion or applicability of a LegalEntity in the role of
Data Exporter""" ;
    skos:exactMatch dpv_upstream:hasDataExporter,
        dpv_owl:hasDataExporter ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-legalrole-properties" .

dpv:has_data_importer a owl:DatatypeProperty ;
    rdfs:label "has_data_importer" ;
    rdfs:subPropertyOf dpv:has_recipient ;
    skos:altLabel "has data importer" ;
    skos:definition """Indicates inclusion or applicability of a LegalEntity in the role of
Data Importer""" ;
    skos:exactMatch dpv_upstream:hasDataImporter,
        dpv_owl:hasDataImporter ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-legalrole-properties" .

dpv:has_data_processor a owl:DatatypeProperty ;
    rdfs:label "has_data_processor" ;
    rdfs:subPropertyOf dpv:has_recipient ;
    skos:altLabel "has data processor" ;
    skos:definition "Indicates inclusion or applicability of a Data Processor" ;
    skos:exactMatch dpv_upstream:hasDataProcessor,
        dpv_owl:hasDataProcessor ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-legalrole-properties" .

dpv:has_data_protection_officer a owl:DatatypeProperty ;
    rdfs:label "has_data_protection_officer" ;
    rdfs:subPropertyOf dpv:has_representative ;
    skos:altLabel "has data protection officer" ;
    skos:definition "Specifies an associated data protection officer" ;
    skos:exactMatch dpv_upstream:hasDataProtectionOfficer,
        dpv_owl:hasDataProtectionOfficer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-legalrole-properties" .

dpv:has_data_source a owl:DatatypeProperty ;
    rdfs:label "has_data_source" ;
    skos:altLabel "has data source" ;
    skos:definition "Indicates the source or origin of data being processed" ;
    skos:exactMatch dpv_upstream:hasDataSource,
        dpv_owl:hasDataSource ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-properties" .

dpv:has_data_subject a owl:DatatypeProperty ;
    rdfs:label "has_data_subject" ;
    rdfs:subPropertyOf dpv:has_human_subject ;
    skos:altLabel "has data subject" ;
    skos:definition "Indicates association with Data Subject" ;
    skos:exactMatch dpv_upstream:hasDataSubject,
        dpv_owl:hasDataSubject ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-properties" .

dpv:has_data_subject_scale a owl:DatatypeProperty ;
    rdfs:label "has_data_subject_scale" ;
    rdfs:subPropertyOf dpv:has_scale ;
    skos:altLabel "has data subject scale" ;
    skos:definition "Indicates the scale of data subjects" ;
    skos:exactMatch dpv_upstream:hasDataSubjectScale,
        dpv_owl:hasDataSubjectScale ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-properties" .

dpv:has_data_volume a owl:DatatypeProperty ;
    rdfs:label "has_data_volume" ;
    rdfs:subPropertyOf dpv:has_scale ;
    skos:altLabel "has data volume" ;
    skos:definition "Indicates the volume of data" ;
    skos:exactMatch dpv_upstream:hasDataVolume,
        dpv_owl:hasDataVolume ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-properties" .

dpv:has_deterrence a owl:DatatypeProperty ;
    rdfs:label "has_deterrence" ;
    rdfs:subPropertyOf dpv:has_rule ;
    skos:altLabel "has deterrence" ;
    skos:definition """Specifies applicability or inclusion of a deterrence rule within
specified context""" ;
    skos:exactMatch dpv_upstream:hasDeterrence,
        dpv_owl:hasDeterrence ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-properties" .

dpv:has_duration a owl:DatatypeProperty ;
    rdfs:label "has_duration" ;
    skos:altLabel "has duration" ;
    skos:definition "Indicates information about duration" ;
    skos:exactMatch dpv_upstream:hasDuration,
        dpv_owl:hasDuration ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-properties" .

dpv:has_entity_control a owl:DatatypeProperty ;
    rdfs:label "has_entity_control" ;
    rdfs:subPropertyOf dpv:has_technical_organisational_measure ;
    skos:altLabel "has entity control" ;
    skos:definition """Indicates a control or measure provided for an entity to perform the
specified action""" ;
    skos:exactMatch dpv_upstream:hasEntityControl,
        dpv_owl:hasEntityControl ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "TOM-properties" .

dpv:has_entity_involvement a owl:DatatypeProperty ;
    rdfs:label "has_entity_involvement" ;
    skos:altLabel "has entity involvement" ;
    skos:definition "Indicates involvement of an entity in specified context" ;
    skos:exactMatch dpv_upstream:hasEntityInvolvement,
        dpv_owl:hasEntityInvolvement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-properties" .

dpv:has_expectation a owl:DatatypeProperty ;
    rdfs:label "has_expectation" ;
    rdfs:subPropertyOf dpv:has_status ;
    skos:altLabel "has expectation" ;
    skos:definition "Indicates whether the specified context was expected or unexpected" ;
    skos:exactMatch dpv_upstream:hasExpectation,
        dpv_owl:hasExpectation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-properties" .

dpv:has_fee a owl:DatatypeProperty ;
    rdfs:label "has_fee" ;
    skos:altLabel "has fee" ;
    skos:definition "Indicates whether a fee is required for the specified context" ;
    skos:exactMatch dpv_upstream:hasFee,
        dpv_owl:hasFee ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-properties" .

dpv:has_frequency a owl:DatatypeProperty ;
    rdfs:label "has_frequency" ;
    skos:altLabel "has frequency" ;
    skos:definition "Indicates the frequency with which something takes place" ;
    skos:exactMatch dpv_upstream:hasFrequency,
        dpv_owl:hasFrequency ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-properties" .

dpv:has_fulfilment_status a owl:DatatypeProperty ;
    rdfs:label "has_fulfilment_status" ;
    rdfs:subPropertyOf dpv:has_status ;
    skos:altLabel "has fulfilment status" ;
    skos:definition "Specifies the fulfillment status associated with a rule" ;
    skos:exactMatch dpv_upstream:hasFulfilmentStatus,
        dpv_owl:hasFulfilmentStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-properties" .

dpv:has_geographic_coverage a owl:DatatypeProperty ;
    rdfs:label "has_geographic_coverage" ;
    rdfs:subPropertyOf dpv:has_scale ;
    skos:altLabel "has geographic coverage" ;
    skos:definition "Indicates the geographic coverage (of specified context)" ;
    skos:exactMatch dpv_upstream:hasGeographicCoverage,
        dpv_owl:hasGeographicCoverage ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-properties" .

dpv:has_human_involvement a owl:DatatypeProperty ;
    rdfs:label "has_human_involvement" ;
    skos:altLabel "has human involvement" ;
    skos:definition """Indicates Involvement of humans in processing such as within automated
decision making process""" ;
    skos:exactMatch dpv_upstream:hasHumanInvolvement,
        dpv_owl:hasHumanInvolvement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Human involvement is also relevant to 'human in the loop'" ;
    dpv:skos_in_scheme "processing-context-properties" .

dpv:has_identifier a owl:DatatypeProperty ;
    rdfs:label "has_identifier" ;
    skos:altLabel "has identifier" ;
    skos:definition "Indicates an identifier associated for identification or reference" ;
    skos:exactMatch dpv_upstream:hasIdentifier,
        dpv_owl:hasIdentifier ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-properties" .

dpv:has_impact a owl:DatatypeProperty ;
    rdfs:label "has_impact" ;
    rdfs:subPropertyOf dpv:has_consequence ;
    skos:altLabel "has impact" ;
    skos:definition """Indicates impact(s) possible or arising as consequences from specified
concept""" ;
    skos:exactMatch dpv_upstream:hasImpact,
        dpv_owl:hasImpact ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-properties" .

dpv:has_impact_assessment a owl:DatatypeProperty ;
    rdfs:label "has_impact_assessment" ;
    rdfs:subPropertyOf dpv:has_assessment ;
    skos:altLabel "has impact assessment" ;
    skos:definition "Indicates an impact assessment associated with the specific context" ;
    skos:exactMatch dpv_upstream:hasImpactAssessment,
        dpv_owl:hasImpactAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-properties" .

dpv:has_impact_on a owl:DatatypeProperty ;
    rdfs:label "has_impact_on" ;
    rdfs:subPropertyOf dpv:has_consequence_on ;
    skos:altLabel "has impact on" ;
    skos:definition """Indicates the thing (e.g. plan, process, or entity) affected by an
impact""" ;
    skos:exactMatch dpv_upstream:hasImpactOn,
        dpv_owl:hasImpactOn ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-properties" .

dpv:has_importance a owl:DatatypeProperty ;
    rdfs:label "has_importance" ;
    skos:altLabel "has importance" ;
    skos:definition "Indicates the importance for specified context or criteria" ;
    skos:exactMatch dpv_upstream:hasImportance,
        dpv_owl:hasImportance ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-properties" .

dpv:has_indication_method a owl:DatatypeProperty ;
    rdfs:label "has_indication_method" ;
    skos:altLabel "has indication method" ;
    skos:definition """Specifies the method by which an entity has indicated the specific
context""" ;
    skos:exactMatch dpv_upstream:hasIndicationMethod,
        dpv_owl:hasIndicationMethod ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
