    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

dpv:ProhibitionViolated a owl:Class ;
    rdfs:label "ProhibitionViolated" ;
    rdfs:subClassOf dpv:RuleFulfilmentStatus,
        dpv:RuleViolated ;
    skos:altLabel "Prohibition Violated" ;
    skos:definition """Status indicating a prohibition has been violated i.e. the activity
stated as being prohibited has been carried out""" ;
    skos:exactMatch dpv:ProhibitionViolated,
        dpv_upstream:ProhibitionViolated,
        dpv_owl:ProhibitionViolated ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

