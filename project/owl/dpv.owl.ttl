    rdfs:label "ProfessionalConfidentialData" ;
    rdfs:subClassOf dpv:ConfidentialData ;
    skos:altLabel "Professional Confidential Data" ;
    skos:definition """Data protected by professional secrecy or confidentiality, including but
not limited to data covered by professional privilege or secrecy
obligations such as that covered by lawyer or doctor-patient
confidentiality and other forms of recognised professional
confidentiality obligations""" ;
    skos:exactMatch dpv:ProfessionalConfidentialData,
        dpv_upstream:ProfessionalConfidentialData,
        dpv_owl:ProfessionalConfidentialData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:ProfessionalTraining a owl:Class ;
    rdfs:label "ProfessionalTraining" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:StaffTraining ;
    skos:altLabel "Professional Training" ;
    skos:definition """Training methods that are intended to provide professional knowledge and
expertise""" ;
    skos:exactMatch dpv:ProfessionalTraining,
        dpv_upstream:ProfessionalTraining,
        dpv_owl:ProfessionalTraining ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:Profiling a owl:Class ;
    rdfs:label "Profiling" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Use ;
    skos:altLabel "Profiling" ;
    skos:definition "to create a profile that describes or represents a person" ;
    skos:exactMatch dpv:Profiling,
        dpv_upstream:Profiling,
        dpv_owl:Profiling ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch iso22989:Prediction ;
    dpv:skos_in_scheme "processing-classes" .

dpv:Prohibition a owl:Class ;
    rdfs:label "Prohibition" ;
    rdfs:subClassOf dpv:Rule,
        dpv:UnacceptableRule ;
    skos:altLabel "Prohibition" ;
    skos:definition "A rule describing a prohibition to perform an activity" ;
    skos:exactMatch dpv:Prohibition,
        dpv_upstream:Prohibition,
        dpv_owl:Prohibition ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Prohibitions are aligned with the term MUST NOT in RFC2119 where
specified activities are prohibited from being carried out""" ;
    dpv:skos_in_scheme "rules-classes" .

dpv:ProhibitionUnviolated a owl:Class ;
    rdfs:label "ProhibitionUnviolated" ;
    rdfs:subClassOf dpv:RuleFulfilled,
        dpv:RuleFulfilmentStatus ;
    skos:altLabel "Prohibition Unviolated" ;
    skos:definition """Status indicating a prohibition has not been violated i.e. the activity
