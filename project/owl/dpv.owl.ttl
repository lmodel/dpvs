    dpv:skos_in_scheme "technical-measures-classes" .

dpv:DirectMarketing a owl:Class ;
    rdfs:label "DirectMarketing" ;
    rdfs:subClassOf dpv:Marketing,
        dpv:Purpose ;
    skos:altLabel "Direct Marketing" ;
    skos:definition """Purposes associated with conducting direct marketing i.e. marketing
