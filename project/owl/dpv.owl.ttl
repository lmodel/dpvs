    skos:exactMatch dpv:ProvideOfficialStatistics,
        dpv_upstream:ProvideOfficialStatistics,
        dpv_owl:ProvideOfficialStatistics ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.16" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ProvideProductRecommendations a owl:Class ;
    rdfs:label "ProvideProductRecommendations" ;
    rdfs:subClassOf dpv:ProvidePersonalisedRecommendations,
        dpv:Purpose ;
    skos:altLabel "Provide Product Recommendations" ;
    skos:definition """Purposes associated with creating and providing product recommendations
e.g. suggest similar products""" ;
    skos:exactMatch dpv:ProvideProductRecommendations,
        dpv_upstream:ProvideProductRecommendations,
        dpv_owl:ProvideProductRecommendations ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpu:Marketing ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ProvidedPersonalData a owl:Class ;
    rdfs:label "ProvidedPersonalData" ;
    rdfs:subClassOf dpv:CollectedPersonalData,
        dpv:ProvidedData ;
    skos:altLabel "Provided Personal Data" ;
    skos:definition """Personal Data that has been provided by an entity such as the Data
Subject""" ;
    skos:exactMatch dpv:ProvidedPersonalData,
        dpv_upstream:ProvidedPersonalData,
        dpv_owl:ProvidedPersonalData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Provided personal data involves one entity (e.g. data subject)
explicitly providing the data, which the other entity (e.g. data
controller) then collects""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:ProviderStandardFormContract a owl:Class ;
    rdfs:label "ProviderStandardFormContract" ;
    rdfs:subClassOf dpv:LegalBasis,
        dpv:StandardFormContract ;
    skos:altLabel "Provider Standard Form Contract" ;
    skos:definition """A contract where the terms and conditions are determined by parties in
the role of a 'provider', and the other parties have negligible or no
ability to negotiate the terms and conditions""" ;
    skos:exactMatch dpv:ProviderStandardFormContract,
        dpv_upstream:ProviderStandardFormContract,
        dpv_owl:ProviderStandardFormContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:Pseudonymise a owl:Class ;
    rdfs:label "Pseudonymise" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Transform ;
    skos:altLabel "Pseudonymise" ;
    skos:definition "to replace personal identifiable information by artificial identifiers" ;
    skos:exactMatch dpv:Pseudonymise,
        dpv_upstream:Pseudonymise,
        dpv_owl:Pseudonymise ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:PublicDataSource a owl:Class ;
    rdfs:label "PublicDataSource" ;
    rdfs:subClassOf dpv:DataSource ;
    skos:altLabel "Public Data Source" ;
    skos:definition "A source of data that is publicly accessible or available" ;
    skos:exactMatch dpv:PublicDataSource,
        dpv_upstream:PublicDataSource,
        dpv_owl:PublicDataSource ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The term 'Public' is used here in a broad sense. Actual consideration of
what is 'Public Data' can vary based on several contextual or
jurisdictional factors such as definition of open, methods of access,
permissions and licenses.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:PublicInterest a owl:Class ;
    rdfs:label "PublicInterest" ;
    rdfs:subClassOf dpv:LegalBasis ;
    skos:altLabel "Public Interest" ;
    skos:definition """Activities are necessary or beneficial for interest of the public or
society at large""" ;
    skos:exactMatch dpv:PublicInterest,
        dpv_upstream:PublicInterest,
        dpv_owl:PublicInterest ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:PublicInterestCompleted a owl:Class ;
    rdfs:label "PublicInterestCompleted" ;
    rdfs:subClassOf dpv:PublicInterestStatus ;
    skos:altLabel "Public Interest Completed" ;
    skos:definition "Status where the public interest activity has been completed" ;
    skos:exactMatch dpv:PublicInterestCompleted,
        dpv_upstream:PublicInterestCompleted,
        dpv_owl:PublicInterestCompleted ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:PublicInterestObjected a owl:Class ;
    rdfs:label "PublicInterestObjected" ;
    rdfs:subClassOf dpv:PublicInterestStatus ;
    skos:altLabel "Public Interest Objected" ;
    skos:definition """Status where the public interest activity was objected to by the Data
Subject or another relevant entity""" ;
    skos:exactMatch dpv:PublicInterestObjected,
        dpv_upstream:PublicInterestObjected,
        dpv_owl:PublicInterestObjected ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:PublicInterestOngoing a owl:Class ;
    rdfs:label "PublicInterestOngoing" ;
    rdfs:subClassOf dpv:PublicInterestStatus ;
    skos:altLabel "Public Interest Ongoing" ;
    skos:definition "Status where the public interest activity is ongoing" ;
    skos:exactMatch dpv:PublicInterestOngoing,
        dpv_upstream:PublicInterestOngoing,
        dpv_owl:PublicInterestOngoing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:PublicInterestPending a owl:Class ;
    rdfs:label "PublicInterestPending" ;
    rdfs:subClassOf dpv:PublicInterestStatus ;
    skos:altLabel "Public Interest Pending" ;
    skos:definition "Status where the public interest activity has not started" ;
    skos:exactMatch dpv:PublicInterestPending,
        dpv_upstream:PublicInterestPending,
        dpv_owl:PublicInterestPending ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:PublicLocation a owl:Class ;
    rdfs:label "PublicLocation" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:LocalLocation ;
    skos:altLabel "Public Location (deprecated)" ;
    skos:definition "Location that is or can be accessed by the public" ;
    skos:exactMatch dpv:PublicLocation,
        dpv_upstream:PublicLocation,
        dpv_owl:PublicLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept will be deprecated in a future DPV release, it is suggested
to use the better defined and legally aligned dpv:PublicSpace instead""" ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:PublicPolicyMaking a owl:Class ;
    rdfs:label "PublicPolicyMaking" ;
    rdfs:subClassOf dpv:PublicBenefit,
        dpv:Purpose ;
    skos:altLabel "Public Policy Making" ;
    skos:definition """Purposes associated with public policy making, such as the development
of new laws""" ;
    skos:exactMatch dpv:PublicPolicyMaking,
        dpv_upstream:PublicPolicyMaking,
        dpv_owl:PublicPolicyMaking ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.16" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:PublicRelations a owl:Class ;
    rdfs:label "PublicRelations" ;
    rdfs:subClassOf dpv:Marketing,
        dpv:Purpose ;
    skos:altLabel "Public Relations" ;
    skos:definition """Purposes associated with managing and conducting public relations
processes, including creating goodwill for the organisation""" ;
    skos:exactMatch dpv:PublicRelations,
        dpv_upstream:PublicRelations,
        dpv_owl:PublicRelations ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:PublicSectorBody a owl:Class ;
    rdfs:label "PublicSectorBody" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Public Sector Body" ;
    skos:definition """A government-controlled organisation that provides services or goods to
the public""" ;
    skos:exactMatch dpv:PublicSectorBody,
        dpv_upstream:PublicSectorBody,
        dpv_owl:PublicSectorBody ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:PubliclyOwnedSpace a owl:Class ;
    rdfs:label "PubliclyOwnedSpace" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:PublicSpace ;
    skos:altLabel "Publicly Owned Space" ;
    skos:definition "A space that is owned by the public e.g. national parks, forests" ;
    skos:exactMatch dpv:PubliclyOwnedSpace,
        dpv_upstream:PubliclyOwnedSpace,
        dpv_owl:PubliclyOwnedSpace ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:QuantumCryptography a owl:Class ;
    rdfs:label "QuantumCryptography" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Quantum Cryptography" ;
    skos:definition """Cryptographic methods that utilise quantum mechanical properties to
perform cryptographic tasks""" ;
    skos:exactMatch dpv:QuantumCryptography,
        dpv_upstream:QuantumCryptography,
        dpv_owl:QuantumCryptography ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:Query a owl:Class ;
    rdfs:label "Query" ;
    rdfs:subClassOf dpv:Consult,
        dpv:Processing ;
    skos:altLabel "Query" ;
    skos:definition "to query or make enquiries over data" ;
    skos:exactMatch dpv:Query,
        dpv_upstream:Query,
        dpv_owl:Query ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:RNGPseudonymisation a owl:Class ;
    rdfs:label "RNGPseudonymisation" ;
    rdfs:subClassOf dpv:Pseudonymisation,
        dpv:TechnicalMeasure ;
    skos:altLabel "RNG Pseudonymisation" ;
    skos:definition """A pseudonymisation method where identifiers are substituted by a number
chosen by a Random Number Generator (RNG)""" ;
    skos:exactMatch dpv:RNGPseudonymisation,
        dpv_upstream:RNGPseudonymisation,
        dpv_owl:RNGPseudonymisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:ROPA a owl:Class ;
    rdfs:label "ROPA" ;
    rdfs:subClassOf dpv:DataProcessingRecord,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Records of Processing Activities" ;
    skos:definition """A Record of Processing Activities (ROPA) is a document detailing
processing activities""" ;
    skos:exactMatch dpv:ROPA,
        dpv_upstream:ROPA,
        dpv_owl:ROPA ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """ROPA under GDPR Art.30 has specific requirements regarding the
information to be maintained. Additionally, Data Protection Authorities
also provide additional information guidelines for information to be
maintained in a ROPA. For more information see https://w3id.org/dpcat""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:RandomLocation a owl:Class ;
    rdfs:label "RandomLocation" ;
    rdfs:subClassOf dpv:LocationFixture ;
    skos:altLabel "Random Location" ;
    skos:definition "Location that is random or unknown" ;
    skos:exactMatch dpv:RandomLocation,
        dpv_upstream:RandomLocation,
        dpv_owl:RandomLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:RecertificationPolicy a owl:Class ;
    rdfs:label "RecertificationPolicy" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:Policy ;
    skos:altLabel "Recertification Policy" ;
    skos:definition "Policy regarding repetition or renewal of existing certification(s)" ;
    skos:exactMatch dpv:RecertificationPolicy,
        dpv_upstream:RecertificationPolicy,
        dpv_owl:RecertificationPolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:RecipientInformed a owl:Class ;
    rdfs:label "RecipientInformed" ;
    rdfs:subClassOf dpv:EntityInformed,
        dpv:EntityInformedStatus ;
    skos:altLabel "Recipient Informed" ;
    skos:definition """Status indicating Recipient has been informed about the specified
context""" ;
    skos:exactMatch dpv:RecipientInformed,
        dpv_upstream:RecipientInformed,
        dpv_owl:RecipientInformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:RecipientUninformed a owl:Class ;
    rdfs:label "RecipientUninformed" ;
    rdfs:subClassOf dpv:EntityInformedStatus,
        dpv:EntityUninformed ;
    skos:altLabel "Recipient Uninformed" ;
    skos:definition """Status indicating Recipient is uninformed i.e. has not been informed
about the specified context""" ;
    skos:exactMatch dpv:RecipientUninformed,
        dpv_upstream:RecipientUninformed,
        dpv_owl:RecipientUninformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:Recommendation a owl:Class ;
    rdfs:label "Recommendation" ;
    rdfs:subClassOf dpv:AcceptableRule,
        dpv:Rule ;
    skos:altLabel "Recommendation" ;
    skos:definition "A rule describing a recommendation for performing an activity" ;
    skos:exactMatch dpv:Recommendation,
        dpv_upstream:Recommendation,
        dpv_owl:Recommendation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Recommendations are aligned with the term SHOULD in RFC2119 where
specified activities should be carried out but are not obligations""" ;
    dpv:skos_in_scheme "rules-classes" .

dpv:RecommendationFollowed a owl:Class ;
    rdfs:label "RecommendationFollowed" ;
    rdfs:subClassOf dpv:RuleFulfilled,
        dpv:RuleFulfilmentStatus ;
    skos:altLabel "Recommendation Followed" ;
    skos:definition """Status indicating a recommendation has been followed i.e. the activity
stated as being recommended has been carried out""" ;
    skos:exactMatch dpv:RecommendationFollowed,
        dpv_upstream:RecommendationFollowed,
        dpv_owl:RecommendationFollowed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

dpv:RecommendationNotFollowed a owl:Class ;
    rdfs:label "RecommendationNotFollowed" ;
    rdfs:subClassOf dpv:RuleFulfilmentStatus,
        dpv:RuleUnfulfilled ;
    skos:altLabel "Recommendation Not Followed" ;
    skos:definition """Status indicating a recommendation has not been followed i.e. the
activity stated as being recommended has not been carried out""" ;
    skos:exactMatch dpv:RecommendationNotFollowed,
        dpv_upstream:RecommendationNotFollowed,
        dpv_owl:RecommendationNotFollowed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

dpv:RecordManagement a owl:Class ;
    rdfs:label "RecordManagement" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Record Management" ;
    skos:definition """Purposes associated with manage creation, storage, and use of records
relevant to operations, events, and processes e.g. to store logs or
access requests""" ;
    skos:exactMatch dpv:RecordManagement,
        dpv_upstream:RecordManagement,
        dpv_owl:RecordManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This purpose relates specifically for record creation and management.
This can be combined or used along with other purposes to express
intentions such as records for legal compliance or vendor payments.""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentApplicantBackgroundCheck a owl:Class ;
    rdfs:label "RecruitmentApplicantBackgroundCheck" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentManagement ;
    skos:altLabel "Recruitment Applicant Background Check" ;
    skos:definition """Purposes assocaited with conducting background checks for prospective
and current job applicants for recruitment""" ;
    skos:exactMatch dpv:RecruitmentApplicantBackgroundCheck,
        dpv_upstream:RecruitmentApplicantBackgroundCheck,
        dpv_owl:RecruitmentApplicantBackgroundCheck ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentApplicantCriminalBackgroundCheck a owl:Class ;
    rdfs:label "RecruitmentApplicantCriminalBackgroundCheck" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentManagement ;
    skos:altLabel "Recruitment Applicant Criminal Background Check" ;
    skos:definition """Purposes associated with conducting criminal background assessment for
prospective and current job applicants for recruitment""" ;
    skos:exactMatch dpv:RecruitmentApplicantCriminalBackgroundCheck,
        dpv_upstream:RecruitmentApplicantCriminalBackgroundCheck,
        dpv_owl:RecruitmentApplicantCriminalBackgroundCheck ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentApplicantInformationAuthentication a owl:Class ;
    rdfs:label "RecruitmentApplicantInformationAuthentication" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentManagement ;
    skos:altLabel "Recruitment Applicant Information Authentication" ;
    skos:definition """Purposes associated with authentication and verification of information
as part of recruitment""" ;
    skos:exactMatch dpv:RecruitmentApplicantInformationAuthentication,
        dpv_upstream:RecruitmentApplicantInformationAuthentication,
        dpv_owl:RecruitmentApplicantInformationAuthentication ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentApplicantSelection a owl:Class ;
    rdfs:label "RecruitmentApplicantSelection" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentManagement ;
    skos:altLabel "Recruitment Applicant Selection" ;
    skos:definition """Purposes associated with determination or selection of candidates,
whether for a specific job or job pool, or for a specific stage as part
of recruitment""" ;
    skos:exactMatch dpv:RecruitmentApplicantSelection,
        dpv_upstream:RecruitmentApplicantSelection,
        dpv_owl:RecruitmentApplicantSelection ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentApplicationAnalysis a owl:Class ;
    rdfs:label "RecruitmentApplicationAnalysis" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentApplicationManagement ;
    skos:altLabel "Recruitment Application Analysis" ;
    skos:definition """Purposes assocaited with analysis of job applications or job candidates
for recruitment""" ;
    skos:exactMatch dpv:RecruitmentApplicationAnalysis,
        dpv_upstream:RecruitmentApplicationAnalysis,
        dpv_owl:RecruitmentApplicationAnalysis ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentApplicationScreening a owl:Class ;
    rdfs:label "RecruitmentApplicationScreening" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentApplicationManagement ;
    skos:altLabel "Recruitment Application Screening" ;
    skos:definition """Purposes associated with screening and filtering of job applications or
job candidates for recruitment""" ;
    skos:exactMatch dpv:RecruitmentApplicationScreening,
        dpv_upstream:RecruitmentApplicationScreening,
        dpv_owl:RecruitmentApplicationScreening ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentInterviewAnalysis a owl:Class ;
    rdfs:label "RecruitmentInterviewAnalysis" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentInterviewManagement ;
    skos:altLabel "Recruitment Interview Analysis" ;
    skos:definition """Purposes associated with analysis of interviews, including the people
and involved, for recruitment""" ;
    skos:exactMatch dpv:RecruitmentInterviewAnalysis,
        dpv_upstream:RecruitmentInterviewAnalysis,
        dpv_owl:RecruitmentInterviewAnalysis ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentInterviewAssessment a owl:Class ;
    rdfs:label "RecruitmentInterviewAssessment" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentInterviewManagement ;
    skos:altLabel "Recruitment Interview Assessment" ;
    skos:definition """Purposes associated with assessment of interviews, including assessment
of people and information, for recruitment""" ;
    skos:exactMatch dpv:RecruitmentInterviewAssessment,
        dpv_upstream:RecruitmentInterviewAssessment,
        dpv_owl:RecruitmentInterviewAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentInterviewScheduling a owl:Class ;
    rdfs:label "RecruitmentInterviewScheduling" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentInterviewManagement ;
    skos:altLabel "Recruitment Interview Scheduling" ;
    skos:definition "Purposes associated with scheduling interviews for recruitment" ;
    skos:exactMatch dpv:RecruitmentInterviewScheduling,
        dpv_upstream:RecruitmentInterviewScheduling,
        dpv_owl:RecruitmentInterviewScheduling ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentTargetedAdvertising a owl:Class ;
    rdfs:label "RecruitmentTargetedAdvertising" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentAdvertising,
        dpv:TargetedAdvertising ;
    skos:altLabel "Targeted Recruitment Advertising" ;
    skos:definition """Purposes associated with targeted advertisement for Recruitments and
personnel hiring""" ;
    skos:exactMatch dpv:RecruitmentTargetedAdvertising,
        dpv_upstream:RecruitmentTargetedAdvertising,
        dpv_owl:RecruitmentTargetedAdvertising ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Reformat a owl:Class ;
    rdfs:label "Reformat" ;
    rdfs:subClassOf dpv:Format,
        dpv:Processing ;
    skos:altLabel "Reformat" ;
    skos:definition "to rearrange or restructure data to change its form" ;
    skos:exactMatch dpv:Reformat,
        dpv_upstream:Reformat,
        dpv_owl:Reformat ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 12.d" ;
    dpv:skos_in_scheme "processing-classes" .

dpv:RefuseConsent a owl:Class ;
    rdfs:label "RefuseConsent" ;
    rdfs:subClassOf dpv:ConsentControl ;
    skos:altLabel "Refuse Consent" ;
    skos:definition "Control for refusing consent" ;
    skos:exactMatch dpv:RefuseConsent,
        dpv_upstream:RefuseConsent,
        dpv_owl:RefuseConsent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Indicates how the controller (with dpv:ObtainConsent) or data subject
(with dpv:ProvideConsent) can reaffirm consent e.g. used with
dpv:isExercisedAt""" ;
    dpv:skos_in_scheme "consent-controls-classes" .

dpv:RefuseContract a owl:Class ;
    rdfs:label "RefuseContract" ;
    rdfs:subClassOf dpv:ContractControl ;
    skos:altLabel "Refuse Contract" ;
    skos:definition "Control for refusing a contract" ;
    skos:exactMatch dpv:RefuseContract,
        dpv_upstream:RefuseContract,
        dpv_owl:RefuseContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-control-classes" .

dpv:RegionalAuthority a owl:Class ;
    rdfs:label "RegionalAuthority" ;
    rdfs:subClassOf dpv:DpvAuthority ;
    skos:altLabel "Regional Authority" ;
    skos:definition "An authority tasked with overseeing legal compliance for a region" ;
    skos:exactMatch dpv:RegionalAuthority,
        dpv_upstream:RegionalAuthority,
        dpv_owl:RegionalAuthority ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-authority-classes" .

dpv:RegionalScale a owl:Class ;
    rdfs:label "RegionalScale" ;
    rdfs:subClassOf dpv:GeographicCoverage ;
    skos:altLabel "Regional Scale" ;
    skos:definition "Geographic coverage spanning a specific region or regions" ;
    skos:exactMatch dpv:RegionalScale,
        dpv_upstream:RegionalScale,
        dpv_owl:RegionalScale ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:RegulatorySandbox a owl:Class ;
    rdfs:label "RegulatorySandbox" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:Safeguard ;
    skos:altLabel "Regulatory Sandbox" ;
    skos:definition """Mechanism used by regulators and businesses for gauging the
compatibility of regulations and innovative products, particularly in
the context of digitalisation, in a controlled real-world environment
with appropriate safeguards in place""" ;
    skos:exactMatch dpv:RegulatorySandbox,
        dpv_upstream:RegulatorySandbox,
        dpv_owl:RegulatorySandbox ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ReligiousAssociations a owl:Class ;
    rdfs:label "ReligiousAssociations" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "Religious Associations" ;
    skos:definition """An organisations that supports the practice, promotion, and management
of religious activities and beliefs""" ;
    skos:exactMatch dpv:ReligiousAssociations,
        dpv_upstream:ReligiousAssociations,
        dpv_owl:ReligiousAssociations ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:RenewedConsentGiven a owl:Class ;
    rdfs:label "RenewedConsentGiven" ;
    rdfs:subClassOf dpv:ConsentStatus,
        dpv:ConsentStatusValidForProcessing ;
    skos:altLabel "Renewed Consent Given" ;
    skos:definition """The state where a previously given consent has been 'renewed' or
'refreshed' or 'reaffirmed' to form a new instance of given consent""" ;
    skos:exactMatch dpv:RenewedConsentGiven,
        dpv_upstream:RenewedConsentGiven,
        dpv_owl:RenewedConsentGiven ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of this state is when a previously given consent has expired,
and the individual is presented a notice regarding continuing associated
processing operations - to which they agree. This state can be useful to
keep track of 'reconfirmed' or 'refreshed' consent within consent
records, assist notices and contextual agents to create better
consenting dialogues, and assist with specific legal obligations related
to subsequent consenting""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:RepairImpairments a owl:Class ;
    rdfs:label "RepairImpairments" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceManagement ;
    skos:altLabel "Repair Impairments" ;
    skos:definition """Purposes associated with identifying, rectifying, or otherwise
undertaking activities intended to fix or repair impairments to existing
functionalities""" ;
    skos:exactMatch dpv:RepairImpairments,
        dpv_upstream:RepairImpairments,
        dpv_owl:RepairImpairments ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of identifying and rectifying impairments is the process of
finding and fixing errors in products, commonly referred to as debugging""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RequestAccepted a owl:Class ;
    rdfs:label "RequestAccepted" ;
    rdfs:subClassOf dpv:RequestStatus ;
    skos:altLabel "Request Accepted" ;
    skos:definition "State of a request being accepted towards fulfilment" ;
    skos:exactMatch dpv:RequestAccepted,
        dpv_upstream:RequestAccepted,
        dpv_owl:RequestAccepted ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:RequestAcknowledged a owl:Class ;
    rdfs:label "RequestAcknowledged" ;
    rdfs:subClassOf dpv:RequestStatus ;
    skos:altLabel "Request Acknowledged" ;
    skos:definition "State of a request being acknowledged" ;
    skos:exactMatch dpv:RequestAcknowledged,
        dpv_upstream:RequestAcknowledged,
        dpv_owl:RequestAcknowledged ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:RequestActionDelayed a owl:Class ;
    rdfs:label "RequestActionDelayed" ;
    rdfs:subClassOf dpv:RequestStatus ;
    skos:altLabel "Request Action Delayed" ;
    skos:definition "State of a request being delayed towards fulfilment" ;
    skos:exactMatch dpv:RequestActionDelayed,
        dpv_upstream:RequestActionDelayed,
        dpv_owl:RequestActionDelayed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:RequestFulfilled a owl:Class ;
    rdfs:label "RequestFulfilled" ;
    rdfs:subClassOf dpv:RequestStatus ;
    skos:altLabel "Request Fulfilled" ;
    skos:definition "State of a request being fulfilled" ;
    skos:exactMatch dpv:RequestFulfilled,
        dpv_upstream:RequestFulfilled,
        dpv_owl:RequestFulfilled ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:RequestInitiated a owl:Class ;
    rdfs:label "RequestInitiated" ;
    rdfs:subClassOf dpv:RequestStatus ;
    skos:altLabel "Request Initiated" ;
    skos:definition "State of a request being initiated" ;
    skos:exactMatch dpv:RequestInitiated,
        dpv_upstream:RequestInitiated,
        dpv_owl:RequestInitiated ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:RequestRejected a owl:Class ;
    rdfs:label "RequestRejected" ;
    rdfs:subClassOf dpv:RequestStatus ;
    skos:altLabel "Request Rejected" ;
    skos:definition "State of a request being rejected towards non-fulfilment" ;
    skos:exactMatch dpv:RequestRejected,
        dpv_upstream:RequestRejected,
        dpv_owl:RequestRejected ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:RequestRequiredActionPerformed a owl:Class ;
    rdfs:label "RequestRequiredActionPerformed" ;
    rdfs:subClassOf dpv:RequestStatus ;
    skos:altLabel "Request Required Action Performed" ;
    skos:definition """State of a request's required action having been performed by the other
party""" ;
    skos:exactMatch dpv:RequestRequiredActionPerformed,
        dpv_upstream:RequestRequiredActionPerformed,
        dpv_owl:RequestRequiredActionPerformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:RequestRequiresAction a owl:Class ;
    rdfs:label "RequestRequiresAction" ;
    rdfs:subClassOf dpv:RequestStatus ;
    skos:altLabel "Request Requires Action" ;
    skos:definition """State of a request requiring an action to be performed from another
party""" ;
    skos:exactMatch dpv:RequestRequiresAction,
        dpv_upstream:RequestRequiresAction,
        dpv_owl:RequestRequiresAction ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:RequestStatusQuery a owl:Class ;
    rdfs:label "RequestStatusQuery" ;
    rdfs:subClassOf dpv:RequestStatus ;
    skos:altLabel "Request Status Query" ;
    skos:definition "State of a request's status being queried" ;
    skos:exactMatch dpv:RequestStatusQuery,
        dpv_upstream:RequestStatusQuery,
        dpv_owl:RequestStatusQuery ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:RequestUnfulfilled a owl:Class ;
    rdfs:label "RequestUnfulfilled" ;
    rdfs:subClassOf dpv:RequestStatus ;
    skos:altLabel "Request Unfulfilled" ;
    skos:definition "State of a request being unfulfilled" ;
    skos:exactMatch dpv:RequestUnfulfilled,
        dpv_upstream:RequestUnfulfilled,
        dpv_owl:RequestUnfulfilled ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:Required a owl:Class ;
    rdfs:label "Required" ;
    rdfs:subClassOf dpv:Necessity ;
    skos:altLabel "Required" ;
    skos:definition "Indication of 'required' or 'necessary'" ;
    skos:exactMatch dpv:Required,
        dpv_upstream:Required,
        dpv_owl:Required ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:ResidualRisk a owl:Class ;
    rdfs:label "ResidualRisk" ;
    rdfs:subClassOf dpv:Risk ;
    skos:altLabel "Residual Risk" ;
    skos:definition "Risk remaining after treatment or mitigation" ;
    skos:exactMatch dpv:ResidualRisk,
        dpv_upstream:ResidualRisk,
        dpv_owl:ResidualRisk,
        nist_ai_rmf:ResidualRisk ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch iso27001:RiskTreatmentPlan ;
    dpv:skos_in_scheme "risk-classes" .

dpv:Restrict a owl:Class ;
    rdfs:label "Restrict" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Transform ;
    skos:altLabel "Restrict" ;
    skos:definition "to apply a restriction on the processing of specific records" ;
    skos:exactMatch dpv:Restrict,
        dpv_upstream:Restrict,
        dpv_owl:Restrict ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:Retrieve a owl:Class ;
    rdfs:label "Retrieve" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Use ;
    skos:altLabel "Retrieve" ;
    skos:definition "to retrieve data, often in an automated manner" ;
    skos:exactMatch dpv:Retrieve,
        dpv_upstream:Retrieve,
        dpv_owl:Retrieve ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:ReversingProcessEffects a owl:Class ;
    rdfs:label "ReversingProcessEffects" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Reversing Process Effects" ;
    skos:definition "Involvement where entity can reverse effects of specified context" ;
    skos:exactMatch dpv:ReversingProcessEffects,
        dpv_upstream:ReversingProcessEffects,
        dpv_owl:ReversingProcessEffects ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Effects refer to consequences and impacts arising from the process or
from the outputs of a process""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ReversingProcessInput a owl:Class ;
    rdfs:label "ReversingProcessInput" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Reversing Process Input" ;
    skos:definition "Involvement where entity can reverse input of specified context" ;
    skos:exactMatch dpv:ReversingProcessInput,
        dpv_upstream:ReversingProcessInput,
        dpv_owl:ReversingProcessInput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Reversion can be considered a form of correction in some instances. We
welcome inputs to further explore and define this relation between
correction and reversion concepts.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ReversingProcessOutput a owl:Class ;
    rdfs:label "ReversingProcessOutput" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Reversing Process Output" ;
    skos:definition "Involvement where entity can reverse output of specified context" ;
    skos:exactMatch dpv:ReversingProcessOutput,
        dpv_upstream:ReversingProcessOutput,
        dpv_owl:ReversingProcessOutput ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Reversing of outputs indicate discarding the output and going back to
the previous output. This is different from correction of output which
allows modification of the output - implying continuation of the
process.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ReviewImpactAssessment a owl:Class ;
    rdfs:label "ReviewImpactAssessment" ;
    rdfs:subClassOf dpv:ImpactAssessment,
        dpv:OrganisationalMeasure,
        dpv:ReviewProcedure ;
    skos:altLabel "Review Impact Assessment" ;
    skos:definition """Procedures to review impact assessments in terms of continued validity,
adequacy for intended purposes, and conformance of processes with
findings""" ;
    skos:exactMatch dpv:ReviewImpactAssessment,
        dpv_upstream:ReviewImpactAssessment,
        dpv_owl:ReviewImpactAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:RightExerciseActivity a owl:Class ;
    rdfs:label "RightExerciseActivity" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Right Exercise Activity" ;
    skos:definition "An activity representing an exercising of an active right" ;
    skos:exactMatch dpv:RightExerciseActivity,
        dpv_upstream:RightExerciseActivity,
        dpv_owl:RightExerciseActivity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """There may be multiple activities associated with exercising and
fulfilling rights. See the RightExerciseRecord concept for
record-keeping of such activities in a cohesive manner.""" ;
    dpv:skos_in_scheme "rights-classes" .

dpv:RightExerciseRecord a owl:Class ;
    rdfs:label "RightExerciseRecord" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RecordsOfActivities ;
    skos:altLabel "Right Exercise Record" ;
    skos:definition "Record of a Right being exercised" ;
    skos:exactMatch dpv:RightExerciseRecord,
        dpv_upstream:RightExerciseRecord,
        dpv_owl:RightExerciseRecord ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept represents a record of one or more right exercise
activities, such as those associated with a single data subject or
service or entity""" ;
    dpv:skos_in_scheme "rights-classes" .

dpv:RightFulfilmentNotice a owl:Class ;
    rdfs:label "RightFulfilmentNotice" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RightExerciseNotice ;
    skos:altLabel "Right Fulfilment Notice" ;
    skos:definition "Notice provided regarding fulfilment of a right" ;
    skos:exactMatch dpv:RightFulfilmentNotice,
        dpv_upstream:RightFulfilmentNotice,
        dpv_owl:RightFulfilmentNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This notice is associated with situations where information is provided
with the intention of progressing the fulfilment of a right. For
example, a notice asking for more information regarding the scope of the
right, or providing information on where to access the data provided
under a right.""" ;
    dpv:skos_in_scheme "rights-classes" .

dpv:RightNonFulfilmentNotice a owl:Class ;
    rdfs:label "RightNonFulfilmentNotice" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RightExerciseNotice ;
    skos:altLabel "Right Non-Fulfilment Notice" ;
    skos:definition "Notice provided regarding non-fulfilment of a right" ;
    skos:exactMatch dpv:RightNonFulfilmentNotice,
        dpv_upstream:RightNonFulfilmentNotice,
        dpv_owl:RightNonFulfilmentNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This notice is associated with situations where information is provided
with the intention of communicating non-fulfilment of a right. For
example, to provide justifications on why a right could not be fulfilled
or providing information about another entity who should be approached
for exercising this right.""" ;
    dpv:skos_in_scheme "rights-classes" .

dpv:RightsFulfilment a owl:Class ;
    rdfs:label "RightsFulfilment" ;
    rdfs:subClassOf dpv:LegalObligation,
        dpv:Purpose ;
    skos:altLabel "Rights Fulfilment" ;
    skos:definition "Purposes associated with the fulfillment of rights specified in law" ;
    skos:exactMatch dpv:RightsFulfilment,
        dpv_upstream:RightsFulfilment,
        dpv_owl:RightsFulfilment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Where Rights Fulfillment includes activities that are not legal
obligations, for example conducting Identity Verification, the
documentation should indicate this by expressing them as separate
purposes within the same activity""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RiskMitigationMeasure a owl:Class ;
    rdfs:label "RiskMitigationMeasure" ;
    rdfs:subClassOf dpv:TechnicalOrganisationalMeasure ;
    skos:altLabel "Risk Mitigation Measure" ;
    skos:closeMatch iso27001:RiskTreatmentOption,
        iso29100:PrivacySafeguardingRequirement,
        iso42001:AIRiskTreatmentPlan,
        oscal:Control ;
    skos:definition "Measures intended to mitigate, minimise, or prevent risk." ;
    skos:exactMatch dpv:RiskMitigationMeasure,
        dpv_upstream:RiskMitigationMeasure,
        dpv_owl:RiskMitigationMeasure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch nist_ai_rmf:Function,
        nist_csf_v2:CSFSubcategory ;
    dpv:skos_in_scheme "risk-classes" .

dpv:SMEOrganisation a owl:Class ;
    rdfs:label "SMEOrganisation" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "SME Organisation" ;
    skos:definition """An organisation that is characterised as a Small or Medium-sized
Enterprise based on limited staff and revenue""" ;
    skos:exactMatch dpv:SMEOrganisation,
        dpv_upstream:SMEOrganisation,
        dpv_owl:SMEOrganisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:SafeguardForDataTransfer a owl:Class ;
    rdfs:label "SafeguardForDataTransfer" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:Safeguard ;
    skos:altLabel "Safeguard for Data Transfer" ;
    skos:definition """Represents a safeguard used for data transfer. Can include technical or
organisational measures.""" ;
    skos:exactMatch dpv:SafeguardForDataTransfer,
        dpv_upstream:SafeguardForDataTransfer,
        dpv_owl:SafeguardForDataTransfer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ScientificResearch a owl:Class ;
    rdfs:label "ScientificResearch" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ResearchAndDevelopment ;
    skos:altLabel "Scientific Research" ;
    skos:definition "Purposes associated with scientific research" ;
    skos:exactMatch dpv:ScientificResearch,
        dpv_upstream:ScientificResearch,
        dpv_owl:ScientificResearch ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.16" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Scope a owl:Class ;
    rdfs:label "Scope" ;
    rdfs:subClassOf dpv:Context ;
    skos:altLabel "Scope" ;
    skos:definition """Indication of the extent or range or boundaries associated with(in) a
context""" ;
    skos:exactMatch dpv:Scope,
        dpv_upstream:Scope,
        dpv_owl:Scope ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:Screen a owl:Class ;
    rdfs:label "Screen" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Transform ;
    skos:altLabel "Screen" ;
    skos:definition "to remove data for some criteria" ;
    skos:exactMatch dpv:Screen,
        dpv_upstream:Screen,
        dpv_owl:Screen ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:Seal a owl:Class ;
    rdfs:label "Seal" ;
    rdfs:subClassOf dpv:CertificationSeal,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Seal" ;
    skos:definition """A seal or a mark indicating proof of certification to some certification
or standard""" ;
    skos:exactMatch dpv:Seal,
        dpv_upstream:Seal,
        dpv_owl:Seal ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SearchFunctionalities a owl:Class ;
    rdfs:label "SearchFunctionalities" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceProvision ;
    skos:altLabel "Search Functionalities" ;
    skos:definition """Purposes associated with providing searching, querying, or other forms
of information retrieval related functionalities""" ;
    skos:exactMatch dpv:SearchFunctionalities,
        dpv_upstream:SearchFunctionalities,
        dpv_owl:SearchFunctionalities ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:SecondaryImportance a owl:Class ;
    rdfs:label "SecondaryImportance" ;
    rdfs:subClassOf dpv:Importance ;
    skos:altLabel "Secondary Importance" ;
    skos:definition "Indication of 'secondary' or 'minor' or 'auxiliary' importance" ;
    skos:exactMatch dpv:SecondaryImportance,
        dpv_upstream:SecondaryImportance,
        dpv_owl:SecondaryImportance ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:SecondaryUse a owl:Class ;
    rdfs:label "SecondaryUse" ;
    rdfs:subClassOf dpv:ReuseCompatibility ;
    skos:altLabel "Secondary Use" ;
    skos:definition """Status indicating incompatibility based on the use not being compatible
with an earlier context""" ;
    skos:exactMatch dpv:SecondaryUse,
        dpv_upstream:SecondaryUse,
        dpv_owl:SecondaryUse ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Secondary Use refers to an assessment where two contexts are found to be
incompatible, e.g. if purpose is used to test compatibility, then for
two activities the second activity is said be the secondary use if its
purpose is incompatible with the first activity's purpose""" ;
    dpv:skos_in_scheme "status-classes" .

dpv:SecretSharingSchemes a owl:Class ;
    rdfs:label "SecretSharingSchemes" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Secret Sharing Schemes" ;
    skos:definition """Use of secret sharing schemes where the secret can only be reconstructed
through combination of sufficient number of individuals""" ;
    skos:exactMatch dpv:SecretSharingSchemes,
        dpv_upstream:SecretSharingSchemes,
        dpv_owl:SecretSharingSchemes ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:SecureMultiPartyComputation a owl:Class ;
    rdfs:label "SecureMultiPartyComputation" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Secure Multi-Party Computation" ;
    skos:definition """Use of cryptographic methods for entities to jointly compute functions
without revealing inputs""" ;
    skos:exactMatch dpv:SecureMultiPartyComputation,
        dpv_upstream:SecureMultiPartyComputation,
        dpv_owl:SecureMultiPartyComputation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:SecureProcessingEnvironment a owl:Class ;
    rdfs:label "SecureProcessingEnvironment" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SecurityProcedure ;
    skos:altLabel "Secure Processing Environment" ;
    skos:definition """A physical or virtual environment supported by organisational means that
integrates security and compliance requirements and allows supervising
data processing actions""" ;
    skos:exactMatch dpv:SecureProcessingEnvironment,
        dpv_upstream:SecureProcessingEnvironment,
        dpv_owl:SecureProcessingEnvironment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.20" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SecurityAudit a owl:Class ;
    rdfs:label "SecurityAudit" ;
    rdfs:subClassOf dpv:Audit,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Security Audit" ;
    skos:definition """An audit that systematically examines the existence and use of security
risks and measures within information systems, networks, and security
policies to identify vulnerabilities, risks, and gaps""" ;
    skos:exactMatch dpv:SecurityAudit,
        dpv_upstream:SecurityAudit,
        dpv_owl:SecurityAudit ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SecurityIncidentRecord a owl:Class ;
    rdfs:label "SecurityIncidentRecord" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RecordsOfActivities ;
    skos:altLabel "Security Incident Record" ;
    skos:definition "Record of a security incident" ;
    skos:exactMatch dpv:SecurityIncidentRecord,
        dpv_upstream:SecurityIncidentRecord,
        dpv_owl:SecurityIncidentRecord ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SecurityKnowledgeTraining a owl:Class ;
    rdfs:label "SecurityKnowledgeTraining" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:StaffTraining ;
    skos:altLabel "Security Knowledge Training" ;
    skos:definition "Training intended to increase knowledge regarding security" ;
    skos:exactMatch dpv:SecurityKnowledgeTraining,
        dpv_upstream:SecurityKnowledgeTraining,
        dpv_owl:SecurityKnowledgeTraining ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SecurityRoleProcedures a owl:Class ;
    rdfs:label "SecurityRoleProcedures" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SecurityProcedure ;
    skos:altLabel "Security Role Procedures" ;
    skos:definition "Procedures related to security roles" ;
    skos:exactMatch dpv:SecurityRoleProcedures,
        dpv_upstream:SecurityRoleProcedures,
        dpv_owl:SecurityRoleProcedures ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SellDataToThirdParties a owl:Class ;
    rdfs:label "SellDataToThirdParties" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:SellProducts ;
    skos:altLabel "Sell Data to Third Parties" ;
    skos:definition """Purposes associated with selling or sharing data or information to third
parties""" ;
    skos:exactMatch dpv:SellDataToThirdParties,
        dpv_upstream:SellDataToThirdParties,
        dpv_owl:SellDataToThirdParties ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Sell here means exchange, submit, or provide in return for direct or
indirect compensation. Was subclass of commercial interest, changed to
reflect selling something""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:SellInsightsFromData a owl:Class ;
    rdfs:label "SellInsightsFromData" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:SellProducts ;
    skos:altLabel "Sell Insights from Data" ;
    skos:definition """Purposes associated with selling or sharing insights obtained from
analysis of data""" ;
    skos:exactMatch dpv:SellInsightsFromData,
        dpv_upstream:SellInsightsFromData,
        dpv_owl:SellInsightsFromData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Sell here means exchange, submit, or provide in return for direct or
indirect compensation. Was subclass of commercial interest, changed to
reflect selling something""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:SellProductsToDataSubject a owl:Class ;
    rdfs:label "SellProductsToDataSubject" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:SellProducts ;
    skos:altLabel "Sell Products to Data Subject" ;
    skos:definition """Purposes associated with selling products or services to the user,
consumer, or data subjects""" ;
    skos:exactMatch dpv:SellProductsToDataSubject,
        dpv_upstream:SellProductsToDataSubject,
        dpv_owl:SellProductsToDataSubject ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Sell Products here refers to processing necessary to provide and
complete a sale to customers. It should not be confused with providing
services with a cost based on an established agreement.""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:SemiPrivateSpace a owl:Class ;
    rdfs:label "SemiPrivateSpace" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:PrivateSpace ;
    skos:altLabel "Semi Private Space" ;
    skos:definition """A private space that acts as a shared space with other entities but
which is still essentially private for the individuals e.g. a
semi-private hospital room shared with another patient""" ;
    skos:exactMatch dpv:SemiPrivateSpace,
        dpv_upstream:SemiPrivateSpace,
        dpv_owl:SemiPrivateSpace ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:SensitiveNonPersonalData a owl:Class ;
    rdfs:label "SensitiveNonPersonalData" ;
    rdfs:subClassOf dpv:SensitiveData ;
    skos:altLabel "Sensitive Non Personal Data" ;
    skos:definition "Non-personal data deemed sensitive" ;
    skos:exactMatch dpv:SensitiveNonPersonalData,
        dpv_upstream:SensitiveNonPersonalData,
        dpv_owl:SensitiveNonPersonalData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 30(a)" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:SensitivityLevel a owl:Class ;
    rdfs:label "SensitivityLevel" ;
    rdfs:subClassOf dpv:Severity ;
    skos:altLabel "Sensitivity Level" ;
    skos:definition """Sensitivity' reflects the risk of impact if not secured or utilised with
appropriate measures and controls e.g. for sensitive data""" ;
    skos:exactMatch dpv:SensitivityLevel,
        dpv_upstream:SensitivityLevel,
        dpv_owl:SensitivityLevel ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """ISO/IEC TS 38505-3:2021 defines 'data sensitivity' as the potential harm
of unauthorised disclosure. DPV's use of the concept goes beyond
disclosure as it refers to the level of safeguards or controls the data
requires as a reflection of its 'sensitive' nature. To indicate
quantified levels of sensitivity, e.g. "high sensitivity", instances of
severity can be directly used or specialised""" ;
    dpv:skos_in_scheme "risk-classes" .

dpv:ServiceAccessDetermination a owl:Class ;
    rdfs:label "ServiceAccessDetermination" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceManagement ;
    skos:altLabel "Service Access Determination" ;
    skos:definition """Purposes associated with the determination of whether specific
conditions or criteria are met for accessing, using, or gaining access
to a service""" ;
    skos:exactMatch dpv:ServiceAccessDetermination,
        dpv_upstream:ServiceAccessDetermination,
        dpv_owl:ServiceAccessDetermination ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ServiceConsumer a owl:Class ;
    rdfs:label "ServiceConsumer" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Service Consumer" ;
    skos:definition "The entity that consumes or receives the service" ;
    skos:exactMatch dpv:ServiceConsumer,
        dpv_upstream:ServiceConsumer,
        dpv_owl:ServiceConsumer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:ServiceLevelAgreement a owl:Class ;
    rdfs:label "ServiceLevelAgreement" ;
    rdfs:subClassOf dpv:ContractByDomain,
        dpv:LegalBasis ;
    skos:altLabel "Service Level Agreement (SLA)" ;
    skos:definition """A contract regarding the provision of a service which outlines the
acceptable metrics and performance of the service for the consumer""" ;
    skos:exactMatch dpv:ServiceLevelAgreement,
        dpv_upstream:ServiceLevelAgreement,
        dpv_owl:ServiceLevelAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:ServiceProvider a owl:Class ;
    rdfs:label "ServiceProvider" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Service Provider" ;
    skos:definition "The entity that provides a service" ;
    skos:exactMatch dpv:ServiceProvider,
        dpv_upstream:ServiceProvider,
        dpv_owl:ServiceProvider ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:ServiceRegistration a owl:Class ;
    rdfs:label "ServiceRegistration" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceManagement ;
    skos:altLabel "Service Registration" ;
    skos:definition """Purposes associated with registering users and collecting information
required for providing a service""" ;
    skos:exactMatch dpv:ServiceRegistration,
        dpv_upstream:ServiceRegistration,
        dpv_owl:ServiceRegistration ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """An example of service registration is to provide a form that collects
information such as preferred language or media format for downloading a
movie""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ServiceUsageAnalytics a owl:Class ;
    rdfs:label "ServiceUsageAnalytics" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceMonitoring ;
    skos:altLabel "Service Usage Analytics" ;
    skos:definition """Purposes associated with conducting analysis and reporting related to
usage of services or products""" ;
    skos:exactMatch dpv:ServiceUsageAnalytics,
        dpv_upstream:ServiceUsageAnalytics,
        dpv_owl:ServiceUsageAnalytics ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Was \"UsageAnalytics\", prefixed with Service to better reflect scope" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Share a owl:Class ;
    rdfs:label "Share" ;
    rdfs:subClassOf dpv:Disclose,
        dpv:Processing ;
    skos:altLabel "Share" ;
    skos:definition "to give data (or a portion of it) to others" ;
    skos:exactMatch dpv:Share,
        dpv_upstream:Share,
        dpv_owl:Share ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:SingleSignOn a owl:Class ;
    rdfs:label "SingleSignOn" ;
    rdfs:subClassOf dpv:AuthenticationProtocols,
        dpv:TechnicalMeasure ;
    skos:altLabel "Single Sign On" ;
    skos:definition """Use of credentials or processes that enable using one set of credentials
to authenticate multiple contexts.""" ;
    skos:exactMatch dpv:SingleSignOn,
        dpv_upstream:SingleSignOn,
        dpv_owl:SingleSignOn ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:SingularDataVolume a owl:Class ;
    rdfs:label "SingularDataVolume" ;
    rdfs:subClassOf dpv:DataVolume ;
    skos:altLabel "Singular Data Volume" ;
    skos:definition """Data volume that is considered singular i.e. a specific instance or
single item""" ;
    skos:exactMatch dpv:SingularDataVolume,
        dpv_upstream:SingularDataVolume,
        dpv_owl:SingularDataVolume ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:SingularFrequency a owl:Class ;
    rdfs:label "SingularFrequency" ;
    rdfs:subClassOf dpv:Frequency ;
    skos:altLabel "Singular Frequency" ;
    skos:definition "Frequency where occurrences are singular i.e. they take place only once" ;
    skos:exactMatch dpv:SingularFrequency,
        dpv_upstream:SingularFrequency,
        dpv_owl:SingularFrequency ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:SingularScaleOfDataSubjects a owl:Class ;
    rdfs:label "SingularScaleOfDataSubjects" ;
    rdfs:subClassOf dpv:DataSubjectScale ;
    skos:altLabel "Singular Scale Of Data Subjects" ;
    skos:definition "Scale of data subjects considered singular i.e. a specific data subject" ;
    skos:exactMatch dpv:SingularScaleOfDataSubjects,
        dpv_upstream:SingularScaleOfDataSubjects,
        dpv_owl:SingularScaleOfDataSubjects ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:SmallDataVolume a owl:Class ;
    rdfs:label "SmallDataVolume" ;
    rdfs:subClassOf dpv:DataVolume ;
    skos:altLabel "Small Data Volume" ;
    skos:definition "Data volume that is considered small or limited within the context" ;
    skos:exactMatch dpv:SmallDataVolume,
        dpv_upstream:SmallDataVolume,
        dpv_owl:SmallDataVolume ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:SmallScaleOfDataSubjects a owl:Class ;
    rdfs:label "SmallScaleOfDataSubjects" ;
    rdfs:subClassOf dpv:DataSubjectScale ;
    skos:altLabel "Small Scale Of Data Subjects" ;
    skos:definition "Scale of data subjects considered small or limited within the context" ;
    skos:exactMatch dpv:SmallScaleOfDataSubjects,
        dpv_upstream:SmallScaleOfDataSubjects,
        dpv_owl:SmallScaleOfDataSubjects ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:SmallScaleProcessing a owl:Class ;
    rdfs:label "SmallScaleProcessing" ;
    rdfs:subClassOf dpv:ProcessingScale ;
    skos:altLabel "Small Scale Processing" ;
    skos:definition """Processing that takes place at small scales (as specified by some
criteria)""" ;
    skos:exactMatch dpv:SmallScaleProcessing,
        dpv_upstream:SmallScaleProcessing,
        dpv_owl:SmallScaleProcessing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:SocialMediaMarketing a owl:Class ;
    rdfs:label "SocialMediaMarketing" ;
    rdfs:subClassOf dpv:Marketing,
        dpv:Purpose ;
    skos:altLabel "Social Media Marketing" ;
    skos:definition "Purposes associated with conducting marketing through social media" ;
    skos:exactMatch dpv:SocialMediaMarketing,
        dpv_upstream:SocialMediaMarketing,
        dpv_owl:SocialMediaMarketing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:SpecialCategoryPersonalData a owl:Class ;
    rdfs:label "SpecialCategoryPersonalData" ;
    rdfs:subClassOf dpv:SensitivePersonalData ;
    skos:altLabel "Special Category Personal Data" ;
    skos:definition """Sensitive Personal Data whose use requires specific additional legal
permission or justification""" ;
    skos:exactMatch dpv:SpecialCategoryPersonalData,
        dpv_upstream:SpecialCategoryPersonalData,
        dpv_owl:SpecialCategoryPersonalData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The term 'special category' is based on GDPR Art.9, but should not be
considered as exclusive to it. DPV considers all Special Categories to
also be Sensitive, but whose use is either prohibited or regulated and
therefore requires additional legal basis for justification that is
separate from that for general personal data.""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:SporadicDataVolume a owl:Class ;
    rdfs:label "SporadicDataVolume" ;
    rdfs:subClassOf dpv:DataVolume ;
    skos:altLabel "Sporadic Data Volume" ;
    skos:definition "Data volume that is considered sporadic or sparse within the context" ;
    skos:exactMatch dpv:SporadicDataVolume,
        dpv_upstream:SporadicDataVolume,
        dpv_owl:SporadicDataVolume ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:SporadicFrequency a owl:Class ;
    rdfs:label "SporadicFrequency" ;
    rdfs:subClassOf dpv:Frequency ;
    skos:altLabel "Sporadic Frequency" ;
    skos:definition "Frequency where occurrences are sporadic or infrequent or sparse" ;
    skos:exactMatch dpv:SporadicFrequency,
        dpv_upstream:SporadicFrequency,
        dpv_owl:SporadicFrequency ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:SporadicScaleOfDataSubjects a owl:Class ;
    rdfs:label "SporadicScaleOfDataSubjects" ;
    rdfs:subClassOf dpv:DataSubjectScale ;
    skos:altLabel "Sporadic Scale Of Data Subjects" ;
    skos:definition "Scale of data subjects considered sporadic or sparse within the context" ;
    skos:exactMatch dpv:SporadicScaleOfDataSubjects,
        dpv_upstream:SporadicScaleOfDataSubjects,
        dpv_owl:SporadicScaleOfDataSubjects ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:StandardsConformance a owl:Class ;
    rdfs:label "StandardsConformance" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Standards Conformance" ;
    skos:definition """Purposes associated with activities undertaken to ensure or achieve
conformance with standards""" ;
    skos:exactMatch dpv:StandardsConformance,
        dpv_upstream:StandardsConformance,
        dpv_owl:StandardsConformance ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 12.d" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:StartupOrganisation a owl:Class ;
    rdfs:label "StartupOrganisation" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Startup Organisation" ;
    skos:definition """An organisation that is newly established and is nascent in terms of
available resources""" ;
    skos:exactMatch dpv:StartupOrganisation,
        dpv_upstream:StartupOrganisation,
        dpv_owl:StartupOrganisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:StatisticalConfidentialityAgreement a owl:Class ;
    rdfs:label "StatisticalConfidentialityAgreement" ;
    rdfs:subClassOf dpv:LegalAgreement,
        dpv:LegalMeasure ;
    skos:altLabel "Statistical Confidentiality Agreement" ;
    skos:definition """An agreement outlining conditions, criteria, obligations,
responsibilities, and specifics for classification and management of
'confidential data' based on a statistical framework""" ;
    skos:exactMatch dpv:StatisticalConfidentialityAgreement,
        dpv_upstream:StatisticalConfidentialityAgreement,
        dpv_owl:StatisticalConfidentialityAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-measures-classes" .

dpv:StatisticallyConfidentialData a owl:Class ;
    rdfs:label "StatisticallyConfidentialData" ;
    rdfs:subClassOf dpv:ConfidentialData ;
    skos:altLabel "Statistically Confidential Data" ;
    skos:definition """Data protected through Statistical Confidentiality regulations and
agreements""" ;
    skos:exactMatch dpv:StatisticallyConfidentialData,
        dpv_upstream:StatisticallyConfidentialData,
        dpv_owl:StatisticallyConfidentialData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2(20)" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:StorageDeletion a owl:Class ;
    rdfs:label "StorageDeletion" ;
    rdfs:subClassOf dpv:StorageCondition ;
    skos:altLabel "Storage Deletion" ;
    skos:definition "Deletion or Erasure of data including any deletion guarantees" ;
    skos:exactMatch dpv:StorageDeletion,
        dpv_upstream:StorageDeletion,
        dpv_owl:StorageDeletion ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:StorageDuration a owl:Class ;
    rdfs:label "StorageDuration" ;
    rdfs:subClassOf dpv:ProcessingDuration,
        dpv:StorageCondition ;
    skos:altLabel "Storage Duration" ;
    skos:definition "Duration or temporal limitation on storage of data" ;
    skos:exactMatch dpv:StorageDuration,
        dpv_upstream:StorageDuration,
        dpv_owl:StorageDuration ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:StorageLocation a owl:Class ;
    rdfs:label "StorageLocation" ;
    rdfs:subClassOf dpv:ProcessingLocation,
        dpv:StorageCondition ;
    skos:altLabel "Storage Location" ;
    skos:closeMatch gists:GeoLocation,
        ocsf:Location,
        oscal:Location ;
    skos:definition "Location or geospatial scope where the data is stored" ;
    skos:exactMatch dpv:StorageLocation,
        dpv_upstream:StorageLocation,
        dpv_owl:StorageLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:StorageRestoration a owl:Class ;
    rdfs:label "StorageRestoration" ;
    rdfs:subClassOf dpv:StorageCondition ;
    skos:altLabel "Storage Restoration" ;
    skos:definition """Regularity and temporal span of data restoration/backup mechanisms that
guarantee that data is preserved""" ;
    skos:exactMatch dpv:StorageRestoration,
        dpv_upstream:StorageRestoration,
        dpv_owl:StorageRestoration ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:Store a owl:Class ;
    rdfs:label "Store" ;
    rdfs:subClassOf dpv:Processing ;
    skos:altLabel "Store" ;
    skos:definition "to keep data for future use" ;
    skos:exactMatch dpv:Store,
        dpv_upstream:Store,
        dpv_owl:Store ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:Student a owl:Class ;
    rdfs:label "Student" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Student" ;
    skos:definition "Humans that are students" ;
    skos:exactMatch dpv:Student,
        dpv_upstream:Student,
        dpv_owl:Student ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:SubProcessorAgreement a owl:Class ;
    rdfs:label "SubProcessorAgreement" ;
    rdfs:subClassOf dpv:DataProcessingAgreement,
        dpv:LegalBasis,
        dpv:LegalMeasure ;
    skos:altLabel "Sub-Processor Agreement" ;
    skos:definition """An agreement outlining conditions, criteria, obligations,
responsibilities, and specifics for carrying out processing of data
between a Data Processor and a Data (Sub-)Processor""" ;
    skos:exactMatch dpv:SubProcessorAgreement,
        dpv_upstream:SubProcessorAgreement,
        dpv_owl:SubProcessorAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:Subscriber a owl:Class ;
    rdfs:label "Subscriber" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Subscriber" ;
    skos:definition "Humans that subscribe to service(s)" ;
    skos:exactMatch dpv:Subscriber,
        dpv_upstream:Subscriber,
        dpv_owl:Subscriber ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "note: subscriber can be customer or consumer" ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:SubsidiaryLegalEntity a owl:Class ;
    rdfs:label "SubsidiaryLegalEntity" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "Subsidiary Legal Entity" ;
    skos:definition "A legal entity that operates as a subsidiary of another legal entity" ;
    skos:exactMatch dpv:SubsidiaryLegalEntity,
        dpv_upstream:SubsidiaryLegalEntity,
        dpv_owl:SubsidiaryLegalEntity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-classes" .

dpv:SupportContractNegotiation a owl:Class ;
    rdfs:label "SupportContractNegotiation" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SupportEntityDecisionMaking ;
    skos:altLabel "Support Contract Negotiation" ;
    skos:definition """Supporting entities, including individuals, with negotiating a contract
and its terms and conditions""" ;
    skos:exactMatch dpv:SupportContractNegotiation,
        dpv_upstream:SupportContractNegotiation,
        dpv_owl:SupportContractNegotiation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.15" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SupportExchangeOfViews a owl:Class ;
    rdfs:label "SupportExchangeOfViews" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SupportEntityDecisionMaking ;
    skos:altLabel "Support Exchange of Views" ;
    skos:definition """Supporting individuals and entities in exchanging views e.g. regarding
data processing purposes for their best interests""" ;
    skos:exactMatch dpv:SupportExchangeOfViews,
        dpv_upstream:SupportExchangeOfViews,
        dpv_owl:SupportExchangeOfViews ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.15" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SupportInformedConsentDecision a owl:Class ;
    rdfs:label "SupportInformedConsentDecision" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SupportEntityDecisionMaking ;
    skos:altLabel "Support Informed Consent Decision" ;
    skos:definition """Supporting individuals with making a decision regarding their informed
consent""" ;
    skos:exactMatch dpv:SupportInformedConsentDecision,
        dpv_upstream:SupportInformedConsentDecision,
        dpv_owl:SupportInformedConsentDecision ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.15" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SupraNationalAuthority a owl:Class ;
    rdfs:label "SupraNationalAuthority" ;
    rdfs:subClassOf dpv:DpvAuthority ;
    skos:altLabel "Supranational Authority" ;
    skos:definition """An authority tasked with overseeing legal compliance for a
supra-national union e.g. EU""" ;
    skos:exactMatch dpv:SupraNationalAuthority,
        dpv_upstream:SupraNationalAuthority,
        dpv_owl:SupraNationalAuthority ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-authority-classes" .

dpv:SupraNationalUnion a owl:Class ;
    rdfs:label "SupraNationalUnion" ;
    rdfs:subClassOf dpv:DpvJurisdiction ;
    skos:altLabel "Supranational Union" ;
    skos:definition """A political union of two or more countries with an establishment of
common authority""" ;
    skos:exactMatch dpv:SupraNationalUnion,
        dpv_upstream:SupraNationalUnion,
        dpv_owl:SupraNationalUnion ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:SymmetricCryptography a owl:Class ;
    rdfs:label "SymmetricCryptography" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Symmetric Cryptography" ;
    skos:definition """Use of cryptography where the same keys are utilised for encryption and
decryption of information""" ;
    skos:exactMatch dpv:SymmetricCryptography,
        dpv_upstream:SymmetricCryptography,
        dpv_owl:SymmetricCryptography ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:SymmetricEncryption a owl:Class ;
    rdfs:label "SymmetricEncryption" ;
    rdfs:subClassOf dpv:Encryption,
        dpv:TechnicalMeasure ;
    skos:altLabel "Symmetric Encryption" ;
    skos:definition "Use of symmetric cryptography to encrypt data" ;
    skos:exactMatch dpv:SymmetricEncryption,
        dpv_upstream:SymmetricEncryption,
        dpv_owl:SymmetricEncryption ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:SyntheticData a owl:Class ;
    rdfs:label "SyntheticData" ;
    rdfs:subClassOf dpv:GeneratedData ;
    skos:altLabel "Synthetic Data" ;
    skos:definition """Synthetic data refers to artificially created data such that it is
intended to resemble real data (personal or non-personal), but does not
refer to any specific identified or identifiable individual, or to the
real measure of an observable parameter in the case of non-personal data""" ;
    skos:exactMatch dpv:SyntheticData,
        dpv_upstream:SyntheticData,
        dpv_owl:SyntheticData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:SystematicMonitoring a owl:Class ;
    rdfs:label "SystematicMonitoring" ;
    rdfs:subClassOf dpv:ProcessingContext ;
    skos:altLabel "Systematic Monitoring" ;
    skos:definition "Processing that involves systematic monitoring of individuals" ;
    skos:exactMatch dpv:SystematicMonitoring,
        dpv_upstream:SystematicMonitoring,
        dpv_owl:SystematicMonitoring ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:TechnicalServiceProvision a owl:Class ;
    rdfs:label "TechnicalServiceProvision" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceProvision ;
    skos:altLabel "Technical Service Provision" ;
    skos:definition """Purposes associated with managing and providing technical processes and
functions necessary for delivering services""" ;
    skos:exactMatch dpv:TechnicalServiceProvision,
        dpv_upstream:TechnicalServiceProvision,
        dpv_owl:TechnicalServiceProvision ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:TechnicalStandard a owl:Class ;
    rdfs:label "TechnicalStandard" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:Standard ;
    skos:altLabel "Technical Standard" ;
    skos:definition """A technical standard is a standard that establishes norms or
requirements regarding technology or technical processes""" ;
    skos:exactMatch dpv:TechnicalStandard,
        dpv_upstream:TechnicalStandard,
        dpv_owl:TechnicalStandard ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:TemporalDuration a owl:Class ;
    rdfs:label "TemporalDuration" ;
    rdfs:subClassOf dpv:DpvDuration ;
    skos:altLabel "Temporal Duration" ;
    skos:definition "Duration that has a fixed temporal duration e.g. 6 months" ;
    skos:exactMatch dpv:TemporalDuration,
        dpv_upstream:TemporalDuration,
        dpv_owl:TemporalDuration ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:TerminateContract a owl:Class ;
    rdfs:label "TerminateContract" ;
    rdfs:subClassOf dpv:ContractControl ;
    skos:altLabel "Terminate Contract" ;
    skos:definition "Control for terminating a contract" ;
    skos:exactMatch dpv:TerminateContract,
        dpv_upstream:TerminateContract,
        dpv_owl:TerminateContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-control-classes" .

dpv:TermsOfService a owl:Class ;
    rdfs:label "TermsOfService" ;
    rdfs:subClassOf dpv:ContractualClause ;
    skos:altLabel "Terms of Service" ;
    skos:definition """Contractual clauses outlining the terms and conditions regarding the
provision of a service, typically between a service provider and a
service consumer, also know as 'Terms of Use' and 'Terms and Conditions'
and commonly abbreviated as TOS, ToS, ToU, or T&C""" ;
    skos:exactMatch dpv:TermsOfService,
        dpv_upstream:TermsOfService,
        dpv_owl:TermsOfService ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:ThirdCountry a owl:Class ;
    rdfs:label "ThirdCountry" ;
    rdfs:subClassOf dpv:DpvCountry ;
    skos:altLabel "Third Country" ;
    skos:definition """Represents a country outside applicable or compatible jurisdiction as
outlined in law""" ;
    skos:exactMatch dpv:ThirdCountry,
        dpv_upstream:ThirdCountry,
        dpv_owl:ThirdCountry ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:ThirdParty a owl:Class ;
    rdfs:label "ThirdParty" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Third Party" ;
    skos:closeMatch common_domain_model:RelatedParty,
        iso27001:InterestedParty,
        iso42001:ThirdPartyRelationship ;
    skos:definition """A ‘third party’ means any natural or legal person other than - the
entities directly involved or operating under those directly involved in
a process""" ;
    skos:exactMatch dpv:ThirdParty,
        dpv_upstream:ThirdParty,
        dpv_owl:ThirdParty,
        iso29100:ThirdParty ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:narrowMatch gists:Organization ;
    skos:note """Third Party in the context of personal data processing are entities
other than the data subject, controllers, processors, and authorities""" ;
    skos:relatedMatch ocsf:Actor ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:ThirdPartyAgreement a owl:Class ;
    rdfs:label "ThirdPartyAgreement" ;
    rdfs:subClassOf dpv:LegalBasis,
        dpv:LegalMeasure,
        dpv:ThirdPartyContract ;
    skos:altLabel "Third-Party Agreement" ;
    skos:definition """An agreement outlining conditions, criteria, obligations,
responsibilities, and specifics for carrying out processing of data
between a Data Controller or Processor and a Third Party""" ;
    skos:exactMatch dpv:ThirdPartyAgreement,
        dpv_upstream:ThirdPartyAgreement,
        dpv_owl:ThirdPartyAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:ThirdPartyDataSource a owl:Class ;
    rdfs:label "ThirdPartyDataSource" ;
    rdfs:subClassOf dpv:DataSource ;
    skos:altLabel "Third Party as Data Source" ;
    skos:definition """Data Sourced from a Third Party, e.g. when data is collected from an
entity that is neither the Controller nor the Data Subject""" ;
    skos:exactMatch dpv:ThirdPartyDataSource,
        dpv_upstream:ThirdPartyDataSource,
        dpv_owl:ThirdPartyDataSource ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ThirdPartySecurityProcedures a owl:Class ;
    rdfs:label "ThirdPartySecurityProcedures" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SecurityProcedure ;
    skos:altLabel "Third Party Security Procedures" ;
    skos:definition "Procedures related to security associated with Third Parties" ;
    skos:exactMatch dpv:ThirdPartySecurityProcedures,
        dpv_upstream:ThirdPartySecurityProcedures,
        dpv_owl:ThirdPartySecurityProcedures ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:Tourist a owl:Class ;
    rdfs:label "Tourist" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Tourist" ;
    skos:definition "Humans that are tourists i.e. not citizens and not immigrants" ;
    skos:exactMatch dpv:Tourist,
        dpv_upstream:Tourist,
        dpv_owl:Tourist ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:TrackingByFirstParty a owl:Class ;
    rdfs:label "TrackingByFirstParty" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Tracking ;
    skos:altLabel "Tracking by First Party" ;
    skos:definition """to perform tracking where the performing entity is a first party within
the context""" ;
    skos:exactMatch dpv:TrackingByFirstParty,
        dpv_upstream:TrackingByFirstParty,
        dpv_owl:TrackingByFirstParty ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept does not strictly only specify the processing operation,
but also the relation of the individual with the implementing entity.
These concepts may change in the future based on discussions around how
to express First and Third Party.""" ;
    dpv:skos_in_scheme "processing-classes" .

dpv:TrackingByThirdParty a owl:Class ;
    rdfs:label "TrackingByThirdParty" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Tracking ;
    skos:altLabel "Tracking by Third Party" ;
    skos:definition """to perform tracking where the performing entity is a third party within
the context""" ;
    skos:exactMatch dpv:TrackingByThirdParty,
        dpv_upstream:TrackingByThirdParty,
        dpv_owl:TrackingByThirdParty ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept does not strictly only specify the processing operation,
but also the relation of the individual with the implementing entity.
These concepts may change in the future based on discussions around how
to express First and Third Party.""" ;
    dpv:skos_in_scheme "processing-classes" .

dpv:Transmit a owl:Class ;
    rdfs:label "Transmit" ;
    rdfs:subClassOf dpv:Disclose,
        dpv:Processing ;
    skos:altLabel "Transmit" ;
    skos:definition "to send out data" ;
    skos:exactMatch dpv:Transmit,
        dpv_upstream:Transmit,
        dpv_owl:Transmit ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:TrustedComputing a owl:Class ;
    rdfs:label "TrustedComputing" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Trusted Computing" ;
    skos:definition """Use of cryptographic methods to restrict access and execution to trusted
parties and code""" ;
    skos:exactMatch dpv:TrustedComputing,
        dpv_upstream:TrustedComputing,
        dpv_owl:TrustedComputing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:TrustedExecutionEnvironment a owl:Class ;
    rdfs:label "TrustedExecutionEnvironment" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Trusted Execution Environment" ;
    skos:definition """Use of cryptographic methods to restrict access and execution to trusted
parties and code within a dedicated execution environment""" ;
    skos:exactMatch dpv:TrustedExecutionEnvironment,
        dpv_upstream:TrustedExecutionEnvironment,
        dpv_owl:TrustedExecutionEnvironment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:UncategorisedData a owl:Class ;
    rdfs:label "UncategorisedData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Uncategorised Data" ;
    skos:definition """Data whose categorisation is not known e.g. whether it is personal or
non-personal data""" ;
    skos:exactMatch dpv:UncategorisedData,
        dpv_upstream:UncategorisedData,
        dpv_owl:UncategorisedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept is intended for indicating that a legally relevant
categorisation of data has not been made - specifically regarding
whether it is personal data or not, but it can also be extended for
other categorisations such as sensitive data or domain-specific
confidential data""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:Unexpected a owl:Class ;
    rdfs:label "Unexpected" ;
    rdfs:subClassOf dpv:ExpectationStatus ;
    skos:altLabel "Unexpected" ;
    skos:definition "Status indicating the specified context was unexpected i.e. not expected" ;
    skos:exactMatch dpv:Unexpected,
        dpv_upstream:Unexpected,
        dpv_owl:Unexpected ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:UninformedConsent a owl:Class ;
    rdfs:label "UninformedConsent" ;
    rdfs:subClassOf dpv:Consent,
        dpv:LegalBasis ;
    skos:altLabel "Uninformed Consent" ;
    skos:definition """Consent that is uninformed i.e. without requirement to provide
sufficient information to make a consenting decision""" ;
    skos:exactMatch dpv:UninformedConsent,
        dpv_upstream:UninformedConsent,
        dpv_owl:UninformedConsent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "consent-types-classes" .

dpv:UnknownApplicability a owl:Class ;
    rdfs:label "UnknownApplicability" ;
    rdfs:subClassOf dpv:Applicability ;
    skos:altLabel "Unknown Applicability" ;
    skos:definition """Concept indicating information or context availability is unknown i.e.
it is not known if the information exists or is applicable and therefore
statements about its availability cannot be made (yet)""" ;
    skos:exactMatch dpv:UnknownApplicability,
        dpv_upstream:UnknownApplicability,
        dpv_owl:UnknownApplicability ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept is useful when describing situations where it cannot be
stated whether the context applies or whether the information is not
available yet. For example, if a form field asks about whether a process
X was completed and it is not yet known whether X applies or not and
therefore it is also unclear whether X was completed or not. Using
UnknownApplicability is a signal that the applicability of X should be
assessed, and if applicable, then information about X should be
identified and used here.""" ;
    dpv:skos_in_scheme "context-classes" .

dpv:Unlawful a owl:Class ;
    rdfs:label "Unlawful" ;
    rdfs:subClassOf dpv:Lawfulness ;
    skos:altLabel "Unlawful" ;
    skos:definition "State of being unlawful or legally non-compliant" ;
    skos:exactMatch dpv:Unlawful,
        dpv_upstream:Unlawful,
        dpv_owl:Unlawful ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:UnstructuredData a owl:Class ;
    rdfs:label "UnstructuredData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Unstructured Data" ;
    skos:definition """Data that is without a predefined data model or is not organised in a
pre-defined manner""" ;
    skos:exactMatch dpv:UnstructuredData,
        dpv_upstream:UnstructuredData,
        dpv_owl:UnstructuredData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept is relevant to application of privacy/data protection
regulations like GDPR as unstructured data may contain PII/personal data
and it is useful to flag such data with unknown or incomplete modelling
information for audits. It is also useful to flag data for potential
quality issues""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:UntilEventDuration a owl:Class ;
    rdfs:label "UntilEventDuration" ;
    rdfs:subClassOf dpv:DpvDuration ;
    skos:altLabel "Until Event Duration" ;
    skos:definition """Duration that takes place until a specific event occurs e.g. Account
Closure""" ;
    skos:exactMatch dpv:UntilEventDuration,
        dpv_upstream:UntilEventDuration,
        dpv_owl:UntilEventDuration ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:UntilTimeDuration a owl:Class ;
    rdfs:label "UntilTimeDuration" ;
    rdfs:subClassOf dpv:DpvDuration ;
    skos:altLabel "Until Time Duration" ;
    skos:definition "Duration that has a fixed end date e.g. 2022-12-31" ;
    skos:exactMatch dpv:UntilTimeDuration,
        dpv_upstream:UntilTimeDuration,
        dpv_owl:UntilTimeDuration ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:UnverifiedData a owl:Class ;
    rdfs:label "UnverifiedData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Unverified Data" ;
    skos:definition """Data that has not been verified in terms of accuracy, inconsistency, or
quality""" ;
    skos:exactMatch dpv:UnverifiedData,
        dpv_upstream:UnverifiedData,
        dpv_owl:UnverifiedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:UsageControl a owl:Class ;
    rdfs:label "UsageControl" ;
    rdfs:subClassOf dpv:AccessControlMethod,
        dpv:TechnicalMeasure ;
    skos:altLabel "Usage Control" ;
    skos:definition """Management of usage, which is intended to be broader than access control
and may cover trust, digital rights, or other relevant controls""" ;
    skos:exactMatch dpv:UsageControl,
        dpv_upstream:UsageControl,
        dpv_owl:UsageControl ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:UseSyntheticData a owl:Class ;
    rdfs:label "UseSyntheticData" ;
    rdfs:subClassOf dpv:SecurityMethod,
        dpv:TechnicalMeasure ;
    skos:altLabel "Use of Synthetic Data" ;
    skos:definition """Use of synthetic data to preserve privacy, security, or other effects
and side-effects""" ;
    skos:exactMatch dpv:UseSyntheticData,
        dpv_upstream:UseSyntheticData,
        dpv_owl:UseSyntheticData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:UserInterfacePersonalisation a owl:Class ;
    rdfs:label "UserInterfacePersonalisation" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServicePersonalisation ;
    skos:altLabel "User Interface Personalisation" ;
    skos:definition """Purposes associated with personalisation of interfaces presented to the
user""" ;
    skos:exactMatch dpv:UserInterfacePersonalisation,
        dpv_upstream:UserInterfacePersonalisation,
        dpv_owl:UserInterfacePersonalisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Examples of user-interface personalisation include changing the language
to match the locale""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:VariableLocation a owl:Class ;
    rdfs:label "VariableLocation" ;
    rdfs:subClassOf dpv:LocationFixture ;
    skos:altLabel "Variable Location" ;
    skos:definition """Location that is known but is variable e.g. somewhere within a given
area""" ;
    skos:exactMatch dpv:VariableLocation,
        dpv_upstream:VariableLocation,
        dpv_owl:VariableLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:VendorPayment a owl:Class ;
    rdfs:label "VendorPayment" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:VendorManagement ;
    skos:altLabel "Vendor Payment" ;
    skos:definition "Purposes associated with managing payment of vendors" ;
    skos:exactMatch dpv:VendorPayment,
        dpv_upstream:VendorPayment,
        dpv_owl:VendorPayment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:VendorRecordsManagement a owl:Class ;
    rdfs:label "VendorRecordsManagement" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:VendorManagement ;
    skos:altLabel "Vendor Records Management" ;
    skos:definition "Purposes associated with managing records and orders related to vendors" ;
    skos:exactMatch dpv:VendorRecordsManagement,
        dpv_upstream:VendorRecordsManagement,
        dpv_owl:VendorRecordsManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:VendorSelectionAssessment a owl:Class ;
    rdfs:label "VendorSelectionAssessment" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:VendorManagement ;
    skos:altLabel "Vendor Selection Assessment" ;
    skos:definition """Purposes associated with managing selection, assessment, and evaluation
related to vendors""" ;
    skos:exactMatch dpv:VendorSelectionAssessment,
        dpv_upstream:VendorSelectionAssessment,
        dpv_owl:VendorSelectionAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:VerifiedData a owl:Class ;
    rdfs:label "VerifiedData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Verified Data" ;
    skos:definition """Data that has been verified in terms of accuracy, consistency, or
quality""" ;
    skos:exactMatch dpv:VerifiedData,
        dpv_upstream:VerifiedData,
        dpv_owl:VerifiedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:VirtualisationSecurity a owl:Class ;
    rdfs:label "VirtualisationSecurity" ;
    rdfs:subClassOf dpv:SecurityMethod,
        dpv:TechnicalMeasure ;
    skos:altLabel "Virtualisation Security" ;
    skos:definition "Security implemented at or through virtualised environments" ;
    skos:exactMatch dpv:VirtualisationSecurity,
        dpv_upstream:VirtualisationSecurity,
        dpv_owl:VirtualisationSecurity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:Visitor a owl:Class ;
    rdfs:label "Visitor" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Visitor" ;
    skos:definition "Humans that are temporary visitors" ;
    skos:exactMatch dpv:Visitor,
        dpv_upstream:Visitor,
        dpv_owl:Visitor ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:VitalInterestCompleted a owl:Class ;
    rdfs:label "VitalInterestCompleted" ;
    rdfs:subClassOf dpv:VitalInterestStatus ;
    skos:altLabel "Vital Interest Completed" ;
    skos:definition "Status where the vital interest activity has been completed" ;
    skos:exactMatch dpv:VitalInterestCompleted,
        dpv_upstream:VitalInterestCompleted,
        dpv_owl:VitalInterestCompleted ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:VitalInterestObjected a owl:Class ;
    rdfs:label "VitalInterestObjected" ;
    rdfs:subClassOf dpv:VitalInterestStatus ;
    skos:altLabel "Vital Interest Objected" ;
    skos:definition """Status where the vital interest activity was objected to by the Data
Subject or another relevant entity""" ;
    skos:exactMatch dpv:VitalInterestObjected,
        dpv_upstream:VitalInterestObjected,
        dpv_owl:VitalInterestObjected ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:VitalInterestOfDataSubject a owl:Class ;
    rdfs:label "VitalInterestOfDataSubject" ;
    rdfs:subClassOf dpv:LegalBasis,
        dpv:VitalInterestOfNaturalPerson ;
    skos:altLabel "Vital Interest of Data Subject" ;
    skos:definition """Activities are necessary or required to protect vital interests of a
data subject""" ;
    skos:exactMatch dpv:VitalInterestOfDataSubject,
        dpv_upstream:VitalInterestOfDataSubject,
        dpv_owl:VitalInterestOfDataSubject ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:VitalInterestOngoing a owl:Class ;
    rdfs:label "VitalInterestOngoing" ;
    rdfs:subClassOf dpv:VitalInterestStatus ;
    skos:altLabel "Vital Interest Ongoing" ;
    skos:definition "Status where the vital interest activity is ongoing" ;
    skos:exactMatch dpv:VitalInterestOngoing,
        dpv_upstream:VitalInterestOngoing,
        dpv_owl:VitalInterestOngoing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:VitalInterestPending a owl:Class ;
    rdfs:label "VitalInterestPending" ;
    rdfs:subClassOf dpv:VitalInterestStatus ;
    skos:altLabel "Vital Interest Pending" ;
    skos:definition "Status where the vital interest activity has not started" ;
    skos:exactMatch dpv:VitalInterestPending,
        dpv_upstream:VitalInterestPending,
        dpv_owl:VitalInterestPending ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:VulnerabilityTestingMethods a owl:Class ;
    rdfs:label "VulnerabilityTestingMethods" ;
    rdfs:subClassOf dpv:SecurityMethod,
        dpv:TechnicalMeasure ;
    skos:altLabel "Vulnerability Testing Methods" ;
    skos:definition "Methods that assess or discover vulnerabilities in a system" ;
    skos:exactMatch dpv:VulnerabilityTestingMethods,
        dpv_upstream:VulnerabilityTestingMethods,
        dpv_owl:VulnerabilityTestingMethods ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:WebBrowserSecurity a owl:Class ;
    rdfs:label "WebBrowserSecurity" ;
    rdfs:subClassOf dpv:SecurityMethod,
        dpv:TechnicalMeasure ;
    skos:altLabel "WebBrowser Security" ;
    skos:definition "Security implemented at or over web browsers" ;
    skos:exactMatch dpv:WebBrowserSecurity,
        dpv_upstream:WebBrowserSecurity,
        dpv_owl:WebBrowserSecurity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:WebSecurityProtocols a owl:Class ;
    rdfs:label "WebSecurityProtocols" ;
    rdfs:subClassOf dpv:SecurityMethod,
        dpv:TechnicalMeasure ;
    skos:altLabel "Web Security Protocols" ;
    skos:definition "Security implemented at or over web-based protocols" ;
    skos:exactMatch dpv:WebSecurityProtocols,
        dpv_upstream:WebSecurityProtocols,
        dpv_owl:WebSecurityProtocols ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:WirelessSecurityProtocols a owl:Class ;
    rdfs:label "WirelessSecurityProtocols" ;
    rdfs:subClassOf dpv:SecurityMethod,
        dpv:TechnicalMeasure ;
    skos:altLabel "Wireless Security Protocols" ;
    skos:definition "Security implemented at or over wireless communication protocols" ;
    skos:exactMatch dpv:WirelessSecurityProtocols,
        dpv_upstream:WirelessSecurityProtocols,
        dpv_owl:WirelessSecurityProtocols ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:WithinDevice a owl:Class ;
    rdfs:label "WithinDevice" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:LocalLocation ;
    skos:altLabel "Within Device (deprecated)" ;
    skos:definition "Location is local and entirely within a device, such as a smartphone" ;
    skos:exactMatch dpv:WithinDevice,
        dpv_upstream:WithinDevice,
        dpv_owl:WithinDevice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept will be deprecated in a future DPV release, it is suggested
to use the existing concepts representing device as tech:Device to have
parity and consistency between the use of device as a technology and for
data storage""" ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:WithinPhysicalEnvironment a owl:Class ;
    rdfs:label "WithinPhysicalEnvironment" ;
    rdfs:subClassOf dpv:DpvLocation ;
    skos:altLabel "Within Physical Environment" ;
    skos:definition """Location is local and entirely within a physical environment, such as a
room""" ;
    skos:exactMatch dpv:WithinPhysicalEnvironment,
        dpv_upstream:WithinPhysicalEnvironment,
        dpv_owl:WithinPhysicalEnvironment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept will be deprecated in a future DPV release, it is suggested
to use other concepts that also represent the nature of the location
e.g. dpv:PrivateSpace or its accessibility dpv:PubliclyAccessibleSpace""" ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:WithinVirtualEnvironment a owl:Class ;
    rdfs:label "WithinVirtualEnvironment" ;
    rdfs:subClassOf dpv:DpvLocation ;
    skos:altLabel "Within Virtual Environment" ;
    skos:definition """Location is local and entirely within a virtual environment, such as a
software system""" ;
    skos:exactMatch dpv:WithinVirtualEnvironment,
        dpv_upstream:WithinVirtualEnvironment,
        dpv_owl:WithinVirtualEnvironment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept will be deprecated in a future DPV release, it is suggested
to use the existing concepts representing device as tech:Software and
its taxonomy to have parity and consistency between the use of software
as a technology and as a virtual environment for data storage and
operations""" ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:ZeroKnowledgeAuthentication a owl:Class ;
    rdfs:label "ZeroKnowledgeAuthentication" ;
    rdfs:subClassOf dpv:AuthenticationProtocols,
        dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Zero Knowledge Authentication" ;
    skos:definition "Authentication using Zero-Knowledge proofs" ;
    skos:exactMatch dpv:ZeroKnowledgeAuthentication,
        dpv_upstream:ZeroKnowledgeAuthentication,
        dpv_owl:ZeroKnowledgeAuthentication ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:has_compliance_status a owl:DatatypeProperty ;
    rdfs:label "has_compliance_status" ;
    rdfs:subPropertyOf dpv:has_status ;
    skos:altLabel "has compliance status" ;
    skos:definition "Indicates the status of compliance of specified concept" ;
    skos:exactMatch dpv_upstream:hasComplianceStatus,
        dpv_owl:hasComplianceStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-properties" .

dpv:has_consequence a owl:DatatypeProperty ;
    rdfs:label "has_consequence" ;
    skos:altLabel "has consequence" ;
    skos:definition "Indicates consequence(s) possible or arising from specified concept" ;
    skos:exactMatch dpv_upstream:hasConsequence,
        dpv_owl:hasConsequence ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Removed plural suffix for consistency" ;
    dpv:skos_in_scheme "risk-properties" .

dpv:has_consequence_on a owl:DatatypeProperty ;
    rdfs:label "has_consequence_on" ;
    skos:altLabel "has consequence on" ;
    skos:definition """Indicates the thing (e.g. plan, process, or entity) affected by a
consequence""" ;
    skos:exactMatch dpv_upstream:hasConsequenceOn,
        dpv_owl:hasConsequenceOn ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-properties" .

dpv:has_contract_status a owl:DatatypeProperty ;
    rdfs:label "has_contract_status" ;
    rdfs:subPropertyOf dpv:has_status ;
    skos:altLabel "has contract status" ;
    skos:definition "Indicates the status of the contract" ;
    skos:exactMatch dpv_upstream:hasContractStatus,
        dpv_owl:hasContractStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-properties" .

dpv:has_country a owl:DatatypeProperty ;
    rdfs:label "has_country" ;
    rdfs:subPropertyOf dpv:has_location ;
    skos:altLabel "has country" ;
    skos:definition "Indicates applicability of specified country" ;
    skos:exactMatch dpv_upstream:hasCountry,
        dpv_owl:hasCountry ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-properties" .

dpv:has_data_controller a owl:DatatypeProperty ;
    rdfs:label "has_data_controller" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "has data controller" ;
    skos:definition "Indicates association with Data Controller" ;
    skos:exactMatch dpv_upstream:hasDataController,
        dpv_owl:hasDataController ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-legalrole-properties" .

dpv:has_human_subject a owl:DatatypeProperty ;
    rdfs:label "has_human_subject" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "has human subject" ;
    skos:definition "Indicates association with Human Subject" ;
    skos:exactMatch dpv_upstream:hasHumanSubject,
        dpv_owl:hasHumanSubject ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-properties" .

dpv:has_processing_condition a owl:DatatypeProperty ;
    rdfs:label "has_processing_condition" ;
    skos:altLabel "has processing condition" ;
    skos:definition "Indicates information about processing condition" ;
    skos:exactMatch dpv_upstream:hasProcessingCondition,
        dpv_owl:hasProcessingCondition ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-properties" .

dpv:has_representative a owl:DatatypeProperty ;
    rdfs:label "has_representative" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "has representative" ;
    skos:definition "Specifies representative of the legal entity" ;
    skos:exactMatch dpv_upstream:hasRepresentative,
        dpv_owl:hasRepresentative ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-properties" .

dpv:B2BContract a owl:Class ;
    rdfs:label "B2BContract" ;
    rdfs:subClassOf dpv:ContractByEntityType,
        dpv:LegalBasis ;
    skos:altLabel "Business-to-Business Contract" ;
    skos:definition "A contract between two businesses" ;
    skos:exactMatch dpv:B2BContract,
        dpv_upstream:B2BContract,
        dpv_owl:B2BContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:B2CContract a owl:Class ;
    rdfs:label "B2CContract" ;
    rdfs:subClassOf dpv:ContractByEntityType,
        dpv:LegalBasis ;
    skos:altLabel "Business-to-Consumer Contract" ;
    skos:definition """A contract between a business and a consumer where the business provides
goods or services to the consumer""" ;
    skos:exactMatch dpv:B2CContract,
        dpv_upstream:B2CContract,
        dpv_owl:B2CContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:CommercialPurpose a owl:Class ;
    rdfs:label "CommercialPurpose" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Commercial Purpose" ;
    skos:definition """Purposes associated with processing activities performed in a commercial
setting or with intention to commercialise""" ;
    skos:exactMatch dpv:CommercialPurpose,
        dpv_upstream:CommercialPurpose,
        dpv_owl:CommercialPurpose ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 4.4" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:CommunicationManagement a owl:Class ;
    rdfs:label "CommunicationManagement" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Communication Management" ;
    skos:definition """Communication Management refers to purposes associated with providing or
managing communication activities e.g. to send an email for notifying
some information""" ;
    skos:exactMatch dpv:CommunicationManagement,
        dpv_upstream:CommunicationManagement,
        dpv_owl:CommunicationManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This purpose by itself does not sufficiently and clearly indicate what
the communication is about. As such, it is recommended to combine it
with another purpose to indicate the application. For example,
Communication of Payment.""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ComplianceAssessment a owl:Class ;
    rdfs:label "ComplianceAssessment" ;
    rdfs:subClassOf dpv:Assessment,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Compliance Assessment" ;
    skos:definition "Assessment regarding compliance (e.g. internal policy, regulations)" ;
    skos:exactMatch dpv:ComplianceAssessment,
        dpv_upstream:ComplianceAssessment,
        dpv_owl:ComplianceAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ConsentRecord a owl:Class ;
    rdfs:label "ConsentRecord" ;
    rdfs:subClassOf dpv:DataProcessingRecord,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Consent Record" ;
    skos:definition "A Record of Consent or Consent related activities" ;
    skos:exactMatch dpv:ConsentRecord,
        dpv_upstream:ConsentRecord,
        dpv_owl:ConsentRecord,
        iso29100:ConsentRecord ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch oscal:Resource ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ConsultationWithDataSubject a owl:Class ;
    rdfs:label "ConsultationWithDataSubject" ;
    rdfs:subClassOf dpv:Consultation,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Consultation with Data Subject" ;
    skos:definition "Consultation with data subject(s) or their representative(s)" ;
    skos:exactMatch dpv:ConsultationWithDataSubject,
        dpv_upstream:ConsultationWithDataSubject,
        dpv_owl:ConsultationWithDataSubject ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ContractualTerms a owl:Class ;
    rdfs:label "ContractualTerms" ;
    rdfs:subClassOf dpv:LegalMeasure ;
    skos:altLabel "Contractual Terms" ;
    skos:definition "Contractual terms governing data handling within or with an entity" ;
    skos:exactMatch dpv:ContractualTerms,
        dpv_upstream:ContractualTerms,
        dpv_owl:ContractualTerms ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-measures-classes" .

dpv:CustomerCare a owl:Class ;
    rdfs:label "CustomerCare" ;
    rdfs:subClassOf dpv:CustomerManagement,
        dpv:Purpose ;
    skos:altLabel "Customer Care" ;
    skos:definition """Customer Care refers to purposes associated with purposes for providing
assistance, resolving issues, ensuring satisfaction, etc. in relation to
services provided""" ;
    skos:exactMatch dpv:CustomerCare,
        dpv_upstream:CustomerCare,
        dpv_owl:CustomerCare ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpu:Feedback ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:CustomerRelationshipManagement a owl:Class ;
    rdfs:label "CustomerRelationshipManagement" ;
    rdfs:subClassOf dpv:CustomerManagement,
        dpv:Purpose ;
    skos:altLabel "Customer Relationship Management" ;
    skos:definition """Customer Relationship Management refers to purposes associated with
managing and analysing interactions with past, current, and potential
customers""" ;
    skos:exactMatch dpv:CustomerRelationshipManagement,
        dpv_upstream:CustomerRelationshipManagement,
        dpv_owl:CustomerRelationshipManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:DataController a owl:Class ;
    rdfs:label "DataController" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Data Controller" ;
    skos:definition """The individual or organisation that decides (or controls) the purpose(s)
of processing personal data.""" ;
    skos:exactMatch dpv:DataController,
        dpv_upstream:DataController,
        dpv_owl:DataController,
        iso29100:PIIController ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The terms 'Controller', 'Data Controller', and 'PII Controller' refer to
the same concept""" ;
    skos:relatedMatch common_domain_model:Counterparty,
        iso22989:AIProvider,
        iso27001:Organization,
        nist_ai_rmf:AiActor,
        oscal:ResponsibleParty ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:DataControllerContract a owl:Class ;
    rdfs:label "DataControllerContract" ;
    rdfs:subClassOf dpv:DataProcessingAgreement,
        dpv:LegalBasis ;
    skos:altLabel "Data Controller Contract" ;
    skos:definition """Creation, completion, fulfilment, or performance of a contract, with
Data Controllers as parties being Joint Data Controllers, and involving
specified processing of data or technologies. NOTE: This concept is
being deprecated - use dpv:JointDataControllersAgreement which has a
more explicit definition of the entities involved and the intent of the
contract""" ;
    skos:exactMatch dpv:DataControllerContract,
        dpv_upstream:DataControllerContract,
        dpv_owl:DataControllerContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:DataProcessor a owl:Class ;
    rdfs:label "DataProcessor" ;
    rdfs:subClassOf dpv:DpvRecipient ;
    skos:altLabel "Data Processor" ;
    skos:definition """A ‘processor’ means a natural or legal person, public authority, agency
or other body which processes data on behalf of the controller.""" ;
    skos:exactMatch dpv:DataProcessor,
        dpv_upstream:DataProcessor,
        dpv_owl:DataProcessor,
        iso29100:PIIProcessor ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch common_domain_model:Counterparty,
        iso27001:Organization ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:DataProcessorContract a owl:Class ;
    rdfs:label "DataProcessorContract" ;
    rdfs:subClassOf dpv:DataProcessingAgreement,
        dpv:LegalBasis ;
    skos:altLabel "Data Processor Contract" ;
    skos:definition """Creation, completion, fulfilment, or performance of a contract, with the
Data Controller and Data Processor as parties, and involving specified
processing of data or technologies. NOTE: This concept is being
deprecated - use dpv:ControllerProcessorAgreement which has a more
explicit definition of the entities involved and the intent of the
contract""" ;
    skos:exactMatch dpv:DataProcessorContract,
        dpv_upstream:DataProcessorContract,
        dpv_owl:DataProcessorContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:DataQualityAssessment a owl:Class ;
    rdfs:label "DataQualityAssessment" ;
    rdfs:subClassOf dpv:Assessment,
        dpv:DataQualityManagement,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Quality Assessment" ;
    skos:definition "Measures associated with assessment of data quality" ;
    skos:exactMatch dpv:DataQualityAssessment,
        dpv_upstream:DataQualityAssessment,
        dpv_owl:DataQualityAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataSubjectContract a owl:Class ;
    rdfs:label "DataSubjectContract" ;
    rdfs:subClassOf dpv:DataProcessingAgreement,
        dpv:LegalBasis ;
    skos:altLabel "Data Subject Contract" ;
    skos:definition """Creation, completion, fulfilment, or performance of a contract, with the
Data Controller and Data Subject as parties, and involving specified
processing of data or technologies. NOTE: This concept is being
deprecated - use dpv:ControllerDataSubjectAgreement which has a more
explicit definition of the entities involved and the intent of the
contract""" ;
    skos:exactMatch dpv:DataSubjectContract,
        dpv_upstream:DataSubjectContract,
        dpv_owl:DataSubjectContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:DataSubjectDataSource a owl:Class ;
    rdfs:label "DataSubjectDataSource" ;
    rdfs:subClassOf dpv:DataSource ;
    skos:altLabel "Data Subject as Data Source" ;
    skos:definition """Data Sourced from Data Subject(s), e.g. when data is collected via a
form or observed from their activities""" ;
    skos:exactMatch dpv:DataSubjectDataSource,
        dpv_upstream:DataSubjectDataSource,
        dpv_owl:DataSubjectDataSource ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:DecisionMaking a owl:Class ;
    rdfs:label "DecisionMaking" ;
    rdfs:subClassOf dpv:ProcessingContext ;
    skos:altLabel "Decision Making" ;
    skos:closeMatch iso22989:Decision ;
    skos:definition "Processing that involves decision making" ;
    skos:exactMatch dpv:DecisionMaking,
        dpv_upstream:DecisionMaking,
        dpv_owl:DecisionMaking ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:Derive a owl:Class ;
    rdfs:label "Derive" ;
    rdfs:subClassOf dpv:Obtain,
        dpv:Processing ;
    skos:altLabel "Derive" ;
    skos:definition "to create new derivative data from the original data" ;
    skos:exactMatch dpv:Derive,
        dpv_upstream:Derive,
        dpv_owl:Derive ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Derive indicates data is present or obtainable from existing data. For
data that is created without such existence, see Infer.""" ;
    skos:relatedMatch svpr:Derive ;
    dpv:skos_in_scheme "processing-classes" .

dpv:DerivedPersonalData a owl:Class ;
    rdfs:label "DerivedPersonalData" ;
    rdfs:subClassOf dpv:DerivedData,
        dpv:PersonalData ;
    skos:altLabel "Derived Personal Data" ;
    skos:definition "Personal Data that is obtained or derived from other data" ;
    skos:exactMatch dpv:DerivedPersonalData,
        dpv_upstream:DerivedPersonalData,
        dpv_owl:DerivedPersonalData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Derived Data is data that is obtained through processing of existing
data, e.g. deriving first name from full name. To indicate data that is
derived but which was not present or evident within the source data,
InferredPersonalData should be used.""" ;
    skos:relatedMatch svd:Derived ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:DpvCountry a owl:Class ;
    rdfs:label "DpvCountry" ;
    rdfs:subClassOf dpv:DpvJurisdiction ;
    skos:altLabel "Country" ;
    skos:definition """A political entity indicative of a sovereign or non-sovereign
territorial state comprising of distinct geographical areas""" ;
    skos:exactMatch dpv:Country,
        dpv_upstream:Country,
        dpv_owl:Country ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The definition of country is not intended for political interpretation.
DPVCG welcomes alternate definitions based in existing sources with
global scope, such as UN or ISO.""" ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:DpvRecipient a owl:Class ;
    rdfs:label "DpvRecipient" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Recipient" ;
    skos:definition "Entities that receive data or technologies" ;
    skos:exactMatch dpv:Recipient,
        dpv_upstream:Recipient,
        dpv_owl:Recipient ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Recipients that receive personal data can be a Third Party, Data
Controller, or Data Processor.""" ;
    skos:relatedMatch usage_policy:AnyRecipient ;
    dpv:skos_in_scheme "entities-legalrole-classes" .

dpv:ExpressedConsent a owl:Class ;
    rdfs:label "ExpressedConsent" ;
    rdfs:subClassOf dpv:InformedConsent,
        dpv:LegalBasis ;
    skos:altLabel "Expressed Consent" ;
    skos:definition """Consent that is expressed through an action intended to convey a
consenting decision""" ;
    skos:exactMatch dpv:ExpressedConsent,
        dpv_upstream:ExpressedConsent,
        dpv_owl:ExpressedConsent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Expressed consent requires the individual take a specific and
unambiguous action that directly indicates their consent. This action
may be a part of other processes such as setting preferences, or
agreeing to a contract, or other matters not relating to consent. An
example of expressed consent is interacting with a checkbox within a
dashboard or clicking a button on a web form""" ;
    dpv:skos_in_scheme "consent-types-classes" .

dpv:Format a owl:Class ;
    rdfs:label "Format" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Structure ;
    skos:altLabel "Format" ;
    skos:definition "to arrange or structure data in a specific form" ;
    skos:exactMatch dpv:Format,
        dpv_upstream:Format,
        dpv_owl:Format ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 12.d" ;
    dpv:skos_in_scheme "processing-classes" .

dpv:GeneratedData a owl:Class ;
    rdfs:label "GeneratedData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Generated Data" ;
    skos:definition """Data that is generated or brought into existence without relation to
existing data i.e. it is not derived or inferred from other data""" ;
    skos:exactMatch dpv:GeneratedData,
        dpv_upstream:GeneratedData,
        dpv_owl:GeneratedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:GovernmentalOrganisation a owl:Class ;
    rdfs:label "GovernmentalOrganisation" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "Governmental Organisation" ;
    skos:definition "An organisation managed or part of government" ;
    skos:exactMatch dpv:GovernmentalOrganisation,
        dpv_upstream:GovernmentalOrganisation,
        dpv_owl:GovernmentalOrganisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:GuardianOfHuman a owl:Class ;
    rdfs:label "GuardianOfHuman" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Guardian(s) of Human" ;
    skos:definition "Guardian(s) of humans" ;
    skos:exactMatch dpv:GuardianOfHuman,
        dpv_upstream:GuardianOfHuman,
        dpv_owl:GuardianOfHuman ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:HumanResourceManagement a owl:Class ;
    rdfs:label "HumanResourceManagement" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Human Resource Management" ;
    skos:definition """Purposes associated with managing humans and 'human resources' within
the organisation for effective and efficient operations.""" ;
    skos:exactMatch dpv:HumanResourceManagement,
        dpv_upstream:HumanResourceManagement,
        dpv_owl:HumanResourceManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """HR is a broad concept. Its management includes, amongst others -
recruiting employees and intermediaries e.g. brokers, independent
representatives; payroll administration, remunerations, commissions, and
wages; and application of social legislation.""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:InferredData a owl:Class ;
    rdfs:label "InferredData" ;
    rdfs:subClassOf dpv:DerivedData ;
    skos:altLabel "Inferred Data" ;
    skos:definition "Data that has been obtained through inferences of other data" ;
    skos:exactMatch dpv:InferredData,
        dpv_upstream:InferredData,
        dpv_owl:InferredData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:InformationAudit a owl:Class ;
    rdfs:label "InformationAudit" ;
    rdfs:subClassOf dpv:Audit,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Information Audit" ;
    skos:definition """An audit that systematically examines the existence and use of
information along with its associated resources (e.g. where it is
stored) and flows (e.g. where it originates and with whom it is being
shared)""" ;
    skos:exactMatch dpv:InformationAudit,
        dpv_upstream:InformationAudit,
        dpv_owl:InformationAudit ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:Intended a owl:Class ;
    rdfs:label "Intended" ;
    rdfs:subClassOf dpv:IntentionStatus ;
    skos:altLabel "Intended" ;
    skos:definition "Status indicating the specified context was intended" ;
    skos:exactMatch dpv:Intended,
        dpv_upstream:Intended,
        dpv_owl:Intended ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:Law a owl:Class ;
    rdfs:label "Law" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Law" ;
    skos:definition "A law is a set of rules created by government or authorities" ;
    skos:exactMatch dpv:Law,
        dpv_upstream:Law,
        dpv_owl:Law ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:LegalObligation a owl:Class ;
    rdfs:label "LegalObligation" ;
    rdfs:subClassOf dpv:LegalBasis ;
    skos:altLabel "Legal Obligation" ;
    skos:definition "Legal Obligation to conduct the specified activities" ;
    skos:exactMatch dpv:LegalObligation,
        dpv_upstream:LegalObligation,
        dpv_owl:LegalObligation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:LicenseAgreement a owl:Class ;
    rdfs:label "LicenseAgreement" ;
    rdfs:subClassOf dpv:ContractByDomain,
        dpv:LegalBasis ;
    skos:altLabel "License Agreement" ;
    skos:definition """A Legal Document providing permission to utilise data or resource and
outlining the conditions under which such use is considered valid""" ;
    skos:exactMatch dpv:LicenseAgreement,
        dpv_upstream:LicenseAgreement,
        dpv_owl:LicenseAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:Likelihood a owl:Class ;
    rdfs:label "Likelihood" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Likelihood" ;
    skos:definition """The likelihood or probability or chance of something taking place or
occurring""" ;
    skos:exactMatch dpv:Likelihood,
        dpv_upstream:Likelihood,
        dpv_owl:Likelihood ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Likelihood can be expressed in a subjective manner, such as 'Unlikely',
or in a quantitative manner such as "Twice in a Day" (frequency per
period). The suggestion is to use quantitative values, or to associate
them with subjective terms used so as to enable accurate interpretations
and interoperability. See the concepts related to Frequency and Duration
for possible uses as a combination to express Likelihood.""" ;
    dpv:skos_in_scheme "risk-classes" .

dpv:MentallyVulnerableHuman a owl:Class ;
    rdfs:label "MentallyVulnerableHuman" ;
    rdfs:subClassOf dpv:HumanSubject,
        dpv:VulnerableHuman ;
    skos:altLabel "Mentally Vulnerable Human" ;
    skos:definition "Humans that are considered mentally vulnerable within the context" ;
    skos:exactMatch dpv:MentallyVulnerableHuman,
        dpv_upstream:MentallyVulnerableHuman,
        dpv_owl:MentallyVulnerableHuman ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:MisusePreventionAndDetection a owl:Class ;
    rdfs:label "MisusePreventionAndDetection" ;
    rdfs:subClassOf dpv:EnforceSecurity,
        dpv:Purpose ;
    skos:altLabel "Misuse, Prevention and Detection" ;
    skos:definition "Prevention and Detection of Misuse or Abuse of services" ;
    skos:exactMatch dpv:MisusePreventionAndDetection,
        dpv_upstream:MisusePreventionAndDetection,
        dpv_owl:MisusePreventionAndDetection ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 22.1(a)" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:NonCommercialPurpose a owl:Class ;
    rdfs:label "NonCommercialPurpose" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Non-commercial Purpose" ;
    skos:definition """Purposes associated with processing activities performed in a
non-commercial setting or without intention to commercialise""" ;
    skos:exactMatch dpv:NonCommercialPurpose,
        dpv_upstream:NonCommercialPurpose,
        dpv_owl:NonCommercialPurpose ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 4.4" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:NonPersonalData a owl:Class ;
    rdfs:label "NonPersonalData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Non-Personal Data" ;
    skos:definition "Data that is not Personal Data" ;
    skos:exactMatch dpv:NonPersonalData,
        dpv_upstream:NonPersonalData,
        dpv_owl:NonPersonalData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The term NonPersonalData is provided to distinguish between PersonalData
and other data, e.g. for indicating which data is regulated by privacy
laws. To specify personal data that has been anonymised, the concept
AnonymisedData should be used as the anonymisation process has a risk of
not being fully effective and such anonymous data may be found to be
personal data depending on circumstances.""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:NoticeIcon a owl:Class ;
    rdfs:label "NoticeIcon" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Notice Icon" ;
    skos:definition "An icon within a notice associated with specific information or elements" ;
    skos:exactMatch dpv:NoticeIcon,
        dpv_upstream:NoticeIcon,
        dpv_owl:NoticeIcon ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes" .

dpv:NoticeLayer a owl:Class ;
    rdfs:label "NoticeLayer" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Notice Layer" ;
    skos:definition """A layer within a layered notice where the layer can be used for
providing specific information or controls""" ;
    skos:exactMatch dpv:NoticeLayer,
        dpv_upstream:NoticeLayer,
        dpv_owl:NoticeLayer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes" .

dpv:Notification a owl:Class ;
    rdfs:label "Notification" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Notification" ;
    skos:definition "Notification represents the provision of a notice i.e. notifying" ;
    skos:exactMatch dpv:Notification,
        dpv_upstream:Notification,
        dpv_owl:Notification ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Notice refers to the information whereas Notification refers to the
provision of that notice. The distinction is important as there are
specific obligations associated with notice and notifications. For
example, a data breach notice refers to the information about the breach
intended to be provided to another entity, whereas notification refers
to the act of providing the entity with the notice""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ObservedData a owl:Class ;
    rdfs:label "ObservedData" ;
    rdfs:subClassOf dpv:CollectedData ;
    skos:altLabel "Observed Data" ;
    skos:definition "Data that has been obtained through observations of a source" ;
    skos:exactMatch dpv:ObservedData,
        dpv_upstream:ObservedData,
        dpv_owl:ObservedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:OptimisationForConsumer a owl:Class ;
    rdfs:label "OptimisationForConsumer" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceOptimisation ;
    skos:altLabel "Optimisation for Consumer" ;
    skos:definition """Purposes associated with optimisation of activities and services for
consumer or user""" ;
    skos:exactMatch dpv:OptimisationForConsumer,
        dpv_upstream:OptimisationForConsumer,
        dpv_owl:OptimisationForConsumer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The term optimisation here refers to the efficiency of the service in
terms of technical provision (or similar means) with benefits for
everybody. Personalisation implies making changes that benefit the
current user or persona.""" ;
    skos:relatedMatch svpu:Custom ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:OptingInToProcess a owl:Class ;
    rdfs:label "OptingInToProcess" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Opting in to Process" ;
    skos:definition "Involvement where entity can opt-in to specified context" ;
    skos:exactMatch dpv:OptingInToProcess,
        dpv_upstream:OptingInToProcess,
        dpv_owl:OptingInToProcess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:Organise a owl:Class ;
    rdfs:label "Organise" ;
    rdfs:subClassOf dpv:Processing ;
    skos:altLabel "Organise" ;
    skos:definition "to organize data for arranging or classifying" ;
    skos:exactMatch dpv:Organise,
        dpv_upstream:Organise,
        dpv_owl:Organise ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:ParentOfHuman a owl:Class ;
    rdfs:label "ParentOfHuman" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Parent of Human" ;
    skos:definition "Parent(s) of humans" ;
    skos:exactMatch dpv:ParentOfHuman,
        dpv_upstream:ParentOfHuman,
        dpv_owl:ParentOfHuman ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:PermissionManagement a owl:Class ;
    rdfs:label "PermissionManagement" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RightsManagement ;
    skos:altLabel "Permission Management" ;
    skos:definition """Methods to obtain, provide, modify, and withdraw permissions along with
maintaining a record of permissions, retrieving records, and processing
changes in permission states""" ;
    skos:exactMatch dpv:PermissionManagement,
        dpv_upstream:PermissionManagement,
        dpv_owl:PermissionManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Permission is a broader concept than '(Informed) Consent' as consent
when used as a legal basis has specific requirements to be valid. For
management of consent, see the concept dpv:ConsentManagement""" ;
    dpv:dct_source "DGA 12.n" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:PersonalisedAdvertising a owl:Class ;
    rdfs:label "PersonalisedAdvertising" ;
    rdfs:subClassOf dpv:Advertising,
        dpv:Personalisation,
        dpv:Purpose ;
    skos:altLabel "Personalised Advertising" ;
    skos:definition "Purposes associated with creating and providing personalised advertising" ;
    skos:exactMatch dpv:PersonalisedAdvertising,
        dpv_upstream:PersonalisedAdvertising,
        dpv_owl:PersonalisedAdvertising ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:PrivacyNotice a owl:Class ;
    rdfs:label "PrivacyNotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Privacy Notice" ;
    skos:closeMatch iso29100:PrivacyPolicy ;
    skos:definition "Represents a notice or document outlining information regarding privacy" ;
    skos:exactMatch dpv:PrivacyNotice,
        dpv_upstream:PrivacyNotice,
        dpv_owl:PrivacyNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes, organisational-measures-classes" .

dpv:PrivatelyOwnedSpace a owl:Class ;
    rdfs:label "PrivatelyOwnedSpace" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:PrivateSpace ;
    skos:altLabel "Privately Owned Space" ;
    skos:definition "A place that is privately owned e.g. offices, malls" ;
    skos:exactMatch dpv:PrivatelyOwnedSpace,
        dpv_upstream:PrivatelyOwnedSpace,
        dpv_owl:PrivatelyOwnedSpace ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:ProcessingDuration a owl:Class ;
    rdfs:label "ProcessingDuration" ;
    rdfs:subClassOf dpv:DpvDuration,
        dpv:ProcessingCondition ;
    skos:altLabel "Processing Duration" ;
    skos:definition "Conditions regarding duration or temporal limitation for processing" ;
    skos:exactMatch dpv:ProcessingDuration,
        dpv_upstream:ProcessingDuration,
        dpv_owl:ProcessingDuration ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ProcessingLocation a owl:Class ;
    rdfs:label "ProcessingLocation" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:ProcessingCondition ;
    skos:altLabel "Processing Location" ;
    skos:definition """Conditions regarding location or geospatial scope where processing takes
places""" ;
    skos:exactMatch dpv:ProcessingLocation,
        dpv_upstream:ProcessingLocation,
        dpv_owl:ProcessingLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ProvideConsent a owl:Class ;
    rdfs:label "ProvideConsent" ;
    rdfs:subClassOf dpv:ConsentControl,
        dpv:OptingInToProcess ;
    skos:altLabel "Provide Consent" ;
    skos:definition "Control for providing consent" ;
    skos:exactMatch dpv:ProvideConsent,
        dpv_upstream:ProvideConsent,
        dpv_owl:ProvideConsent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Indicates how the data subject can provide consent e.g. used with
dpv:isExercisedAt""" ;
    dpv:skos_in_scheme "consent-controls-classes" .

dpv:ProvidedData a owl:Class ;
    rdfs:label "ProvidedData" ;
    rdfs:subClassOf dpv:CollectedData ;
    skos:altLabel "Provided Data" ;
    skos:definition "Data that has been provided by an entity" ;
    skos:exactMatch dpv:ProvidedData,
        dpv_upstream:ProvidedData,
        dpv_owl:ProvidedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Provided data involves one entity explicitly providing the data, which
the other entity then collects""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:PseudonymisedData a owl:Class ;
    rdfs:label "PseudonymisedData" ;
    rdfs:subClassOf dpv:PersonalData ;
    skos:altLabel "Pseudonymised Data" ;
    skos:definition """Pseudonymised Data is data that has gone a partial or incomplete
anonymisation process by replacing the identifiable information with
artificial identifiers or 'pseudonyms', and is still considered as
personal data""" ;
    skos:exactMatch dpv:PseudonymisedData,
        dpv_upstream:PseudonymisedData,
        dpv_owl:PseudonymisedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:PublicRegisterOfEntities a owl:Class ;
    rdfs:label "PublicRegisterOfEntities" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Public Register of Entities" ;
    skos:definition """A publicly available list of entities e.g. to indicate which entities
perform a certain activity within a certain location or jurisdiction""" ;
    skos:exactMatch dpv:PublicRegisterOfEntities,
        dpv_upstream:PublicRegisterOfEntities,
        dpv_owl:PublicRegisterOfEntities ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-classes" .

dpv:PubliclyAccessibleSpace a owl:Class ;
    rdfs:label "PubliclyAccessibleSpace" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:PublicSpace ;
    skos:altLabel "Publicly Accessible Space" ;
    skos:definition """A space that is accessible to all members of the public e.g. parks,
malls, train stations""" ;
    skos:exactMatch dpv:PubliclyAccessibleSpace,
        dpv_upstream:PubliclyAccessibleSpace,
        dpv_owl:PubliclyAccessibleSpace ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:ReaffirmConsent a owl:Class ;
    rdfs:label "ReaffirmConsent" ;
    rdfs:subClassOf dpv:ConsentControl ;
    skos:altLabel "Reaffirm Consent" ;
    skos:definition "Control for affirming consent" ;
    skos:exactMatch dpv:ReaffirmConsent,
        dpv_upstream:ReaffirmConsent,
        dpv_owl:ReaffirmConsent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Indicates how the controller (with dpv:ObtainConsent) or data subject
(with dpv:ProvideConsent) can reaffirm consent e.g. used with
dpv:isExercisedAt""" ;
    dpv:skos_in_scheme "consent-controls-classes" .

dpv:RecruitmentAdvertising a owl:Class ;
    rdfs:label "RecruitmentAdvertising" ;
    rdfs:subClassOf dpv:Advertising,
        dpv:PersonnelHiring,
        dpv:Purpose ;
    skos:altLabel "Recruitment Advertising" ;
    skos:definition """Purposes associated with advertisement for Recruitments and personnel
hiring""" ;
    skos:exactMatch dpv:RecruitmentAdvertising,
        dpv_upstream:RecruitmentAdvertising,
        dpv_owl:RecruitmentAdvertising ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RemoteLocation a owl:Class ;
    rdfs:label "RemoteLocation" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:LocationLocality ;
    skos:altLabel "Remote Location" ;
    skos:definition "Location is remote i.e. not local" ;
    skos:exactMatch dpv:RemoteLocation,
        dpv_upstream:RemoteLocation,
        dpv_owl:RemoteLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:Representative a owl:Class ;
    rdfs:label "Representative" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Representative" ;
    skos:definition "A representative of a legal entity" ;
    skos:exactMatch dpv:Representative,
        dpv_upstream:Representative,
        dpv_owl:Representative ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """A representative may not be a 'legal agent' if it is authorised to only
represent the entity and not to take actions on its behalf""" ;
    dpv:skos_in_scheme "entities-classes" .

dpv:RequestedServiceProvision a owl:Class ;
    rdfs:label "RequestedServiceProvision" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceProvision ;
    skos:altLabel "Requested Service Provision" ;
    skos:definition """Purposes associated with delivering services as requested by user or
consumer""" ;
    skos:exactMatch dpv:RequestedServiceProvision,
        dpv_upstream:RequestedServiceProvision,
        dpv_owl:RequestedServiceProvision ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The use of 'request' here includes where an user explicitly asks for the
service and also when an established contract requires the provision of
the service""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ReviewProcedure a owl:Class ;
    rdfs:label "ReviewProcedure" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Review Procedure" ;
    skos:definition """A procedure or process that reviews the correctness and validity of
other procedures and policies e.g. to ensure continued validity,
adequacy for intended purposes, and conformance of processes with
findings""" ;
    skos:exactMatch dpv:ReviewProcedure,
        dpv_upstream:ReviewProcedure,
        dpv_owl:ReviewProcedure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:RightNotice a owl:Class ;
    rdfs:label "RightNotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Right Notice" ;
    skos:definition """Information associated with rights, such as which rights exist, when and
where they are applicable, and other relevant information""" ;
    skos:exactMatch dpv:RightNotice,
        dpv_upstream:RightNotice,
        dpv_owl:RightNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept also covers information about rights exercise, with
dpv:RightExerciseNotice specifically representing information provided
in connection with exercising of rights. Both notices may be needed,
e.g. RightNotice for providing information about existence and exercise
of rights, and RightExerciseNotice for providing additional information
specifically about exercise of rights - such as to request more
information or provide updates on an exercised rights request""" ;
    dpv:skos_in_scheme "rights-classes" .

dpv:Risk a owl:Class ;
    rdfs:label "Risk" ;
    rdfs:subClassOf dpv:RiskConcept ;
    skos:altLabel "Risk" ;
    skos:definition """A risk or possibility or uncertainty of negative effects, impacts, or
consequences""" ;
    skos:exactMatch dpv:Risk,
        dpv_upstream:Risk,
        dpv_owl:Risk ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Risks can be associated with one or more different concepts such as
purpose, processing, personal data, technical or organisational measure""" ;
    dpv:skos_in_scheme "risk-classes" .

dpv:RiskLevel a owl:Class ;
    rdfs:label "RiskLevel" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Risk Level" ;
    skos:definition """The magnitude of a risk expressed as an indication to aid in its
management""" ;
    skos:exactMatch dpv:RiskLevel,
        dpv_upstream:RiskLevel,
        dpv_owl:RiskLevel ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Risk Levels can be defined as a combination of different
characteristics. For example, ISO 31073:2022 defines it as a combination
of consequences and their likelihood. Another example would be the Risk
Matrix where Risk Level is defined as a combination of Likelihood and
Severity associated with the Risk.""" ;
    dpv:skos_in_scheme "risk-classes" .

dpv:ScoringOfIndividuals a owl:Class ;
    rdfs:label "ScoringOfIndividuals" ;
    rdfs:subClassOf dpv:EvaluationScoring ;
    skos:altLabel "Scoring of Individuals" ;
    skos:definition "Processing that involves scoring of individuals" ;
    skos:exactMatch dpv:ScoringOfIndividuals,
        dpv_upstream:ScoringOfIndividuals,
        dpv_owl:ScoringOfIndividuals ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:Sector a owl:Class ;
    rdfs:label "Sector" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Sector" ;
    skos:definition """Sector describes the area of application or domain that indicates or
restricts scope for interpretation and application of purpose e.g.
Agriculture, Banking""" ;
    skos:exactMatch dpv:Sector,
        dpv_upstream:Sector,
        dpv_owl:Sector ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """There are various sector codes used commonly to indicate the domain of
an organisation or business. Examples include NACE (EU), ISIC (UN), SIC
and NAICS (USA).""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:SecurityAssessment a owl:Class ;
    rdfs:label "SecurityAssessment" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RiskAssessment ;
    skos:altLabel "Security Assessment" ;
    skos:definition """Assessment of security intended to identify gaps, vulnerabilities,
risks, and effectiveness of controls""" ;
    skos:exactMatch dpv:SecurityAssessment,
        dpv_upstream:SecurityAssessment,
        dpv_owl:SecurityAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-classes" .

dpv:SecurityIncidentNotice a owl:Class ;
    rdfs:label "SecurityIncidentNotice" ;
    rdfs:subClassOf dpv:Notice,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Security Incident Notice" ;
    skos:definition "A notice providing information about security incident(s)" ;
    skos:exactMatch dpv:SecurityIncidentNotice,
        dpv_upstream:SecurityIncidentNotice,
        dpv_owl:SecurityIncidentNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes, organisational-measures-classes" .

dpv:SecurityIncidentNotification a owl:Class ;
    rdfs:label "SecurityIncidentNotification" ;
    rdfs:subClassOf dpv:Notification,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Security Incident Notification" ;
    skos:definition "Notification of information about security incident(s)" ;
    skos:exactMatch dpv:SecurityIncidentNotification,
        dpv_upstream:SecurityIncidentNotification,
        dpv_owl:SecurityIncidentNotification ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SensitivePersonalData a owl:Class ;
    rdfs:label "SensitivePersonalData" ;
    rdfs:subClassOf dpv:PersonalData,
        dpv:SensitiveData ;
    skos:altLabel "Sensitive Personal Data" ;
    skos:definition """Personal data that is considered 'sensitive' in terms of privacy and/or
impact, and therefore requires additional considerations and/or
protection""" ;
    skos:exactMatch dpv:SensitivePersonalData,
        dpv_upstream:SensitivePersonalData,
        dpv_owl:SensitivePersonalData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Sensitivity' is a matter of context, and may be defined within legal
frameworks. For GDPR, Special categories of personal data are considered
a subset of sensitive data. To illustrate the difference between the
two, consider the situation where Location data is collected, and which
is considered 'sensitive' but not 'special'. As a probable rule,
sensitive data require additional considerations whereas special
category data requires additional legal basis / justifications.""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:ServiceMonitoring a owl:Class ;
    rdfs:label "ServiceMonitoring" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceManagement ;
    skos:altLabel "Service Monitoring" ;
    skos:definition """Purposes associated with the monitoring of services or products to
understand their performance and utilisation with a view to inform their
management""" ;
    skos:exactMatch dpv:ServiceMonitoring,
        dpv_upstream:ServiceMonitoring,
        dpv_owl:ServiceMonitoring ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Structure a owl:Class ;
    rdfs:label "Structure" ;
    rdfs:subClassOf dpv:Organise,
        dpv:Processing ;
    skos:altLabel "Structure" ;
    skos:definition "to arrange data according to a structure" ;
    skos:exactMatch dpv:Structure,
        dpv_upstream:Structure,
        dpv_owl:Structure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:TargetedAdvertising a owl:Class ;
    rdfs:label "TargetedAdvertising" ;
    rdfs:subClassOf dpv:PersonalisedAdvertising,
        dpv:Purpose ;
    skos:altLabel "Targeted Advertising" ;
    skos:definition """Purposes associated with creating and providing personalised
advertisement where the personalisation is targeted to a specific
individual or group of individuals""" ;
    skos:exactMatch dpv:TargetedAdvertising,
        dpv_upstream:TargetedAdvertising,
        dpv_owl:TargetedAdvertising ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Technology a owl:Class ;
    rdfs:label "Technology" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Technology" ;
    skos:definition """The technology, technological implementation, or any techniques, skills,
methods, and processes used or applied""" ;
    skos:exactMatch dpv:Technology,
        dpv_upstream:Technology,
        dpv_owl:Technology ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Examples (non-exhaustive) include: Algorithm, Process, Method, Skill,
Database, Cookies, Server, Device""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ThirdPartyContract a owl:Class ;
    rdfs:label "ThirdPartyContract" ;
    rdfs:subClassOf dpv:DataProcessingAgreement,
        dpv:LegalBasis ;
    skos:altLabel "Third Party Contract" ;
    skos:definition """Creation, completion, fulfilment, or performance of a contract, with the
Data Controller and Third Party as parties, and involving specified
processing of data or technologies. NOTE: This concept is being
deprecated - use dpv:ThirdPartyAgreement which has a more explicit
definition of the entities involved and the intent of the contract""" ;
    skos:exactMatch dpv:ThirdPartyContract,
        dpv_upstream:ThirdPartyContract,
        dpv_owl:ThirdPartyContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:Unintended a owl:Class ;
    rdfs:label "Unintended" ;
    rdfs:subClassOf dpv:IntentionStatus ;
    skos:altLabel "Unintended" ;
    skos:definition "Status indicating the specified context was unintended i.e. not intended" ;
    skos:exactMatch dpv:Unintended,
        dpv_upstream:Unintended,
        dpv_owl:Unintended ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:VitalInterest a owl:Class ;
    rdfs:label "VitalInterest" ;
    rdfs:subClassOf dpv:LegalBasis ;
    skos:altLabel "Vital Interest" ;
    skos:definition """Activities are necessary or required to protect vital interests of a
data subject or other natural person""" ;
    skos:exactMatch dpv:VitalInterest,
        dpv_upstream:VitalInterest,
        dpv_owl:VitalInterest ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:VitalInterestOfNaturalPerson a owl:Class ;
    rdfs:label "VitalInterestOfNaturalPerson" ;
    rdfs:subClassOf dpv:LegalBasis,
        dpv:VitalInterest ;
    skos:altLabel "Vital Interest of Natural Person" ;
    skos:definition """Activities are necessary or required to protect vital interests of a
natural person""" ;
    skos:exactMatch dpv:VitalInterestOfNaturalPerson,
        dpv_upstream:VitalInterestOfNaturalPerson,
        dpv_owl:VitalInterestOfNaturalPerson ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:WithdrawConsent a owl:Class ;
    rdfs:label "WithdrawConsent" ;
    rdfs:subClassOf dpv:ConsentControl,
        dpv:WithdrawingFromProcess ;
    skos:altLabel "Withdraw Consent" ;
    skos:definition "Control for withdrawing consent" ;
    skos:exactMatch dpv:WithdrawConsent,
        dpv_upstream:WithdrawConsent,
        dpv_owl:WithdrawConsent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Indicates how the data subject can withdraw consent e.g. used with
dpv:isExercisedAt""" ;
    dpv:skos_in_scheme "consent-controls-classes" .

dpv:WithdrawingFromProcess a owl:Class ;
    rdfs:label "WithdrawingFromProcess" ;
    rdfs:subClassOf dpv:EntityPermissiveInvolvement ;
    skos:altLabel "Withdrawing from Process" ;
    skos:definition """Involvement where entity can withdraw a previously given assent from
specified context""" ;
    skos:exactMatch dpv:WithdrawingFromProcess,
        dpv_upstream:WithdrawingFromProcess,
        dpv_owl:WithdrawingFromProcess ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:has_assessment a owl:DatatypeProperty ;
    rdfs:label "has_assessment" ;
    rdfs:subPropertyOf dpv:has_organisational_measure ;
    skos:altLabel "has assessment" ;
    skos:definition "Indicates a relevant assessment associated with the specific context" ;
    skos:exactMatch dpv_upstream:hasAssessment,
        dpv_owl:hasAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "TOM-properties" .

dpv:AccessControlMethod a owl:Class ;
    rdfs:label "AccessControlMethod" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Access Control Method" ;
    skos:definition "Methods which restrict access to a place or resource" ;
    skos:exactMatch dpv:AccessControlMethod,
        dpv_upstream:AccessControlMethod,
        dpv_owl:AccessControlMethod ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:Alter a owl:Class ;
    rdfs:label "Alter" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Transform ;
    skos:altLabel "Alter" ;
    skos:definition "to change the data without changing it into something else" ;
    skos:exactMatch dpv:Alter,
        dpv_upstream:Alter,
        dpv_owl:Alter ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:AuthorisationProcedure a owl:Class ;
    rdfs:label "AuthorisationProcedure" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:SecurityProcedure ;
    skos:altLabel "Authorisation Procedure" ;
    skos:definition "Procedures for determining authorisation through permission or authority" ;
    skos:exactMatch dpv:AuthorisationProcedure,
        dpv_upstream:AuthorisationProcedure,
        dpv_owl:AuthorisationProcedure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """non-technical authorisation procedures: How is it described on an
organisational level, who gets access to the data""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:CertificationSeal a owl:Class ;
    rdfs:label "CertificationSeal" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Certification and Seal" ;
    skos:definition """Certifications, seals, and marks indicating compliance to regulations or
practices""" ;
    skos:exactMatch dpv:CertificationSeal,
        dpv_upstream:CertificationSeal,
        dpv_owl:CertificationSeal ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:CollectedPersonalData a owl:Class ;
    rdfs:label "CollectedPersonalData" ;
    rdfs:subClassOf dpv:CollectedData,
        dpv:PersonalData ;
    skos:altLabel "Collected Personal Data" ;
    skos:definition """Personal Data that has been collected from another source such as the
Data Subject""" ;
    skos:exactMatch dpv:CollectedPersonalData,
        dpv_upstream:CollectedPersonalData,
        dpv_owl:CollectedPersonalData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """To indicate the source of data, use the DataSource concept with the
hasDataSource relation""" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:ConformanceStatus a owl:Class ;
    rdfs:label "ConformanceStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Conformance Status" ;
    skos:definition """Status associated with conformance to a standard, guideline, code, or
recommendation""" ;
    skos:exactMatch dpv:ConformanceStatus,
        dpv_upstream:ConformanceStatus,
        dpv_owl:ConformanceStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:Consent a owl:Class ;
    rdfs:label "Consent" ;
    rdfs:subClassOf dpv:LegalBasis ;
    skos:altLabel "Consent" ;
    skos:definition "Consent of the Data Subject for specified process or activity" ;
    skos:exactMatch dpv:Consent,
        dpv_upstream:Consent,
        dpv_owl:Consent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:ConsentStatusValidForProcessing a owl:Class ;
    rdfs:label "ConsentStatusValidForProcessing" ;
    rdfs:subClassOf dpv:ConsentStatus ;
    skos:altLabel "Consent Status Valid for Processing" ;
    skos:definition """States of consent that can be used as valid justifications for
processing data""" ;
    skos:exactMatch dpv:ConsentStatusValidForProcessing,
        dpv_upstream:ConsentStatusValidForProcessing,
        dpv_owl:ConsentStatusValidForProcessing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Practically, given consent is the only valid state for processing" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:Consult a owl:Class ;
    rdfs:label "Consult" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Use ;
    skos:altLabel "Consult" ;
    skos:definition "to consult or query data" ;
    skos:exactMatch dpv:Consult,
        dpv_upstream:Consult,
        dpv_owl:Consult ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpr:Query ;
    dpv:skos_in_scheme "processing-classes" .

dpv:ContractActivationStatus a owl:Class ;
    rdfs:label "ContractActivationStatus" ;
    rdfs:subClassOf dpv:ContractStatus ;
    skos:altLabel "Contract Activation Status" ;
    skos:definition """Status associated with activation of a contract i.e. whether its terms
are active and are required to be performed""" ;
    skos:exactMatch dpv:ContractActivationStatus,
        dpv_upstream:ContractActivationStatus,
        dpv_owl:ContractActivationStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractByNegotiationType a owl:Class ;
    rdfs:label "ContractByNegotiationType" ;
    rdfs:subClassOf dpv:Contract,
        dpv:LegalBasis ;
    skos:altLabel "Contract by Negotiation Type" ;
    skos:definition """A generic concept representing contracts categorised based on their use
or absence of negotiation in the contract forming process""" ;
    skos:exactMatch dpv:ContractByNegotiationType,
        dpv_upstream:ContractByNegotiationType,
        dpv_owl:ContractByNegotiationType ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:DataInteroperabilityManagement a owl:Class ;
    rdfs:label "DataInteroperabilityManagement" ;
    rdfs:subClassOf dpv:DataGovernance,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Interoperability Management" ;
    skos:definition "Measures associated with management of data interoperability" ;
    skos:exactMatch dpv:DataInteroperabilityManagement,
        dpv_upstream:DataInteroperabilityManagement,
        dpv_owl:DataInteroperabilityManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataQualityManagement a owl:Class ;
    rdfs:label "DataQualityManagement" ;
    rdfs:subClassOf dpv:DataGovernance,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Quality Management" ;
    skos:definition "Measures associated with management of data quality" ;
    skos:exactMatch dpv:DataQualityManagement,
        dpv_upstream:DataQualityManagement,
        dpv_owl:DataQualityManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataSanitisationTechnique a owl:Class ;
    rdfs:label "DataSanitisationTechnique" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Data Sanitisation Technique" ;
    skos:definition """Cleaning or any removal or re-organisation of elements in data based on
selective criteria""" ;
    skos:exactMatch dpv:DataSanitisationTechnique,
        dpv_upstream:DataSanitisationTechnique,
        dpv_owl:DataSanitisationTechnique ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:Deidentification a owl:Class ;
    rdfs:label "Deidentification" ;
    rdfs:subClassOf dpv:DataSanitisationTechnique,
        dpv:TechnicalMeasure ;
    skos:altLabel "De-Identification" ;
    skos:definition "Removal of identity or information to reduce identifiability" ;
    skos:exactMatch dpv:Deidentification,
        dpv_upstream:Deidentification,
        dpv_owl:Deidentification ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:DerivedData a owl:Class ;
    rdfs:label "DerivedData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Derived Data" ;
    skos:definition "Data that has been obtained through derivations of other data" ;
    skos:exactMatch dpv:DerivedData,
        dpv_upstream:DerivedData,
        dpv_owl:DerivedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:DigitalLiteracy a owl:Class ;
    rdfs:label "DigitalLiteracy" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Digital Literacy" ;
    skos:definition """Providing skills, knowledge, and understanding to enable reading,
writing, analysing, reasoning, and communicating regarding digital
technologies and their implications""" ;
    skos:exactMatch dpv:DigitalLiteracy,
        dpv_upstream:DigitalLiteracy,
        dpv_owl:DigitalLiteracy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:EvaluationScoring a owl:Class ;
    rdfs:label "EvaluationScoring" ;
    rdfs:subClassOf dpv:ProcessingContext ;
    skos:altLabel "Evaluation and Scoring" ;
    skos:definition "Processing that involves evaluation and scoring of individuals" ;
    skos:exactMatch dpv:EvaluationScoring,
        dpv_upstream:EvaluationScoring,
        dpv_owl:EvaluationScoring ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:FeeRequirement a owl:Class ;
    rdfs:label "FeeRequirement" ;
    rdfs:subClassOf dpv:Context ;
    skos:altLabel "Fee Requirement" ;
    skos:definition "Concept indicating whether a fee is required" ;
    skos:exactMatch dpv:FeeRequirement,
        dpv_upstream:FeeRequirement,
        dpv_owl:FeeRequirement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:FixedLocation a owl:Class ;
    rdfs:label "FixedLocation" ;
    rdfs:subClassOf dpv:LocationFixture ;
    skos:altLabel "Fixed Location" ;
    skos:definition "Location that is fixed i.e. known to occur at a specific place" ;
    skos:exactMatch dpv:FixedLocation,
        dpv_upstream:FixedLocation,
        dpv_owl:FixedLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:FraudPreventionAndDetection a owl:Class ;
    rdfs:label "FraudPreventionAndDetection" ;
    rdfs:subClassOf dpv:MisusePreventionAndDetection,
        dpv:Purpose ;
    skos:altLabel "Fraud Prevention and Detection" ;
    skos:definition "Purposes associated with fraud detection, prevention, and mitigation" ;
    skos:exactMatch dpv:FraudPreventionAndDetection,
        dpv_upstream:FraudPreventionAndDetection,
        dpv_owl:FraudPreventionAndDetection ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpu:Government ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:HybridPublicPrivateSpace a owl:Class ;
    rdfs:label "HybridPublicPrivateSpace" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:PrivateSpace,
        dpv:PublicSpace ;
    skos:altLabel "Hybrid Public Private Space" ;
    skos:definition """A space that is a hybrid space i.e it has both public and private
components - such as by having part of it be a private space or which is
operated privately""" ;
    skos:exactMatch dpv:HybridPublicPrivateSpace,
        dpv_upstream:HybridPublicPrivateSpace,
        dpv_owl:HybridPublicPrivateSpace ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:Importance a owl:Class ;
    rdfs:label "Importance" ;
    rdfs:subClassOf dpv:Context ;
    skos:altLabel "Importance" ;
    skos:definition "An indication of 'importance' within a context" ;
    skos:exactMatch dpv:Importance,
        dpv_upstream:Importance,
        dpv_owl:Importance ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Importance can be used to express importance, desirability, relevance,
or significance as a context.""" ;
    dpv:skos_in_scheme "context-classes" .

dpv:InformedConsent a owl:Class ;
    rdfs:label "InformedConsent" ;
    rdfs:subClassOf dpv:Consent,
        dpv:LegalBasis ;
    skos:altLabel "Informed Consent" ;
    skos:closeMatch iso29100:ConsentMechanism ;
    skos:definition """Consent that is informed i.e. with the requirement to provide sufficient
information to make a consenting decision""" ;
    skos:exactMatch dpv:InformedConsent,
        dpv_upstream:InformedConsent,
        dpv_owl:InformedConsent,
        iso29100:Consent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The specifics for what information should be provided or made available
will depend on the context, use-case, or relevant legal requirements""" ;
    dpv:skos_in_scheme "consent-types-classes" .

dpv:InnovativeUseOfTechnology a owl:Class ;
    rdfs:label "InnovativeUseOfTechnology" ;
    rdfs:subClassOf dpv:ProcessingContext ;
    skos:altLabel "Innovative use of Technology" ;
    skos:definition "Indicates that technology is being used in an innovative manner" ;
    skos:exactMatch dpv:InnovativeUseOfTechnology,
        dpv_upstream:InnovativeUseOfTechnology,
        dpv_owl:InnovativeUseOfTechnology ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Innovative here refers to 'state of the art' rather than the
implementing entity, and can be for either new technology or new uses of
existing technology""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:IntentionStatus a owl:Class ;
    rdfs:label "IntentionStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Intention Status" ;
    skos:definition """Status indicating whether the specified context was intended or
unintended""" ;
    skos:exactMatch dpv:IntentionStatus,
        dpv_upstream:IntentionStatus,
        dpv_owl:IntentionStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Intention is associated with the goal or purpose for what is about to
happen i.e. an ex-ante indication of whether the specified context
is/was planned or intended. Intention and Expectation are closely
related terms. We recommend using Intention when the entity has the
ability to control the implementation and Expectation for when the
entity does not have control or for what happens after or beyond the
exercise of control.""" ;
    dpv:skos_in_scheme "status-classes" .

dpv:LocationLocality a owl:Class ;
    rdfs:label "LocationLocality" ;
    rdfs:subClassOf dpv:DpvLocation ;
    skos:altLabel "Location Locality" ;
    skos:definition """Locality refers to whether the specified location is local within some
context, e.g. for the user""" ;
    skos:exactMatch dpv:LocationLocality,
        dpv_upstream:LocationLocality,
        dpv_owl:LocationLocality ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:ProvidePersonalisedRecommendations a owl:Class ;
    rdfs:label "ProvidePersonalisedRecommendations" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServicePersonalisation ;
    skos:altLabel "Provide Personalised Recommendations" ;
    skos:definition """Purposes associated with creating and providing personalised
recommendations""" ;
    skos:exactMatch dpv:ProvidePersonalisedRecommendations,
        dpv_upstream:ProvidePersonalisedRecommendations,
        dpv_owl:ProvidePersonalisedRecommendations ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RecruitmentApplicationManagement a owl:Class ;
    rdfs:label "RecruitmentApplicationManagement" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentManagement ;
    skos:altLabel "Recruitment Application Management" ;
    skos:definition "Purposes associated with managing job applications for recruitment" ;
    skos:exactMatch dpv:RecruitmentApplicationManagement,
        dpv_upstream:RecruitmentApplicationManagement,
        dpv_owl:RecruitmentApplicationManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RightExerciseNotice a owl:Class ;
    rdfs:label "RightExerciseNotice" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RightNotice ;
    skos:altLabel "Right Exercise Notice" ;
    skos:definition """Information associated with exercising of an active right such as where
and how to exercise the right, information required for it, or updates
on an exercised rights request""" ;
    skos:exactMatch dpv:RightExerciseNotice,
        dpv_upstream:RightExerciseNotice,
        dpv_owl:RightExerciseNotice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept is intended for providing information regarding a right
exercise. For specific instances of such exercises, see
RightExerciseActivity and RightExerciseRecord.""" ;
    dpv:skos_in_scheme "rights-classes" .

dpv:RiskAssessment a owl:Class ;
    rdfs:label "RiskAssessment" ;
    rdfs:subClassOf dpv:Assessment,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Risk Assessment" ;
    skos:closeMatch iso27001:RiskAssessment,
        iso42001:AIRiskAssessment ;
    skos:definition "Assessment involving identification, analysis, and evaluation of risk" ;
    skos:exactMatch dpv:RiskAssessment,
        dpv_upstream:RiskAssessment,
        dpv_owl:RiskAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch nist_ai_rmf:Function,
        nist_csf_v2:CSFCategory ;
    dpv:skos_in_scheme "risk-classes" .

dpv:RuleViolated a owl:Class ;
    rdfs:label "RuleViolated" ;
    rdfs:subClassOf dpv:RuleFulfilmentStatus ;
    skos:altLabel "Rule Violated" ;
    skos:definition """Status indicating a rule has been violated, breached, broken, or
infracted""" ;
    skos:exactMatch dpv:RuleViolated,
        dpv_upstream:RuleViolated,
        dpv_owl:RuleViolated ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

dpv:Safeguard a owl:Class ;
    rdfs:label "Safeguard" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Safeguard" ;
    skos:definition """A safeguard is a precautionary measure for the protection against or
mitigation of negative effects""" ;
    skos:exactMatch dpv:Safeguard,
        dpv_upstream:Safeguard,
        dpv_owl:Safeguard ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept is relevant given the requirement to assert safeguards in
cross-border data transfers""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SensitiveData a owl:Class ;
    rdfs:label "SensitiveData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Sensitive Data" ;
    skos:definition "Data deemed sensitive" ;
    skos:exactMatch dpv:SensitiveData,
        dpv_upstream:SensitiveData,
        dpv_owl:SensitiveData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:ServiceOptimisation a owl:Class ;
    rdfs:label "ServiceOptimisation" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceManagement ;
    skos:altLabel "Service Optimisation" ;
    skos:definition "Purposes associated with optimisation of services or activities" ;
    skos:exactMatch dpv:ServiceOptimisation,
        dpv_upstream:ServiceOptimisation,
        dpv_owl:ServiceOptimisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Subclass of ServiceProvision since optimisation is usually considered
part of providing services""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Severity a owl:Class ;
    rdfs:label "Severity" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Severity" ;
    skos:definition """The magnitude of being unwanted or having negative effects such as
harmful impacts""" ;
    skos:exactMatch dpv:Severity,
        dpv_upstream:Severity,
        dpv_owl:Severity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Severity can be associated with Risk, or its Consequences and Impacts" ;
    dpv:skos_in_scheme "risk-classes" .

dpv:StandardFormContract a owl:Class ;
    rdfs:label "StandardFormContract" ;
    rdfs:subClassOf dpv:ContractByNegotiationType,
        dpv:LegalBasis ;
    skos:altLabel "Standard Form Contract" ;
    skos:definition """A contract where the terms and conditions are determined by one or more
of the parties, and the other parties have negligible or no ability to
negotiate the terms and conditions""" ;
    skos:exactMatch dpv:StandardFormContract,
        dpv_upstream:StandardFormContract,
        dpv_owl:StandardFormContract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Such a contract results in the unempowered parties being in a "take it
or leave it" position as they can only accept or reject the contract.
Standard form contracts are also known as "Adhesion contract" or
"Boilerplate contract\"""" ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:Tracking a owl:Class ;
    rdfs:label "Tracking" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Use ;
    skos:altLabel "Tracking" ;
    skos:definition """to use data to track a specific factor (e.g. a human or their
activities) across multiple distinct contexts""" ;
    skos:exactMatch dpv:Tracking,
        dpv_upstream:Tracking,
        dpv_owl:Tracking ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Tracking is a widely used (and abused) concept and therefore carries
several distinct interpretations, for example see Do Not Track which
defines tracking in the context of the web, and where other forms of
tracking such as location tracking or physical biometric tracking may
exist which are defined differently. For this concept, DPVCG defines
Tracking in the broadest possible sense and strongly recommends adopters
to provide their specific definition or interpretation by either
extending this concept, through a usage note, or by contributing the
specific term back to DPVCG for inclusion in DPV or an extension. This
concept may change in the future based on developments in privacy and
legal spaces. In DPV, Tracking is defined as a type of processing
operation that may collect and/or may use data - which covers both
initial collection and usage as well as subsequent use of existing data
to track an individual. The classification of Tracking as a processing
operation also implies that it is not sufficient as a Purpose on its own
and therefore a suitable purpose from the DPV taxonomy should be used to
justify it.""" ;
    dpv:skos_in_scheme "processing-classes" .

dpv:Transfer a owl:Class ;
    rdfs:label "Transfer" ;
    rdfs:subClassOf dpv:Processing ;
    skos:altLabel "Transfer" ;
    skos:definition "to move data from one place to another" ;
    skos:exactMatch dpv:Transfer,
        dpv_upstream:Transfer,
        dpv_owl:Transfer ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch svpr:Transfer ;
    dpv:skos_in_scheme "processing-classes" .

dpv:UnacceptableRule a owl:Class ;
    rdfs:label "UnacceptableRule" ;
    rdfs:subClassOf dpv:Rule ;
    skos:altLabel "Unacceptable Rule" ;
    skos:definition "A rule that is unacceptable where it is not desirable if it occurs" ;
    skos:exactMatch dpv:UnacceptableRule,
        dpv_upstream:UnacceptableRule,
        dpv_owl:UnacceptableRule ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Unacceptable is a subjective concept that enables specifying something
is to be avoided as compared to "acceptable". By itself it does not
signal any deterrence or prohibition - for which further specific
concepts are defined""" ;
    dpv:skos_in_scheme "rules-classes" .

dpv:Verification a owl:Class ;
    rdfs:label "Verification" ;
    rdfs:subClassOf dpv:EnforceSecurity,
        dpv:Purpose ;
    skos:altLabel "Verification" ;
    skos:definition """Purposes association with verification e.g. information, identity,
integrity""" ;
    skos:exactMatch dpv:Verification,
        dpv_upstream:Verification,
        dpv_owl:Verification ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:VulnerableDataSubject a owl:Class ;
    rdfs:label "VulnerableDataSubject" ;
    rdfs:subClassOf dpv:HumanSubject,
        dpv:VulnerableHuman ;
    skos:altLabel "Vulnerable Data Subject" ;
    skos:definition """Humans which should be considered 'vulnerable' and therefore would
require additional measures and safeguards""" ;
    skos:exactMatch dpv:VulnerableDataSubject,
        dpv_upstream:VulnerableDataSubject,
        dpv_owl:VulnerableDataSubject ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept denotes a Data Subject or a group are vulnerable, but not
what vulnerability they possess or its context. This information can be
provided additionally as comments, or as separate concepts and
relations. Proposals for this are welcome.""" ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:has_data a owl:DatatypeProperty ;
    rdfs:label "has_data" ;
    skos:altLabel "has data" ;
    skos:definition "Indicates associated with Data (may or may not be personal)" ;
    skos:exactMatch dpv_upstream:hasData,
        dpv_owl:hasData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-properties" .

dpv:has_location a owl:DatatypeProperty ;
    rdfs:label "has_location" ;
    skos:altLabel "has location" ;
    skos:definition "Indicates information about location" ;
    skos:exactMatch dpv_upstream:hasLocation,
        dpv_owl:hasLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-properties" .

dpv:id a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition """Stable identifier for the instance. Typically a CURIE or IRI naming the
RDF subject this LinkML instance corresponds to.""" ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> .

dpv:AcceptableRule a owl:Class ;
    rdfs:label "AcceptableRule" ;
    rdfs:subClassOf dpv:Rule ;
    skos:altLabel "Acceptable Rule" ;
    skos:definition """A rule that is acceptable where it is either desirable if it occurs or
it is not unacceptable if it does""" ;
    skos:exactMatch dpv:AcceptableRule,
        dpv_upstream:AcceptableRule,
        dpv_owl:AcceptableRule ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Acceptable is a subjective concept that enables distinguishing with
"unacceptable". By itself it does not signal any permission or
obligation - for which further specific concepts are defined""" ;
    dpv:skos_in_scheme "rules-classes" .

dpv:Advertising a owl:Class ;
    rdfs:label "Advertising" ;
    rdfs:subClassOf dpv:Marketing,
        dpv:Purpose ;
    skos:altLabel "Advertising" ;
    skos:definition """Purposes associated with conducting advertising i.e. process or artefact
used to call attention to a product, service, etc. through
announcements, notices, or other forms of communication""" ;
    skos:exactMatch dpv:Advertising,
        dpv_upstream:Advertising,
        dpv_owl:Advertising ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Advertising is a subset of Marketing. Advertising by itself does not
indicate 'personalisation' i.e. personalised ads.""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Applicability a owl:Class ;
    rdfs:label "Applicability" ;
    rdfs:subClassOf dpv:Context ;
    skos:altLabel "Applicability" ;
    skos:definition """Concept provided to represent indication of cases where the information
or context is not applicable (N/A) or not available or this is not known
or determined yet. If the information is applicable and available, this
concept should not be used.""" ;
    skos:exactMatch dpv:Applicability,
        dpv_upstream:Applicability,
        dpv_owl:Applicability ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """These concepts are useful in closed-world interpretations, for example
in forms where a field must have a value to explicitly denote it is not
applicable or the information is not available yet.""" ;
    dpv:skos_in_scheme "context-classes" .

dpv:Audit a owl:Class ;
    rdfs:label "Audit" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Audit" ;
    skos:closeMatch iso27001:InternalAudit,
        iso42001:InternalAudit ;
    skos:definition """An audit is a systematic examination or evaluation of records,
processes, or systems towards a specific objective such as to assess
accuracy, compliance, effectiveness, or performance""" ;
    skos:exactMatch dpv:Audit,
        dpv_upstream:Audit,
        dpv_owl:Audit ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:CollectedData a owl:Class ;
    rdfs:label "CollectedData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Collected Data" ;
    skos:definition "Data that has been obtained by collecting it from a source" ;
    skos:exactMatch dpv:CollectedData,
        dpv_upstream:CollectedData,
        dpv_owl:CollectedData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:Consultation a owl:Class ;
    rdfs:label "Consultation" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Consultation" ;
    skos:definition """Consultation is a process of receiving feedback, advice, or opinion from
an external agency""" ;
    skos:exactMatch dpv:Consultation,
        dpv_upstream:Consultation,
        dpv_owl:Consultation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataProcessingRecord a owl:Class ;
    rdfs:label "DataProcessingRecord" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RecordsOfActivities ;
    skos:altLabel "Data Processing Record" ;
    skos:definition "Record of data processing, whether ex-ante or ex-post" ;
    skos:exactMatch dpv:DataProcessingRecord,
        dpv_upstream:DataProcessingRecord,
        dpv_owl:DataProcessingRecord ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DpvAuthority a owl:Class ;
    rdfs:label "DpvAuthority" ;
    rdfs:subClassOf dpv:GovernmentalOrganisation ;
    skos:altLabel "Authority" ;
    skos:definition """An authority with the power to create or enforce laws, or determine
their compliance.""" ;
    skos:exactMatch dpv:Authority,
        dpv_upstream:Authority,
        dpv_owl:Authority ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-authority-classes" .

dpv:DpvJurisdiction a owl:Class ;
    rdfs:label "DpvJurisdiction" ;
    rdfs:subClassOf dpv:DpvLocation ;
    skos:altLabel "Jurisdiction" ;
    skos:definition """A jurisdiction represents the locations that define the extent of
authority (or control) claimed, granted, or asserted by a legal entity
(in particular a legal authority) to govern or enforce rules""" ;
    skos:exactMatch dpv:Jurisdiction,
        dpv_upstream:Jurisdiction,
        dpv_owl:Jurisdiction ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:EmergencyServiceProvider a owl:Class ;
    rdfs:label "EmergencyServiceProvider" ;
    rdfs:subClassOf dpv:DpvOrganisation ;
    skos:altLabel "Emergency Service Provider" ;
    skos:definition """An organisation tasked with providing emergency services such as by
responding rapidly to urgent situations to protect lives, property, and
the environment""" ;
    skos:exactMatch dpv:EmergencyServiceProvider,
        dpv_upstream:EmergencyServiceProvider,
        dpv_owl:EmergencyServiceProvider ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:ExpectationStatus a owl:Class ;
    rdfs:label "ExpectationStatus" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Expectation Status" ;
    skos:definition """Status indicating whether the specified context was intended or
unintended""" ;
    skos:exactMatch dpv:ExpectationStatus,
        dpv_upstream:ExpectationStatus,
        dpv_owl:ExpectationStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Expectation is associated with the outcome of a goal or purpose for what
is expected to happen i.e. an ex-post indication of what was expected to
happen in the specified context. Intention and Expectation are closely
related terms. We recommend using Intention when the entity has the
ability to control the implementation and Expectation for when the
entity does not have control or for what happens after or beyond the
exercise of control.""" ;
    dpv:skos_in_scheme "status-classes" .

dpv:FulfilmentOfObligation a owl:Class ;
    rdfs:label "FulfilmentOfObligation" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Fulfilment of Obligation" ;
    skos:definition """Purposes associated with carrying out data processing to fulfill an
obligation""" ;
    skos:exactMatch dpv:FulfilmentOfObligation,
        dpv_upstream:FulfilmentOfObligation,
        dpv_owl:FulfilmentOfObligation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:InvolvementStatus a owl:Class ;
    rdfs:label "InvolvementStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Involvement Status" ;
    skos:definition "Status indicating whether the involvement of specified context" ;
    skos:exactMatch dpv:InvolvementStatus,
        dpv_upstream:InvolvementStatus,
        dpv_owl:InvolvementStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:Lawfulness a owl:Class ;
    rdfs:label "Lawfulness" ;
    rdfs:subClassOf dpv:ComplianceStatus ;
    skos:altLabel "Lawfulness" ;
    skos:definition "Status associated with expressing lawfulness or legal compliance" ;
    skos:exactMatch dpv:Lawfulness,
        dpv_upstream:Lawfulness,
        dpv_owl:Lawfulness ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:LegalAgreement a owl:Class ;
    rdfs:label "LegalAgreement" ;
    rdfs:subClassOf dpv:LegalMeasure ;
    skos:altLabel "Legal Agreement" ;
    skos:definition "A legally binding agreement" ;
    skos:exactMatch dpv:LegalAgreement,
        dpv_upstream:LegalAgreement,
        dpv_owl:LegalAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-measures-classes" .

dpv:LegalObligationStatus a owl:Class ;
    rdfs:label "LegalObligationStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Legal ObligationStatus" ;
    skos:definition "Status associated with use of Legal Obligation as a legal basis" ;
    skos:exactMatch dpv:LegalObligationStatus,
        dpv_upstream:LegalObligationStatus,
        dpv_owl:LegalObligationStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:LegitimateInterest a owl:Class ;
    rdfs:label "LegitimateInterest" ;
    rdfs:subClassOf dpv:LegalBasis ;
    skos:altLabel "Legitimate Interest" ;
    skos:definition """Legitimate Interests of a Party as justification for specified
activities""" ;
    skos:exactMatch dpv:LegitimateInterest,
        dpv_upstream:LegitimateInterest,
        dpv_owl:LegitimateInterest ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:LocalLocation a owl:Class ;
    rdfs:label "LocalLocation" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:LocationLocality ;
    skos:altLabel "Local Location" ;
    skos:definition "Location is local" ;
    skos:exactMatch dpv:LocalLocation,
        dpv_upstream:LocalLocation,
        dpv_owl:LocalLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:Necessity a owl:Class ;
    rdfs:label "Necessity" ;
    rdfs:subClassOf dpv:Context ;
    skos:altLabel "Necessity" ;
    skos:definition "An indication of 'necessity' within a context" ;
    skos:exactMatch dpv:Necessity,
        dpv_upstream:Necessity,
        dpv_owl:Necessity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Necessity can be used to express need, essentiality, requirement, or
compulsion.""" ;
    dpv:skos_in_scheme "context-classes" .

dpv:OfficialAuthorityExerciseStatus a owl:Class ;
    rdfs:label "OfficialAuthorityExerciseStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Official Authority Exercise Status" ;
    skos:definition "Status associated with use of Official Authority as a legal basis" ;
    skos:exactMatch dpv:OfficialAuthorityExerciseStatus,
        dpv_upstream:OfficialAuthorityExerciseStatus,
        dpv_owl:OfficialAuthorityExerciseStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:Personalisation a owl:Class ;
    rdfs:label "Personalisation" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Personalisation" ;
    skos:definition """Purposes associated with creating and providing customisation based on
attributes and/or needs of person(s) or context(s).""" ;
    skos:exactMatch dpv:Personalisation,
        dpv_upstream:Personalisation,
        dpv_owl:Personalisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This term is a blanket purpose category for indicating personalisation
of some other purpose, e.g. by creating a subclass of the other concept
and Personalisation""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:PersonnelHiring a owl:Class ;
    rdfs:label "PersonnelHiring" ;
    rdfs:subClassOf dpv:PersonnelManagement,
        dpv:Purpose ;
    skos:altLabel "Personnel Hiring" ;
    skos:definition """Purposes associated with management and execution of hiring processes of
personnel""" ;
    skos:exactMatch dpv:PersonnelHiring,
        dpv_upstream:PersonnelHiring,
        dpv_owl:PersonnelHiring ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:PersonnelMonitoring a owl:Class ;
    rdfs:label "PersonnelMonitoring" ;
    rdfs:subClassOf dpv:PersonnelManagement,
        dpv:Purpose ;
    skos:altLabel "Personnel Monitoring" ;
    skos:definition "Purposes associated with monitoring of personnel" ;
    skos:exactMatch dpv:PersonnelMonitoring,
        dpv_upstream:PersonnelMonitoring,
        dpv_owl:PersonnelMonitoring ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:PersonnelPerformanceManagement a owl:Class ;
    rdfs:label "PersonnelPerformanceManagement" ;
    rdfs:subClassOf dpv:PersonnelManagement,
        dpv:PersonnelMonitoring,
        dpv:Purpose ;
    skos:altLabel "Personnel Performance Management" ;
    skos:definition "Purposes associated with management of performance of personnel" ;
    skos:exactMatch dpv:PersonnelPerformanceManagement,
        dpv_upstream:PersonnelPerformanceManagement,
        dpv_owl:PersonnelPerformanceManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ProcessingCondition a owl:Class ;
    rdfs:label "ProcessingCondition" ;
    rdfs:subClassOf dpv:ProcessingContext ;
    skos:altLabel "Processing Condition" ;
    skos:definition """Conditions required or followed regarding processing of data or use of
technologies""" ;
    skos:exactMatch dpv:ProcessingCondition,
        dpv_upstream:ProcessingCondition,
        dpv_owl:ProcessingCondition ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ProcessingScale a owl:Class ;
    rdfs:label "ProcessingScale" ;
    rdfs:subClassOf dpv:Scale ;
    skos:altLabel "Processing Scale" ;
    skos:definition "Scale of Processing" ;
    skos:exactMatch dpv:ProcessingScale,
        dpv_upstream:ProcessingScale,
        dpv_owl:ProcessingScale ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The exact definition of what constitutes "scale" depends on use of
jurisdictional, domain-specific, or other forms of externally defined
criteria. Where possible, this should be reflected by extending the
scales provided with the appropriate context.""" ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:PublicSpace a owl:Class ;
    rdfs:label "PublicSpace" ;
    rdfs:subClassOf dpv:DpvLocation ;
    skos:altLabel "Public Space" ;
    skos:definition "Any space that is accessible to the public or is owned by the public" ;
    skos:exactMatch dpv:PublicSpace,
        dpv_upstream:PublicSpace,
        dpv_owl:PublicSpace ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Public space is distinct from places under (public) government ownership
as such places can exclude public from accessing the place e.g.
government military installations or reserved land""" ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:RecruitmentInterviewManagement a owl:Class ;
    rdfs:label "RecruitmentInterviewManagement" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:RecruitmentManagement ;
    skos:altLabel "Recruitment Interview Management" ;
    skos:definition "Purposes associated conducting and managing interviews for recruitment" ;
    skos:exactMatch dpv:RecruitmentInterviewManagement,
        dpv_upstream:RecruitmentInterviewManagement,
        dpv_owl:RecruitmentInterviewManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Remove a owl:Class ;
    rdfs:label "Remove" ;
    rdfs:subClassOf dpv:Processing ;
    skos:altLabel "Remove" ;
    skos:definition "to destruct or erase data" ;
    skos:exactMatch dpv:Remove,
        dpv_upstream:Remove,
        dpv_owl:Remove ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:ReuseCompatibility a owl:Class ;
    rdfs:label "ReuseCompatibility" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "ReuseCompatibility" ;
    skos:definition """Status indicating whether the specified context is compatible with
another earlier context""" ;
    skos:exactMatch dpv:ReuseCompatibility,
        dpv_upstream:ReuseCompatibility,
        dpv_owl:ReuseCompatibility ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Compatibility refers to whether two contexts, such as dpv:Process
instances, are compatible with each other based on a criteria which is
not defined by the concept. This criteria can be based on requirements
from law, such as GDPR's purpose compatibility or can be based on
privacy norms such as contextual integrity. To express such
interpretations, further concepts should be expanded from this base
concept""" ;
    dpv:skos_in_scheme "status-classes" .

dpv:RightsImpactAssessment a owl:Class ;
    rdfs:label "RightsImpactAssessment" ;
    rdfs:subClassOf dpv:ImpactAssessment,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Rights Impact Assessment" ;
    skos:definition """Impact assessment which involves determining the impact on rights and
freedoms""" ;
    skos:exactMatch dpv:RightsImpactAssessment,
        dpv_upstream:RightsImpactAssessment,
        dpv_owl:RightsImpactAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The rights and freedoms may be those defined in law or other norms, and
may be bound to a jurisdiction""" ;
    dpv:skos_in_scheme "risk-classes" .

dpv:RightsManagement a owl:Class ;
    rdfs:label "RightsManagement" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Rights Management" ;
    skos:definition """Methods associated with rights management where 'rights' refer to
controlling who can do what with a resource""" ;
    skos:exactMatch dpv:RightsManagement,
        dpv_upstream:RightsManagement,
        dpv_owl:RightsManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:RiskConcept a owl:Class ;
    rdfs:label "RiskConcept" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Risk Concept" ;
    skos:definition """Parent concept for combining concepts associated with risk assessment
such as actual and potential Risk, Risk Source, Consequences, and
Impacts""" ;
    skos:exactMatch dpv:RiskConcept,
        dpv_upstream:RiskConcept,
        dpv_owl:RiskConcept ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """RiskConcept is a generic concept used for creation of specific
taxonomies in the RISK extension to provide guidance on how a concept
can potentially be a risk, risk source, consequence, and impact. It is
not intended to be used directly and is only created for organisation of
concepts in DPV vocabularies""" ;
    dpv:skos_in_scheme "risk-classes" .

dpv:RuleUnfulfilled a owl:Class ;
    rdfs:label "RuleUnfulfilled" ;
    rdfs:subClassOf dpv:RuleFulfilmentStatus ;
    skos:altLabel "Rule Unfulfilled" ;
    skos:definition "Status indicating a rule has not been fulfilled nor violated" ;
    skos:exactMatch dpv:RuleUnfulfilled,
        dpv_upstream:RuleUnfulfilled,
        dpv_owl:RuleUnfulfilled ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

dpv:SellProducts a owl:Class ;
    rdfs:label "SellProducts" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceProvision ;
    skos:altLabel "Sell Products" ;
    skos:definition "Purposes associated with selling products or services" ;
    skos:exactMatch dpv:SellProducts,
        dpv_upstream:SellProducts,
        dpv_owl:SellProducts ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Sell here means exchange, submit, or provide in return for direct or
indirect compensation.""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ServicePersonalisation a owl:Class ;
    rdfs:label "ServicePersonalisation" ;
    rdfs:subClassOf dpv:Personalisation,
        dpv:Purpose,
        dpv:ServiceManagement ;
    skos:altLabel "Service Personalisation" ;
    skos:definition """Purposes associated with providing personalisation within services or
product or activities""" ;
    skos:exactMatch dpv:ServicePersonalisation,
        dpv_upstream:ServicePersonalisation,
        dpv_owl:ServicePersonalisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Standard a owl:Class ;
    rdfs:label "Standard" ;
    rdfs:subClassOf dpv:GuidelinesPrinciple,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Standard" ;
    skos:definition """A set of requirements or norms that are agreed upon i.e. they are
considered a 'standard'""" ;
    skos:exactMatch dpv:Standard,
        dpv_upstream:Standard,
        dpv_owl:Standard ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """DPV does not restrict the notion of 'standard' to those published by
specific or 'formal' bodies""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:SupportEntityDecisionMaking a owl:Class ;
    rdfs:label "SupportEntityDecisionMaking" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Support Entity Decision Making" ;
    skos:definition "Supporting entities, including individuals, in making decisions" ;
    skos:exactMatch dpv:SupportEntityDecisionMaking,
        dpv_upstream:SupportEntityDecisionMaking,
        dpv_owl:SupportEntityDecisionMaking ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 2.15" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:VendorManagement a owl:Class ;
    rdfs:label "VendorManagement" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Vendor Management" ;
    skos:definition """Purposes associated with manage orders, payment, evaluation, and
prospecting related to vendors""" ;
    skos:exactMatch dpv:VendorManagement,
        dpv_upstream:VendorManagement,
        dpv_owl:VendorManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:has_organisational_measure a owl:DatatypeProperty ;
    rdfs:label "has_organisational_measure" ;
    rdfs:subPropertyOf dpv:has_technical_organisational_measure ;
    skos:altLabel "has organisational measure" ;
    skos:definition "Indicates use or applicability of Organisational measure" ;
    skos:exactMatch dpv_upstream:hasOrganisationalMeasure,
        dpv_owl:hasOrganisationalMeasure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "TOM-properties" .

dpv:has_recipient a owl:DatatypeProperty ;
    rdfs:label "has_recipient" ;
    rdfs:subPropertyOf dpv:has_entity ;
    skos:altLabel "has recipient" ;
    skos:definition "Indicates Recipient of Data" ;
    skos:exactMatch dpv_upstream:hasRecipient,
        dpv_owl:hasRecipient ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Also used to indicate the Recipient of a Right Exercise Activity" ;
    dpv:skos_in_scheme "entities-legalrole-properties, rights-properties" .

dpv:has_scale a owl:DatatypeProperty ;
    rdfs:label "has_scale" ;
    skos:altLabel "has scale" ;
    skos:definition "Indicates the scale of specified concept" ;
    skos:exactMatch dpv_upstream:hasScale,
        dpv_owl:hasScale ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-properties" .

dpv:ConfidentialData a owl:Class ;
    rdfs:label "ConfidentialData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Confidential Data" ;
    skos:definition "Data deemed confidential" ;
    skos:exactMatch dpv:ConfidentialData,
        dpv_upstream:ConfidentialData,
        dpv_owl:ConfidentialData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 5.10" ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:Consequence a owl:Class ;
    rdfs:label "Consequence" ;
    rdfs:subClassOf dpv:RiskConcept ;
    skos:altLabel "Consequence" ;
    skos:definition "The consequence(s) possible or arising from specified context" ;
    skos:exactMatch dpv:Consequence,
        dpv_upstream:Consequence,
        dpv_owl:Consequence ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "risk-classes" .

dpv:ContractByDomain a owl:Class ;
    rdfs:label "ContractByDomain" ;
    rdfs:subClassOf dpv:Contract,
        dpv:LegalBasis ;
    skos:altLabel "Contract by Domain" ;
    skos:definition """A generic concept representing contracts categorised by specific domains
which dictate the drafting and interpretation of contracts""" ;
    skos:exactMatch dpv:ContractByDomain,
        dpv_upstream:ContractByDomain,
        dpv_owl:ContractByDomain ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:ContractExecutionStatus a owl:Class ;
    rdfs:label "ContractExecutionStatus" ;
    rdfs:subClassOf dpv:ContractStatus ;
    skos:altLabel "Contract Execution Status" ;
    skos:definition """Status associated with execution of a contract (i.e. signing and
procedural aspects before the contract terms come in to effect)""" ;
    skos:exactMatch dpv:ContractExecutionStatus,
        dpv_upstream:ContractExecutionStatus,
        dpv_owl:ContractExecutionStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractFulfilmentStatus a owl:Class ;
    rdfs:label "ContractFulfilmentStatus" ;
    rdfs:subClassOf dpv:ContractStatus ;
    skos:altLabel "Contract Fulfilment Status" ;
    skos:definition "Status associated with fulfilment of a contract" ;
    skos:exactMatch dpv:ContractFulfilmentStatus,
        dpv_upstream:ContractFulfilmentStatus,
        dpv_owl:ContractFulfilmentStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractPerformanceStatus a owl:Class ;
    rdfs:label "ContractPerformanceStatus" ;
    rdfs:subClassOf dpv:ContractStatus ;
    skos:altLabel "Contract Performance Status" ;
    skos:definition "Status associated with performance of a contract" ;
    skos:exactMatch dpv:ContractPerformanceStatus,
        dpv_upstream:ContractPerformanceStatus,
        dpv_owl:ContractPerformanceStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractualClauseFulfilmentStatus a owl:Class ;
    rdfs:label "ContractualClauseFulfilmentStatus" ;
    rdfs:subClassOf dpv:ContractStatus ;
    skos:altLabel "Contractual Clause Fulfilment Status" ;
    skos:definition "Status associated with fulfilment of a contractual clause" ;
    skos:exactMatch dpv:ContractualClauseFulfilmentStatus,
        dpv_upstream:ContractualClauseFulfilmentStatus,
        dpv_owl:ContractualClauseFulfilmentStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:CryptographicAuthentication a owl:Class ;
    rdfs:label "CryptographicAuthentication" ;
    rdfs:subClassOf dpv:AuthenticationProtocols,
        dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Cryptographic Authentication" ;
    skos:definition "Use of cryptography for authentication" ;
    skos:exactMatch dpv:CryptographicAuthentication,
        dpv_upstream:CryptographicAuthentication,
        dpv_owl:CryptographicAuthentication ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:DpvEntity a owl:Class ;
    rdfs:label "DpvEntity" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Entity" ;
    skos:definition "A human or non-human 'thing' that constitutes as an entity" ;
    skos:exactMatch dpv:Entity,
        dpv_upstream:Entity,
        dpv_owl:Entity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-classes" .

dpv:DpvProcess a owl:Class ;
    rdfs:label "DpvProcess" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Process" ;
    skos:definition "An action, activity, or method" ;
    skos:exactMatch dpv:Process,
        dpv_upstream:Process,
        dpv_owl:Process ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "process-classes" .

dpv:EnforceSecurity a owl:Class ;
    rdfs:label "EnforceSecurity" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Enforce Security" ;
    skos:definition """Purposes associated with ensuring and enforcing security for data,
personnel, or other related matters""" ;
    skos:exactMatch dpv:EnforceSecurity,
        dpv_upstream:EnforceSecurity,
        dpv_owl:EnforceSecurity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Was previous \"Security\". Prefixed to distinguish from TechOrg measures." ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:EntityInformed a owl:Class ;
    rdfs:label "EntityInformed" ;
    rdfs:subClassOf dpv:EntityInformedStatus ;
    skos:altLabel "Entity Informed" ;
    skos:definition "Status indicating entity has been informed about specified context" ;
    skos:exactMatch dpv:EntityInformed,
        dpv_upstream:EntityInformed,
        dpv_owl:EntityInformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:EntityInvolvementStatus a owl:Class ;
    rdfs:label "EntityInvolvementStatus" ;
    rdfs:subClassOf dpv:EntityInvolvement,
        dpv:Status ;
    skos:altLabel "Entity Involvement Status" ;
    skos:definition "Status indicating whether an entity is involved" ;
    skos:exactMatch dpv:EntityInvolvementStatus,
        dpv_upstream:EntityInvolvementStatus,
        dpv_owl:EntityInvolvementStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:EntityUninformed a owl:Class ;
    rdfs:label "EntityUninformed" ;
    rdfs:subClassOf dpv:EntityInformedStatus ;
    skos:altLabel "Entity Uninformed" ;
    skos:definition """Status indicating entity is uninformed i.e. has been not been informed
about specified context""" ;
    skos:exactMatch dpv:EntityUninformed,
        dpv_upstream:EntityUninformed,
        dpv_owl:EntityUninformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:Frequency a owl:Class ;
    rdfs:label "Frequency" ;
    rdfs:subClassOf dpv:Context ;
    skos:altLabel "Frequency" ;
    skos:definition """The frequency or information about periods and repetitions in terms of
recurrence.""" ;
    skos:exactMatch dpv:Frequency,
        dpv_upstream:Frequency,
        dpv_owl:Frequency ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:ImpactAssessment a owl:Class ;
    rdfs:label "ImpactAssessment" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:RiskAssessment ;
    skos:altLabel "Impact Assessment" ;
    skos:closeMatch iso42001:AISystemImpactAssessment ;
    skos:definition """Calculating or determining the likelihood of impact of an existing or
proposed process, which can involve risks or detriments.""" ;
    skos:exactMatch dpv:ImpactAssessment,
        dpv_upstream:ImpactAssessment,
        dpv_owl:ImpactAssessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch nist_ai_rmf:Impact ;
    dpv:skos_in_scheme "risk-classes" .

dpv:LegitimateInterestStatus a owl:Class ;
    rdfs:label "LegitimateInterestStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Legitimate InterestStatus" ;
    skos:definition "Status associated with use of Legitimate Interest as a legal basis" ;
    skos:exactMatch dpv:LegitimateInterestStatus,
        dpv_upstream:LegitimateInterestStatus,
        dpv_owl:LegitimateInterestStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:Marketing a owl:Class ;
    rdfs:label "Marketing" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Marketing" ;
    skos:definition """Purposes associated with conducting marketing in relation to
organisation or products or services e.g. promoting, selling, and
distributing""" ;
    skos:exactMatch dpv:Marketing,
        dpv_upstream:Marketing,
        dpv_owl:Marketing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Was commercial interest, changed to consider Marketing a separate
Purpose category by itself""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:OptimisationForController a owl:Class ;
    rdfs:label "OptimisationForController" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceOptimisation ;
    skos:altLabel "Optimisation for Controller" ;
    skos:definition """Purposes associated with optimisation of activities and services for
provider or controller""" ;
    skos:exactMatch dpv:OptimisationForController,
        dpv_upstream:OptimisationForController,
        dpv_owl:OptimisationForController ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:PublicInterestStatus a owl:Class ;
    rdfs:label "PublicInterestStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Public Interest Status" ;
    skos:definition "Status associated with use of Public Interest as a legal basis" ;
    skos:exactMatch dpv:PublicInterestStatus,
        dpv_upstream:PublicInterestStatus,
        dpv_owl:PublicInterestStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:RecordsOfActivities a owl:Class ;
    rdfs:label "RecordsOfActivities" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Records of Activities" ;
    skos:definition """Records of activities within some context such as maintenance tasks or
governance functions""" ;
    skos:exactMatch dpv:RecordsOfActivities,
        dpv_upstream:RecordsOfActivities,
        dpv_owl:RecordsOfActivities ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Records can be any information associated with the activity e.g. logs,
summaries.""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:ResearchAndDevelopment a owl:Class ;
    rdfs:label "ResearchAndDevelopment" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Research and Development" ;
    skos:definition """Purposes associated with conducting research and development for new
methods, products, or services""" ;
    skos:exactMatch dpv:ResearchAndDevelopment,
        dpv_upstream:ResearchAndDevelopment,
        dpv_owl:ResearchAndDevelopment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Right a owl:Class ;
    rdfs:label "Right" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Right" ;
    skos:definition "The right(s) applicable, provided, or expected" ;
    skos:exactMatch dpv:Right,
        dpv_upstream:Right,
        dpv_owl:Right ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """A 'right' is a legal, social, or ethical principle of freedom or
entitlement which dictate the norms regarding what is allowed or owed.
Rights as a concept encompass a broad area of norms and entities, and
are not specific to Individuals or Data Protection / Privacy. For
individual specific rights, see dpv:DataSubjectRight""" ;
    dpv:skos_in_scheme "rights-classes" .

dpv:Scale a owl:Class ;
    rdfs:label "Scale" ;
    rdfs:subClassOf dpv:ProcessingContext ;
    skos:altLabel "Scale" ;
    skos:definition "A measurement along some dimension" ;
    skos:exactMatch dpv:Scale,
        dpv_upstream:Scale,
        dpv_owl:Scale ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Scales are subjective concepts that need to be defined and interpreted
within the context of their application. For example, what would be
small within one context could be large within another.""" ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:ServiceProvision a owl:Class ;
    rdfs:label "ServiceProvision" ;
    rdfs:subClassOf dpv:Purpose,
        dpv:ServiceManagement ;
    skos:altLabel "Service Provision" ;
    skos:definition "Purposes associated with providing service or product or activities" ;
    skos:exactMatch dpv:ServiceProvision,
        dpv_upstream:ServiceProvision,
        dpv_owl:ServiceProvision ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept was modified as a breaking change in v2.3 with the
introduction of `dpv:ServiceManagement`. This concept should therefore
be used only to describe the provision of a service, and should not be
used to represent its management, monitoring, or other non-provision
related purposes (see the taxonomy for other Service Management related
purposes)""" ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:StorageCondition a owl:Class ;
    rdfs:label "StorageCondition" ;
    rdfs:subClassOf dpv:ProcessingCondition ;
    skos:altLabel "Storage Condition" ;
    skos:definition "Conditions required or followed regarding storage of data" ;
    skos:exactMatch dpv:StorageCondition,
        dpv_upstream:StorageCondition,
        dpv_owl:StorageCondition ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:VitalInterestStatus a owl:Class ;
    rdfs:label "VitalInterestStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Vital Interest Status" ;
    skos:definition "Status associated with use of Vital Interest as a legal basis" ;
    skos:exactMatch dpv:VitalInterestStatus,
        dpv_upstream:VitalInterestStatus,
        dpv_owl:VitalInterestStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:has_rule a owl:DatatypeProperty ;
    rdfs:label "has_rule" ;
    skos:altLabel "has rule" ;
    skos:definition "Specifies applicability or inclusion of a rule within specified context" ;
    skos:exactMatch dpv_upstream:hasRule,
        dpv_owl:hasRule ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-properties" .

dpv:ConsentControl a owl:Class ;
    rdfs:label "ConsentControl" ;
    rdfs:subClassOf dpv:EntityInvolvement ;
    skos:altLabel "Consent Control" ;
    skos:definition """The control or activity associated with obtaining, providing,
withdrawing, or reaffirming consent""" ;
    skos:exactMatch dpv:ConsentControl,
        dpv_upstream:ConsentControl,
        dpv_owl:ConsentControl ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "consent-controls-classes" .

dpv:ContractControl a owl:Class ;
    rdfs:label "ContractControl" ;
    rdfs:subClassOf dpv:EntityInvolvement ;
    skos:altLabel "Contract Control" ;
    skos:definition """The control or activity associated with accepting, refusing, and other
actions associated with a contract""" ;
    skos:exactMatch dpv:ContractControl,
        dpv_upstream:ContractControl,
        dpv_owl:ContractControl ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-control-classes" .

dpv:ContractTerminationStatus a owl:Class ;
    rdfs:label "ContractTerminationStatus" ;
    rdfs:subClassOf dpv:ContractStatus ;
    skos:altLabel "Contract Termination Status" ;
    skos:definition "Status associated with termination of a contract" ;
    skos:exactMatch dpv:ContractTerminationStatus,
        dpv_upstream:ContractTerminationStatus,
        dpv_owl:ContractTerminationStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:CustomerManagement a owl:Class ;
    rdfs:label "CustomerManagement" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Customer Management" ;
    skos:definition """Customer Management refers to purposes associated with managing
activities related with past, current, and future customers""" ;
    skos:exactMatch dpv:CustomerManagement,
        dpv_upstream:CustomerManagement,
        dpv_owl:CustomerManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:DataProcessingAgreement a owl:Class ;
    rdfs:label "DataProcessingAgreement" ;
    rdfs:subClassOf dpv:Contract,
        dpv:LegalBasis,
        dpv:LegalMeasure ;
    skos:altLabel "Data Processing Agreement" ;
    skos:definition """An agreement outlining conditions, criteria, obligations,
responsibilities, and specifics for carrying out processing of data""" ;
    skos:exactMatch dpv:DataProcessingAgreement,
        dpv_upstream:DataProcessingAgreement,
        dpv_owl:DataProcessingAgreement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:narrowMatch gists:Agreement ;
    skos:note """For specific role-based data processing agreements, see concepts for
Processors and JointDataController agreements.""" ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:DataSource a owl:Class ;
    rdfs:label "DataSource" ;
    rdfs:subClassOf dpv:ProcessingContext ;
    skos:altLabel "Data Source" ;
    skos:definition "The source or origin of data" ;
    skos:exactMatch dpv:DataSource,
        dpv_upstream:DataSource,
        dpv_owl:DataSource ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Source' is the direct point of data collection; 'origin' would indicate
the original/others points of where the data originates from.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:NotificationStatus a owl:Class ;
    rdfs:label "NotificationStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Notification Status" ;
    skos:definition """Status indicating whether notification(s) are planned, completed, or
failed""" ;
    skos:exactMatch dpv:NotificationStatus,
        dpv_upstream:NotificationStatus,
        dpv_owl:NotificationStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:OrganisationGovernance a owl:Class ;
    rdfs:label "OrganisationGovernance" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Organisation Governance" ;
    skos:definition """Purposes associated with conducting activities and functions for
governance of an organisation""" ;
    skos:exactMatch dpv:OrganisationGovernance,
        dpv_upstream:OrganisationGovernance,
        dpv_owl:OrganisationGovernance ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:PrivateSpace a owl:Class ;
    rdfs:label "PrivateSpace" ;
    rdfs:subClassOf dpv:DpvLocation ;
    skos:altLabel "Private Space" ;
    skos:definition """A space that is owned or controlled by a private entity and where access
to members of the public is restricted""" ;
    skos:exactMatch dpv:PrivateSpace,
        dpv_upstream:PrivateSpace,
        dpv_owl:PrivateSpace ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:Pseudonymisation a owl:Class ;
    rdfs:label "Pseudonymisation" ;
    rdfs:subClassOf dpv:Deidentification,
        dpv:TechnicalMeasure ;
    skos:altLabel "Pseudonymisation" ;
    skos:definition """Pseudonymisation means the processing of personal data in such a manner
that the personal data can no longer be attributed to a specific data
subject without the use of additional information, provided that such
additional information is kept separately and is subject to technical
and organisational measures to ensure that the personal data are not
attributed to an identified or identifiable natural person;""" ;
    skos:exactMatch dpv:Pseudonymisation,
        dpv_upstream:Pseudonymisation,
        dpv_owl:Pseudonymisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:StaffTraining a owl:Class ;
    rdfs:label "StaffTraining" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Staff Training" ;
    skos:definition "Practices and policies regarding training of staff members" ;
    skos:exactMatch dpv:StaffTraining,
        dpv_upstream:StaffTraining,
        dpv_owl:StaffTraining ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:VulnerableHuman a owl:Class ;
    rdfs:label "VulnerableHuman" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Vulnerable Human" ;
    skos:definition "Human(s) which should be considered 'vulnerable' within the context" ;
    skos:exactMatch dpv:VulnerableHuman,
        dpv_upstream:VulnerableHuman,
        dpv_owl:VulnerableHuman ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:has_technical_organisational_measure a owl:DatatypeProperty ;
    rdfs:label "has_technical_organisational_measure" ;
    skos:altLabel "has technical and organisational measure" ;
    skos:definition "Indicates use or applicability of Technical or Organisational measure" ;
    skos:exactMatch dpv_upstream:hasTechnicalOrganisationalMeasure,
        dpv_owl:hasTechnicalOrganisationalMeasure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "TOM-properties" .

dpv:ActivityStatus a owl:Class ;
    rdfs:label "ActivityStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Activity Status" ;
    skos:definition "Status associated with activity operations and lifecycles" ;
    skos:exactMatch dpv:ActivityStatus,
        dpv_upstream:ActivityStatus,
        dpv_owl:ActivityStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:AuditStatus a owl:Class ;
    rdfs:label "AuditStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Audit Status" ;
    skos:definition "Status associated with Auditing or Investigation" ;
    skos:exactMatch dpv:AuditStatus,
        dpv_upstream:AuditStatus,
        dpv_owl:AuditStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:AuthenticationProtocols a owl:Class ;
    rdfs:label "AuthenticationProtocols" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Authentication Protocols" ;
    skos:definition """Protocols involving validation of identity i.e. authentication of a
person or information""" ;
    skos:exactMatch dpv:AuthenticationProtocols,
        dpv_upstream:AuthenticationProtocols,
        dpv_owl:AuthenticationProtocols ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:Contract a owl:Class ;
    rdfs:label "Contract" ;
    rdfs:subClassOf dpv:LegalBasis ;
    skos:altLabel "Contract" ;
    skos:definition """Creation, completion, fulfilment, or performance of a contract involving
specified processing of data or technologies""" ;
    skos:exactMatch dpv:Contract,
        dpv_upstream:Contract,
        dpv_owl:Contract ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:DataGovernance a owl:Class ;
    rdfs:label "DataGovernance" ;
    rdfs:subClassOf dpv:OrganisationGovernance,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Data Governance" ;
    skos:definition """Measures associated with topics typically considered to be part of 'Data
Governance'""" ;
    skos:exactMatch dpv:DataGovernance,
        dpv_upstream:DataGovernance,
        dpv_owl:DataGovernance ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch iso42001:DataResource,
        nist_csf_v2:CSFFunction ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataProcessingPolicy a owl:Class ;
    rdfs:label "DataProcessingPolicy" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:Policy ;
    skos:altLabel "Data Processing Policy" ;
    skos:definition "Policy regarding data processing activities" ;
    skos:exactMatch dpv:DataProcessingPolicy,
        dpv_upstream:DataProcessingPolicy,
        dpv_owl:DataProcessingPolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This only refers to the policy or plan or procedure describing how the
data processing should be conducted. To represent the granular details,
see further concepts e.g. dpv:DataStoragePolicy to describe policy
regarding storage, or dpv:DataStorageCondition to represent information
within the policy for how information should be stored""" ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:DataSubjectScale a owl:Class ;
    rdfs:label "DataSubjectScale" ;
    rdfs:subClassOf dpv:Scale ;
    skos:altLabel "Data Subject Scale" ;
    skos:definition "Scale of Data Subject(s)" ;
    skos:exactMatch dpv:DataSubjectScale,
        dpv_upstream:DataSubjectScale,
        dpv_owl:DataSubjectScale ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:DataVolume a owl:Class ;
    rdfs:label "DataVolume" ;
    rdfs:subClassOf dpv:Scale ;
    skos:altLabel "Data Volume" ;
    skos:definition "Volume or Scale of Data" ;
    skos:exactMatch dpv:DataVolume,
        dpv_upstream:DataVolume,
        dpv_owl:DataVolume ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:DpvDuration a owl:Class ;
    rdfs:label "DpvDuration" ;
    rdfs:subClassOf dpv:Context ;
    skos:altLabel "Duration" ;
    skos:definition "The duration or temporal limitation" ;
    skos:exactMatch dpv:Duration,
        dpv_upstream:Duration,
        dpv_owl:Duration ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "context-classes" .

dpv:Encryption a owl:Class ;
    rdfs:label "Encryption" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Encryption" ;
    skos:definition "Technical measures consisting of encryption" ;
    skos:exactMatch dpv:Encryption,
        dpv_upstream:Encryption,
        dpv_owl:Encryption ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:narrowMatch iso27001:SecurityControl ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:GuidelinesPrinciple a owl:Class ;
    rdfs:label "GuidelinesPrinciple" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Guidelines Principle" ;
    skos:definition "Guidelines or Principles regarding processing and operational measures" ;
    skos:exactMatch dpv:GuidelinesPrinciple,
        dpv_upstream:GuidelinesPrinciple,
        dpv_owl:GuidelinesPrinciple ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:Obtain a owl:Class ;
    rdfs:label "Obtain" ;
    rdfs:subClassOf dpv:Processing ;
    skos:altLabel "Obtain" ;
    skos:definition "to solicit or gather data from someone" ;
    skos:exactMatch dpv:Obtain,
        dpv_upstream:Obtain,
        dpv_owl:Obtain ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:PersonalData a owl:Class ;
    rdfs:label "PersonalData" ;
    rdfs:subClassOf dpv:DpvData ;
    skos:altLabel "Personal Data" ;
    skos:closeMatch iso29100:PersonallyIdentifiableInformation ;
    skos:definition "Data directly or indirectly associated or related to an individual" ;
    skos:exactMatch dpv:PersonalData,
        dpv_upstream:PersonalData,
        dpv_owl:PersonalData ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:narrowMatch iso27001:Asset ;
    skos:note """This definition of personal data encompasses the concepts used in GDPR
Art.4-1 for 'personal data' and ISO/IEC 2700 for 'personally
identifiable information (PII)'.""" ;
    skos:relatedMatch usage_policy:AnyData ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:Policy a owl:Class ;
    rdfs:label "Policy" ;
    rdfs:subClassOf dpv:GovernanceProcedures,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Policy" ;
    skos:definition """A guidance document outlining any of: procedures, plans, principles,
decisions, intent, or protocols.""" ;
    skos:exactMatch dpv:Policy,
        dpv_upstream:Policy,
        dpv_owl:Policy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:RecruitmentManagement a owl:Class ;
    rdfs:label "RecruitmentManagement" ;
    rdfs:subClassOf dpv:PersonnelHiring,
        dpv:Purpose ;
    skos:altLabel "Recruitment Management" ;
    skos:definition """Purposes assocaited with recruitment of personnel, which includes
identifying, sourcing, screening, filtering, shortlisting, and
interviewing candidates""" ;
    skos:exactMatch dpv:RecruitmentManagement,
        dpv_upstream:RecruitmentManagement,
        dpv_owl:RecruitmentManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RuleFulfilled a owl:Class ;
    rdfs:label "RuleFulfilled" ;
    rdfs:subClassOf dpv:RuleFulfilmentStatus ;
    skos:altLabel "Rule Fulfilled" ;
    skos:definition "Status indicating a rule has been fulfilled, completed, or satisfied" ;
    skos:exactMatch dpv:RuleFulfilled,
        dpv_upstream:RuleFulfilled,
        dpv_owl:RuleFulfilled ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

dpv:SecurityProcedure a owl:Class ;
    rdfs:label "SecurityProcedure" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Security Procedure" ;
    skos:definition """Procedures associated with assessing, implementing, and evaluating
security""" ;
    skos:exactMatch dpv:SecurityProcedure,
        dpv_upstream:SecurityProcedure,
        dpv_owl:SecurityProcedure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:TechnicalOrganisationalMeasure a owl:Class ;
    rdfs:label "TechnicalOrganisationalMeasure" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Technical and Organisational Measure" ;
    skos:closeMatch oscal:Control ;
    skos:definition """Technical and Organisational measures used to safeguard and ensure good
practices in connection with data and technologies""" ;
    skos:exactMatch dpv:TechnicalOrganisationalMeasure,
        dpv_upstream:TechnicalOrganisationalMeasure,
        dpv_owl:TechnicalOrganisationalMeasure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "TOM-classes" .

dpv:Assessment a owl:Class ;
    rdfs:label "Assessment" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Assessment" ;
    skos:definition """The document, plan, or process for assessment or determination towards a
purpose e.g. assessment of legality or impact assessments""" ;
    skos:exactMatch dpv:Assessment,
        dpv_upstream:Assessment,
        dpv_owl:Assessment ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:AutomationLevel a owl:Class ;
    rdfs:label "AutomationLevel" ;
    rdfs:subClassOf dpv:ProcessingContext ;
    skos:altLabel "Automation Level" ;
    skos:definition """Indication of degree or level of automation associated with specified
context""" ;
    skos:exactMatch dpv:AutomationLevel,
        dpv_upstream:AutomationLevel,
        dpv_owl:AutomationLevel ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "This concept was called 'Automation' in previous versions" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:ComplianceStatus a owl:Class ;
    rdfs:label "ComplianceStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Compliance Status" ;
    skos:definition """Status associated with Compliance with some norms, objectives, or
requirements""" ;
    skos:exactMatch dpv:ComplianceStatus,
        dpv_upstream:ComplianceStatus,
        dpv_owl:ComplianceStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ContractByEntityType a owl:Class ;
    rdfs:label "ContractByEntityType" ;
    rdfs:subClassOf dpv:Contract,
        dpv:LegalBasis ;
    skos:altLabel "Contract by Entity Type" ;
    skos:definition """A generic concept representing contracts categorised by the type of
entities involved - such as Businesses (B), Consumers (C), and
Governments (G)""" ;
    skos:exactMatch dpv:ContractByEntityType,
        dpv_upstream:ContractByEntityType,
        dpv_owl:ContractByEntityType ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-types-classes" .

dpv:ContractPreparationStatus a owl:Class ;
    rdfs:label "ContractPreparationStatus" ;
    rdfs:subClassOf dpv:ContractStatus ;
    skos:altLabel "Contract Preparation Status" ;
    skos:definition """Status associated with preparation of contracts before they are signed
or accepted or executed""" ;
    skos:exactMatch dpv:ContractPreparationStatus,
        dpv_upstream:ContractPreparationStatus,
        dpv_owl:ContractPreparationStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:ContractStatus a owl:Class ;
    rdfs:label "ContractStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Contract Status" ;
    skos:definition "Status associated with a contract" ;
    skos:exactMatch dpv:ContractStatus,
        dpv_upstream:ContractStatus,
        dpv_owl:ContractStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-status-classes" .

dpv:GeographicCoverage a owl:Class ;
    rdfs:label "GeographicCoverage" ;
    rdfs:subClassOf dpv:Scale ;
    skos:altLabel "Geographic Coverage" ;
    skos:definition "Indicate of scale in terms of geographic coverage" ;
    skos:exactMatch dpv:GeographicCoverage,
        dpv_upstream:GeographicCoverage,
        dpv_owl:GeographicCoverage ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:NoticeStatus a owl:Class ;
    rdfs:label "NoticeStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Notice Status" ;
    skos:definition "Status associated with notice provision, use, and management" ;
    skos:exactMatch dpv:NoticeStatus,
        dpv_upstream:NoticeStatus,
        dpv_owl:NoticeStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "notice-classes" .

dpv:ConsentStatusInvalidForProcessing a owl:Class ;
    rdfs:label "ConsentStatusInvalidForProcessing" ;
    rdfs:subClassOf dpv:ConsentStatus ;
    skos:altLabel "Consent Status Invalid for Processing" ;
    skos:definition """States of consent that cannot be used as valid justifications for
processing data""" ;
    skos:exactMatch dpv:ConsentStatusInvalidForProcessing,
        dpv_upstream:ConsentStatusInvalidForProcessing,
        dpv_owl:ConsentStatusInvalidForProcessing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This identifies the stages associated with consent that should not be
used to process data""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:Disclose a owl:Class ;
    rdfs:label "Disclose" ;
    rdfs:subClassOf dpv:Processing ;
    skos:altLabel "Disclose" ;
    skos:definition "to make data known" ;
    skos:exactMatch dpv:Disclose,
        dpv_upstream:Disclose,
        dpv_owl:Disclose ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:HumanInvolvement a owl:Class ;
    rdfs:label "HumanInvolvement" ;
    rdfs:subClassOf dpv:EntityInvolvement ;
    skos:altLabel "Human Involvement" ;
    skos:definition "The involvement of humans in specified context" ;
    skos:exactMatch dpv:HumanInvolvement,
        dpv_upstream:HumanInvolvement,
        dpv_owl:HumanInvolvement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Human Involvement here broadly refers to any involvement by a human in
the context of carrying out processing. This may include verification of
outcomes, providing input data for making decisions, or overseeing
activities. To indicate whether humans are involved or not, see relevant
concepts of dpv:HumanInvolved and dpv:HumanNotInvolved. The term 'Human
in the loop' and its varieties are absent from DPV due to their
contradictory and non-compatible use across different sources.""" ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:LocationFixture a owl:Class ;
    rdfs:label "LocationFixture" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Location Fixture" ;
    skos:definition "The fixture of location refers to whether the location is fixed" ;
    skos:exactMatch dpv:LocationFixture,
        dpv_upstream:LocationFixture,
        dpv_owl:LocationFixture ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:PersonnelManagement a owl:Class ;
    rdfs:label "PersonnelManagement" ;
    rdfs:subClassOf dpv:HumanResourceManagement,
        dpv:Purpose ;
    skos:altLabel "Personnel Management" ;
    skos:definition """Purposes associated with management of personnel associated with the
organisation e.g. evaluation and management of employees and
intermediaries""" ;
    skos:exactMatch dpv:PersonnelManagement,
        dpv_upstream:PersonnelManagement,
        dpv_owl:PersonnelManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Rule a owl:Class ;
    rdfs:label "Rule" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Rule" ;
    skos:definition """A rule describing a process or control that directs or determines if and
how an activity should be conducted""" ;
    skos:exactMatch dpv:Rule,
        dpv_upstream:Rule,
        dpv_owl:Rule ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

dpv:ServiceManagement a owl:Class ;
    rdfs:label "ServiceManagement" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Service Management" ;
    skos:definition "Purposes associated with the management of services or products" ;
    skos:exactMatch dpv:ServiceManagement,
        dpv_upstream:ServiceManagement,
        dpv_owl:ServiceManagement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:Use a owl:Class ;
    rdfs:label "Use" ;
    rdfs:subClassOf dpv:Processing ;
    skos:altLabel "Use" ;
    skos:definition "to use data" ;
    skos:exactMatch dpv:Use,
        dpv_upstream:Use,
        dpv_owl:Use ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:ContractualClause a owl:Class ;
    rdfs:label "ContractualClause" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Contractual Clause" ;
    skos:definition "A part or component within a contract that outlines its specifics" ;
    skos:exactMatch dpv:ContractualClause,
        dpv_upstream:ContractualClause,
        dpv_owl:ContractualClause ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "contract-clause-classes" .

dpv:Transform a owl:Class ;
    rdfs:label "Transform" ;
    rdfs:subClassOf dpv:Processing ;
    skos:altLabel "Transform" ;
    skos:definition "to change the form or nature of data" ;
    skos:exactMatch dpv:Transform,
        dpv_upstream:Transform,
        dpv_owl:Transform ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:has_status a owl:DatatypeProperty ;
    rdfs:label "has_status" ;
    skos:altLabel "has status" ;
    skos:definition "Indicates the status of specified concept" ;
    skos:exactMatch dpv_upstream:hasStatus,
        dpv_owl:hasStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Also used to Indicate the status of a Right Exercise Activity" ;
    dpv:skos_in_scheme "rights-properties, status-properties" .

dpv:EntityInformedStatus a owl:Class ;
    rdfs:label "EntityInformedStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Entity Informed Status" ;
    skos:definition """Status indicating whether an entity is informed or uninformed about
specified context""" ;
    skos:exactMatch dpv:EntityInformedStatus,
        dpv_upstream:EntityInformedStatus,
        dpv_owl:EntityInformedStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:ProcessingContext a owl:Class ;
    rdfs:label "ProcessingContext" ;
    rdfs:subClassOf dpv:Context ;
    skos:altLabel "Processing Context" ;
    skos:definition "Context or conditions within which processing takes place" ;
    skos:exactMatch dpv:ProcessingContext,
        dpv_upstream:ProcessingContext,
        dpv_owl:ProcessingContext ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:PublicBenefit a owl:Class ;
    rdfs:label "PublicBenefit" ;
    rdfs:subClassOf dpv:Purpose ;
    skos:altLabel "Public Benefit" ;
    skos:definition "Purposes undertaken and intended to provide benefit to public or society" ;
    skos:exactMatch dpv:PublicBenefit,
        dpv_upstream:PublicBenefit,
        dpv_owl:PublicBenefit ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:RequestStatus a owl:Class ;
    rdfs:label "RequestStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Request Status" ;
    skos:definition "Status associated with requests" ;
    skos:exactMatch dpv:RequestStatus,
        dpv_upstream:RequestStatus,
        dpv_owl:RequestStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:Context a owl:Class ;
    rdfs:label "Context" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Context" ;
    skos:definition "Contextually relevant information" ;
    skos:exactMatch dpv:Context,
        dpv_upstream:Context,
        dpv_owl:Context ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Context is a catch-all concept for information of relevance not possible
to represent through other core concepts. DPV offers specific contextual
concepts such as Necessity, Frequency, and Duration. More can be created
by extending Context within use-cases.""" ;
    dpv:skos_in_scheme "context-classes" .

dpv:EntityInvolvement a owl:Class ;
    rdfs:label "EntityInvolvement" ;
    rdfs:subClassOf dpv:ProcessingContext ;
    skos:altLabel "Entity Involvement" ;
    skos:definition "Involvement of an entity in specific context" ;
    skos:exactMatch dpv:EntityInvolvement,
        dpv_upstream:EntityInvolvement,
        dpv_owl:EntityInvolvement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:GovernanceProcedures a owl:Class ;
    rdfs:label "GovernanceProcedures" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Governance Procedures" ;
    skos:definition """Procedures related to governance (e.g. organisation, unit, team,
process, system)""" ;
    skos:exactMatch dpv:GovernanceProcedures,
        dpv_upstream:GovernanceProcedures,
        dpv_owl:GovernanceProcedures ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:PhysicalMeasure a owl:Class ;
    rdfs:label "PhysicalMeasure" ;
    rdfs:subClassOf dpv:TechnicalOrganisationalMeasure ;
    skos:altLabel "Physical Measure" ;
    skos:definition """Physical measures used to safeguard and ensure good practices in
connection with data and technologies""" ;
    skos:exactMatch dpv:PhysicalMeasure,
        dpv_upstream:PhysicalMeasure,
        dpv_owl:PhysicalMeasure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "TOM-classes" .

dpv:ConsentStatus a owl:Class ;
    rdfs:label "ConsentStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Consent Status" ;
    skos:definition """The state or status of 'consent' that provides information reflecting
its operational status and validity for processing data""" ;
    skos:exactMatch dpv:ConsentStatus,
        dpv_upstream:ConsentStatus,
        dpv_owl:ConsentStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """States are useful as information artefacts to implement them in
controlling processing, and to reflect the process and flow of obtaining
and maintaining consent. For example, a database table that stores
consent states for specific processing and can be queried to obtain them
in an efficient manner. States are also useful in investigations to
determine the use and validity of consenting practices""" ;
    dpv:skos_in_scheme "consent-status-classes" .

dpv:DpvData a owl:Class ;
    rdfs:label "DpvData" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Data" ;
    skos:definition "A broad concept representing 'data' or 'information'" ;
    skos:exactMatch dpv:Data,
        dpv_upstream:Data,
        dpv_owl:Data ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "personal-data-classes" .

dpv:LegalMeasure a owl:Class ;
    rdfs:label "LegalMeasure" ;
    rdfs:subClassOf dpv:TechnicalOrganisationalMeasure ;
    skos:altLabel "Legal Measure" ;
    skos:definition """Legal measures used to safeguard and ensure good practices in connection
with data and technologies""" ;
    skos:exactMatch dpv:LegalMeasure,
        dpv_upstream:LegalMeasure,
        dpv_owl:LegalMeasure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "DGA 12.j" ;
    dpv:skos_in_scheme "TOM-classes" .

dpv:EntityNonPermissiveInvolvement a owl:Class ;
    rdfs:label "EntityNonPermissiveInvolvement" ;
    rdfs:subClassOf dpv:EntityInvolvement ;
    skos:altLabel "Entity Non-Permissive Involvement" ;
    skos:definition """Involvement of an entity in specific context where it is not permitted
or able to do something""" ;
    skos:exactMatch dpv:EntityNonPermissiveInvolvement,
        dpv_upstream:EntityNonPermissiveInvolvement,
        dpv_owl:EntityNonPermissiveInvolvement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:EntityPermissiveInvolvement a owl:Class ;
    rdfs:label "EntityPermissiveInvolvement" ;
    rdfs:subClassOf dpv:EntityInvolvement ;
    skos:altLabel "Entity Permissive Involvement" ;
    skos:definition """Involvement of an entity in specific context where it is permitted or
able to do something""" ;
    skos:exactMatch dpv:EntityPermissiveInvolvement,
        dpv_upstream:EntityPermissiveInvolvement,
        dpv_owl:EntityPermissiveInvolvement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:Notice a owl:Class ;
    rdfs:label "Notice" ;
    rdfs:subClassOf dpv:OrganisationalMeasure ;
    skos:altLabel "Notice" ;
    skos:definition "A notice is an artefact for providing information, choices, or controls" ;
    skos:exactMatch dpv:Notice,
        dpv_upstream:Notice,
        dpv_owl:Notice ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Notice refers to the information whereas Notification refers to the
provision of that notice. In several cases, they are used
interchangeably - for example Privacy Notice as a measure or control
refers to both the information as well as the act of making it
available. For 'active' contexts where this distinction is important,
e.g. data breach notifications, see Notification concept.""" ;
    dpv:skos_in_scheme "notice-classes, organisational-measures-classes" .

dpv:RuleFulfilmentStatus a owl:Class ;
    rdfs:label "RuleFulfilmentStatus" ;
    rdfs:subClassOf dpv:Status ;
    skos:altLabel "Rule Fulfilment Status" ;
    skos:definition """Status associated with a rule for indicating whether it is applicable,
or has been utilised, and whether the requirements of the rule have been
fulfilled or violated""" ;
    skos:exactMatch dpv:RuleFulfilmentStatus,
        dpv_upstream:RuleFulfilmentStatus,
        dpv_owl:RuleFulfilmentStatus ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "rules-classes" .

dpv:LegalEntity a owl:Class ;
    rdfs:label "LegalEntity" ;
    rdfs:subClassOf dpv:DpvEntity ;
    skos:altLabel "Legal Entity" ;
    skos:closeMatch gists:Organization,
        ocsf:Organization,
        oscal:Party ;
    skos:definition """A human or non-human 'thing' that constitutes as an entity and which is
recognised and defined in law""" ;
    skos:exactMatch dpv:LegalEntity,
        dpv_upstream:LegalEntity,
        dpv_owl:LegalEntity,
        common_domain_model:LegalEntity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-classes" .

dpv:DpvOrganisation a owl:Class ;
    rdfs:label "DpvOrganisation" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Organisation" ;
    skos:definition """A general term reflecting a company or a business or a group acting as a
unit""" ;
    skos:exactMatch dpv:Organisation,
        dpv_upstream:Organisation,
        dpv_owl:Organisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:SecurityMethod a owl:Class ;
    rdfs:label "SecurityMethod" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Security Method" ;
    skos:definition "Methods that relate to creating and providing security" ;
    skos:exactMatch dpv:SecurityMethod,
        dpv_upstream:SecurityMethod,
        dpv_owl:SecurityMethod ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:CryptographicMethods a owl:Class ;
    rdfs:label "CryptographicMethods" ;
    rdfs:subClassOf dpv:TechnicalMeasure ;
    skos:altLabel "Cryptographic Methods" ;
    skos:definition "Use of cryptographic methods to perform tasks" ;
    skos:exactMatch dpv:CryptographicMethods,
        dpv_upstream:CryptographicMethods,
        dpv_owl:CryptographicMethods ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:has_entity a owl:DatatypeProperty ;
    rdfs:label "has_entity" ;
    skos:altLabel "has entity" ;
    skos:definition "Indicates inclusion or applicability of an entity to some concept" ;
    skos:exactMatch dpv_upstream:hasEntity,
        dpv_owl:hasEntity ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """parent property for controller, processor, data subject, authority,
etc.?""" ;
    dpv:skos_in_scheme "entities-properties" .

dpv:Status a owl:Class ;
    rdfs:label "Status" ;
    rdfs:subClassOf dpv:Context ;
    skos:altLabel "Status" ;
    skos:definition "The status or state of something" ;
    skos:exactMatch dpv:Status,
        dpv_upstream:Status,
        dpv_owl:Status ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "status-classes" .

dpv:DpvLocation a owl:Class ;
    rdfs:label "DpvLocation" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Location" ;
    skos:definition "A location is a position, site, or area where something is located" ;
    skos:exactMatch dpv:Location,
        dpv_upstream:Location,
        dpv_owl:Location ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "Location may be geographic, physical, or virtual." ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:DpvThing a owl:Class ;
    rdfs:label "DpvThing" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty dpv:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty dpv:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dpv:id ],
        [ owl:unionOf ( dpv:Context dpv:ContractualClause dpv:DpvData dpv:DpvEntity dpv:DpvLocation dpv:DpvProcess dpv:ExpectationStatus dpv:Law dpv:LegalBasis dpv:Likelihood dpv:LocationFixture dpv:NoticeIcon dpv:NoticeLayer dpv:Processing dpv:PublicRegisterOfEntities dpv:Purpose dpv:Right dpv:RiskConcept dpv:RiskLevel dpv:Rule dpv:Sector dpv:Severity dpv:TechnicalOrganisationalMeasure dpv:Technology ) ] ;
    skos:definition """Abstract base class for every DPV entity. Provides a uniform ``id``
identifier slot. Does NOT enumerate DPV properties: the upstream OWL
declares no ``rdfs:domain`` triples, so any DPV property is semantically
applicable to any DPV class (open-world). Generators that need a
closed-world property list per class should consume the W3C DPV OWL
release directly rather than this LinkML projection.""" ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> .

dpv:HumanSubject a owl:Class ;
    rdfs:label "HumanSubject" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Human Subject" ;
    skos:definition """The individual (or category of individuals) that is the subject within
some context such as personal data (dpv:DataSubject) or technology
(tech:Subject)""" ;
    skos:exactMatch dpv:HumanSubject,
        dpv_upstream:HumanSubject,
        dpv_owl:HumanSubject ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:LegalBasis a owl:Class ;
    rdfs:label "LegalBasis" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Legal Basis" ;
    skos:definition """Legal basis used to justify processing of data or use of technology in
accordance with a law""" ;
    skos:exactMatch dpv:LegalBasis,
        dpv_upstream:LegalBasis,
        dpv_owl:LegalBasis ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Legal basis (plural: legal bases) are defined by legislations and
regulations, whose applicability is usually restricted to specific
jurisdictions which can be represented using dpv:hasJurisdiction or
dpv:hasLaw. Legal basis can be used without such declarations, e.g.
'Consent', however their interpretation will require association with a
law, e.g. 'EU GDPR'.""" ;
    dpv:skos_in_scheme "legal-basis-classes" .

dpv:Processing a owl:Class ;
    rdfs:label "Processing" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Processing" ;
    skos:closeMatch iso29100:PIIProcessingOperation ;
    skos:definition "Operations or 'processing' performed on data" ;
    skos:exactMatch dpv:Processing,
        dpv_upstream:Processing,
        dpv_owl:Processing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:relatedMatch usage_policy:AnyProcessing ;
    dpv:skos_in_scheme "processing-classes" .

dpv:TechnicalMeasure a owl:Class ;
    rdfs:label "TechnicalMeasure" ;
    rdfs:subClassOf dpv:TechnicalOrganisationalMeasure ;
    skos:altLabel "Technical Measure" ;
    skos:broadMatch iso29100:PrivacyControl,
        nist_csf_v2:CSFSubcategory ;
    skos:definition """Technical measures used to safeguard and ensure good practices in
connection with data and technologies""" ;
    skos:exactMatch dpv:TechnicalMeasure,
        dpv_upstream:TechnicalMeasure,
        dpv_owl:TechnicalMeasure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:narrowMatch iso27001:SecurityControl,
        oscal:Control ;
    skos:relatedMatch ocsf:DataSecurity ;
    dpv:skos_in_scheme "TOM-classes" .

dpv:Purpose a owl:Class ;
    rdfs:label "Purpose" ;
    rdfs:subClassOf dpv:DpvThing ;
    skos:altLabel "Purpose" ;
    skos:definition "Purpose or (broader) Goal associated with data or technology" ;
    skos:exactMatch dpv:Purpose,
        dpv_upstream:Purpose,
        dpv_owl:Purpose ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """The purpose or goal here is intended to sufficiently describe the
intention or objective of why the data or technology is being used, and
should be broader than mere technical descriptions of achieving a
capability. For example, "Analyse Data" is an abstract purpose with no
indication of what the analyses is for as compared to a purpose such as
"Marketing" or "Service Provision" which provide clarity and
comprehension of the 'purpose' and can be enhanced with additional
descriptions. Such modelling is in line with regulatory requirements
regarding the specificity of purposes, for example in GDPR""" ;
    skos:relatedMatch usage_policy:AnyPurpose ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:OrganisationalMeasure a owl:Class ;
    rdfs:label "OrganisationalMeasure" ;
    rdfs:subClassOf dpv:TechnicalOrganisationalMeasure ;
    skos:altLabel "Organisational Measure" ;
    skos:broadMatch iso29100:PrivacyControl,
        nist_csf_v2:CSFSubcategory ;
    skos:definition """Organisational measures used to safeguard and ensure good practices in
connection with data and technologies""" ;
    skos:exactMatch dpv:OrganisationalMeasure,
        dpv_upstream:OrganisationalMeasure,
        dpv_owl:OrganisationalMeasure ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:narrowMatch iso27001:SecurityControl,
        oscal:Control ;
    dpv:skos_in_scheme "TOM-classes" .


