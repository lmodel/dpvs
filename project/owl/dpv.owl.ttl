dpv:PrivacyByDefault a owl:Class ;
    rdfs:label "PrivacyByDefault" ;
    rdfs:subClassOf dpv:GuidelinesPrinciple,
        dpv:OrganisationalMeasure ;
    skos:altLabel "Privacy by Default" ;
    skos:definition """Practices regarding setting the default configurations of information
and services to implement data protection and privacy (synonymous with
Data Protection by Default)""" ;
    skos:exactMatch dpv:PrivacyByDefault,
        dpv_upstream:PrivacyByDefault,
