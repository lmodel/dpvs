Design)""" ;
    skos:exactMatch dpv:PrivacyByDesign,
        dpv_upstream:PrivacyByDesign,
        dpv_owl:PrivacyByDesign ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:PrivacyPreservingProtocol a owl:Class ;
    rdfs:label "PrivacyPreservingProtocol" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Privacy Preserving Protocol" ;
    skos:definition """Use of protocols designed with the intention of provided additional
guarantees regarding privacy""" ;
    skos:exactMatch dpv:PrivacyPreservingProtocol,
        dpv_upstream:PrivacyPreservingProtocol,
        dpv_owl:PrivacyPreservingProtocol ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:PrivateCommunalSpace a owl:Class ;
    rdfs:label "PrivateCommunalSpace" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:PrivateSpace ;
    skos:altLabel "Private Communal Space" ;
    skos:definition """A space that is accessible to a group or a community within a private
space and where members of the public do not have access to it e.g.
society amenities such as gyms and pools""" ;
    skos:exactMatch dpv:PrivateCommunalSpace,
        dpv_upstream:PrivateCommunalSpace,
        dpv_owl:PrivateCommunalSpace ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:PrivateInformationRetrieval a owl:Class ;
    rdfs:label "PrivateInformationRetrieval" ;
    rdfs:subClassOf dpv:CryptographicMethods,
        dpv:TechnicalMeasure ;
    skos:altLabel "Private Information Retrieval" ;
    skos:definition """Use of cryptographic methods to retrieve a record from a system without
revealing which record is retrieved""" ;
    skos:exactMatch dpv:PrivateInformationRetrieval,
        dpv_upstream:PrivateInformationRetrieval,
        dpv_owl:PrivateInformationRetrieval ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "technical-measures-classes" .

dpv:PrivateLocation a owl:Class ;
    rdfs:label "PrivateLocation" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:LocalLocation ;
    skos:altLabel "Private Location (deprecated)" ;
    skos:definition """Location that is not or cannot be accessed by the public and is
controlled as a private space""" ;
    skos:exactMatch dpv:PrivateLocation,
        dpv_upstream:PrivateLocation,
        dpv_owl:PrivateLocation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """This concept will be deprecated in a future DPV release, it is suggested
to use the better defined and legally aligned dpv:PrivateSpace instead""" ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:PrivateSectorBody a owl:Class ;
    rdfs:label "PrivateSectorBody" ;
    rdfs:subClassOf dpv:LegalEntity ;
    skos:altLabel "Private Sector Body" ;
    skos:definition "An organisation owned and operated by private individuals or companies" ;
    skos:exactMatch dpv:PrivateSectorBody,
        dpv_upstream:PrivateSectorBody,
        dpv_owl:PrivateSectorBody ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-organisation-classes" .

dpv:PrivatelyOperatedPublicSpace a owl:Class ;
    rdfs:label "PrivatelyOperatedPublicSpace" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:HybridPublicPrivateSpace,
        dpv:PubliclyAccessibleSpace ;
    skos:altLabel "Privately Operated Public Space" ;
    skos:definition """A space that is operated or managed by a private entity but which is
accessible to the public e.g. a public bus station operated by a
specific company""" ;
    skos:exactMatch dpv:PrivatelyOperatedPublicSpace,
        dpv_upstream:PrivatelyOperatedPublicSpace,
        dpv_owl:PrivatelyOperatedPublicSpace ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

dpv:PrivatelyOwnedPublicSpace a owl:Class ;
    rdfs:label "PrivatelyOwnedPublicSpace" ;
    rdfs:subClassOf dpv:DpvLocation,
        dpv:HybridPublicPrivateSpace,
        dpv:PrivatelyOwnedSpace ;
    skos:altLabel "Privately Owned Public Space" ;
    skos:definition """A space that is privately owned but which is accessible and usable by
the public - whether freely or through a process which is open to all
members of the public e.g. hotel lobby, shopping mall atriums""" ;
    skos:exactMatch dpv:PrivatelyOwnedPublicSpace,
        dpv_upstream:PrivatelyOwnedPublicSpace,
        dpv_owl:PrivatelyOwnedPublicSpace ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "jurisdiction-classes" .

