    skos:exactMatch dpv:LegitimateInterestUninformed,
        dpv_upstream:LegitimateInterestUninformed,
        dpv_owl:LegitimateInterestUninformed ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "legal-basis-status-classes" .

dpv:LocalEnvironmentScale a owl:Class ;
    rdfs:label "LocalEnvironmentScale" ;
    rdfs:subClassOf dpv:GeographicCoverage ;
    skos:altLabel "Local Environment Scale" ;
    skos:definition "Geographic coverage spanning a specific environment within the locality" ;
    skos:exactMatch dpv:LocalEnvironmentScale,
        dpv_upstream:LocalEnvironmentScale,
        dpv_owl:LocalEnvironmentScale ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """For example, geographic scale of an event take place in a specific
building or room""" ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:LocalityScale a owl:Class ;
    rdfs:label "LocalityScale" ;
    rdfs:subClassOf dpv:GeographicCoverage ;
    skos:altLabel "Locality Scale" ;
    skos:definition "Geographic coverage spanning a specific locality" ;
    skos:exactMatch dpv:LocalityScale,
        dpv_upstream:LocalityScale,
        dpv_owl:LocalityScale ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note "For example, geographic scale of a city or an area within a city" ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:LoggingPolicy a owl:Class ;
    rdfs:label "LoggingPolicy" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:Policy ;
    skos:altLabel "Logging Policy" ;
    skos:definition "Policy for logging of information" ;
    skos:exactMatch dpv:LoggingPolicy,
        dpv_upstream:LoggingPolicy,
        dpv_owl:LoggingPolicy ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:MaintainFraudDatabase a owl:Class ;
    rdfs:label "MaintainFraudDatabase" ;
    rdfs:subClassOf dpv:FraudPreventionAndDetection,
        dpv:Purpose ;
    skos:altLabel "Maintain Fraud Database" ;
    skos:definition """Purposes associated with maintaining a database related to identifying
and identified fraud risks and fraud incidents""" ;
    skos:exactMatch dpv:MaintainFraudDatabase,
        dpv_upstream:MaintainFraudDatabase,
        dpv_owl:MaintainFraudDatabase ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:MakeAvailable a owl:Class ;
    rdfs:label "MakeAvailable" ;
    rdfs:subClassOf dpv:Disclose,
        dpv:Processing ;
    skos:altLabel "Make Available" ;
    skos:definition "to transform or publish data to be used" ;
    skos:exactMatch dpv:MakeAvailable,
        dpv_upstream:MakeAvailable,
        dpv_owl:MakeAvailable ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:ManageConsent a owl:Class ;
    rdfs:label "ManageConsent" ;
    rdfs:subClassOf dpv:ProvideConsent,
        dpv:ReaffirmConsent,
        dpv:WithdrawConsent ;
    skos:altLabel "Manage Consent" ;
    skos:definition """Control for managing a given consent in terms of providing, reaffirming,
or withdrawing it""" ;
    skos:exactMatch dpv:ManageConsent,
        dpv_upstream:ManageConsent,
        dpv_owl:ManageConsent ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    skos:note """Indicates how the data subject can manage their consent in terms of
providing it, or reaffirming or withdrawing a given consent. This
concept is useful to represent a single location or interface where
multiple controls are provided for consent""" ;
    dpv:skos_in_scheme "consent-controls-classes" .

dpv:ManagementStandard a owl:Class ;
    rdfs:label "ManagementStandard" ;
    rdfs:subClassOf dpv:OrganisationalMeasure,
        dpv:Standard ;
    skos:altLabel "Management Standard" ;
    skos:definition """A management standard is a standard that establishes norms or
requirements regarding the management operations and processes e.g. in
an organisation""" ;
    skos:exactMatch dpv:ManagementStandard,
        dpv_upstream:ManagementStandard,
        dpv_owl:ManagementStandard ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "organisational-measures-classes" .

dpv:Match a owl:Class ;
    rdfs:label "Match" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Use ;
    skos:altLabel "Match" ;
    skos:definition "to combine, compare, or match data from different sources" ;
    skos:exactMatch dpv:Match,
        dpv_upstream:Match,
        dpv_owl:Match ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-classes" .

dpv:MediumDataVolume a owl:Class ;
    rdfs:label "MediumDataVolume" ;
    rdfs:subClassOf dpv:DataVolume ;
    skos:altLabel "Medium Data Volume" ;
    skos:definition """Data volume that is considered medium i.e. neither large nor small
within the context""" ;
    skos:exactMatch dpv:MediumDataVolume,
        dpv_upstream:MediumDataVolume,
        dpv_owl:MediumDataVolume ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:MediumScaleOfDataSubjects a owl:Class ;
    rdfs:label "MediumScaleOfDataSubjects" ;
    rdfs:subClassOf dpv:DataSubjectScale ;
    skos:altLabel "Medium Scale Of Data Subjects" ;
    skos:definition """Scale of data subjects considered medium i.e. neither large nor small
within the context""" ;
    skos:exactMatch dpv:MediumScaleOfDataSubjects,
        dpv_upstream:MediumScaleOfDataSubjects,
        dpv_owl:MediumScaleOfDataSubjects ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:MediumScaleProcessing a owl:Class ;
    rdfs:label "MediumScaleProcessing" ;
    rdfs:subClassOf dpv:ProcessingScale ;
    skos:altLabel "Medium Scale Processing" ;
    skos:definition """Processing that takes place at medium scales (as specified by some
criteria)""" ;
    skos:exactMatch dpv:MediumScaleProcessing,
        dpv_upstream:MediumScaleProcessing,
        dpv_owl:MediumScaleProcessing ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-scale-classes" .

dpv:Member a owl:Class ;
    rdfs:label "Member" ;
    rdfs:subClassOf dpv:HumanSubject ;
    skos:altLabel "Member" ;
    skos:definition "Humans that are members of a group, organisation, or other collectives" ;
    skos:exactMatch dpv:Member,
        dpv_upstream:Member,
        dpv_owl:Member ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "entities-datasubject-classes" .

dpv:MemberPartnerManagement a owl:Class ;
    rdfs:label "MemberPartnerManagement" ;
    rdfs:subClassOf dpv:OrganisationGovernance,
        dpv:Purpose ;
    skos:altLabel "Members and Partners Management" ;
