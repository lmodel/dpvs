    rdfs:label "EncryptionInTransfer" ;
    rdfs:subClassOf dpv:Encryption,
        dpv:TechnicalMeasure ;
    skos:altLabel "Encryption in Transfer" ;
    skos:definition """Encryption of data in transit e.g. when being transferred from one
