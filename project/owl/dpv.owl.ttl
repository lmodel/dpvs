dpv:DocumentRandomisedPseudonymisation a owl:Class ;
    rdfs:label "DocumentRandomisedPseudonymisation" ;
    rdfs:subClassOf dpv:Pseudonymisation,
        dpv:TechnicalMeasure ;
    skos:altLabel "Document Randomised Pseudonymisation" ;
    skos:definition """Use of randomised pseudonymisation where the same elements are assigned
different values in the same document or database""" ;
    skos:exactMatch dpv:DocumentRandomisedPseudonymisation,
        dpv_upstream:DocumentRandomisedPseudonymisation,
        dpv_owl:DocumentRandomisedPseudonymisation ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
