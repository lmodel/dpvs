    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "purposes-classes" .

dpv:ProvideOfficialStatistics a owl:Class ;
    rdfs:label "ProvideOfficialStatistics" ;
    rdfs:subClassOf dpv:PublicBenefit,
        dpv:Purpose ;
    skos:altLabel "Provide Official Statistics" ;
    skos:definition """Purposes associated with facilitating the development, production and
