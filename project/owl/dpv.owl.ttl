dpv:DistributionAgreement a owl:Class ;
    rdfs:label "DistributionAgreement" ;
    rdfs:subClassOf dpv:ContractByDomain,
        dpv:LegalBasis ;
    skos:altLabel "Distribution Agreement" ;
    skos:definition """A contract regarding supply of data or technologies between a
