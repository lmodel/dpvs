dpv:EntityUnintendedInvolvement a owl:Class ;
    rdfs:label "EntityUnintendedInvolvement" ;
    rdfs:subClassOf dpv:EntityInvolvement,
        dpv:EntityInvolvementStatus,
        dpv:Unintended ;
    skos:altLabel "Entity Unintended Involvement" ;
    skos:definition "Status indicating the involvement of the entity is not intended" ;
    skos:exactMatch dpv:EntityUnintendedInvolvement,
        dpv_upstream:EntityUnintendedInvolvement,
        dpv_owl:EntityUnintendedInvolvement ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:skos_in_scheme "processing-context-classes" .

dpv:EnvironmentalProtection a owl:Class ;
    rdfs:label "EnvironmentalProtection" ;
    rdfs:subClassOf dpv:PhysicalMeasure ;
    skos:altLabel "Environmental Protection" ;
    skos:definition """Physical protection against environmental threats such as fire, floods,
storms, etc.""" ;
    skos:exactMatch dpv:EnvironmentalProtection,
        dpv_upstream:EnvironmentalProtection,
        dpv_owl:EnvironmentalProtection ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
    dpv:dct_source "NIST SP 800-13" ;
    dpv:skos_in_scheme "physical-measures-classes" .

dpv:Erase a owl:Class ;
    rdfs:label "Erase" ;
    rdfs:subClassOf dpv:Processing,
        dpv:Remove ;
    skos:altLabel "Erase" ;
    skos:definition "to remove data from existence i.e. without the possibility of retrieval" ;
    skos:exactMatch dpv:Erase,
        dpv_upstream:Erase,
        dpv_owl:Erase ;
    skos:inScheme <https://w3id.org/lmodel/dpv/core> ;
