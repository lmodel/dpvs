    skos:exactMatch dpv:ProhibitionUnviolated,
        dpv_owl:ProhibitionUnviolated,
        dpvs:ProhibitionUnviolated ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:ProhibitionViolated a owl:Class ;
    rdfs:label "ProhibitionViolated" ;
    rdfs:subClassOf dpvs:RuleFulfilmentStatus,
        dpvs:RuleViolated ;
    skos:altLabel "Prohibition Violated" ;
    skos:definition """Status indicating a prohibition has been violated i.e. the activity
