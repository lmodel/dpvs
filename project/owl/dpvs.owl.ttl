    skos:exactMatch dpv:LegalComplianceAudit,
        dpv_owl:LegalComplianceAudit,
        dpvs:LegalComplianceAudit ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

