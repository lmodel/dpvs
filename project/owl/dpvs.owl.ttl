    skos:inScheme dpvs:core ;
    skos:note """This concept will be deprecated in a future DPV release, it is suggested
to use the existing concepts representing device as tech:Software and
its taxonomy to have parity and consistency between the use of software
as a technology and as a virtual environment for data storage and
operations""" ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

