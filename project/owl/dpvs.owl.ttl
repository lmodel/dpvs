attack by a quantum computer""" ;
    skos:exactMatch dpv:PostQuantumCryptography,
        dpv_owl:PostQuantumCryptography,
        dpvs:PostQuantumCryptography ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:PostedNotice a owl:Class ;
    rdfs:label "PostedNotice" ;
    rdfs:subClassOf dpvs:Notice,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Posted Notice" ;
    skos:definition "A notice that is posted as a sign or banner" ;
    skos:exactMatch dpv:PostedNotice,
        dpv_owl:PostedNotice,
        dpvs:PostedNotice ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:PrimaryImportance a owl:Class ;
    rdfs:label "PrimaryImportance" ;
    rdfs:subClassOf dpvs:Importance ;
    skos:altLabel "Primary Importance" ;
    skos:definition "Indication of 'primary' or 'main' or 'core' importance" ;
    skos:exactMatch dpv:PrimaryImportance,
        dpv_owl:PrimaryImportance,
        dpvs:PrimaryImportance ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "context-classes" .

dpvs:PrimaryUse a owl:Class ;
    rdfs:label "PrimaryUse" ;
    rdfs:subClassOf dpvs:ReuseCompatibility ;
    skos:altLabel "Primary Use" ;
    skos:definition """Status indicating compatibility based on the use being either the
original context or something that is compatible with it""" ;
    skos:exactMatch dpv:PrimaryUse,
        dpv_owl:PrimaryUse,
        dpvs:PrimaryUse ;
    skos:inScheme dpvs:core ;
    skos:note """Primary Use refers to an assessment where two contexts are found to be
compatible, e.g. if purpose is used to test compatibility, then for two
activities the second activity is said be the primary use if its purpose
is compatible with the first activity's purpose""" ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:Principle a owl:Class ;
    rdfs:label "Principle" ;
    rdfs:subClassOf dpvs:GuidelinesPrinciple,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Principle" ;
    skos:definition """A representation of values or norms that must be taken into
consideration when conducting activities""" ;
    skos:exactMatch dpv:Principle,
        dpv_owl:Principle,
        dpvs:Principle ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:PrintedNotice a owl:Class ;
    rdfs:label "PrintedNotice" ;
    rdfs:subClassOf dpvs:Notice,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Printed Notice" ;
    skos:definition "A notice that is provided in a printed form on or along with a device" ;
    skos:exactMatch dpv:PrintedNotice,
        dpv_owl:PrintedNotice,
        dpvs:PrintedNotice ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:PrivacyByDefault a owl:Class ;
    rdfs:label "PrivacyByDefault" ;
    rdfs:subClassOf dpvs:GuidelinesPrinciple,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Privacy by Default" ;
    skos:definition """Practices regarding setting the default configurations of information
and services to implement data protection and privacy (synonymous with
Data Protection by Default)""" ;
    skos:exactMatch dpv:PrivacyByDefault,
        dpv_owl:PrivacyByDefault,
        dpvs:PrivacyByDefault ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:PrivacyByDesign a owl:Class ;
    rdfs:label "PrivacyByDesign" ;
    rdfs:subClassOf dpvs:GuidelinesPrinciple,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Privacy by Design" ;
    skos:definition """Practices regarding incorporating data protection and privacy in the
design of information and services (synonymous with Data Protection by
Design)""" ;
    skos:exactMatch dpv:PrivacyByDesign,
        dpv_owl:PrivacyByDesign,
        dpvs:PrivacyByDesign ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:PrivacyPreservingProtocol a owl:Class ;
    rdfs:label "PrivacyPreservingProtocol" ;
    rdfs:subClassOf dpvs:CryptographicMethods,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Privacy Preserving Protocol" ;
    skos:definition """Use of protocols designed with the intention of provided additional
guarantees regarding privacy""" ;
    skos:exactMatch dpv:PrivacyPreservingProtocol,
        dpv_owl:PrivacyPreservingProtocol,
        dpvs:PrivacyPreservingProtocol ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:PrivateCommunalSpace a owl:Class ;
    rdfs:label "PrivateCommunalSpace" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:PrivateSpace ;
    skos:altLabel "Private Communal Space" ;
    skos:definition """A space that is accessible to a group or a community within a private
space and where members of the public do not have access to it e.g.
society amenities such as gyms and pools""" ;
    skos:exactMatch dpv:PrivateCommunalSpace,
        dpv_owl:PrivateCommunalSpace,
        dpvs:PrivateCommunalSpace ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:PrivateInformationRetrieval a owl:Class ;
    rdfs:label "PrivateInformationRetrieval" ;
    rdfs:subClassOf dpvs:CryptographicMethods,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Private Information Retrieval" ;
    skos:definition """Use of cryptographic methods to retrieve a record from a system without
revealing which record is retrieved""" ;
    skos:exactMatch dpv:PrivateInformationRetrieval,
        dpv_owl:PrivateInformationRetrieval,
        dpvs:PrivateInformationRetrieval ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:PrivateLocation a owl:Class ;
    rdfs:label "PrivateLocation" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:LocalLocation ;
    skos:altLabel "Private Location (deprecated)" ;
    skos:definition """Location that is not or cannot be accessed by the public and is
controlled as a private space""" ;
    skos:exactMatch dpv:PrivateLocation,
        dpv_owl:PrivateLocation,
        dpvs:PrivateLocation ;
    skos:inScheme dpvs:core ;
    skos:note """This concept will be deprecated in a future DPV release, it is suggested
to use the better defined and legally aligned dpv:PrivateSpace instead""" ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:PrivateSectorBody a owl:Class ;
    rdfs:label "PrivateSectorBody" ;
    rdfs:subClassOf dpvs:LegalEntity ;
    skos:altLabel "Private Sector Body" ;
    skos:definition "An organisation owned and operated by private individuals or companies" ;
    skos:exactMatch dpv:PrivateSectorBody,
        dpv_owl:PrivateSectorBody,
        dpvs:PrivateSectorBody ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-organisation-classes" .

dpvs:PrivatelyOperatedPublicSpace a owl:Class ;
    rdfs:label "PrivatelyOperatedPublicSpace" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:HybridPublicPrivateSpace,
        dpvs:PubliclyAccessibleSpace ;
    skos:altLabel "Privately Operated Public Space" ;
    skos:definition """A space that is operated or managed by a private entity but which is
accessible to the public e.g. a public bus station operated by a
specific company""" ;
    skos:exactMatch dpv:PrivatelyOperatedPublicSpace,
        dpv_owl:PrivatelyOperatedPublicSpace,
        dpvs:PrivatelyOperatedPublicSpace ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:PrivatelyOwnedPublicSpace a owl:Class ;
    rdfs:label "PrivatelyOwnedPublicSpace" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:HybridPublicPrivateSpace,
        dpvs:PrivatelyOwnedSpace ;
    skos:altLabel "Privately Owned Public Space" ;
    skos:definition """A space that is privately owned but which is accessible and usable by
the public - whether freely or through a process which is open to all
members of the public e.g. hotel lobby, shopping mall atriums""" ;
    skos:exactMatch dpv:PrivatelyOwnedPublicSpace,
        dpv_owl:PrivatelyOwnedPublicSpace,
        dpvs:PrivatelyOwnedPublicSpace ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:ProfessionalConfidentialData a owl:Class ;
    rdfs:label "ProfessionalConfidentialData" ;
    rdfs:subClassOf dpvs:ConfidentialData ;
