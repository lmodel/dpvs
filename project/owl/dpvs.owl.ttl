    skos:inScheme dpvs:core ;
    skos:note """The fundamental rights and freedoms may be those defined in law or other
norms, and may be bound to a jurisdiction - for example see EU Charter
of Fundamental Rights""" ;
    dpvs:dct_source "AI Act Art.27" ;
    dpvs:skos_in_scheme "risk-classes" .

