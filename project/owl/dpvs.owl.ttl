        dpvs:RecruitmentManagement ;
    skos:altLabel "Recruitment Interview Management" ;
    skos:definition "Purposes associated conducting and managing interviews for recruitment" ;
    skos:exactMatch dpv:RecruitmentInterviewManagement,
