    skos:altLabel "Cannot Challenge Process Input" ;
    skos:definition "Involvement where entity cannot challenge input of specified context" ;
    skos:exactMatch dpv:CannotChallengeProcessInput,
        dpv_owl:CannotChallengeProcessInput,
