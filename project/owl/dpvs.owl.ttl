    rdfs:subClassOf dpvs:Consult,
        dpvs:Processing ;
    skos:altLabel "Monitor" ;
    skos:definition "to monitor data for some criteria" ;
    skos:exactMatch dpv:Monitor,
        dpv_owl:Monitor,
        dpvs:Monitor ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:MonitoringPolicy a owl:Class ;
    rdfs:label "MonitoringPolicy" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure,
        dpvs:Policy ;
    skos:altLabel "Monitoring Policy" ;
    skos:definition "Policy for monitoring (e.g. progress, performance)" ;
    skos:exactMatch dpv:MonitoringPolicy,
        dpv_owl:MonitoringPolicy,
        dpvs:MonitoringPolicy ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:MonotonicCounterPseudonymisation a owl:Class ;
    rdfs:label "MonotonicCounterPseudonymisation" ;
    rdfs:subClassOf dpvs:Pseudonymisation,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Monotonic Counter Pseudonymisation" ;
    skos:definition """A simple pseudonymisation method where identifiers are substituted by a
number chosen by a monotonic counter""" ;
    skos:exactMatch dpv:MonotonicCounterPseudonymisation,
        dpv_owl:MonotonicCounterPseudonymisation,
        dpvs:MonotonicCounterPseudonymisation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:Move a owl:Class ;
    rdfs:label "Move" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Transfer ;
    skos:altLabel "Move" ;
    skos:definition """to move data from one location to another including deleting the
original copy""" ;
    skos:exactMatch dpv:Move,
        dpv_owl:Move,
        dpvs:Move ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch svpr:Move ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:MultiFactorAuthentication a owl:Class ;
    rdfs:label "MultiFactorAuthentication" ;
    rdfs:subClassOf dpvs:AuthenticationProtocols,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Multi-Factor Authentication (MFA)" ;
    skos:definition "An authentication system that uses two or more methods to authenticate" ;
    skos:exactMatch dpv:MultiFactorAuthentication,
        dpv_owl:MultiFactorAuthentication,
        dpvs:MultiFactorAuthentication ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:MultiNationalScale a owl:Class ;
    rdfs:label "MultiNationalScale" ;
    rdfs:subClassOf dpvs:GeographicCoverage ;
    skos:altLabel "Multi National Scale" ;
    skos:definition "Geographic coverage spanning multiple nations" ;
    skos:exactMatch dpv:MultiNationalScale,
        dpv_owl:MultiNationalScale,
        dpvs:MultiNationalScale ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-scale-classes" .

dpvs:NDA a owl:Class ;
    rdfs:label "NDA" ;
    rdfs:subClassOf dpvs:LegalAgreement,
        dpvs:LegalMeasure ;
    skos:altLabel "Non-Disclosure Agreement (NDA)" ;
    skos:definition "Non-disclosure Agreements e.g. preserving confidentiality of information" ;
    skos:exactMatch dpv:NDA,
        dpv_owl:NDA,
        dpvs:NDA ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-measures-classes" .

dpvs:NationalAuthority a owl:Class ;
    rdfs:label "NationalAuthority" ;
    rdfs:subClassOf dpvs:DpvAuthority ;
    skos:altLabel "National Authority" ;
    skos:definition "An authority tasked with overseeing legal compliance for a nation" ;
    skos:exactMatch dpv:NationalAuthority,
        dpv_owl:NationalAuthority,
        dpvs:NationalAuthority ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-authority-classes" .

dpvs:NationalScale a owl:Class ;
    rdfs:label "NationalScale" ;
    rdfs:subClassOf dpvs:GeographicCoverage ;
    skos:altLabel "National Scale" ;
    skos:definition "Geographic coverage spanning a nation" ;
    skos:exactMatch dpv:NationalScale,
        dpv_owl:NationalScale,
        dpvs:NationalScale ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-scale-classes" .

dpvs:NaturalPerson a owl:Class ;
    rdfs:label "NaturalPerson" ;
    rdfs:subClassOf dpvs:DpvEntity ;
    skos:altLabel "Natural Person" ;
    skos:closeMatch ocsf:User ;
    skos:definition "A human" ;
    skos:exactMatch dpv:NaturalPerson,
        dpv_owl:NaturalPerson,
        common_domain_model:NaturalPerson,
        dpvs:NaturalPerson,
        gists:Person ;
    skos:inScheme dpvs:core ;
    skos:narrowMatch oscal:Party ;
    dpvs:skos_in_scheme "entities-classes" .

dpvs:NearlyGlobalScale a owl:Class ;
    rdfs:label "NearlyGlobalScale" ;
    rdfs:subClassOf dpvs:GeographicCoverage ;
    skos:altLabel "Nearly Global Scale" ;
    skos:definition "Geographic coverage nearly spanning the entire globe" ;
    skos:exactMatch dpv:NearlyGlobalScale,
        dpv_owl:NearlyGlobalScale,
        dpvs:NearlyGlobalScale ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-scale-classes" .

dpvs:NegotiateContract a owl:Class ;
    rdfs:label "NegotiateContract" ;
    rdfs:subClassOf dpvs:ContractControl ;
    skos:altLabel "Negotiate Contract" ;
    skos:definition "Control for negotiating a contract" ;
    skos:exactMatch dpv:NegotiateContract,
        dpv_owl:NegotiateContract,
        dpvs:NegotiateContract ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-control-classes" .

dpvs:NegotiatedContract a owl:Class ;
    rdfs:label "NegotiatedContract" ;
    rdfs:subClassOf dpvs:ContractByNegotiationType,
        dpvs:LegalBasis ;
    skos:altLabel "Negotiated Contract" ;
    skos:definition """A contract where the terms and conditions are determined with all
parties having the ability to negotiate the terms and conditions""" ;
    skos:exactMatch dpv:NegotiatedContract,
        dpv_owl:NegotiatedContract,
        dpvs:NegotiatedContract ;
    skos:inScheme dpvs:core ;
    skos:note """Negotiation here refers to the opportunity for a party on their own
initiative to modify or dictate terms and conditions within a contract.
If the party is provided a set of options to choose from or in other
ways is dictated which terms and conditions can be present in the
contract, neither of these should be considered a negotiation""" ;
    dpvs:skos_in_scheme "contract-types-classes" .

dpvs:NetworkProxyRouting a owl:Class ;
    rdfs:label "NetworkProxyRouting" ;
    rdfs:subClassOf dpvs:SecurityMethod,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Network Proxy Routing" ;
    skos:definition "Use of network routing using proxy" ;
    skos:exactMatch dpv:NetworkProxyRouting,
        dpv_owl:NetworkProxyRouting,
        dpvs:NetworkProxyRouting ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:NetworkSecurityProtocols a owl:Class ;
    rdfs:label "NetworkSecurityProtocols" ;
    rdfs:subClassOf dpvs:SecurityMethod,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Network Security Protocols" ;
    skos:definition "Security implemented at or over networks protocols" ;
    skos:exactMatch dpv:NetworkSecurityProtocols,
        dpv_owl:NetworkSecurityProtocols,
        dpvs:NetworkSecurityProtocols ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:NonCitizen a owl:Class ;
    rdfs:label "NonCitizen" ;
    rdfs:subClassOf dpvs:HumanSubject ;
    skos:altLabel "Non-Citizen" ;
    skos:definition "Humans that are not citizens (for a jurisdiction)" ;
    skos:exactMatch dpv:NonCitizen,
        dpv_owl:NonCitizen,
        dpvs:NonCitizen ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

dpvs:NonCommercialResearch a owl:Class ;
    rdfs:label "NonCommercialResearch" ;
    rdfs:subClassOf dpvs:NonCommercialPurpose,
        dpvs:Purpose,
        dpvs:ResearchAndDevelopment ;
    skos:altLabel "Non-Commercial Research" ;
    skos:definition """Purposes associated with conducting research in a non-commercial setting
e.g. for a non-profit-organisation (NGO)""" ;
    skos:exactMatch dpv:NonCommercialResearch,
        dpv_owl:NonCommercialResearch,
        dpvs:NonCommercialResearch ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:NonCompliant a owl:Class ;
    rdfs:label "NonCompliant" ;
    rdfs:subClassOf dpvs:ComplianceStatus ;
    skos:altLabel "Non Compliant" ;
    skos:definition """State of non-compliance where objectives have not been met, but have not
been violated""" ;
    skos:exactMatch dpv:NonCompliant,
        dpv_owl:NonCompliant,
        dpvs:NonCompliant ;
    skos:inScheme dpvs:core ;
    skos:note "Changed from not compliant for consistency in commonly used terms" ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:NonConformant a owl:Class ;
    rdfs:label "NonConformant" ;
    rdfs:subClassOf dpvs:ConformanceStatus ;
    skos:altLabel "NonConformant" ;
    skos:definition "State of being non-conformant" ;
    skos:exactMatch dpv:NonConformant,
        dpv_owl:NonConformant,
        dpvs:NonConformant ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:NonGovernmentalOrganisation a owl:Class ;
    rdfs:label "NonGovernmentalOrganisation" ;
    rdfs:subClassOf dpvs:DpvOrganisation ;
    skos:altLabel "Non-Governmental Organisation" ;
    skos:definition "An organisation not part of or independent from the government" ;
    skos:exactMatch dpv:NonGovernmentalOrganisation,
        dpv_owl:NonGovernmentalOrganisation,
        dpvs:NonGovernmentalOrganisation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-organisation-classes" .

dpvs:NonPersonalDataProcess a owl:Class ;
    rdfs:label "NonPersonalDataProcess" ;
    rdfs:subClassOf dpvs:DpvProcess ;
    skos:altLabel "Non-Personal Data Process" ;
    skos:definition """An action, activity, or method involving non-personal data, and
asserting that no personal data is involved""" ;
    skos:exactMatch dpv:NonPersonalDataProcess,
        dpv_owl:NonPersonalDataProcess,
        dpvs:NonPersonalDataProcess ;
    skos:inScheme dpvs:core ;
    skos:note """Use of personal data within NonPersonalDataProcess should be considered
a violation of the explicit constraint that no personal data is
involved.""" ;
    dpvs:skos_in_scheme "process-classes" .

dpvs:NonProfitOrganisation a owl:Class ;
    rdfs:label "NonProfitOrganisation" ;
    rdfs:subClassOf dpvs:DpvOrganisation ;
    skos:altLabel "Non-Profit Organisation" ;
    skos:definition "An organisation that does not aim to achieve profit as its primary goal" ;
    skos:exactMatch dpv:NonProfitOrganisation,
        dpv_owl:NonProfitOrganisation,
        dpvs:NonProfitOrganisation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-organisation-classes" .

dpvs:NonPublicDataSource a owl:Class ;
    rdfs:label "NonPublicDataSource" ;
    rdfs:subClassOf dpvs:DataSource ;
    skos:altLabel "Non-Public Data Source" ;
    skos:definition "A source of data that is not publicly accessible or available" ;
    skos:exactMatch dpv:NonPublicDataSource,
        dpv_owl:NonPublicDataSource,
        dpvs:NonPublicDataSource ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:NotApplicable a owl:Class ;
    rdfs:label "NotApplicable" ;
    rdfs:subClassOf dpvs:Applicability ;
    skos:altLabel "Not Applicable" ;
    skos:definition "Concept indicating the information or context is not applicable" ;
    skos:exactMatch dpv:NotApplicable,
        dpv_owl:NotApplicable,
        dpvs:NotApplicable ;
    skos:inScheme dpvs:core ;
    skos:note """This relates to a 'Stop' state as distinct from a 'Halt' state. It makes
no comments on whether the Activity can be resumed or continued towards
completion.""" ;
    dpvs:skos_in_scheme "context-classes" .

dpvs:NotAutomated a owl:Class ;
    rdfs:label "NotAutomated" ;
    rdfs:subClassOf dpvs:AutomationLevel ;
    skos:altLabel "Not Automated" ;
    skos:definition """Level of automation corresponding to Level 0 in ISO/IEC 22989:2022 where
there is no automation in the system""" ;
    skos:exactMatch dpv:NotAutomated,
        dpv_owl:NotAutomated,
        dpvs:NotAutomated ;
    skos:inScheme dpvs:core ;
    skos:note "Human Involvement is necessary here as there is no automation" ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:NotAvailable a owl:Class ;
    rdfs:label "NotAvailable" ;
    rdfs:subClassOf dpvs:Applicability ;
    skos:altLabel "Not Available" ;
    skos:definition """Concept indicating the information or context is applicable but
information is not yet available""" ;
    skos:exactMatch dpv:NotAvailable,
        dpv_owl:NotAvailable,
        dpvs:NotAvailable ;
    skos:inScheme dpvs:core ;
    skos:note """This concept is useful when describing situations where information is
required but is not available (yet). For example, if in a form a field
asks about whether a process X was completed, and it is correct to
interpret that process X is applicable and must be completed, but the
information is not yet available as to whether this was done - then
NotAvailable is useful to represent this.""" ;
    dpvs:skos_in_scheme "context-classes" .

dpvs:NotInvolved a owl:Class ;
    rdfs:label "NotInvolved" ;
    rdfs:subClassOf dpvs:InvolvementStatus ;
    skos:altLabel "Not Involved" ;
    skos:definition "Status indicating the specified context is 'not' involved" ;
    skos:exactMatch dpv:NotInvolved,
        dpv_owl:NotInvolved,
        dpvs:NotInvolved ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:NotRequired a owl:Class ;
    rdfs:label "NotRequired" ;
    rdfs:subClassOf dpvs:Necessity ;
    skos:altLabel "Not Required" ;
    skos:definition """Indication of neither being required nor optional i.e. not relevant or
needed""" ;
    skos:exactMatch dpv:NotRequired,
        dpv_owl:NotRequired,
        dpvs:NotRequired ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "context-classes" .

dpvs:NoticeCommunicated a owl:Class ;
    rdfs:label "NoticeCommunicated" ;
    rdfs:subClassOf dpvs:NoticeStatus ;
    skos:altLabel "Notice Communicated" ;
    skos:definition "Status indicating the notice has been communicated" ;
    skos:exactMatch dpv:NoticeCommunicated,
        dpv_owl:NoticeCommunicated,
        dpvs:NoticeCommunicated ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:NoticeGenerated a owl:Class ;
    rdfs:label "NoticeGenerated" ;
    rdfs:subClassOf dpvs:NoticeStatus ;
    skos:altLabel "Notice Generated" ;
    skos:definition "Status indicating the notice has been generated" ;
    skos:exactMatch dpv:NoticeGenerated,
        dpv_owl:NoticeGenerated,
        dpvs:NoticeGenerated ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:NoticeLatest a owl:Class ;
    rdfs:label "NoticeLatest" ;
    rdfs:subClassOf dpvs:NoticeStatus ;
    skos:altLabel "Notice Latest" ;
    skos:definition "Status indicating the notice is currently at its latest iteration" ;
    skos:exactMatch dpv:NoticeLatest,
        dpv_owl:NoticeLatest,
        dpvs:NoticeLatest ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:NoticeStale a owl:Class ;
    rdfs:label "NoticeStale" ;
    rdfs:subClassOf dpvs:NoticeStatus ;
    skos:altLabel "Notice Stale" ;
    skos:definition """Status indicating the notice is stale or not up to date or not the
latest version""" ;
    skos:exactMatch dpv:NoticeStale,
        dpv_owl:NoticeStale,
        dpvs:NoticeStale ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:NoticeUnused a owl:Class ;
    rdfs:label "NoticeUnused" ;
    rdfs:subClassOf dpvs:NoticeStatus ;
    skos:altLabel "Notice Unused" ;
    skos:definition """Status indicating the notice has been communicated but has not yet been
used e.g. the recipient has not acknowledged it or has not taken the
intended action""" ;
    skos:exactMatch dpv:NoticeUnused,
        dpv_owl:NoticeUnused,
        dpvs:NoticeUnused ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:NoticeUpdated a owl:Class ;
    rdfs:label "NoticeUpdated" ;
    rdfs:subClassOf dpvs:NoticeStatus ;
    skos:altLabel "Notice Updated" ;
    skos:definition """Status indicating the notice has been updated and its contents or
implications have changed""" ;
    skos:exactMatch dpv:NoticeUpdated,
        dpv_owl:NoticeUpdated,
        dpvs:NoticeUpdated ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:NoticeUsed a owl:Class ;
    rdfs:label "NoticeUsed" ;
    rdfs:subClassOf dpvs:NoticeStatus ;
    skos:altLabel "Notice Used" ;
    skos:definition """Status indicating the notice has been communicated and has been used
e.g. the recipient has acknowledged it or taken the intended action""" ;
    skos:exactMatch dpv:NoticeUsed,
        dpv_owl:NoticeUsed,
        dpvs:NoticeUsed ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:NotificationCompleted a owl:Class ;
    rdfs:label "NotificationCompleted" ;
    rdfs:subClassOf dpvs:NotificationStatus ;
    skos:altLabel "Notification Completed" ;
    skos:definition "Status indicating notification(s) are completed" ;
    skos:exactMatch dpv:NotificationCompleted,
        dpv_owl:NotificationCompleted,
        dpvs:NotificationCompleted ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:NotificationFailed a owl:Class ;
    rdfs:label "NotificationFailed" ;
    rdfs:subClassOf dpvs:NotificationStatus ;
    skos:altLabel "Notification Failed" ;
    skos:definition """Status indicating notification(s) could not be completed due to a
failure""" ;
    skos:exactMatch dpv:NotificationFailed,
        dpv_owl:NotificationFailed,
        dpvs:NotificationFailed ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:NotificationNotNeeded a owl:Class ;
    rdfs:label "NotificationNotNeeded" ;
    rdfs:subClassOf dpvs:NotificationStatus ;
    skos:altLabel "Notification Not Needed" ;
    skos:definition "Status indicating notification(s) are not needed" ;
    skos:exactMatch dpv:NotificationNotNeeded,
        dpv_owl:NotificationNotNeeded,
        dpvs:NotificationNotNeeded ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:NotificationOngoing a owl:Class ;
    rdfs:label "NotificationOngoing" ;
    rdfs:subClassOf dpvs:NotificationStatus ;
    skos:altLabel "Notification Ongoing" ;
    skos:definition "Status indicating notification(s) are ongoing" ;
    skos:exactMatch dpv:NotificationOngoing,
        dpv_owl:NotificationOngoing,
        dpvs:NotificationOngoing ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:NotificationPlanned a owl:Class ;
    rdfs:label "NotificationPlanned" ;
    rdfs:subClassOf dpvs:NotificationStatus ;
    skos:altLabel "Notification Planned" ;
    skos:definition "Status indicating notification(s) are planned" ;
    skos:exactMatch dpv:NotificationPlanned,
        dpv_owl:NotificationPlanned,
        dpvs:NotificationPlanned ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:ObjectingToProcess a owl:Class ;
    rdfs:label "ObjectingToProcess" ;
    rdfs:subClassOf dpvs:EntityPermissiveInvolvement ;
    skos:altLabel "Objecting to Process" ;
    skos:definition "Involvement where entity can object to process of specified context" ;
    skos:exactMatch dpv:ObjectingToProcess,
        dpv_owl:ObjectingToProcess,
        dpvs:ObjectingToProcess ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:Obligation a owl:Class ;
    rdfs:label "Obligation" ;
    rdfs:subClassOf dpvs:AcceptableRule,
        dpvs:Rule ;
    skos:altLabel "Obligation" ;
    skos:closeMatch gists:ContingentObligation ;
    skos:definition "A rule describing an obligation for performing an activity" ;
    skos:exactMatch dpv:Obligation,
        dpv_owl:Obligation,
        dpvs:Obligation ;
    skos:inScheme dpvs:core ;
    skos:note """Obligations are aligned with the term MUST in RFC2119 where specified
activities are mandatory to be carried out""" ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:ObligationFulfilled a owl:Class ;
    rdfs:label "ObligationFulfilled" ;
    rdfs:subClassOf dpvs:RuleFulfilled,
        dpvs:RuleFulfilmentStatus ;
    skos:altLabel "Obligation Fulfilled" ;
    skos:definition """Status indicating an obligation has been fulfilled i.e. the activity
stated as being required to be carried out has been successfully
completed""" ;
    skos:exactMatch dpv:ObligationFulfilled,
        dpv_owl:ObligationFulfilled,
        dpvs:ObligationFulfilled ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:ObligationUnfulfilled a owl:Class ;
    rdfs:label "ObligationUnfulfilled" ;
    rdfs:subClassOf dpvs:RuleFulfilmentStatus,
        dpvs:RuleUnfulfilled ;
    skos:altLabel "Obligation Unfulfilled" ;
    skos:definition """Status indicating an obligation has not been fulfilled i.e. the activity
stated as being required to be carried out has not been carried out but
this is not considered as a violation e.g. there is still time to
conduct the activity""" ;
    skos:exactMatch dpv:ObligationUnfulfilled,
        dpv_owl:ObligationUnfulfilled,
        dpvs:ObligationUnfulfilled ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:ObligationViolated a owl:Class ;
    rdfs:label "ObligationViolated" ;
    rdfs:subClassOf dpvs:RuleFulfilmentStatus,
        dpvs:RuleViolated ;
    skos:altLabel "Obligation Violated" ;
    skos:definition """Status indicating an obligation has been violated i.e. the activity
stated as being required to be carried out has not been carried out and
this is considered as a violation i.e. the activity can no longer be
carried out to fulfil the obligation""" ;
    skos:exactMatch dpv:ObligationViolated,
        dpv_owl:ObligationViolated,
        dpvs:ObligationViolated ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:Observe a owl:Class ;
    rdfs:label "Observe" ;
    rdfs:subClassOf dpvs:Obtain,
        dpvs:Processing ;
    skos:altLabel "Observe" ;
    skos:definition "to obtain data through observation" ;
    skos:exactMatch dpv:Observe,
        dpv_owl:Observe,
        dpvs:Observe ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:ObservedPersonalData a owl:Class ;
    rdfs:label "ObservedPersonalData" ;
    rdfs:subClassOf dpvs:CollectedPersonalData,
        dpvs:ObservedData ;
    skos:altLabel "Observed Personal Data" ;
    skos:definition """Personal Data that has been collected through observation of the Data
Subject(s)""" ;
    skos:exactMatch dpv:ObservedPersonalData,
        dpv_owl:ObservedPersonalData,
        dpvs:ObservedPersonalData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:ObtainConsent a owl:Class ;
    rdfs:label "ObtainConsent" ;
    rdfs:subClassOf dpvs:ConsentControl ;
    skos:altLabel "Obtain Consent" ;
    skos:definition "Control for obtaining consent" ;
    skos:exactMatch dpv:ObtainConsent,
        dpv_owl:ObtainConsent,
        dpvs:ObtainConsent ;
    skos:inScheme dpvs:core ;
    skos:note """Indicates how the controller or entity can obtain consent e.g. used with
dpv:isExercisedAt""" ;
    dpvs:skos_in_scheme "consent-controls-classes" .

dpvs:OfferContract a owl:Class ;
    rdfs:label "OfferContract" ;
    rdfs:subClassOf dpvs:ContractControl ;
    skos:altLabel "Offer Contract" ;
    skos:definition "Control for offering a contract" ;
    skos:exactMatch dpv:OfferContract,
        dpv_owl:OfferContract,
        dpvs:OfferContract ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-control-classes" .

dpvs:OfficialAuthorityExerciseCompleted a owl:Class ;
    rdfs:label "OfficialAuthorityExerciseCompleted" ;
    rdfs:subClassOf dpvs:OfficialAuthorityExerciseStatus ;
    skos:altLabel "Official Authority Exercise Completed" ;
    skos:definition "Status where the official authority has been exercised to completion" ;
    skos:exactMatch dpv:OfficialAuthorityExerciseCompleted,
        dpv_owl:OfficialAuthorityExerciseCompleted,
        dpvs:OfficialAuthorityExerciseCompleted ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-status-classes" .

dpvs:OfficialAuthorityExerciseOngoing a owl:Class ;
    rdfs:label "OfficialAuthorityExerciseOngoing" ;
    rdfs:subClassOf dpvs:OfficialAuthorityExerciseStatus ;
    skos:altLabel "Official Authority Exercise Ongoing" ;
    skos:definition "Status where the official authority is being exercised" ;
    skos:exactMatch dpv:OfficialAuthorityExerciseOngoing,
        dpv_owl:OfficialAuthorityExerciseOngoing,
        dpvs:OfficialAuthorityExerciseOngoing ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-status-classes" .

dpvs:OfficialAuthorityExercisePending a owl:Class ;
    rdfs:label "OfficialAuthorityExercisePending" ;
    rdfs:subClassOf dpvs:OfficialAuthorityExerciseStatus ;
    skos:altLabel "Official Authority Exercise Pending" ;
    skos:definition "Status where the official authority has not been exercised" ;
    skos:exactMatch dpv:OfficialAuthorityExercisePending,
        dpv_owl:OfficialAuthorityExercisePending,
        dpvs:OfficialAuthorityExercisePending ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-status-classes" .

dpvs:OfficialAuthorityOfController a owl:Class ;
    rdfs:label "OfficialAuthorityOfController" ;
    rdfs:subClassOf dpvs:LegalBasis ;
    skos:altLabel "Official Authority of Controller" ;
    skos:definition """Activities are necessary or authorised through the official authority
granted to or vested in the Data Controller""" ;
    skos:exactMatch dpv:OfficialAuthorityOfController,
        dpv_owl:OfficialAuthorityOfController,
        dpvs:OfficialAuthorityOfController ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-classes" .

dpvs:OftenFrequency a owl:Class ;
    rdfs:label "OftenFrequency" ;
    rdfs:subClassOf dpvs:Frequency ;
    skos:altLabel "Often Frequency" ;
    skos:definition "Frequency where occurrences are often or frequent, but not continuous" ;
    skos:exactMatch dpv:OftenFrequency,
        dpv_owl:OftenFrequency,
        dpvs:OftenFrequency ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "context-classes" .

dpvs:OperatingSystemSecurity a owl:Class ;
    rdfs:label "OperatingSystemSecurity" ;
    rdfs:subClassOf dpvs:SecurityMethod,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Operating System Security" ;
    skos:definition "Security implemented at or through operating systems" ;
    skos:exactMatch dpv:OperatingSystemSecurity,
        dpv_owl:OperatingSystemSecurity,
        dpvs:OperatingSystemSecurity ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:OptimiseUserInterface a owl:Class ;
    rdfs:label "OptimiseUserInterface" ;
    rdfs:subClassOf dpvs:OptimisationForConsumer,
        dpvs:Purpose ;
    skos:altLabel "Optimise User Interface" ;
    skos:definition """Purposes associated with optimisation of interfaces presented to the
user""" ;
    skos:exactMatch dpv:OptimiseUserInterface,
        dpv_owl:OptimiseUserInterface,
        dpvs:OptimiseUserInterface ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:OptingOutFromProcess a owl:Class ;
    rdfs:label "OptingOutFromProcess" ;
    rdfs:subClassOf dpvs:EntityPermissiveInvolvement ;
    skos:altLabel "Opting out of Process" ;
    skos:definition "Involvement where entity can opt-out from specified context" ;
    skos:exactMatch dpv:OptingOutFromProcess,
        dpv_owl:OptingOutFromProcess,
        dpvs:OptingOutFromProcess ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:OralNotice a owl:Class ;
    rdfs:label "OralNotice" ;
    rdfs:subClassOf dpvs:Notice,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Oral Notice" ;
    skos:definition "A notice provided orally or verbally" ;
    skos:exactMatch dpv:OralNotice,
        dpv_owl:OralNotice,
        dpvs:OralNotice ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:OrganisationComplianceManagement a owl:Class ;
    rdfs:label "OrganisationComplianceManagement" ;
    rdfs:subClassOf dpvs:OrganisationGovernance,
        dpvs:Purpose ;
    skos:altLabel "Organisation Compliance Management" ;
    skos:definition """Purposes associated with managing compliance for organisation in
relation to internal policies""" ;
    skos:exactMatch dpv:OrganisationComplianceManagement,
        dpv_owl:OrganisationComplianceManagement,
        dpvs:OrganisationComplianceManagement ;
    skos:inScheme dpvs:core ;
    skos:note """Note that this concept relates to internal organisational compliance.
The concept LegalCompliance should be used for external legal or
regulatory compliance.""" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:OrganisationRiskManagement a owl:Class ;
    rdfs:label "OrganisationRiskManagement" ;
    rdfs:subClassOf dpvs:OrganisationGovernance,
        dpvs:Purpose ;
    skos:altLabel "Organisation Risk Management" ;
    skos:definition "Purposes associated with managing risk for organisation's activities" ;
    skos:exactMatch dpv:OrganisationRiskManagement,
        dpv_owl:OrganisationRiskManagement,
        dpvs:OrganisationRiskManagement ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch iso27001:RiskAssessmentProcess ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:OrganisationalUnit a owl:Class ;
    rdfs:label "OrganisationalUnit" ;
    rdfs:subClassOf dpvs:DpvEntity ;
    skos:altLabel "Organisational Unit" ;
    skos:closeMatch common_domain_model:BusinessUnit,
        iso27001:Organization ;
    skos:definition """Entity within an organisation that does not constitute as a separate
legal entity""" ;
    skos:exactMatch dpv:OrganisationalUnit,
        dpv_owl:OrganisationalUnit,
        dpvs:OrganisationalUnit ;
    skos:inScheme dpvs:core ;
    skos:narrowMatch gists:Organization ;
    dpvs:skos_in_scheme "entities-organisation-classes" .

dpvs:PIA a owl:Class ;
    rdfs:label "PIA" ;
    rdfs:subClassOf dpvs:ImpactAssessment,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Privacy Impact Assessment (PIA)" ;
    skos:closeMatch iso42001:AISystemImpactAssessment ;
    skos:definition "Impact assessment regarding privacy risks" ;
    skos:exactMatch dpv:PIA,
        dpv_owl:PIA,
        dpvs:PIA,
        iso29100:PrivacyImpactAssessment ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "risk-classes" .

dpvs:ParentLegalEntity a owl:Class ;
    rdfs:label "ParentLegalEntity" ;
    rdfs:subClassOf dpvs:DpvOrganisation ;
    skos:altLabel "Parent Legal Entity" ;
    skos:definition """A legal entity that has one or more subsidiary entities operating under
it""" ;
    skos:exactMatch dpv:ParentLegalEntity,
        dpv_owl:ParentLegalEntity,
        dpvs:ParentLegalEntity ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-classes" .

dpvs:ParentOfDataSubject a owl:Class ;
    rdfs:label "ParentOfDataSubject" ;
    rdfs:subClassOf dpvs:HumanSubject,
        dpvs:ParentOfHuman ;
    skos:altLabel "Parent(s) of Data Subject" ;
    skos:definition "Parent(s) of data subjects such as children" ;
    skos:exactMatch dpv:ParentOfDataSubject,
        dpv_owl:ParentOfDataSubject,
        dpvs:ParentOfDataSubject ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

dpvs:PartialAutomation a owl:Class ;
    rdfs:label "PartialAutomation" ;
    rdfs:subClassOf dpvs:AutomationLevel ;
    skos:altLabel "Partial Automation" ;
    skos:definition """Level of automation corresponding to Level 2 in ISO/IEC 22989:2022 where
the automation is present in multiple parts of the system or in a manner
that does not require the human to control/use these parts while still
retaining control over the system""" ;
    skos:exactMatch dpv:PartialAutomation,
        dpv_owl:PartialAutomation,
        dpvs:PartialAutomation ;
    skos:inScheme dpvs:core ;
    skos:note """Human Involvement is implied here, specifically the ability to Control
operations, but also possibly for intervention, oversight, and
verification""" ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:PartiallyCompliant a owl:Class ;
    rdfs:label "PartiallyCompliant" ;
    rdfs:subClassOf dpvs:ComplianceStatus ;
    skos:altLabel "Partially Compliant" ;
    skos:definition """State of partially being compliant i.e. only some objectives have been
met, and others have not been in violation""" ;
    skos:exactMatch dpv:PartiallyCompliant,
        dpv_owl:PartiallyCompliant,
        dpvs:PartiallyCompliant ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:Participant a owl:Class ;
    rdfs:label "Participant" ;
    rdfs:subClassOf dpvs:HumanSubject ;
    skos:altLabel "Participant" ;
    skos:definition "Humans that participate in some context such as volunteers in a function" ;
    skos:exactMatch dpv:Participant,
        dpv_owl:Participant,
        dpvs:Participant ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

dpvs:PassiveRight a owl:Class ;
    rdfs:label "PassiveRight" ;
    rdfs:subClassOf dpvs:Right ;
    skos:altLabel "Passive Right" ;
    skos:definition """The right(s) applicable, provided, or expected that are always
(passively) applicable""" ;
    skos:exactMatch dpv:PassiveRight,
        dpv_owl:PassiveRight,
        dpvs:PassiveRight ;
    skos:inScheme dpvs:core ;
    skos:note """Passive rights do not require the entity to request or exercise them.
They are considered to be always applicable. For example, the Right to
Privacy (in EU) does not require an exercise for it to be fulfilled.""" ;
    dpvs:skos_in_scheme "rights-classes" .

dpvs:PassivelyInvolved a owl:Class ;
    rdfs:label "PassivelyInvolved" ;
    rdfs:subClassOf dpvs:InvolvementStatus ;
    skos:altLabel "Passively Involved" ;
    skos:definition "Status indicating the specified context is 'passively' involved" ;
    skos:exactMatch dpv:PassivelyInvolved,
        dpv_owl:PassivelyInvolved,
        dpvs:PassivelyInvolved ;
    skos:inScheme dpvs:core ;
    skos:note "An example of passive involvement is a person being monitored by a CCTV" ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:PasswordAuthentication a owl:Class ;
    rdfs:label "PasswordAuthentication" ;
    rdfs:subClassOf dpvs:AuthenticationProtocols,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Password Authentication" ;
    skos:definition "Use of passwords to perform authentication" ;
    skos:exactMatch dpv:PasswordAuthentication,
        dpv_owl:PasswordAuthentication,
        dpvs:PasswordAuthentication ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:Patient a owl:Class ;
    rdfs:label "Patient" ;
    rdfs:subClassOf dpvs:HumanSubject ;
    skos:altLabel "Patient" ;
    skos:definition """Humans that receive medical attention, treatment, care, advice, or other
health related services""" ;
    skos:exactMatch dpv:Patient,
        dpv_owl:Patient,
        dpvs:Patient ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

dpvs:PaymentManagement a owl:Class ;
    rdfs:label "PaymentManagement" ;
    rdfs:subClassOf dpvs:Purpose,
        dpvs:ServiceManagement ;
    skos:altLabel "Payment Management" ;
    skos:definition """Purposes associated with processing and managing payment in relation to
service, including invoicing and records""" ;
    skos:exactMatch dpv:PaymentManagement,
        dpv_owl:PaymentManagement,
        dpvs:PaymentManagement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PenetrationTestingMethods a owl:Class ;
    rdfs:label "PenetrationTestingMethods" ;
    rdfs:subClassOf dpvs:SecurityMethod,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Penetration Testing Methods" ;
    skos:definition """Use of penetration testing to identify weaknesses and vulnerabilities
through simulations""" ;
    skos:exactMatch dpv:PenetrationTestingMethods,
        dpv_owl:PenetrationTestingMethods,
        dpvs:PenetrationTestingMethods ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:Permission a owl:Class ;
    rdfs:label "Permission" ;
    rdfs:subClassOf dpvs:AcceptableRule,
        dpvs:Rule ;
    skos:altLabel "Permission" ;
    skos:definition "A rule describing a permission to perform an activity" ;
    skos:exactMatch dpv:Permission,
        dpv_owl:Permission,
        dpvs:Permission,
        gists:Permission ;
    skos:inScheme dpvs:core ;
    skos:note """Permissions are aligned with the term MAY in RFC2119 where specified
activities may or may not be carried out""" ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:PermissionNotUtilised a owl:Class ;
    rdfs:label "PermissionNotUtilised" ;
    rdfs:subClassOf dpvs:RuleFulfilled,
        dpvs:RuleFulfilmentStatus ;
    skos:altLabel "Permission Not Utilised" ;
    skos:definition """Status indicating a permission has not been utilised i.e. the activity
stated as being permitted has not been carried out""" ;
    skos:exactMatch dpv:PermissionNotUtilised,
        dpv_owl:PermissionNotUtilised,
        dpvs:PermissionNotUtilised ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:PermissionUtilised a owl:Class ;
    rdfs:label "PermissionUtilised" ;
    rdfs:subClassOf dpvs:RuleFulfilled,
        dpvs:RuleFulfilmentStatus ;
    skos:altLabel "Permission Utilised" ;
    skos:definition """Status indicating a permission has been utilised i.e. the activity
stated as being permitted has been carried out""" ;
    skos:exactMatch dpv:PermissionUtilised,
        dpv_owl:PermissionUtilised,
        dpvs:PermissionUtilised ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:PersonalDataAudit a owl:Class ;
    rdfs:label "PersonalDataAudit" ;
    rdfs:subClassOf dpvs:InformationAudit,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Personal Data Audit" ;
    skos:definition """An audit that systematically examines the existence and use of personal
data along with its associated resources (e.g. where it is stored) and
flows (e.g. where it originates and with whom it is being shared)""" ;
    skos:exactMatch dpv:PersonalDataAudit,
        dpv_owl:PersonalDataAudit,
        dpvs:PersonalDataAudit ;
    skos:inScheme dpvs:core ;
    skos:note """This concept is the same as "Data Mapping" and "Data Flow Mapping
Exercise" used by the Information Commissioner's Office as "to document
the data that flows in, around, and out of information processing
systems or services\"""" ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:PersonalDataHandling a owl:Class ;
    rdfs:label "PersonalDataHandling" ;
    rdfs:subClassOf dpvs:DpvProcess ;
    skos:altLabel "Personal Data Handling" ;
    skos:definition "An abstract concept describing 'personal data handling'" ;
    skos:exactMatch dpv:PersonalDataHandling,
        dpv_owl:PersonalDataHandling,
        dpvs:PersonalDataHandling,
        iso29100:PIIFlowScenario ;
    skos:inScheme dpvs:core ;
    skos:note """This concept will be deprecated in future updates. It is recommended to
use dpv:Process as the equivalent alternative which is better aligned
with legal and operational terminology.""" ;
    dpvs:skos_in_scheme "process-classes" .

dpvs:PersonalDataProcess a owl:Class ;
    rdfs:label "PersonalDataProcess" ;
    rdfs:subClassOf dpvs:DpvProcess ;
    skos:altLabel "Personal Data Process" ;
    skos:closeMatch iso22989:DataProcess ;
    skos:definition "An action, activity, or method involving personal data" ;
    skos:exactMatch dpv:PersonalDataProcess,
        dpv_owl:PersonalDataProcess,
        dpvs:PersonalDataProcess,
        iso29100:PIIProcessingActivity ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "process-classes" .

dpvs:PersonalSpace a owl:Class ;
    rdfs:label "PersonalSpace" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:PrivateSpace ;
    skos:altLabel "Personal Space" ;
    skos:definition """A private space associated with an individual in a personal capacity -
such as their home or the space around their physical person e.g. my
home or my room""" ;
    skos:exactMatch dpv:PersonalSpace,
        dpv_owl:PersonalSpace,
        dpvs:PersonalSpace ;
    skos:inScheme dpvs:core ;
    skos:narrowMatch gists:GeoRegion ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:PersonalisedBenefits a owl:Class ;
    rdfs:label "PersonalisedBenefits" ;
    rdfs:subClassOf dpvs:Purpose,
        dpvs:ServicePersonalisation ;
    skos:altLabel "Personalised Benefits" ;
    skos:definition """Purposes associated with creating and providing personalised benefits
for a service""" ;
    skos:exactMatch dpv:PersonalisedBenefits,
        dpv_owl:PersonalisedBenefits,
        dpvs:PersonalisedBenefits ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PersonnelBehaviourMonitoring a owl:Class ;
    rdfs:label "PersonnelBehaviourMonitoring" ;
    rdfs:subClassOf dpvs:PersonnelMonitoring,
        dpvs:Purpose ;
    skos:altLabel "Personnel Behaviour Monitoring" ;
    skos:definition "Purposes associated with monitoring behaviour of personnel" ;
    skos:exactMatch dpv:PersonnelBehaviourMonitoring,
        dpv_owl:PersonnelBehaviourMonitoring,
        dpvs:PersonnelBehaviourMonitoring ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PersonnelOffboarding a owl:Class ;
    rdfs:label "PersonnelOffboarding" ;
    rdfs:subClassOf dpvs:PersonnelManagement,
        dpvs:Purpose ;
    skos:altLabel "Personnel Offboarding" ;
    skos:definition """Purposes associated with offboarding of personnel i.e. activities and
processes carried out when the person is exiting the company or role""" ;
    skos:exactMatch dpv:PersonnelOffboarding,
        dpv_owl:PersonnelOffboarding,
        dpvs:PersonnelOffboarding ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PersonnelOnboarding a owl:Class ;
    rdfs:label "PersonnelOnboarding" ;
    rdfs:subClassOf dpvs:PersonnelHiring,
        dpvs:Purpose ;
    skos:altLabel "Personnel Onboarding" ;
    skos:definition """Purposes associated with onboarding and integration of personnel within
an organisation""" ;
    skos:exactMatch dpv:PersonnelOnboarding,
        dpv_owl:PersonnelOnboarding,
        dpvs:PersonnelOnboarding ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PersonnelPayment a owl:Class ;
    rdfs:label "PersonnelPayment" ;
    rdfs:subClassOf dpvs:PersonnelManagement,
        dpvs:Purpose ;
    skos:altLabel "Personnel Payment" ;
    skos:definition """Purposes associated with management and execution of payment of
personnel""" ;
    skos:exactMatch dpv:PersonnelPayment,
        dpv_owl:PersonnelPayment,
        dpvs:PersonnelPayment ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PersonnelPerformanceEvaluation a owl:Class ;
    rdfs:label "PersonnelPerformanceEvaluation" ;
    rdfs:subClassOf dpvs:PersonnelPerformanceManagement,
        dpvs:Purpose ;
    skos:altLabel "Personnel Performance Evaluation" ;
    skos:definition """Purposes associated with evaluation or assessment of performance of
employees""" ;
    skos:exactMatch dpv:PersonnelPerformanceEvaluation,
        dpv_owl:PersonnelPerformanceEvaluation,
        dpvs:PersonnelPerformanceEvaluation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PersonnelPerformanceMonitoring a owl:Class ;
    rdfs:label "PersonnelPerformanceMonitoring" ;
    rdfs:subClassOf dpvs:PersonnelMonitoring,
        dpvs:PersonnelPerformanceManagement,
        dpvs:Purpose ;
    skos:altLabel "Personnel Performance Monitoring" ;
    skos:definition "Purposes associated with monitoring of performance of personnel" ;
    skos:exactMatch dpv:PersonnelPerformanceMonitoring,
        dpv_owl:PersonnelPerformanceMonitoring,
        dpvs:PersonnelPerformanceMonitoring ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PersonnelPerformancePrediction a owl:Class ;
    rdfs:label "PersonnelPerformancePrediction" ;
    rdfs:subClassOf dpvs:PersonnelPerformanceManagement,
        dpvs:Purpose ;
    skos:altLabel "Personnel Performance Prediction" ;
    skos:definition "Purposes associated with prediction of performance of personnel" ;
    skos:exactMatch dpv:PersonnelPerformancePrediction,
        dpv_owl:PersonnelPerformancePrediction,
        dpvs:PersonnelPerformancePrediction ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PersonnelPromotionManagement a owl:Class ;
    rdfs:label "PersonnelPromotionManagement" ;
    rdfs:subClassOf dpvs:PersonnelManagement,
        dpvs:Purpose ;
    skos:altLabel "Personnel Promotion Management" ;
    skos:definition """Purposes associated with determination and management of promotion of
personnel""" ;
    skos:exactMatch dpv:PersonnelPromotionManagement,
        dpv_owl:PersonnelPromotionManagement,
        dpvs:PersonnelPromotionManagement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PersonnelTerminationManagement a owl:Class ;
    rdfs:label "PersonnelTerminationManagement" ;
    rdfs:subClassOf dpvs:PersonnelManagement,
        dpvs:Purpose ;
    skos:altLabel "Personnel Termination Management" ;
    skos:definition """Purposes associated with determination and management of termination of
personnel""" ;
    skos:exactMatch dpv:PersonnelTerminationManagement,
        dpv_owl:PersonnelTerminationManagement,
        dpvs:PersonnelTerminationManagement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PersonnelWorkloadManagement a owl:Class ;
    rdfs:label "PersonnelWorkloadManagement" ;
    rdfs:subClassOf dpvs:PersonnelManagement,
        dpvs:Purpose ;
    skos:altLabel "Personnel Workload Management" ;
    skos:definition """Purposes assocaited with determination, scheduling, planning, and
carrying out workload management of personnel""" ;
    skos:exactMatch dpv:PersonnelWorkloadManagement,
        dpv_owl:PersonnelWorkloadManagement,
        dpvs:PersonnelWorkloadManagement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PhysicalAccessControlMethod a owl:Class ;
    rdfs:label "PhysicalAccessControlMethod" ;
    rdfs:subClassOf dpvs:AccessControlMethod,
        dpvs:PhysicalMeasure ;
    skos:altLabel "Physical Access Control Method" ;
    skos:definition "Access control applied for physical access e.g. premises or equipment" ;
    skos:exactMatch dpv:PhysicalAccessControlMethod,
        dpv_owl:PhysicalAccessControlMethod,
        dpvs:PhysicalAccessControlMethod ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "NIST SP 800-12" ;
    dpvs:skos_in_scheme "physical-measures-classes" .

dpvs:PhysicalAuthentication a owl:Class ;
    rdfs:label "PhysicalAuthentication" ;
    rdfs:subClassOf dpvs:PhysicalMeasure ;
    skos:altLabel "Physical Authentication" ;
    skos:definition """Physical implementation of authentication e.g. by matching the person to
their ID card""" ;
    skos:exactMatch dpv:PhysicalAuthentication,
        dpv_owl:PhysicalAuthentication,
        dpvs:PhysicalAuthentication ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "NIST SP 800-15" ;
    dpvs:skos_in_scheme "physical-measures-classes" .

dpvs:PhysicalAuthorisation a owl:Class ;
    rdfs:label "PhysicalAuthorisation" ;
    rdfs:subClassOf dpvs:PhysicalMeasure ;
    skos:altLabel "Physical Authorisation" ;
    skos:definition "Physical implementation of authorisation e.g. by stamping a visitor pass" ;
    skos:exactMatch dpv:PhysicalAuthorisation,
        dpv_owl:PhysicalAuthorisation,
        dpvs:PhysicalAuthorisation ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "NIST SP 800-16" ;
    dpvs:skos_in_scheme "physical-measures-classes" .

dpvs:PhysicalDeviceSecurity a owl:Class ;
    rdfs:label "PhysicalDeviceSecurity" ;
    rdfs:subClassOf dpvs:PhysicalMeasure ;
    skos:altLabel "Physical Device Security" ;
    skos:definition "Physical protection for devices and equipment" ;
    skos:exactMatch dpv:PhysicalDeviceSecurity,
        dpv_owl:PhysicalDeviceSecurity,
        dpvs:PhysicalDeviceSecurity ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "NIST SP 800-19" ;
    dpvs:skos_in_scheme "physical-measures-classes" .

dpvs:PhysicalInterceptionProtection a owl:Class ;
    rdfs:label "PhysicalInterceptionProtection" ;
    rdfs:subClassOf dpvs:PhysicalMeasure ;
    skos:altLabel "Physical Interception Protection" ;
    skos:definition "Physical protection against interception e.g. by posting a guard" ;
    skos:exactMatch dpv:PhysicalInterceptionProtection,
        dpv_owl:PhysicalInterceptionProtection,
        dpvs:PhysicalInterceptionProtection ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "NIST SP 800-20" ;
