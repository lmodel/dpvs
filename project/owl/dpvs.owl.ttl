    skos:inScheme dpvs:core ;
    dpvs:dct_source "NIST SP 800-171" ;
    dpvs:skos_in_scheme "physical-measures-classes" .

dpvs:PhysicalSupplySecurity a owl:Class ;
    rdfs:label "PhysicalSupplySecurity" ;
    rdfs:subClassOf dpvs:PhysicalMeasure ;
    skos:altLabel "Physical Supply Security" ;
    skos:definition "Physically securing the supply of resources" ;
    skos:exactMatch dpv:PhysicalSupplySecurity,
        dpv_owl:PhysicalSupplySecurity,
        dpvs:PhysicalSupplySecurity ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "NIST SP 800-14" ;
    dpvs:skos_in_scheme "physical-measures-classes" .

dpvs:PhysicalSurveillance a owl:Class ;
    rdfs:label "PhysicalSurveillance" ;
    rdfs:subClassOf dpvs:PhysicalMeasure ;
