    skos:exactMatch dpv:B2B2CContract,
        dpv_owl:B2B2CContract,
        dpvs:B2B2CContract ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-types-classes" .

dpvs:BackgroundChecks a owl:Class ;
