        dpv_owl:ProfessionalConfidentialData,
        dpvs:ProfessionalConfidentialData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:ProfessionalTraining a owl:Class ;
