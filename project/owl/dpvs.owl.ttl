dpvs:RenewedConsentGiven a owl:Class ;
    rdfs:label "RenewedConsentGiven" ;
    rdfs:subClassOf dpvs:ConsentStatus,
        dpvs:ConsentStatusValidForProcessing ;
    skos:altLabel "Renewed Consent Given" ;
    skos:definition """The state where a previously given consent has been 'renewed' or
'refreshed' or 'reaffirmed' to form a new instance of given consent""" ;
    skos:exactMatch dpv:RenewedConsentGiven,
        dpv_owl:RenewedConsentGiven,
        dpvs:RenewedConsentGiven ;
    skos:inScheme dpvs:core ;
    skos:note """An example of this state is when a previously given consent has expired,
and the individual is presented a notice regarding continuing associated
processing operations - to which they agree. This state can be useful to
keep track of 'reconfirmed' or 'refreshed' consent within consent
records, assist notices and contextual agents to create better
consenting dialogues, and assist with specific legal obligations related
to subsequent consenting""" ;
    dpvs:skos_in_scheme "consent-status-classes" .

dpvs:RepairImpairments a owl:Class ;
