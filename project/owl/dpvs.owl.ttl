    rdfs:subClassOf dpvs:CryptographicMethods,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Asymmetric Cryptography" ;
    skos:definition """Use of public-key cryptography or asymmetric cryptography involving a
public and private pair of keys""" ;
    skos:exactMatch dpv:AsymmetricCryptography,
        dpv_owl:AsymmetricCryptography,
        dpvs:AsymmetricCryptography ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:AsymmetricEncryption a owl:Class ;
    rdfs:label "AsymmetricEncryption" ;
    rdfs:subClassOf dpvs:Encryption,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Asymmetric Encryption" ;
    skos:definition "Use of asymmetric cryptography to encrypt data" ;
    skos:exactMatch dpv:AsymmetricEncryption,
        dpv_owl:AsymmetricEncryption,
        dpvs:AsymmetricEncryption ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:AuditApproved a owl:Class ;
    rdfs:label "AuditApproved" ;
    rdfs:subClassOf dpvs:AuditStatus ;
    skos:altLabel "Audit Approved" ;
    skos:definition "State of being approved through the audit" ;
    skos:exactMatch dpv:AuditApproved,
        dpv_owl:AuditApproved,
        dpvs:AuditApproved ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:AuditConditionallyApproved a owl:Class ;
    rdfs:label "AuditConditionallyApproved" ;
    rdfs:subClassOf dpvs:AuditStatus ;
    skos:altLabel "Audit Conditionally Approved" ;
    skos:definition "State of being conditionally approved through the audit" ;
    skos:exactMatch dpv:AuditConditionallyApproved,
        dpv_owl:AuditConditionallyApproved,
        dpvs:AuditConditionallyApproved ;
    skos:inScheme dpvs:core ;
    skos:note """A "conditional approval" is intended to reflect states where the audit
has identified further changes which must be implemented before
considering the audit has been 'passed', without requiring another audit
to validate them. This is distinct from the case where an audit has
state 'rejected', which means changes must be made and submitted for
review. The requirements of a 'conditional acceptance' are expected to
be minor or not significant enough to warrant another audit to review
them.""" ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:AuditNotRequired a owl:Class ;
    rdfs:label "AuditNotRequired" ;
    rdfs:subClassOf dpvs:AuditStatus ;
    skos:altLabel "Audit Not Required" ;
    skos:definition "State where an audit is determined as not being required" ;
    skos:exactMatch dpv:AuditNotRequired,
        dpv_owl:AuditNotRequired,
        dpvs:AuditNotRequired ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:AuditRejected a owl:Class ;
    rdfs:label "AuditRejected" ;
    rdfs:subClassOf dpvs:AuditStatus ;
    skos:altLabel "Audit Rejected" ;
    skos:definition "State of not being approved or being rejected through the audit" ;
    skos:exactMatch dpv:AuditRejected,
        dpv_owl:AuditRejected,
        dpvs:AuditRejected ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:AuditRequested a owl:Class ;
    rdfs:label "AuditRequested" ;
    rdfs:subClassOf dpvs:AuditStatus ;
    skos:altLabel "Audit Requested" ;
    skos:definition "State of an audit being requested whose outcome is not yet known" ;
    skos:exactMatch dpv:AuditRequested,
        dpv_owl:AuditRequested,
        dpvs:AuditRequested ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:AuditRequired a owl:Class ;
    rdfs:label "AuditRequired" ;
    rdfs:subClassOf dpvs:AuditStatus ;
    skos:altLabel "Audit Required" ;
    skos:definition """State where an audit is determined as being required but has not been
conducted""" ;
    skos:exactMatch dpv:AuditRequired,
        dpv_owl:AuditRequired,
        dpvs:AuditRequired ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:AuthorisationProtocols a owl:Class ;
    rdfs:label "AuthorisationProtocols" ;
    rdfs:subClassOf dpvs:TechnicalMeasure ;
    skos:altLabel "Authorisation Protocols" ;
    skos:definition """Protocols involving authorisation of roles or profiles to determine
permission, rights, or privileges""" ;
    skos:exactMatch dpv:AuthorisationProtocols,
        dpv_owl:AuthorisationProtocols,
        dpvs:AuthorisationProtocols ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:AuthorityInformed a owl:Class ;
    rdfs:label "AuthorityInformed" ;
    rdfs:subClassOf dpvs:EntityInformed,
        dpvs:EntityInformedStatus ;
    skos:altLabel "Authority Informed" ;
    skos:definition """Status indicating Authority has been informed about the specified
context""" ;
    skos:exactMatch dpv:AuthorityInformed,
        dpv_owl:AuthorityInformed,
        dpvs:AuthorityInformed ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:AuthorityUninformed a owl:Class ;
    rdfs:label "AuthorityUninformed" ;
    rdfs:subClassOf dpvs:EntityInformedStatus,
        dpvs:EntityUninformed ;
    skos:altLabel "Authority Uninformed" ;
    skos:definition """Status indicating Authority is uninformed i.e. has not been informed
about the specified context""" ;
    skos:exactMatch dpv:AuthorityUninformed,
        dpv_owl:AuthorityUninformed,
        dpvs:AuthorityUninformed ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:AutomatedDecisionMaking a owl:Class ;
    rdfs:label "AutomatedDecisionMaking" ;
    rdfs:subClassOf dpvs:DecisionMaking ;
    skos:altLabel "Automated Decision Making" ;
    skos:definition "Processing that involves automated decision making" ;
    skos:exactMatch dpv:AutomatedDecisionMaking,
        dpv_owl:AutomatedDecisionMaking,
        dpvs:AutomatedDecisionMaking ;
    skos:inScheme dpvs:core ;
    skos:note """Automated decision making can be defined as “the ability to make
decisions by technological means without human involvement.”
(“Guidelines on Automated individual decision-making and Profiling for
the purposes of Regulation 2016/679 (wp251rev.01)”, 2018, p. 8)""" ;
    skos:relatedMatch iso22989:Decision ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:AutomatedScoringOfIndividuals a owl:Class ;
    rdfs:label "AutomatedScoringOfIndividuals" ;
    rdfs:subClassOf dpvs:ScoringOfIndividuals ;
    skos:altLabel "Automated Scoring of Individuals" ;
    skos:definition "Processing that involves automated scoring of individuals" ;
    skos:exactMatch dpv:AutomatedScoringOfIndividuals,
        dpv_owl:AutomatedScoringOfIndividuals,
        dpvs:AutomatedScoringOfIndividuals ;
    skos:inScheme dpvs:core ;
    skos:note """Scoring can lead to the action being considered Decision Making if the
scoring is itself a decision - see 2023-MAR-16 opinion of Advocate
General on Case C 634/21. Therefore, the assessment of whether scoring
was automated or not is important given the legal obligations
surrounding automated decision making e.g. in GDPR""" ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:Autonomous a owl:Class ;
    rdfs:label "Autonomous" ;
    rdfs:subClassOf dpvs:AutomationLevel ;
    skos:altLabel "Autonomous" ;
    skos:definition """Level of automation corresponding to Level 6 in ISO/IEC 22989:2022 where
the automation in system is capable of modifying its operation domain or
its goals without external intervention, control or oversight""" ;
    skos:exactMatch dpv:Autonomous,
        dpv_owl:Autonomous,
        dpvs:Autonomous ;
    skos:inScheme dpvs:core ;
    skos:note """Though Autonomous, such operations can still be associated with
dpv:HumanInvolved e.g. for inputs, oversight or verification""" ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:B2B2CContract a owl:Class ;
    rdfs:label "B2B2CContract" ;
    rdfs:subClassOf dpvs:B2BContract,
        dpvs:B2CContract,
