        dpvs:ProhibitionViolated ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:ProtectionOfIPR a owl:Class ;
    rdfs:label "ProtectionOfIPR" ;
