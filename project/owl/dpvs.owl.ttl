    skos:exactMatch dpv:hasUnstructuredData,
        dpv_owl:hasUnstructuredData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-properties" .

dpvs:is_after a owl:DatatypeProperty ;
    rdfs:label "is_after" ;
    skos:altLabel "is after" ;
    skos:definition "Indicates the specified concepts is 'after' this concept in some context" ;
    skos:exactMatch dpv:isAfter,
        dpv_owl:isAfter ;
    skos:inScheme dpvs:core ;
    skos:note """Also used for specifying a RightExerciseActivity occurs before another
RightExerciseActivity""" ;
    dpvs:skos_in_scheme "context-properties, rights-properties" .

dpvs:is_applicable_for a owl:DatatypeProperty ;
    rdfs:label "is_applicable_for" ;
    skos:altLabel "is applicable for" ;
    skos:definition "Indicates the concept or information is applicable for specified context" ;
    skos:exactMatch dpv:isApplicableFor,
        dpv_owl:isApplicableFor ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "context-properties" .

dpvs:is_authority_for a owl:DatatypeProperty ;
    rdfs:label "is_authority_for" ;
    skos:altLabel "is authority for" ;
    skos:definition "Indicates area, scope, or applicability of an Authority" ;
    skos:exactMatch dpv:isAuthorityFor,
        dpv_owl:isAuthorityFor ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-authority-properties" .

dpvs:is_before a owl:DatatypeProperty ;
    rdfs:label "is_before" ;
    skos:altLabel "is before" ;
    skos:definition """Indicates the specified concepts is 'before' this concept in some
context""" ;
    skos:exactMatch dpv:isBefore,
        dpv_owl:isBefore ;
    skos:inScheme dpvs:core ;
    skos:note """Also used for specifying a RightExerciseActivity occurs before another
RightExerciseActivity""" ;
    dpvs:skos_in_scheme "context-properties, rights-properties" .

dpvs:is_determined_by_entity a owl:DatatypeProperty ;
    rdfs:label "is_determined_by_entity" ;
    rdfs:subPropertyOf dpvs:has_entity ;
    skos:altLabel "is determined by entity" ;
    skos:definition "Indicates the context is determined by the specified entity" ;
    skos:exactMatch dpv:isDeterminedByEntity,
        dpv_owl:isDeterminedByEntity ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-properties" .

dpvs:is_during a owl:DatatypeProperty ;
    rdfs:label "is_during" ;
    skos:altLabel "is during" ;
    skos:definition """Indicates the specified concepts occur 'during' this concept in some
context""" ;
    skos:exactMatch dpv:isDuring,
        dpv_owl:isDuring ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "context-properties" .

dpvs:is_exercised_at a owl:DatatypeProperty ;
    rdfs:label "is_exercised_at" ;
    skos:altLabel "is exercised at" ;
    skos:definition "Indicates context or information about exercising a right" ;
    skos:exactMatch dpv:isExercisedAt,
        dpv_owl:isExercisedAt ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "rights-properties" .

dpvs:is_implemented_by_entity a owl:DatatypeProperty ;
    rdfs:label "is_implemented_by_entity" ;
    skos:altLabel "is implemented by entity" ;
    skos:definition "Indicates implementation details such as entities or agents" ;
    skos:exactMatch dpv:isImplementedByEntity,
        dpv_owl:isImplementedByEntity ;
    skos:inScheme dpvs:core ;
    skos:note """Also used to indicate the Entity that implements or performs a Right
Exercise Activity""",
        """The use of 'entity' is inclusive of entities (e.g. Data Processor) as
well as 'agent' (e.g. DPO). For indicating technological implementation,
the property isImplementedByTechnology should be used.""" ;
    dpvs:skos_in_scheme "processing-context-properties, rights-properties" .

dpvs:is_implemented_using_technology a owl:DatatypeProperty ;
    rdfs:label "is_implemented_using_technology" ;
    skos:altLabel "is implemented using technology" ;
    skos:definition "Indicates implementation details such as technologies or processes" ;
    skos:exactMatch dpv:isImplementedUsingTechnology,
        dpv_owl:isImplementedUsingTechnology ;
    skos:inScheme dpvs:core ;
    skos:note """The term 'technology' is inclusive of technologies, processes, and
methods.""" ;
    dpvs:skos_in_scheme "processing-context-properties" .

dpvs:is_indicated_at_time a owl:DatatypeProperty ;
    rdfs:label "is_indicated_at_time" ;
    skos:altLabel "is indicated at time" ;
    skos:definition """Specifies the temporal information for when the entity has indicated the
specific context""" ;
    skos:exactMatch dpv:isIndicatedAtTime,
        dpv_owl:isIndicatedAtTime ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-properties" .

dpvs:is_indicated_by a owl:DatatypeProperty ;
    rdfs:label "is_indicated_by" ;
    skos:altLabel "is indicated by" ;
    skos:definition "Specifies entity who indicates the specific context" ;
    skos:exactMatch dpv:isIndicatedBy,
        dpv_owl:isIndicatedBy ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-properties" .

dpvs:is_mitigated_by_measure a owl:DatatypeProperty ;
    rdfs:label "is_mitigated_by_measure" ;
    rdfs:subPropertyOf dpvs:has_technical_organisational_measure ;
    skos:altLabel "is mitigated by measure" ;
    skos:definition "Indicate a risk is mitigated by specified measure" ;
    skos:exactMatch dpv:isMitigatedByMeasure,
        dpv_owl:isMitigatedByMeasure ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "risk-properties" .

dpvs:is_not_applicable_for a owl:DatatypeProperty ;
    rdfs:label "is_not_applicable_for" ;
    skos:altLabel "is not applicable for" ;
    skos:definition """Indicates the concept or information is not applicable for specified
context""" ;
    skos:exactMatch dpv:isNotApplicableFor,
        dpv_owl:isNotApplicableFor ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "context-properties" .

dpvs:is_organisational_unit_of a owl:DatatypeProperty ;
    rdfs:label "is_organisational_unit_of" ;
    rdfs:subPropertyOf dpvs:has_entity ;
    skos:altLabel "is organisational unit of" ;
    skos:definition "Indicates this entity is an organisational unit of the specified entity" ;
    skos:exactMatch dpv:isOrganisationalUnitOf,
        dpv_owl:isOrganisationalUnitOf ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-properties" .

dpvs:is_outside_of_location a owl:DatatypeProperty ;
    rdfs:label "is_outside_of_location" ;
    rdfs:subPropertyOf dpvs:has_location ;
    skos:altLabel "is outside of location" ;
    skos:definition """Indicates the interpretation where the location being referenced is
outside of the indicated concept""" ;
    skos:exactMatch dpv:isOutsideOfLocation,
        dpv_owl:isOutsideOfLocation ;
    skos:inScheme dpvs:core ;
    skos:note """This property is helpful for cases where a distinction needs to be made
between inside/outside of a concept, and the area outside of that
concept is to be referenced. For example, using Home with
dpv:hasLocation means inside the Home, and using this property along
with Home means outside of Home - such as the yard or porch""" ;
    dpvs:skos_in_scheme "jurisdiction-properties" .

dpvs:is_policy_for a owl:DatatypeProperty ;
    rdfs:label "is_policy_for" ;
    skos:altLabel "is policy for" ;
    skos:definition "Indicates the context or application of policy" ;
    skos:exactMatch dpv:isPolicyFor,
        dpv_owl:isPolicyFor ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "TOM-properties" .

dpvs:is_representative_for a owl:DatatypeProperty ;
    rdfs:label "is_representative_for" ;
    rdfs:subPropertyOf dpvs:has_entity ;
    skos:altLabel "is representative for" ;
    skos:definition "Indicates the entity is a representative for specified entity" ;
    skos:exactMatch dpv:isRepresentativeFor,
        dpv_owl:isRepresentativeFor ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-properties" .

dpvs:is_residual_risk_of a owl:DatatypeProperty ;
    rdfs:label "is_residual_risk_of" ;
    skos:altLabel "is residual risk of" ;
    skos:definition """Indicates this risk is the remaining or residual risk from applying
mitigation measures or treatments to specified risk""" ;
    skos:exactMatch dpv:isResidualRiskOf,
        dpv_owl:isResidualRiskOf ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "risk-properties" .

dpvs:is_subsidiary_of a owl:DatatypeProperty ;
    rdfs:label "is_subsidiary_of" ;
    rdfs:subPropertyOf dpvs:has_entity ;
    skos:altLabel "is subsidiary of" ;
    skos:definition "Indicates this entity is the subsidiary of the specified entity" ;
    skos:exactMatch dpv:isSubsidiaryOf,
        dpv_owl:isSubsidiaryOf ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-properties" .

dpvs:mitigates_risk a owl:DatatypeProperty ;
    rdfs:label "mitigates_risk" ;
    skos:altLabel "mitigates risk" ;
    skos:definition "Indicates risks mitigated by this concept" ;
    skos:exactMatch dpv:mitigatesRisk,
        dpv_owl:mitigatesRisk ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "risk-properties" .

dpvs:supports_compliance_with a owl:DatatypeProperty ;
    rdfs:label "supports_compliance_with" ;
    skos:altLabel "supports Compliance With" ;
    skos:definition """Indicate the measure is required for meeting specified requirement or
satisfying specified condition/constraint""" ;
    skos:exactMatch dpv:supportsComplianceWith,
        dpv_owl:supportsComplianceWith ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "TOM-properties" .

dpvs:AIGovernance a owl:Class ;
    rdfs:label "AIGovernance" ;
    rdfs:subClassOf dpvs:GovernanceProcedures,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "AI Governance" ;
    skos:closeMatch iso42001:AIManagementSystem ;
    skos:definition """Procedures related to governance of AI, including its procurement,
development, deployment, and assessments""" ;
    skos:exactMatch dpv:AIGovernance,
        dpv_owl:AIGovernance,
        dpvs:AIGovernance ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch iso22989:AILifecycleProcess,
        nist_ai_rmf:Function,
        nist_csf_v2:CSFFunction ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:AILiteracy a owl:Class ;
    rdfs:label "AILiteracy" ;
    rdfs:subClassOf dpvs:DigitalLiteracy,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "AI Literacy" ;
    skos:definition """Providing skills, knowledge, and understanding to enable reading,
writing, analysing, reasoning, and communicating regarding AI""" ;
    skos:exactMatch dpv:AILiteracy,
        dpv_owl:AILiteracy,
        dpvs:AILiteracy ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch iso42001:AIReferenceControl ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:AINotice a owl:Class ;
    rdfs:label "AINotice" ;
    rdfs:subClassOf dpvs:Notice,
        dpvs:OrganisationalMeasure ;
