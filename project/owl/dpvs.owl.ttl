    skos:altLabel "Customer Relationship Management" ;
    skos:definition """Customer Relationship Management refers to purposes associated with
managing and analysing interactions with past, current, and potential
customers""" ;
    skos:exactMatch dpv:CustomerRelationshipManagement,
        dpv_owl:CustomerRelationshipManagement,
        dpvs:CustomerRelationshipManagement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:DataController a owl:Class ;
    rdfs:label "DataController" ;
    rdfs:subClassOf dpvs:LegalEntity ;
    skos:altLabel "Data Controller" ;
    skos:definition """The individual or organisation that decides (or controls) the purpose(s)
of processing personal data.""" ;
    skos:exactMatch dpv:DataController,
        dpv_owl:DataController,
        dpvs:DataController,
        iso29100:PIIController ;
    skos:inScheme dpvs:core ;
    skos:note """The terms 'Controller', 'Data Controller', and 'PII Controller' refer to
the same concept""" ;
    skos:relatedMatch common_domain_model:Counterparty,
        iso22989:AIProvider,
        iso27001:Organization,
        nist_ai_rmf:AiActor,
        oscal:ResponsibleParty ;
    dpvs:skos_in_scheme "entities-legalrole-classes" .

dpvs:DataControllerContract a owl:Class ;
    rdfs:label "DataControllerContract" ;
    rdfs:subClassOf dpvs:DataProcessingAgreement,
        dpvs:LegalBasis ;
    skos:altLabel "Data Controller Contract" ;
    skos:definition """Creation, completion, fulfilment, or performance of a contract, with
Data Controllers as parties being Joint Data Controllers, and involving
specified processing of data or technologies. NOTE: This concept is
being deprecated - use dpv:JointDataControllersAgreement which has a
more explicit definition of the entities involved and the intent of the
contract""" ;
    skos:exactMatch dpv:DataControllerContract,
        dpv_owl:DataControllerContract,
        dpvs:DataControllerContract ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-types-classes" .

dpvs:DataProcessor a owl:Class ;
    rdfs:label "DataProcessor" ;
    rdfs:subClassOf dpvs:DpvRecipient ;
    skos:altLabel "Data Processor" ;
    skos:definition """A ‘processor’ means a natural or legal person, public authority, agency
or other body which processes data on behalf of the controller.""" ;
    skos:exactMatch dpv:DataProcessor,
        dpv_owl:DataProcessor,
        dpvs:DataProcessor,
        iso29100:PIIProcessor ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch common_domain_model:Counterparty,
        iso27001:Organization ;
    dpvs:skos_in_scheme "entities-legalrole-classes" .

dpvs:DataProcessorContract a owl:Class ;
    rdfs:label "DataProcessorContract" ;
    rdfs:subClassOf dpvs:DataProcessingAgreement,
        dpvs:LegalBasis ;
    skos:altLabel "Data Processor Contract" ;
    skos:definition """Creation, completion, fulfilment, or performance of a contract, with the
Data Controller and Data Processor as parties, and involving specified
processing of data or technologies. NOTE: This concept is being
deprecated - use dpv:ControllerProcessorAgreement which has a more
explicit definition of the entities involved and the intent of the
contract""" ;
    skos:exactMatch dpv:DataProcessorContract,
        dpv_owl:DataProcessorContract,
        dpvs:DataProcessorContract ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-types-classes" .

dpvs:DataQualityAssessment a owl:Class ;
    rdfs:label "DataQualityAssessment" ;
    rdfs:subClassOf dpvs:Assessment,
        dpvs:DataQualityManagement,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Data Quality Assessment" ;
    skos:definition "Measures associated with assessment of data quality" ;
    skos:exactMatch dpv:DataQualityAssessment,
        dpv_owl:DataQualityAssessment,
        dpvs:DataQualityAssessment ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:DataSubjectContract a owl:Class ;
    rdfs:label "DataSubjectContract" ;
    rdfs:subClassOf dpvs:DataProcessingAgreement,
        dpvs:LegalBasis ;
    skos:altLabel "Data Subject Contract" ;
    skos:definition """Creation, completion, fulfilment, or performance of a contract, with the
Data Controller and Data Subject as parties, and involving specified
processing of data or technologies. NOTE: This concept is being
deprecated - use dpv:ControllerDataSubjectAgreement which has a more
explicit definition of the entities involved and the intent of the
contract""" ;
    skos:exactMatch dpv:DataSubjectContract,
        dpv_owl:DataSubjectContract,
        dpvs:DataSubjectContract ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-types-classes" .

dpvs:DataSubjectDataSource a owl:Class ;
    rdfs:label "DataSubjectDataSource" ;
    rdfs:subClassOf dpvs:DataSource ;
    skos:altLabel "Data Subject as Data Source" ;
    skos:definition """Data Sourced from Data Subject(s), e.g. when data is collected via a
form or observed from their activities""" ;
    skos:exactMatch dpv:DataSubjectDataSource,
        dpv_owl:DataSubjectDataSource,
        dpvs:DataSubjectDataSource ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:DecisionMaking a owl:Class ;
    rdfs:label "DecisionMaking" ;
    rdfs:subClassOf dpvs:ProcessingContext ;
    skos:altLabel "Decision Making" ;
    skos:closeMatch iso22989:Decision ;
    skos:definition "Processing that involves decision making" ;
    skos:exactMatch dpv:DecisionMaking,
        dpv_owl:DecisionMaking,
        dpvs:DecisionMaking ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:Derive a owl:Class ;
    rdfs:label "Derive" ;
    rdfs:subClassOf dpvs:Obtain,
        dpvs:Processing ;
    skos:altLabel "Derive" ;
    skos:definition "to create new derivative data from the original data" ;
    skos:exactMatch dpv:Derive,
        dpv_owl:Derive,
        dpvs:Derive ;
    skos:inScheme dpvs:core ;
    skos:note """Derive indicates data is present or obtainable from existing data. For
data that is created without such existence, see Infer.""" ;
    skos:relatedMatch svpr:Derive ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:DerivedPersonalData a owl:Class ;
    rdfs:label "DerivedPersonalData" ;
    rdfs:subClassOf dpvs:DerivedData,
        dpvs:PersonalData ;
    skos:altLabel "Derived Personal Data" ;
    skos:definition "Personal Data that is obtained or derived from other data" ;
    skos:exactMatch dpv:DerivedPersonalData,
        dpv_owl:DerivedPersonalData,
        dpvs:DerivedPersonalData ;
    skos:inScheme dpvs:core ;
    skos:note """Derived Data is data that is obtained through processing of existing
data, e.g. deriving first name from full name. To indicate data that is
derived but which was not present or evident within the source data,
InferredPersonalData should be used.""" ;
    skos:relatedMatch svd:Derived ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:DpvCountry a owl:Class ;
    rdfs:label "DpvCountry" ;
    rdfs:subClassOf dpvs:DpvJurisdiction ;
    skos:altLabel "Country" ;
    skos:definition """A political entity indicative of a sovereign or non-sovereign
territorial state comprising of distinct geographical areas""" ;
    skos:exactMatch dpv:Country,
        dpv_owl:Country,
        dpvs:Country ;
    skos:inScheme dpvs:core ;
    skos:note """The definition of country is not intended for political interpretation.
DPVCG welcomes alternate definitions based in existing sources with
global scope, such as UN or ISO.""" ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:DpvRecipient a owl:Class ;
    rdfs:label "DpvRecipient" ;
    rdfs:subClassOf dpvs:LegalEntity ;
    skos:altLabel "Recipient" ;
    skos:definition "Entities that receive data or technologies" ;
    skos:exactMatch dpv:Recipient,
        dpv_owl:Recipient,
        dpvs:Recipient ;
    skos:inScheme dpvs:core ;
    skos:note """Recipients that receive personal data can be a Third Party, Data
Controller, or Data Processor.""" ;
    skos:relatedMatch usage_policy:AnyRecipient ;
    dpvs:skos_in_scheme "entities-legalrole-classes" .

dpvs:ExpressedConsent a owl:Class ;
    rdfs:label "ExpressedConsent" ;
    rdfs:subClassOf dpvs:InformedConsent,
        dpvs:LegalBasis ;
    skos:altLabel "Expressed Consent" ;
    skos:definition """Consent that is expressed through an action intended to convey a
consenting decision""" ;
    skos:exactMatch dpv:ExpressedConsent,
        dpv_owl:ExpressedConsent,
        dpvs:ExpressedConsent ;
    skos:inScheme dpvs:core ;
    skos:note """Expressed consent requires the individual take a specific and
unambiguous action that directly indicates their consent. This action
may be a part of other processes such as setting preferences, or
agreeing to a contract, or other matters not relating to consent. An
example of expressed consent is interacting with a checkbox within a
dashboard or clicking a button on a web form""" ;
    dpvs:skos_in_scheme "consent-types-classes" .

dpvs:Format a owl:Class ;
    rdfs:label "Format" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Structure ;
    skos:altLabel "Format" ;
    skos:definition "to arrange or structure data in a specific form" ;
    skos:exactMatch dpv:Format,
        dpv_owl:Format,
        dpvs:Format ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "DGA 12.d" ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:GeneratedData a owl:Class ;
    rdfs:label "GeneratedData" ;
    rdfs:subClassOf dpvs:DpvData ;
    skos:altLabel "Generated Data" ;
    skos:definition """Data that is generated or brought into existence without relation to
existing data i.e. it is not derived or inferred from other data""" ;
    skos:exactMatch dpv:GeneratedData,
        dpv_owl:GeneratedData,
        dpvs:GeneratedData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:GovernmentalOrganisation a owl:Class ;
    rdfs:label "GovernmentalOrganisation" ;
    rdfs:subClassOf dpvs:DpvOrganisation ;
    skos:altLabel "Governmental Organisation" ;
    skos:definition "An organisation managed or part of government" ;
    skos:exactMatch dpv:GovernmentalOrganisation,
        dpv_owl:GovernmentalOrganisation,
        dpvs:GovernmentalOrganisation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-organisation-classes" .

dpvs:GuardianOfHuman a owl:Class ;
    rdfs:label "GuardianOfHuman" ;
    rdfs:subClassOf dpvs:HumanSubject ;
    skos:altLabel "Guardian(s) of Human" ;
    skos:definition "Guardian(s) of humans" ;
    skos:exactMatch dpv:GuardianOfHuman,
        dpv_owl:GuardianOfHuman,
        dpvs:GuardianOfHuman ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

dpvs:HumanResourceManagement a owl:Class ;
    rdfs:label "HumanResourceManagement" ;
    rdfs:subClassOf dpvs:Purpose ;
    skos:altLabel "Human Resource Management" ;
    skos:definition """Purposes associated with managing humans and 'human resources' within
the organisation for effective and efficient operations.""" ;
    skos:exactMatch dpv:HumanResourceManagement,
        dpv_owl:HumanResourceManagement,
        dpvs:HumanResourceManagement ;
    skos:inScheme dpvs:core ;
    skos:note """HR is a broad concept. Its management includes, amongst others -
recruiting employees and intermediaries e.g. brokers, independent
representatives; payroll administration, remunerations, commissions, and
wages; and application of social legislation.""" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:InferredData a owl:Class ;
    rdfs:label "InferredData" ;
    rdfs:subClassOf dpvs:DerivedData ;
    skos:altLabel "Inferred Data" ;
    skos:definition "Data that has been obtained through inferences of other data" ;
    skos:exactMatch dpv:InferredData,
        dpv_owl:InferredData,
        dpvs:InferredData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:InformationAudit a owl:Class ;
    rdfs:label "InformationAudit" ;
    rdfs:subClassOf dpvs:Audit,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Information Audit" ;
    skos:definition """An audit that systematically examines the existence and use of
information along with its associated resources (e.g. where it is
stored) and flows (e.g. where it originates and with whom it is being
shared)""" ;
    skos:exactMatch dpv:InformationAudit,
        dpv_owl:InformationAudit,
        dpvs:InformationAudit ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:Intended a owl:Class ;
    rdfs:label "Intended" ;
    rdfs:subClassOf dpvs:IntentionStatus ;
    skos:altLabel "Intended" ;
    skos:definition "Status indicating the specified context was intended" ;
    skos:exactMatch dpv:Intended,
        dpv_owl:Intended,
        dpvs:Intended ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:Law a owl:Class ;
    rdfs:label "Law" ;
    rdfs:subClassOf dpvs:DpvThing ;
    skos:altLabel "Law" ;
    skos:definition "A law is a set of rules created by government or authorities" ;
    skos:exactMatch dpv:Law,
        dpv_owl:Law,
        dpvs:Law ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:LegalObligation a owl:Class ;
    rdfs:label "LegalObligation" ;
    rdfs:subClassOf dpvs:LegalBasis ;
    skos:altLabel "Legal Obligation" ;
    skos:definition "Legal Obligation to conduct the specified activities" ;
    skos:exactMatch dpv:LegalObligation,
        dpv_owl:LegalObligation,
        dpvs:LegalObligation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-classes" .

dpvs:LicenseAgreement a owl:Class ;
    rdfs:label "LicenseAgreement" ;
    rdfs:subClassOf dpvs:ContractByDomain,
        dpvs:LegalBasis ;
    skos:altLabel "License Agreement" ;
    skos:definition """A Legal Document providing permission to utilise data or resource and
outlining the conditions under which such use is considered valid""" ;
    skos:exactMatch dpv:LicenseAgreement,
        dpv_owl:LicenseAgreement,
        dpvs:LicenseAgreement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-types-classes" .

dpvs:Likelihood a owl:Class ;
    rdfs:label "Likelihood" ;
    rdfs:subClassOf dpvs:DpvThing ;
    skos:altLabel "Likelihood" ;
    skos:definition """The likelihood or probability or chance of something taking place or
occurring""" ;
    skos:exactMatch dpv:Likelihood,
        dpv_owl:Likelihood,
        dpvs:Likelihood ;
    skos:inScheme dpvs:core ;
    skos:note """Likelihood can be expressed in a subjective manner, such as 'Unlikely',
or in a quantitative manner such as "Twice in a Day" (frequency per
period). The suggestion is to use quantitative values, or to associate
them with subjective terms used so as to enable accurate interpretations
and interoperability. See the concepts related to Frequency and Duration
for possible uses as a combination to express Likelihood.""" ;
    dpvs:skos_in_scheme "risk-classes" .

dpvs:MentallyVulnerableHuman a owl:Class ;
    rdfs:label "MentallyVulnerableHuman" ;
    rdfs:subClassOf dpvs:HumanSubject,
        dpvs:VulnerableHuman ;
    skos:altLabel "Mentally Vulnerable Human" ;
    skos:definition "Humans that are considered mentally vulnerable within the context" ;
    skos:exactMatch dpv:MentallyVulnerableHuman,
        dpv_owl:MentallyVulnerableHuman,
        dpvs:MentallyVulnerableHuman ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

dpvs:MisusePreventionAndDetection a owl:Class ;
    rdfs:label "MisusePreventionAndDetection" ;
    rdfs:subClassOf dpvs:EnforceSecurity,
        dpvs:Purpose ;
    skos:altLabel "Misuse, Prevention and Detection" ;
    skos:definition "Prevention and Detection of Misuse or Abuse of services" ;
    skos:exactMatch dpv:MisusePreventionAndDetection,
        dpv_owl:MisusePreventionAndDetection,
        dpvs:MisusePreventionAndDetection ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "DGA 22.1(a)" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:NonCommercialPurpose a owl:Class ;
    rdfs:label "NonCommercialPurpose" ;
    rdfs:subClassOf dpvs:Purpose ;
    skos:altLabel "Non-commercial Purpose" ;
    skos:definition """Purposes associated with processing activities performed in a
non-commercial setting or without intention to commercialise""" ;
    skos:exactMatch dpv:NonCommercialPurpose,
        dpv_owl:NonCommercialPurpose,
        dpvs:NonCommercialPurpose ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "DGA 4.4" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:NonPersonalData a owl:Class ;
    rdfs:label "NonPersonalData" ;
    rdfs:subClassOf dpvs:DpvData ;
    skos:altLabel "Non-Personal Data" ;
    skos:definition "Data that is not Personal Data" ;
    skos:exactMatch dpv:NonPersonalData,
        dpv_owl:NonPersonalData,
        dpvs:NonPersonalData ;
    skos:inScheme dpvs:core ;
    skos:note """The term NonPersonalData is provided to distinguish between PersonalData
and other data, e.g. for indicating which data is regulated by privacy
laws. To specify personal data that has been anonymised, the concept
AnonymisedData should be used as the anonymisation process has a risk of
not being fully effective and such anonymous data may be found to be
personal data depending on circumstances.""" ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:NoticeIcon a owl:Class ;
    rdfs:label "NoticeIcon" ;
    rdfs:subClassOf dpvs:DpvThing ;
    skos:altLabel "Notice Icon" ;
    skos:definition "An icon within a notice associated with specific information or elements" ;
    skos:exactMatch dpv:NoticeIcon,
        dpv_owl:NoticeIcon,
        dpvs:NoticeIcon ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:NoticeLayer a owl:Class ;
    rdfs:label "NoticeLayer" ;
    rdfs:subClassOf dpvs:DpvThing ;
    skos:altLabel "Notice Layer" ;
    skos:definition """A layer within a layered notice where the layer can be used for
providing specific information or controls""" ;
    skos:exactMatch dpv:NoticeLayer,
        dpv_owl:NoticeLayer,
        dpvs:NoticeLayer ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes" .

dpvs:Notification a owl:Class ;
    rdfs:label "Notification" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure ;
    skos:altLabel "Notification" ;
    skos:definition "Notification represents the provision of a notice i.e. notifying" ;
    skos:exactMatch dpv:Notification,
        dpv_owl:Notification,
        dpvs:Notification ;
    skos:inScheme dpvs:core ;
    skos:note """Notice refers to the information whereas Notification refers to the
provision of that notice. The distinction is important as there are
specific obligations associated with notice and notifications. For
example, a data breach notice refers to the information about the breach
intended to be provided to another entity, whereas notification refers
to the act of providing the entity with the notice""" ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:ObservedData a owl:Class ;
    rdfs:label "ObservedData" ;
    rdfs:subClassOf dpvs:CollectedData ;
    skos:altLabel "Observed Data" ;
    skos:definition "Data that has been obtained through observations of a source" ;
    skos:exactMatch dpv:ObservedData,
        dpv_owl:ObservedData,
        dpvs:ObservedData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:OptimisationForConsumer a owl:Class ;
    rdfs:label "OptimisationForConsumer" ;
    rdfs:subClassOf dpvs:Purpose,
        dpvs:ServiceOptimisation ;
    skos:altLabel "Optimisation for Consumer" ;
    skos:definition """Purposes associated with optimisation of activities and services for
consumer or user""" ;
    skos:exactMatch dpv:OptimisationForConsumer,
        dpv_owl:OptimisationForConsumer,
        dpvs:OptimisationForConsumer ;
    skos:inScheme dpvs:core ;
    skos:note """The term optimisation here refers to the efficiency of the service in
terms of technical provision (or similar means) with benefits for
everybody. Personalisation implies making changes that benefit the
current user or persona.""" ;
    skos:relatedMatch svpu:Custom ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:OptingInToProcess a owl:Class ;
    rdfs:label "OptingInToProcess" ;
    rdfs:subClassOf dpvs:EntityPermissiveInvolvement ;
    skos:altLabel "Opting in to Process" ;
    skos:definition "Involvement where entity can opt-in to specified context" ;
    skos:exactMatch dpv:OptingInToProcess,
        dpv_owl:OptingInToProcess,
        dpvs:OptingInToProcess ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:Organise a owl:Class ;
    rdfs:label "Organise" ;
    rdfs:subClassOf dpvs:Processing ;
    skos:altLabel "Organise" ;
    skos:definition "to organize data for arranging or classifying" ;
    skos:exactMatch dpv:Organise,
        dpv_owl:Organise,
        dpvs:Organise ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:ParentOfHuman a owl:Class ;
    rdfs:label "ParentOfHuman" ;
    rdfs:subClassOf dpvs:HumanSubject ;
    skos:altLabel "Parent of Human" ;
    skos:definition "Parent(s) of humans" ;
    skos:exactMatch dpv:ParentOfHuman,
        dpv_owl:ParentOfHuman,
        dpvs:ParentOfHuman ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

dpvs:PermissionManagement a owl:Class ;
    rdfs:label "PermissionManagement" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure,
        dpvs:RightsManagement ;
    skos:altLabel "Permission Management" ;
    skos:definition """Methods to obtain, provide, modify, and withdraw permissions along with
maintaining a record of permissions, retrieving records, and processing
changes in permission states""" ;
    skos:exactMatch dpv:PermissionManagement,
        dpv_owl:PermissionManagement,
        dpvs:PermissionManagement ;
    skos:inScheme dpvs:core ;
    skos:note """Permission is a broader concept than '(Informed) Consent' as consent
when used as a legal basis has specific requirements to be valid. For
management of consent, see the concept dpv:ConsentManagement""" ;
    dpvs:dct_source "DGA 12.n" ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:PersonalisedAdvertising a owl:Class ;
    rdfs:label "PersonalisedAdvertising" ;
    rdfs:subClassOf dpvs:Advertising,
        dpvs:Personalisation,
        dpvs:Purpose ;
    skos:altLabel "Personalised Advertising" ;
    skos:definition "Purposes associated with creating and providing personalised advertising" ;
    skos:exactMatch dpv:PersonalisedAdvertising,
        dpv_owl:PersonalisedAdvertising,
        dpvs:PersonalisedAdvertising ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PrivacyNotice a owl:Class ;
    rdfs:label "PrivacyNotice" ;
    rdfs:subClassOf dpvs:Notice,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Privacy Notice" ;
    skos:closeMatch iso29100:PrivacyPolicy ;
    skos:definition "Represents a notice or document outlining information regarding privacy" ;
    skos:exactMatch dpv:PrivacyNotice,
        dpv_owl:PrivacyNotice,
        dpvs:PrivacyNotice ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes, organisational-measures-classes" .

dpvs:PrivatelyOwnedSpace a owl:Class ;
    rdfs:label "PrivatelyOwnedSpace" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:PrivateSpace ;
    skos:altLabel "Privately Owned Space" ;
    skos:definition "A place that is privately owned e.g. offices, malls" ;
    skos:exactMatch dpv:PrivatelyOwnedSpace,
        dpv_owl:PrivatelyOwnedSpace,
        dpvs:PrivatelyOwnedSpace ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:ProcessingDuration a owl:Class ;
    rdfs:label "ProcessingDuration" ;
    rdfs:subClassOf dpvs:DpvDuration,
        dpvs:ProcessingCondition ;
    skos:altLabel "Processing Duration" ;
    skos:definition "Conditions regarding duration or temporal limitation for processing" ;
    skos:exactMatch dpv:ProcessingDuration,
        dpv_owl:ProcessingDuration,
        dpvs:ProcessingDuration ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:ProcessingLocation a owl:Class ;
    rdfs:label "ProcessingLocation" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:ProcessingCondition ;
    skos:altLabel "Processing Location" ;
    skos:definition """Conditions regarding location or geospatial scope where processing takes
places""" ;
    skos:exactMatch dpv:ProcessingLocation,
        dpv_owl:ProcessingLocation,
        dpvs:ProcessingLocation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:ProvideConsent a owl:Class ;
    rdfs:label "ProvideConsent" ;
    rdfs:subClassOf dpvs:ConsentControl,
        dpvs:OptingInToProcess ;
    skos:altLabel "Provide Consent" ;
    skos:definition "Control for providing consent" ;
    skos:exactMatch dpv:ProvideConsent,
        dpv_owl:ProvideConsent,
        dpvs:ProvideConsent ;
    skos:inScheme dpvs:core ;
    skos:note """Indicates how the data subject can provide consent e.g. used with
dpv:isExercisedAt""" ;
    dpvs:skos_in_scheme "consent-controls-classes" .

dpvs:ProvidedData a owl:Class ;
    rdfs:label "ProvidedData" ;
    rdfs:subClassOf dpvs:CollectedData ;
    skos:altLabel "Provided Data" ;
    skos:definition "Data that has been provided by an entity" ;
    skos:exactMatch dpv:ProvidedData,
        dpv_owl:ProvidedData,
        dpvs:ProvidedData ;
    skos:inScheme dpvs:core ;
    skos:note """Provided data involves one entity explicitly providing the data, which
the other entity then collects""" ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:PseudonymisedData a owl:Class ;
    rdfs:label "PseudonymisedData" ;
    rdfs:subClassOf dpvs:PersonalData ;
    skos:altLabel "Pseudonymised Data" ;
    skos:definition """Pseudonymised Data is data that has gone a partial or incomplete
anonymisation process by replacing the identifiable information with
artificial identifiers or 'pseudonyms', and is still considered as
personal data""" ;
    skos:exactMatch dpv:PseudonymisedData,
        dpv_owl:PseudonymisedData,
        dpvs:PseudonymisedData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:PublicRegisterOfEntities a owl:Class ;
    rdfs:label "PublicRegisterOfEntities" ;
    rdfs:subClassOf dpvs:DpvThing ;
    skos:altLabel "Public Register of Entities" ;
    skos:definition """A publicly available list of entities e.g. to indicate which entities
perform a certain activity within a certain location or jurisdiction""" ;
    skos:exactMatch dpv:PublicRegisterOfEntities,
        dpv_owl:PublicRegisterOfEntities,
        dpvs:PublicRegisterOfEntities ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-classes" .

dpvs:PubliclyAccessibleSpace a owl:Class ;
    rdfs:label "PubliclyAccessibleSpace" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:PublicSpace ;
    skos:altLabel "Publicly Accessible Space" ;
    skos:definition """A space that is accessible to all members of the public e.g. parks,
malls, train stations""" ;
    skos:exactMatch dpv:PubliclyAccessibleSpace,
        dpv_owl:PubliclyAccessibleSpace,
        dpvs:PubliclyAccessibleSpace ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:ReaffirmConsent a owl:Class ;
    rdfs:label "ReaffirmConsent" ;
    rdfs:subClassOf dpvs:ConsentControl ;
    skos:altLabel "Reaffirm Consent" ;
    skos:definition "Control for affirming consent" ;
    skos:exactMatch dpv:ReaffirmConsent,
        dpv_owl:ReaffirmConsent,
        dpvs:ReaffirmConsent ;
    skos:inScheme dpvs:core ;
    skos:note """Indicates how the controller (with dpv:ObtainConsent) or data subject
(with dpv:ProvideConsent) can reaffirm consent e.g. used with
dpv:isExercisedAt""" ;
    dpvs:skos_in_scheme "consent-controls-classes" .

dpvs:RecruitmentAdvertising a owl:Class ;
    rdfs:label "RecruitmentAdvertising" ;
    rdfs:subClassOf dpvs:Advertising,
        dpvs:PersonnelHiring,
        dpvs:Purpose ;
    skos:altLabel "Recruitment Advertising" ;
    skos:definition """Purposes associated with advertisement for Recruitments and personnel
hiring""" ;
    skos:exactMatch dpv:RecruitmentAdvertising,
        dpv_owl:RecruitmentAdvertising,
        dpvs:RecruitmentAdvertising ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:RemoteLocation a owl:Class ;
    rdfs:label "RemoteLocation" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:LocationLocality ;
    skos:altLabel "Remote Location" ;
    skos:definition "Location is remote i.e. not local" ;
    skos:exactMatch dpv:RemoteLocation,
        dpv_owl:RemoteLocation,
        dpvs:RemoteLocation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:Representative a owl:Class ;
    rdfs:label "Representative" ;
    rdfs:subClassOf dpvs:LegalEntity ;
    skos:altLabel "Representative" ;
    skos:definition "A representative of a legal entity" ;
    skos:exactMatch dpv:Representative,
        dpv_owl:Representative,
        dpvs:Representative ;
    skos:inScheme dpvs:core ;
    skos:note """A representative may not be a 'legal agent' if it is authorised to only
represent the entity and not to take actions on its behalf""" ;
    dpvs:skos_in_scheme "entities-classes" .

dpvs:RequestedServiceProvision a owl:Class ;
    rdfs:label "RequestedServiceProvision" ;
    rdfs:subClassOf dpvs:Purpose,
        dpvs:ServiceProvision ;
    skos:altLabel "Requested Service Provision" ;
    skos:definition """Purposes associated with delivering services as requested by user or
consumer""" ;
    skos:exactMatch dpv:RequestedServiceProvision,
        dpv_owl:RequestedServiceProvision,
        dpvs:RequestedServiceProvision ;
    skos:inScheme dpvs:core ;
    skos:note """The use of 'request' here includes where an user explicitly asks for the
service and also when an established contract requires the provision of
the service""" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:ReviewProcedure a owl:Class ;
    rdfs:label "ReviewProcedure" ;
    rdfs:subClassOf dpvs:GovernanceProcedures,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Review Procedure" ;
    skos:definition """A procedure or process that reviews the correctness and validity of
other procedures and policies e.g. to ensure continued validity,
adequacy for intended purposes, and conformance of processes with
findings""" ;
    skos:exactMatch dpv:ReviewProcedure,
        dpv_owl:ReviewProcedure,
        dpvs:ReviewProcedure ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:RightNotice a owl:Class ;
    rdfs:label "RightNotice" ;
    rdfs:subClassOf dpvs:Notice,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Right Notice" ;
    skos:definition """Information associated with rights, such as which rights exist, when and
where they are applicable, and other relevant information""" ;
    skos:exactMatch dpv:RightNotice,
        dpv_owl:RightNotice,
        dpvs:RightNotice ;
    skos:inScheme dpvs:core ;
    skos:note """This concept also covers information about rights exercise, with
dpv:RightExerciseNotice specifically representing information provided
in connection with exercising of rights. Both notices may be needed,
e.g. RightNotice for providing information about existence and exercise
of rights, and RightExerciseNotice for providing additional information
specifically about exercise of rights - such as to request more
information or provide updates on an exercised rights request""" ;
    dpvs:skos_in_scheme "rights-classes" .

dpvs:Risk a owl:Class ;
    rdfs:label "Risk" ;
    rdfs:subClassOf dpvs:RiskConcept ;
    skos:altLabel "Risk" ;
    skos:definition """A risk or possibility or uncertainty of negative effects, impacts, or
consequences""" ;
    skos:exactMatch dpv:Risk,
        dpv_owl:Risk,
        dpvs:Risk ;
    skos:inScheme dpvs:core ;
    skos:note """Risks can be associated with one or more different concepts such as
purpose, processing, personal data, technical or organisational measure""" ;
    dpvs:skos_in_scheme "risk-classes" .

dpvs:RiskLevel a owl:Class ;
    rdfs:label "RiskLevel" ;
    rdfs:subClassOf dpvs:DpvThing ;
    skos:altLabel "Risk Level" ;
    skos:definition """The magnitude of a risk expressed as an indication to aid in its
management""" ;
    skos:exactMatch dpv:RiskLevel,
        dpv_owl:RiskLevel,
        dpvs:RiskLevel ;
    skos:inScheme dpvs:core ;
    skos:note """Risk Levels can be defined as a combination of different
characteristics. For example, ISO 31073:2022 defines it as a combination
of consequences and their likelihood. Another example would be the Risk
Matrix where Risk Level is defined as a combination of Likelihood and
Severity associated with the Risk.""" ;
    dpvs:skos_in_scheme "risk-classes" .

dpvs:ScoringOfIndividuals a owl:Class ;
    rdfs:label "ScoringOfIndividuals" ;
    rdfs:subClassOf dpvs:EvaluationScoring ;
    skos:altLabel "Scoring of Individuals" ;
    skos:definition "Processing that involves scoring of individuals" ;
    skos:exactMatch dpv:ScoringOfIndividuals,
        dpv_owl:ScoringOfIndividuals,
        dpvs:ScoringOfIndividuals ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:Sector a owl:Class ;
    rdfs:label "Sector" ;
    rdfs:subClassOf dpvs:DpvThing ;
    skos:altLabel "Sector" ;
    skos:definition """Sector describes the area of application or domain that indicates or
restricts scope for interpretation and application of purpose e.g.
Agriculture, Banking""" ;
    skos:exactMatch dpv:Sector,
        dpv_owl:Sector,
        dpvs:Sector ;
    skos:inScheme dpvs:core ;
    skos:note """There are various sector codes used commonly to indicate the domain of
an organisation or business. Examples include NACE (EU), ISIC (UN), SIC
and NAICS (USA).""" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:SecurityAssessment a owl:Class ;
    rdfs:label "SecurityAssessment" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure,
        dpvs:RiskAssessment ;
    skos:altLabel "Security Assessment" ;
    skos:definition """Assessment of security intended to identify gaps, vulnerabilities,
risks, and effectiveness of controls""" ;
    skos:exactMatch dpv:SecurityAssessment,
        dpv_owl:SecurityAssessment,
        dpvs:SecurityAssessment ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "risk-classes" .

dpvs:SecurityIncidentNotice a owl:Class ;
    rdfs:label "SecurityIncidentNotice" ;
    rdfs:subClassOf dpvs:Notice,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Security Incident Notice" ;
    skos:definition "A notice providing information about security incident(s)" ;
    skos:exactMatch dpv:SecurityIncidentNotice,
        dpv_owl:SecurityIncidentNotice,
        dpvs:SecurityIncidentNotice ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "notice-classes, organisational-measures-classes" .

dpvs:SecurityIncidentNotification a owl:Class ;
    rdfs:label "SecurityIncidentNotification" ;
    rdfs:subClassOf dpvs:Notification,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Security Incident Notification" ;
    skos:definition "Notification of information about security incident(s)" ;
    skos:exactMatch dpv:SecurityIncidentNotification,
        dpv_owl:SecurityIncidentNotification,
        dpvs:SecurityIncidentNotification ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:SensitivePersonalData a owl:Class ;
    rdfs:label "SensitivePersonalData" ;
    rdfs:subClassOf dpvs:PersonalData,
        dpvs:SensitiveData ;
    skos:altLabel "Sensitive Personal Data" ;
    skos:definition """Personal data that is considered 'sensitive' in terms of privacy and/or
impact, and therefore requires additional considerations and/or
protection""" ;
    skos:exactMatch dpv:SensitivePersonalData,
        dpv_owl:SensitivePersonalData,
        dpvs:SensitivePersonalData ;
    skos:inScheme dpvs:core ;
    skos:note """Sensitivity' is a matter of context, and may be defined within legal
frameworks. For GDPR, Special categories of personal data are considered
a subset of sensitive data. To illustrate the difference between the
two, consider the situation where Location data is collected, and which
is considered 'sensitive' but not 'special'. As a probable rule,
sensitive data require additional considerations whereas special
category data requires additional legal basis / justifications.""" ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:ServiceMonitoring a owl:Class ;
    rdfs:label "ServiceMonitoring" ;
    rdfs:subClassOf dpvs:Purpose,
        dpvs:ServiceManagement ;
    skos:altLabel "Service Monitoring" ;
    skos:definition """Purposes associated with the monitoring of services or products to
understand their performance and utilisation with a view to inform their
management""" ;
    skos:exactMatch dpv:ServiceMonitoring,
        dpv_owl:ServiceMonitoring,
        dpvs:ServiceMonitoring ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:Structure a owl:Class ;
    rdfs:label "Structure" ;
    rdfs:subClassOf dpvs:Organise,
        dpvs:Processing ;
    skos:altLabel "Structure" ;
    skos:definition "to arrange data according to a structure" ;
    skos:exactMatch dpv:Structure,
        dpv_owl:Structure,
        dpvs:Structure ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:TargetedAdvertising a owl:Class ;
    rdfs:label "TargetedAdvertising" ;
    rdfs:subClassOf dpvs:PersonalisedAdvertising,
        dpvs:Purpose ;
    skos:altLabel "Targeted Advertising" ;
    skos:definition """Purposes associated with creating and providing personalised
advertisement where the personalisation is targeted to a specific
individual or group of individuals""" ;
    skos:exactMatch dpv:TargetedAdvertising,
        dpv_owl:TargetedAdvertising,
        dpvs:TargetedAdvertising ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:Technology a owl:Class ;
    rdfs:label "Technology" ;
    rdfs:subClassOf dpvs:DpvThing ;
    skos:altLabel "Technology" ;
    skos:definition """The technology, technological implementation, or any techniques, skills,
methods, and processes used or applied""" ;
    skos:exactMatch dpv:Technology,
        dpv_owl:Technology,
        dpvs:Technology ;
    skos:inScheme dpvs:core ;
    skos:note """Examples (non-exhaustive) include: Algorithm, Process, Method, Skill,
Database, Cookies, Server, Device""" ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:ThirdPartyContract a owl:Class ;
    rdfs:label "ThirdPartyContract" ;
    rdfs:subClassOf dpvs:DataProcessingAgreement,
        dpvs:LegalBasis ;
    skos:altLabel "Third Party Contract" ;
    skos:definition """Creation, completion, fulfilment, or performance of a contract, with the
Data Controller and Third Party as parties, and involving specified
processing of data or technologies. NOTE: This concept is being
deprecated - use dpv:ThirdPartyAgreement which has a more explicit
definition of the entities involved and the intent of the contract""" ;
    skos:exactMatch dpv:ThirdPartyContract,
        dpv_owl:ThirdPartyContract,
        dpvs:ThirdPartyContract ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-types-classes" .

dpvs:Unintended a owl:Class ;
    rdfs:label "Unintended" ;
    rdfs:subClassOf dpvs:IntentionStatus ;
    skos:altLabel "Unintended" ;
    skos:definition "Status indicating the specified context was unintended i.e. not intended" ;
    skos:exactMatch dpv:Unintended,
        dpv_owl:Unintended,
        dpvs:Unintended ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:VitalInterest a owl:Class ;
    rdfs:label "VitalInterest" ;
    rdfs:subClassOf dpvs:LegalBasis ;
    skos:altLabel "Vital Interest" ;
    skos:definition """Activities are necessary or required to protect vital interests of a
data subject or other natural person""" ;
    skos:exactMatch dpv:VitalInterest,
        dpv_owl:VitalInterest,
        dpvs:VitalInterest ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-classes" .

dpvs:VitalInterestOfNaturalPerson a owl:Class ;
    rdfs:label "VitalInterestOfNaturalPerson" ;
    rdfs:subClassOf dpvs:LegalBasis,
        dpvs:VitalInterest ;
    skos:altLabel "Vital Interest of Natural Person" ;
    skos:definition """Activities are necessary or required to protect vital interests of a
natural person""" ;
    skos:exactMatch dpv:VitalInterestOfNaturalPerson,
        dpv_owl:VitalInterestOfNaturalPerson,
        dpvs:VitalInterestOfNaturalPerson ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-classes" .

dpvs:WithdrawConsent a owl:Class ;
    rdfs:label "WithdrawConsent" ;
    rdfs:subClassOf dpvs:ConsentControl,
        dpvs:WithdrawingFromProcess ;
    skos:altLabel "Withdraw Consent" ;
    skos:definition "Control for withdrawing consent" ;
    skos:exactMatch dpv:WithdrawConsent,
        dpv_owl:WithdrawConsent,
        dpvs:WithdrawConsent ;
    skos:inScheme dpvs:core ;
    skos:note """Indicates how the data subject can withdraw consent e.g. used with
dpv:isExercisedAt""" ;
    dpvs:skos_in_scheme "consent-controls-classes" .

dpvs:WithdrawingFromProcess a owl:Class ;
    rdfs:label "WithdrawingFromProcess" ;
    rdfs:subClassOf dpvs:EntityPermissiveInvolvement ;
    skos:altLabel "Withdrawing from Process" ;
    skos:definition """Involvement where entity can withdraw a previously given assent from
specified context""" ;
    skos:exactMatch dpv:WithdrawingFromProcess,
        dpv_owl:WithdrawingFromProcess,
        dpvs:WithdrawingFromProcess ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:has_assessment a owl:DatatypeProperty ;
    rdfs:label "has_assessment" ;
    rdfs:subPropertyOf dpvs:has_organisational_measure ;
    skos:altLabel "has assessment" ;
    skos:definition "Indicates a relevant assessment associated with the specific context" ;
    skos:exactMatch dpv:hasAssessment,
        dpv_owl:hasAssessment ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "TOM-properties" .

dpvs:AccessControlMethod a owl:Class ;
    rdfs:label "AccessControlMethod" ;
    rdfs:subClassOf dpvs:TechnicalMeasure ;
    skos:altLabel "Access Control Method" ;
    skos:definition "Methods which restrict access to a place or resource" ;
    skos:exactMatch dpv:AccessControlMethod,
        dpv_owl:AccessControlMethod,
        dpvs:AccessControlMethod ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:Alter a owl:Class ;
    rdfs:label "Alter" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Transform ;
    skos:altLabel "Alter" ;
    skos:definition "to change the data without changing it into something else" ;
    skos:exactMatch dpv:Alter,
        dpv_owl:Alter,
        dpvs:Alter ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:AuthorisationProcedure a owl:Class ;
    rdfs:label "AuthorisationProcedure" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure,
        dpvs:SecurityProcedure ;
    skos:altLabel "Authorisation Procedure" ;
    skos:definition "Procedures for determining authorisation through permission or authority" ;
    skos:exactMatch dpv:AuthorisationProcedure,
        dpv_owl:AuthorisationProcedure,
        dpvs:AuthorisationProcedure ;
    skos:inScheme dpvs:core ;
    skos:note """non-technical authorisation procedures: How is it described on an
organisational level, who gets access to the data""" ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:CertificationSeal a owl:Class ;
    rdfs:label "CertificationSeal" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure ;
    skos:altLabel "Certification and Seal" ;
    skos:definition """Certifications, seals, and marks indicating compliance to regulations or
practices""" ;
    skos:exactMatch dpv:CertificationSeal,
        dpv_owl:CertificationSeal,
        dpvs:CertificationSeal ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:CollectedPersonalData a owl:Class ;
    rdfs:label "CollectedPersonalData" ;
    rdfs:subClassOf dpvs:CollectedData,
        dpvs:PersonalData ;
    skos:altLabel "Collected Personal Data" ;
    skos:definition """Personal Data that has been collected from another source such as the
Data Subject""" ;
    skos:exactMatch dpv:CollectedPersonalData,
        dpv_owl:CollectedPersonalData,
        dpvs:CollectedPersonalData ;
    skos:inScheme dpvs:core ;
    skos:note """To indicate the source of data, use the DataSource concept with the
hasDataSource relation""" ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:ConformanceStatus a owl:Class ;
    rdfs:label "ConformanceStatus" ;
    rdfs:subClassOf dpvs:Status ;
    skos:altLabel "Conformance Status" ;
    skos:definition """Status associated with conformance to a standard, guideline, code, or
recommendation""" ;
    skos:exactMatch dpv:ConformanceStatus,
        dpv_owl:ConformanceStatus,
        dpvs:ConformanceStatus ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:Consent a owl:Class ;
    rdfs:label "Consent" ;
    rdfs:subClassOf dpvs:LegalBasis ;
    skos:altLabel "Consent" ;
    skos:definition "Consent of the Data Subject for specified process or activity" ;
    skos:exactMatch dpv:Consent,
        dpv_owl:Consent,
        dpvs:Consent ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-classes" .

dpvs:ConsentStatusValidForProcessing a owl:Class ;
    rdfs:label "ConsentStatusValidForProcessing" ;
    rdfs:subClassOf dpvs:ConsentStatus ;
    skos:altLabel "Consent Status Valid for Processing" ;
    skos:definition """States of consent that can be used as valid justifications for
processing data""" ;
    skos:exactMatch dpv:ConsentStatusValidForProcessing,
        dpv_owl:ConsentStatusValidForProcessing,
        dpvs:ConsentStatusValidForProcessing ;
    skos:inScheme dpvs:core ;
    skos:note "Practically, given consent is the only valid state for processing" ;
    dpvs:skos_in_scheme "consent-status-classes" .

dpvs:Consult a owl:Class ;
    rdfs:label "Consult" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Use ;
    skos:altLabel "Consult" ;
    skos:definition "to consult or query data" ;
    skos:exactMatch dpv:Consult,
        dpv_owl:Consult,
        dpvs:Consult ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch svpr:Query ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:ContractActivationStatus a owl:Class ;
    rdfs:label "ContractActivationStatus" ;
    rdfs:subClassOf dpvs:ContractStatus ;
    skos:altLabel "Contract Activation Status" ;
    skos:definition """Status associated with activation of a contract i.e. whether its terms
are active and are required to be performed""" ;
    skos:exactMatch dpv:ContractActivationStatus,
        dpv_owl:ContractActivationStatus,
        dpvs:ContractActivationStatus ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-status-classes" .

dpvs:ContractByNegotiationType a owl:Class ;
    rdfs:label "ContractByNegotiationType" ;
    rdfs:subClassOf dpvs:Contract,
        dpvs:LegalBasis ;
    skos:altLabel "Contract by Negotiation Type" ;
    skos:definition """A generic concept representing contracts categorised based on their use
or absence of negotiation in the contract forming process""" ;
    skos:exactMatch dpv:ContractByNegotiationType,
        dpv_owl:ContractByNegotiationType,
        dpvs:ContractByNegotiationType ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-types-classes" .

dpvs:DataInteroperabilityManagement a owl:Class ;
    rdfs:label "DataInteroperabilityManagement" ;
    rdfs:subClassOf dpvs:DataGovernance,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Data Interoperability Management" ;
    skos:definition "Measures associated with management of data interoperability" ;
    skos:exactMatch dpv:DataInteroperabilityManagement,
        dpv_owl:DataInteroperabilityManagement,
        dpvs:DataInteroperabilityManagement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:DataQualityManagement a owl:Class ;
    rdfs:label "DataQualityManagement" ;
    rdfs:subClassOf dpvs:DataGovernance,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Data Quality Management" ;
    skos:definition "Measures associated with management of data quality" ;
    skos:exactMatch dpv:DataQualityManagement,
        dpv_owl:DataQualityManagement,
        dpvs:DataQualityManagement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:DataSanitisationTechnique a owl:Class ;
    rdfs:label "DataSanitisationTechnique" ;
    rdfs:subClassOf dpvs:TechnicalMeasure ;
    skos:altLabel "Data Sanitisation Technique" ;
    skos:definition """Cleaning or any removal or re-organisation of elements in data based on
selective criteria""" ;
    skos:exactMatch dpv:DataSanitisationTechnique,
        dpv_owl:DataSanitisationTechnique,
        dpvs:DataSanitisationTechnique ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:Deidentification a owl:Class ;
    rdfs:label "Deidentification" ;
    rdfs:subClassOf dpvs:DataSanitisationTechnique,
        dpvs:TechnicalMeasure ;
    skos:altLabel "De-Identification" ;
    skos:definition "Removal of identity or information to reduce identifiability" ;
    skos:exactMatch dpv:Deidentification,
        dpv_owl:Deidentification,
        dpvs:Deidentification ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:DerivedData a owl:Class ;
    rdfs:label "DerivedData" ;
    rdfs:subClassOf dpvs:DpvData ;
    skos:altLabel "Derived Data" ;
    skos:definition "Data that has been obtained through derivations of other data" ;
    skos:exactMatch dpv:DerivedData,
        dpv_owl:DerivedData,
        dpvs:DerivedData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:DigitalLiteracy a owl:Class ;
    rdfs:label "DigitalLiteracy" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure ;
    skos:altLabel "Digital Literacy" ;
    skos:definition """Providing skills, knowledge, and understanding to enable reading,
writing, analysing, reasoning, and communicating regarding digital
technologies and their implications""" ;
    skos:exactMatch dpv:DigitalLiteracy,
        dpv_owl:DigitalLiteracy,
        dpvs:DigitalLiteracy ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:EvaluationScoring a owl:Class ;
    rdfs:label "EvaluationScoring" ;
    rdfs:subClassOf dpvs:ProcessingContext ;
    skos:altLabel "Evaluation and Scoring" ;
    skos:definition "Processing that involves evaluation and scoring of individuals" ;
    skos:exactMatch dpv:EvaluationScoring,
        dpv_owl:EvaluationScoring,
        dpvs:EvaluationScoring ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:FeeRequirement a owl:Class ;
    rdfs:label "FeeRequirement" ;
    rdfs:subClassOf dpvs:Context ;
    skos:altLabel "Fee Requirement" ;
    skos:definition "Concept indicating whether a fee is required" ;
    skos:exactMatch dpv:FeeRequirement,
        dpv_owl:FeeRequirement,
        dpvs:FeeRequirement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "context-classes" .

dpvs:FixedLocation a owl:Class ;
    rdfs:label "FixedLocation" ;
    rdfs:subClassOf dpvs:LocationFixture ;
    skos:altLabel "Fixed Location" ;
    skos:definition "Location that is fixed i.e. known to occur at a specific place" ;
    skos:exactMatch dpv:FixedLocation,
        dpv_owl:FixedLocation,
        dpvs:FixedLocation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:FraudPreventionAndDetection a owl:Class ;
    rdfs:label "FraudPreventionAndDetection" ;
    rdfs:subClassOf dpvs:MisusePreventionAndDetection,
        dpvs:Purpose ;
    skos:altLabel "Fraud Prevention and Detection" ;
    skos:definition "Purposes associated with fraud detection, prevention, and mitigation" ;
    skos:exactMatch dpv:FraudPreventionAndDetection,
        dpv_owl:FraudPreventionAndDetection,
        dpvs:FraudPreventionAndDetection ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch svpu:Government ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:HybridPublicPrivateSpace a owl:Class ;
    rdfs:label "HybridPublicPrivateSpace" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:PrivateSpace,
        dpvs:PublicSpace ;
    skos:altLabel "Hybrid Public Private Space" ;
    skos:definition """A space that is a hybrid space i.e it has both public and private
components - such as by having part of it be a private space or which is
operated privately""" ;
    skos:exactMatch dpv:HybridPublicPrivateSpace,
        dpv_owl:HybridPublicPrivateSpace,
        dpvs:HybridPublicPrivateSpace ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:Importance a owl:Class ;
    rdfs:label "Importance" ;
    rdfs:subClassOf dpvs:Context ;
    skos:altLabel "Importance" ;
    skos:definition "An indication of 'importance' within a context" ;
    skos:exactMatch dpv:Importance,
        dpv_owl:Importance,
        dpvs:Importance ;
    skos:inScheme dpvs:core ;
    skos:note """Importance can be used to express importance, desirability, relevance,
or significance as a context.""" ;
    dpvs:skos_in_scheme "context-classes" .

dpvs:InformedConsent a owl:Class ;
    rdfs:label "InformedConsent" ;
    rdfs:subClassOf dpvs:Consent,
        dpvs:LegalBasis ;
    skos:altLabel "Informed Consent" ;
    skos:closeMatch iso29100:ConsentMechanism ;
    skos:definition """Consent that is informed i.e. with the requirement to provide sufficient
information to make a consenting decision""" ;
    skos:exactMatch dpv:InformedConsent,
        dpv_owl:InformedConsent,
        dpvs:InformedConsent,
        iso29100:Consent ;
    skos:inScheme dpvs:core ;
    skos:note """The specifics for what information should be provided or made available
will depend on the context, use-case, or relevant legal requirements""" ;
    dpvs:skos_in_scheme "consent-types-classes" .

dpvs:InnovativeUseOfTechnology a owl:Class ;
    rdfs:label "InnovativeUseOfTechnology" ;
    rdfs:subClassOf dpvs:ProcessingContext ;
    skos:altLabel "Innovative use of Technology" ;
    skos:definition "Indicates that technology is being used in an innovative manner" ;
    skos:exactMatch dpv:InnovativeUseOfTechnology,
        dpv_owl:InnovativeUseOfTechnology,
        dpvs:InnovativeUseOfTechnology ;
    skos:inScheme dpvs:core ;
    skos:note """Innovative here refers to 'state of the art' rather than the
implementing entity, and can be for either new technology or new uses of
existing technology""" ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:IntentionStatus a owl:Class ;
    rdfs:label "IntentionStatus" ;
    rdfs:subClassOf dpvs:Status ;
    skos:altLabel "Intention Status" ;
    skos:definition """Status indicating whether the specified context was intended or
unintended""" ;
    skos:exactMatch dpv:IntentionStatus,
        dpv_owl:IntentionStatus,
        dpvs:IntentionStatus ;
    skos:inScheme dpvs:core ;
    skos:note """Intention is associated with the goal or purpose for what is about to
happen i.e. an ex-ante indication of whether the specified context
is/was planned or intended. Intention and Expectation are closely
related terms. We recommend using Intention when the entity has the
ability to control the implementation and Expectation for when the
entity does not have control or for what happens after or beyond the
exercise of control.""" ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:LocationLocality a owl:Class ;
    rdfs:label "LocationLocality" ;
    rdfs:subClassOf dpvs:DpvLocation ;
    skos:altLabel "Location Locality" ;
    skos:definition """Locality refers to whether the specified location is local within some
context, e.g. for the user""" ;
    skos:exactMatch dpv:LocationLocality,
        dpv_owl:LocationLocality,
        dpvs:LocationLocality ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:ProvidePersonalisedRecommendations a owl:Class ;
    rdfs:label "ProvidePersonalisedRecommendations" ;
    rdfs:subClassOf dpvs:Purpose,
        dpvs:ServicePersonalisation ;
    skos:altLabel "Provide Personalised Recommendations" ;
    skos:definition """Purposes associated with creating and providing personalised
recommendations""" ;
    skos:exactMatch dpv:ProvidePersonalisedRecommendations,
        dpv_owl:ProvidePersonalisedRecommendations,
        dpvs:ProvidePersonalisedRecommendations ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:RecruitmentApplicationManagement a owl:Class ;
    rdfs:label "RecruitmentApplicationManagement" ;
    rdfs:subClassOf dpvs:Purpose,
        dpvs:RecruitmentManagement ;
    skos:altLabel "Recruitment Application Management" ;
    skos:definition "Purposes associated with managing job applications for recruitment" ;
    skos:exactMatch dpv:RecruitmentApplicationManagement,
        dpv_owl:RecruitmentApplicationManagement,
        dpvs:RecruitmentApplicationManagement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:RightExerciseNotice a owl:Class ;
    rdfs:label "RightExerciseNotice" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure,
        dpvs:RightNotice ;
    skos:altLabel "Right Exercise Notice" ;
    skos:definition """Information associated with exercising of an active right such as where
and how to exercise the right, information required for it, or updates
on an exercised rights request""" ;
    skos:exactMatch dpv:RightExerciseNotice,
        dpv_owl:RightExerciseNotice,
        dpvs:RightExerciseNotice ;
    skos:inScheme dpvs:core ;
    skos:note """This concept is intended for providing information regarding a right
exercise. For specific instances of such exercises, see
RightExerciseActivity and RightExerciseRecord.""" ;
    dpvs:skos_in_scheme "rights-classes" .

dpvs:RiskAssessment a owl:Class ;
    rdfs:label "RiskAssessment" ;
    rdfs:subClassOf dpvs:Assessment,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Risk Assessment" ;
    skos:closeMatch iso27001:RiskAssessment,
        iso42001:AIRiskAssessment ;
    skos:definition "Assessment involving identification, analysis, and evaluation of risk" ;
    skos:exactMatch dpv:RiskAssessment,
        dpv_owl:RiskAssessment,
        dpvs:RiskAssessment ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch nist_ai_rmf:Function,
        nist_csf_v2:CSFCategory ;
    dpvs:skos_in_scheme "risk-classes" .

dpvs:RuleViolated a owl:Class ;
    rdfs:label "RuleViolated" ;
    rdfs:subClassOf dpvs:RuleFulfilmentStatus ;
    skos:altLabel "Rule Violated" ;
    skos:definition """Status indicating a rule has been violated, breached, broken, or
infracted""" ;
    skos:exactMatch dpv:RuleViolated,
        dpv_owl:RuleViolated,
        dpvs:RuleViolated ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:Safeguard a owl:Class ;
    rdfs:label "Safeguard" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure ;
    skos:altLabel "Safeguard" ;
    skos:definition """A safeguard is a precautionary measure for the protection against or
mitigation of negative effects""" ;
    skos:exactMatch dpv:Safeguard,
        dpv_owl:Safeguard,
        dpvs:Safeguard ;
    skos:inScheme dpvs:core ;
    skos:note """This concept is relevant given the requirement to assert safeguards in
cross-border data transfers""" ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:SensitiveData a owl:Class ;
    rdfs:label "SensitiveData" ;
    rdfs:subClassOf dpvs:DpvData ;
    skos:altLabel "Sensitive Data" ;
    skos:definition "Data deemed sensitive" ;
    skos:exactMatch dpv:SensitiveData,
        dpv_owl:SensitiveData,
        dpvs:SensitiveData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:ServiceOptimisation a owl:Class ;
    rdfs:label "ServiceOptimisation" ;
    rdfs:subClassOf dpvs:Purpose,
        dpvs:ServiceManagement ;
    skos:altLabel "Service Optimisation" ;
    skos:definition "Purposes associated with optimisation of services or activities" ;
    skos:exactMatch dpv:ServiceOptimisation,
        dpv_owl:ServiceOptimisation,
        dpvs:ServiceOptimisation ;
    skos:inScheme dpvs:core ;
    skos:note """Subclass of ServiceProvision since optimisation is usually considered
part of providing services""" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:Severity a owl:Class ;
    rdfs:label "Severity" ;
    rdfs:subClassOf dpvs:DpvThing ;
    skos:altLabel "Severity" ;
    skos:definition """The magnitude of being unwanted or having negative effects such as
harmful impacts""" ;
    skos:exactMatch dpv:Severity,
        dpv_owl:Severity,
        dpvs:Severity ;
    skos:inScheme dpvs:core ;
    skos:note "Severity can be associated with Risk, or its Consequences and Impacts" ;
    dpvs:skos_in_scheme "risk-classes" .

dpvs:StandardFormContract a owl:Class ;
    rdfs:label "StandardFormContract" ;
    rdfs:subClassOf dpvs:ContractByNegotiationType,
        dpvs:LegalBasis ;
    skos:altLabel "Standard Form Contract" ;
    skos:definition """A contract where the terms and conditions are determined by one or more
of the parties, and the other parties have negligible or no ability to
negotiate the terms and conditions""" ;
    skos:exactMatch dpv:StandardFormContract,
        dpv_owl:StandardFormContract,
        dpvs:StandardFormContract ;
    skos:inScheme dpvs:core ;
    skos:note """Such a contract results in the unempowered parties being in a "take it
or leave it" position as they can only accept or reject the contract.
Standard form contracts are also known as "Adhesion contract" or
"Boilerplate contract\"""" ;
    dpvs:skos_in_scheme "contract-types-classes" .

dpvs:Tracking a owl:Class ;
    rdfs:label "Tracking" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Use ;
    skos:altLabel "Tracking" ;
    skos:definition """to use data to track a specific factor (e.g. a human or their
activities) across multiple distinct contexts""" ;
    skos:exactMatch dpv:Tracking,
        dpv_owl:Tracking,
        dpvs:Tracking ;
    skos:inScheme dpvs:core ;
    skos:note """Tracking is a widely used (and abused) concept and therefore carries
several distinct interpretations, for example see Do Not Track which
defines tracking in the context of the web, and where other forms of
tracking such as location tracking or physical biometric tracking may
exist which are defined differently. For this concept, DPVCG defines
Tracking in the broadest possible sense and strongly recommends adopters
to provide their specific definition or interpretation by either
extending this concept, through a usage note, or by contributing the
specific term back to DPVCG for inclusion in DPV or an extension. This
concept may change in the future based on developments in privacy and
legal spaces. In DPV, Tracking is defined as a type of processing
operation that may collect and/or may use data - which covers both
initial collection and usage as well as subsequent use of existing data
to track an individual. The classification of Tracking as a processing
operation also implies that it is not sufficient as a Purpose on its own
and therefore a suitable purpose from the DPV taxonomy should be used to
justify it.""" ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:Transfer a owl:Class ;
    rdfs:label "Transfer" ;
    rdfs:subClassOf dpvs:Processing ;
    skos:altLabel "Transfer" ;
    skos:definition "to move data from one place to another" ;
    skos:exactMatch dpv:Transfer,
        dpv_owl:Transfer,
        dpvs:Transfer ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch svpr:Transfer ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:UnacceptableRule a owl:Class ;
    rdfs:label "UnacceptableRule" ;
    rdfs:subClassOf dpvs:Rule ;
    skos:altLabel "Unacceptable Rule" ;
    skos:definition "A rule that is unacceptable where it is not desirable if it occurs" ;
    skos:exactMatch dpv:UnacceptableRule,
        dpv_owl:UnacceptableRule,
        dpvs:UnacceptableRule ;
    skos:inScheme dpvs:core ;
    skos:note """Unacceptable is a subjective concept that enables specifying something
is to be avoided as compared to "acceptable". By itself it does not
signal any deterrence or prohibition - for which further specific
concepts are defined""" ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:Verification a owl:Class ;
    rdfs:label "Verification" ;
    rdfs:subClassOf dpvs:EnforceSecurity,
        dpvs:Purpose ;
    skos:altLabel "Verification" ;
    skos:definition """Purposes association with verification e.g. information, identity,
integrity""" ;
    skos:exactMatch dpv:Verification,
        dpv_owl:Verification,
        dpvs:Verification ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:VulnerableDataSubject a owl:Class ;
    rdfs:label "VulnerableDataSubject" ;
    rdfs:subClassOf dpvs:HumanSubject,
        dpvs:VulnerableHuman ;
    skos:altLabel "Vulnerable Data Subject" ;
    skos:definition """Humans which should be considered 'vulnerable' and therefore would
require additional measures and safeguards""" ;
    skos:exactMatch dpv:VulnerableDataSubject,
        dpv_owl:VulnerableDataSubject,
        dpvs:VulnerableDataSubject ;
    skos:inScheme dpvs:core ;
    skos:note """This concept denotes a Data Subject or a group are vulnerable, but not
what vulnerability they possess or its context. This information can be
provided additionally as comments, or as separate concepts and
relations. Proposals for this are welcome.""" ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

dpvs:has_data a owl:DatatypeProperty ;
    rdfs:label "has_data" ;
    skos:altLabel "has data" ;
    skos:definition "Indicates associated with Data (may or may not be personal)" ;
    skos:exactMatch dpv:hasData,
        dpv_owl:hasData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-properties" .

dpvs:has_location a owl:DatatypeProperty ;
    rdfs:label "has_location" ;
    skos:altLabel "has location" ;
    skos:definition "Indicates information about location" ;
    skos:exactMatch dpv:hasLocation,
        dpv_owl:hasLocation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-properties" .

dpvs:id a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition """Stable identifier for the instance. Typically a CURIE or IRI naming the
RDF subject this LinkML instance corresponds to.""" ;
    skos:inScheme dpvs:core .

dpvs:AcceptableRule a owl:Class ;
    rdfs:label "AcceptableRule" ;
    rdfs:subClassOf dpvs:Rule ;
    skos:altLabel "Acceptable Rule" ;
    skos:definition """A rule that is acceptable where it is either desirable if it occurs or
it is not unacceptable if it does""" ;
    skos:exactMatch dpv:AcceptableRule,
        dpv_owl:AcceptableRule,
        dpvs:AcceptableRule ;
    skos:inScheme dpvs:core ;
    skos:note """Acceptable is a subjective concept that enables distinguishing with
"unacceptable". By itself it does not signal any permission or
obligation - for which further specific concepts are defined""" ;
    dpvs:skos_in_scheme "rules-classes" .

dpvs:Advertising a owl:Class ;
    rdfs:label "Advertising" ;
    rdfs:subClassOf dpvs:Marketing,
        dpvs:Purpose ;
    skos:altLabel "Advertising" ;
    skos:definition """Purposes associated with conducting advertising i.e. process or artefact
used to call attention to a product, service, etc. through
announcements, notices, or other forms of communication""" ;
    skos:exactMatch dpv:Advertising,
        dpv_owl:Advertising,
        dpvs:Advertising ;
    skos:inScheme dpvs:core ;
    skos:note """Advertising is a subset of Marketing. Advertising by itself does not
indicate 'personalisation' i.e. personalised ads.""" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:Applicability a owl:Class ;
    rdfs:label "Applicability" ;
    rdfs:subClassOf dpvs:Context ;
    skos:altLabel "Applicability" ;
    skos:definition """Concept provided to represent indication of cases where the information
or context is not applicable (N/A) or not available or this is not known
or determined yet. If the information is applicable and available, this
concept should not be used.""" ;
    skos:exactMatch dpv:Applicability,
        dpv_owl:Applicability,
        dpvs:Applicability ;
    skos:inScheme dpvs:core ;
    skos:note """These concepts are useful in closed-world interpretations, for example
in forms where a field must have a value to explicitly denote it is not
applicable or the information is not available yet.""" ;
    dpvs:skos_in_scheme "context-classes" .

dpvs:Audit a owl:Class ;
    rdfs:label "Audit" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure ;
    skos:altLabel "Audit" ;
    skos:closeMatch iso27001:InternalAudit,
        iso42001:InternalAudit ;
    skos:definition """An audit is a systematic examination or evaluation of records,
processes, or systems towards a specific objective such as to assess
accuracy, compliance, effectiveness, or performance""" ;
    skos:exactMatch dpv:Audit,
        dpv_owl:Audit,
        dpvs:Audit ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:CollectedData a owl:Class ;
    rdfs:label "CollectedData" ;
    rdfs:subClassOf dpvs:DpvData ;
    skos:altLabel "Collected Data" ;
    skos:definition "Data that has been obtained by collecting it from a source" ;
    skos:exactMatch dpv:CollectedData,
        dpv_owl:CollectedData,
        dpvs:CollectedData ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:Consultation a owl:Class ;
    rdfs:label "Consultation" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure ;
    skos:altLabel "Consultation" ;
    skos:definition """Consultation is a process of receiving feedback, advice, or opinion from
an external agency""" ;
    skos:exactMatch dpv:Consultation,
        dpv_owl:Consultation,
        dpvs:Consultation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:DataProcessingRecord a owl:Class ;
    rdfs:label "DataProcessingRecord" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure,
        dpvs:RecordsOfActivities ;
    skos:altLabel "Data Processing Record" ;
    skos:definition "Record of data processing, whether ex-ante or ex-post" ;
    skos:exactMatch dpv:DataProcessingRecord,
        dpv_owl:DataProcessingRecord,
        dpvs:DataProcessingRecord ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:DpvAuthority a owl:Class ;
    rdfs:label "DpvAuthority" ;
    rdfs:subClassOf dpvs:GovernmentalOrganisation ;
    skos:altLabel "Authority" ;
    skos:definition """An authority with the power to create or enforce laws, or determine
their compliance.""" ;
    skos:exactMatch dpv:Authority,
        dpv_owl:Authority,
        dpvs:Authority ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-authority-classes" .

dpvs:DpvJurisdiction a owl:Class ;
    rdfs:label "DpvJurisdiction" ;
    rdfs:subClassOf dpvs:DpvLocation ;
    skos:altLabel "Jurisdiction" ;
    skos:definition """A jurisdiction represents the locations that define the extent of
authority (or control) claimed, granted, or asserted by a legal entity
(in particular a legal authority) to govern or enforce rules""" ;
    skos:exactMatch dpv:Jurisdiction,
        dpv_owl:Jurisdiction,
        dpvs:Jurisdiction ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:EmergencyServiceProvider a owl:Class ;
    rdfs:label "EmergencyServiceProvider" ;
    rdfs:subClassOf dpvs:DpvOrganisation ;
    skos:altLabel "Emergency Service Provider" ;
    skos:definition """An organisation tasked with providing emergency services such as by
responding rapidly to urgent situations to protect lives, property, and
the environment""" ;
    skos:exactMatch dpv:EmergencyServiceProvider,
        dpv_owl:EmergencyServiceProvider,
        dpvs:EmergencyServiceProvider ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-organisation-classes" .

dpvs:ExpectationStatus a owl:Class ;
    rdfs:label "ExpectationStatus" ;
    rdfs:subClassOf dpvs:DpvThing ;
    skos:altLabel "Expectation Status" ;
    skos:definition """Status indicating whether the specified context was intended or
unintended""" ;
    skos:exactMatch dpv:ExpectationStatus,
        dpv_owl:ExpectationStatus,
        dpvs:ExpectationStatus ;
    skos:inScheme dpvs:core ;
    skos:note """Expectation is associated with the outcome of a goal or purpose for what
is expected to happen i.e. an ex-post indication of what was expected to
happen in the specified context. Intention and Expectation are closely
related terms. We recommend using Intention when the entity has the
ability to control the implementation and Expectation for when the
entity does not have control or for what happens after or beyond the
exercise of control.""" ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:FulfilmentOfObligation a owl:Class ;
    rdfs:label "FulfilmentOfObligation" ;
    rdfs:subClassOf dpvs:Purpose ;
    skos:altLabel "Fulfilment of Obligation" ;
    skos:definition """Purposes associated with carrying out data processing to fulfill an
obligation""" ;
    skos:exactMatch dpv:FulfilmentOfObligation,
        dpv_owl:FulfilmentOfObligation,
        dpvs:FulfilmentOfObligation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:InvolvementStatus a owl:Class ;
    rdfs:label "InvolvementStatus" ;
    rdfs:subClassOf dpvs:Status ;
    skos:altLabel "Involvement Status" ;
    skos:definition "Status indicating whether the involvement of specified context" ;
    skos:exactMatch dpv:InvolvementStatus,
        dpv_owl:InvolvementStatus,
        dpvs:InvolvementStatus ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:Lawfulness a owl:Class ;
    rdfs:label "Lawfulness" ;
    rdfs:subClassOf dpvs:ComplianceStatus ;
    skos:altLabel "Lawfulness" ;
    skos:definition "Status associated with expressing lawfulness or legal compliance" ;
    skos:exactMatch dpv:Lawfulness,
        dpv_owl:Lawfulness,
        dpvs:Lawfulness ;
    skos:inScheme dpvs:core ;
