        dpvs:ProfessionalTraining ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:Profiling a owl:Class ;
    rdfs:label "Profiling" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Use ;
    skos:altLabel "Profiling" ;
    skos:definition "to create a profile that describes or represents a person" ;
    skos:exactMatch dpv:Profiling,
        dpv_owl:Profiling,
