dpvs:ProhibitionUnviolated a owl:Class ;
    rdfs:label "ProhibitionUnviolated" ;
    rdfs:subClassOf dpvs:RuleFulfilled,
        dpvs:RuleFulfilmentStatus ;
    skos:altLabel "Prohibition Unviolated" ;
    skos:definition """Status indicating a prohibition has not been violated i.e. the activity
