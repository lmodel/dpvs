such as its intended purpose and proper use""" ;
    skos:exactMatch dpv:AINotice,
        dpv_owl:AINotice,
        dpvs:AINotice ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch iso42001:AISystem ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:AcademicResearch a owl:Class ;
    rdfs:label "AcademicResearch" ;
    rdfs:subClassOf dpvs:Purpose,
        dpvs:ResearchAndDevelopment ;
    skos:altLabel "Academic Research" ;
    skos:definition """Purposes associated with conducting or assisting with research conducted
in an academic context e.g. within universities""" ;
    skos:exactMatch dpv:AcademicResearch,
        dpv_owl:AcademicResearch,
        dpvs:AcademicResearch ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch svpu:Education ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:AcademicScientificOrganisation a owl:Class ;
    rdfs:label "AcademicScientificOrganisation" ;
    rdfs:subClassOf dpvs:DpvOrganisation ;
    skos:altLabel "Academic or Scientific Organisation" ;
    skos:definition """Organisations related to academia or scientific pursuits e.g.
Universities, Schools, Research Bodies""" ;
    skos:exactMatch dpv:AcademicScientificOrganisation,
        dpv_owl:AcademicScientificOrganisation,
        dpvs:AcademicScientificOrganisation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-organisation-classes" .

dpvs:AcceptContract a owl:Class ;
    rdfs:label "AcceptContract" ;
    rdfs:subClassOf dpvs:ContractControl ;
    skos:altLabel "Accept Contract" ;
    skos:definition "Control for accepting a contract" ;
    skos:exactMatch dpv:AcceptContract,
        dpv_owl:AcceptContract,
        dpvs:AcceptContract ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-control-classes" .

dpvs:AcceptableUsePolicy a owl:Class ;
    rdfs:label "AcceptableUsePolicy" ;
    rdfs:subClassOf dpvs:OrganisationalMeasure,
        dpvs:Policy ;
    skos:altLabel "Acceptable Use Policy" ;
    skos:definition """Acceptable Use Policy (AUP) refers to conditions, contexts, or uses
which are considered acceptable with the implication that those not
covered by such a policy are to be considered unacceptable""" ;
    skos:exactMatch dpv:AcceptableUsePolicy,
        dpv_owl:AcceptableUsePolicy,
        dpvs:AcceptableUsePolicy ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:Access a owl:Class ;
    rdfs:label "Access" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Use ;
    skos:altLabel "Access" ;
    skos:definition "to access data" ;
    skos:exactMatch dpv:Access,
        dpv_owl:Access,
        dpvs:Access ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:AccountManagement a owl:Class ;
    rdfs:label "AccountManagement" ;
    rdfs:subClassOf dpvs:Purpose ;
    skos:altLabel "Account Management" ;
    skos:definition """Account Management refers to purposes associated with account
management, such as to create, provide, maintain, and manage accounts""" ;
    skos:exactMatch dpv:AccountManagement,
        dpv_owl:AccountManagement,
        dpvs:AccountManagement ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:Acquire a owl:Class ;
    rdfs:label "Acquire" ;
    rdfs:subClassOf dpvs:Obtain,
        dpvs:Processing ;
    skos:altLabel "Acquire" ;
    skos:definition "to come into possession or control of the data" ;
    skos:exactMatch dpv:Acquire,
        dpv_owl:Acquire,
        dpvs:Acquire ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:ActiveRight a owl:Class ;
    rdfs:label "ActiveRight" ;
    rdfs:subClassOf dpvs:Right ;
    skos:altLabel "Active Right" ;
    skos:definition """The right(s) applicable, provided, or expected that need to be
(actively) exercised""" ;
    skos:exactMatch dpv:ActiveRight,
        dpv_owl:ActiveRight,
        dpvs:ActiveRight ;
    skos:inScheme dpvs:core ;
    skos:note """Active rights require the entity to expressly exercise them. For
example, a Data Subject exercising their right to withdraw their
consent.""" ;
    dpvs:skos_in_scheme "rights-classes" .

dpvs:ActivelyInvolved a owl:Class ;
    rdfs:label "ActivelyInvolved" ;
    rdfs:subClassOf dpvs:InvolvementStatus ;
    skos:altLabel "Actively Involved" ;
    skos:definition "Status indicating the specified context is 'actively' involved" ;
    skos:exactMatch dpv:ActivelyInvolved,
        dpv_owl:ActivelyInvolved,
        dpvs:ActivelyInvolved ;
    skos:inScheme dpvs:core ;
    skos:note """An example of active involvement is a person directly using a system to
enter information""" ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:ActivityCompleted a owl:Class ;
    rdfs:label "ActivityCompleted" ;
    rdfs:subClassOf dpvs:ActivityStatus ;
    skos:altLabel "Activity Completed" ;
    skos:definition "State of an activity that has completed i.e. is fully in the past" ;
    skos:exactMatch dpv:ActivityCompleted,
        dpv_owl:ActivityCompleted,
        dpvs:ActivityCompleted ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:ActivityHalted a owl:Class ;
    rdfs:label "ActivityHalted" ;
    rdfs:subClassOf dpvs:ActivityStatus ;
    skos:altLabel "Activity Halted" ;
    skos:definition """State of an activity that was occurring in the past, and has been halted
or paused or stopped""" ;
    skos:exactMatch dpv:ActivityHalted,
        dpv_owl:ActivityHalted,
        dpvs:ActivityHalted ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:ActivityMonitoring a owl:Class ;
    rdfs:label "ActivityMonitoring" ;
    rdfs:subClassOf dpvs:TechnicalMeasure ;
    skos:altLabel "Activity Monitoring" ;
    skos:definition """Monitoring of activities including assessing whether they have been
successfully initiated and completed""" ;
    skos:exactMatch dpv:ActivityMonitoring,
        dpv_owl:ActivityMonitoring,
        dpvs:ActivityMonitoring ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:ActivityNotCompleted a owl:Class ;
    rdfs:label "ActivityNotCompleted" ;
    rdfs:subClassOf dpvs:ActivityStatus ;
    skos:altLabel "Activity Not Completed" ;
    skos:definition """State of an activity that could not be completed, but has reached some
end state""" ;
    skos:exactMatch dpv:ActivityNotCompleted,
        dpv_owl:ActivityNotCompleted,
        dpvs:ActivityNotCompleted ;
    skos:inScheme dpvs:core ;
    skos:note """This relates to a 'Stop' state as distinct from a 'Halt' state. It makes
no comments on whether the Activity can be resumed or continued towards
completion.""" ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:ActivityOngoing a owl:Class ;
    rdfs:label "ActivityOngoing" ;
    rdfs:subClassOf dpvs:ActivityStatus ;
    skos:altLabel "Activity Ongoing" ;
    skos:definition "State of an activity occurring in continuation i.e. currently ongoing" ;
    skos:exactMatch dpv:ActivityOngoing,
        dpv_owl:ActivityOngoing,
        dpvs:ActivityOngoing ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:ActivityPlanned a owl:Class ;
    rdfs:label "ActivityPlanned" ;
    rdfs:subClassOf dpvs:ActivityStatus ;
    skos:altLabel "Activity Planned" ;
    skos:definition """State of an activity being planned with concrete plans for
implementation""" ;
    skos:exactMatch dpv:ActivityPlanned,
        dpv_owl:ActivityPlanned,
        dpvs:ActivityPlanned ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:ActivityProposed a owl:Class ;
    rdfs:label "ActivityProposed" ;
    rdfs:subClassOf dpvs:ActivityStatus ;
    skos:altLabel "Activity Proposed" ;
    skos:definition """State of an activity being proposed without any concrete plans for
implementation""" ;
    skos:exactMatch dpv:ActivityProposed,
        dpv_owl:ActivityProposed,
        dpvs:ActivityProposed ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "status-classes" .

dpvs:Adapt a owl:Class ;
    rdfs:label "Adapt" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Transform ;
    skos:altLabel "Adapt" ;
    skos:definition "to modify the data, often rewritten into a new form for a new use" ;
    skos:exactMatch dpv:Adapt,
        dpv_owl:Adapt,
        dpvs:Adapt ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:Adult a owl:Class ;
    rdfs:label "Adult" ;
    rdfs:subClassOf dpvs:HumanSubject ;
    skos:altLabel "Adult" ;
    skos:definition """A natural person that is not a child i.e. has attained some legally
specified age of adulthood""" ;
    skos:exactMatch dpv:Adult,
        dpv_owl:Adult,
        dpvs:Adult ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

dpvs:AgeVerification a owl:Class ;
    rdfs:label "AgeVerification" ;
    rdfs:subClassOf dpvs:Purpose,
        dpvs:Verification ;
    skos:altLabel "Age Verification" ;
    skos:definition """Purposes associated with verifying or authenticating age or age related
information as a form of security""" ;
    skos:exactMatch dpv:AgeVerification,
        dpv_owl:AgeVerification,
        dpvs:AgeVerification ;
    skos:inScheme dpvs:core ;
    skos:note """Age Verification can include verification of the exact age, e.g. being
21 years old, a date, e.g. birth date is 01 January 1969, or a
condition, e.g. age is over 21 years and the person is an adult.
Specific dedicated resources should be used to further express
information and processes associated with Age Verification, for example
the Age Verification Vocabulary https://w3id.org/age/""" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:Aggregate a owl:Class ;
    rdfs:label "Aggregate" ;
    rdfs:subClassOf dpvs:Alter,
        dpvs:Processing ;
    skos:altLabel "Aggregate" ;
    skos:definition "to aggregate data" ;
    skos:exactMatch dpv:Aggregate,
        dpv_owl:Aggregate,
        dpvs:Aggregate ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch svpr:Aggregate ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:AlgorithmicLogic a owl:Class ;
    rdfs:label "AlgorithmicLogic" ;
    rdfs:subClassOf dpvs:ProcessingContext ;
    skos:altLabel "Algorithmic Logic" ;
    skos:definition "The algorithmic logic applied or used" ;
    skos:exactMatch dpv:AlgorithmicLogic,
        dpv_owl:AlgorithmicLogic,
        dpvs:AlgorithmicLogic ;
    skos:inScheme dpvs:core ;
    skos:note """Algorithmic Logic is intended as a broad concept for explaining the use
of algorithms and automated decisions making within Processing. To
describe the actual algorithm, see the Algorithm concept.""" ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:Align a owl:Class ;
    rdfs:label "Align" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Transform ;
    skos:altLabel "Align" ;
    skos:definition "to adjust the data to be in relation to another data" ;
    skos:exactMatch dpv:Align,
        dpv_owl:Align,
        dpvs:Align ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:AmbulanceProvider a owl:Class ;
    rdfs:label "AmbulanceProvider" ;
    rdfs:subClassOf dpvs:EmergencyServiceProvider ;
    skos:altLabel "Ambulance Provider" ;
    skos:definition """An organisation that that offers transportation and medical care to
patients requiring urgent medical attention""" ;
    skos:exactMatch dpv:AmbulanceProvider,
        dpv_owl:AmbulanceProvider,
        dpvs:AmbulanceProvider ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-organisation-classes" .

dpvs:Analyse a owl:Class ;
    rdfs:label "Analyse" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Use ;
    skos:altLabel "Analyse" ;
    skos:definition "to study or examine the data in detail" ;
    skos:exactMatch dpv:Analyse,
        dpv_owl:Analyse,
        dpvs:Analyse ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch svpr:Analyse ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:Anonymisation a owl:Class ;
    rdfs:label "Anonymisation" ;
    rdfs:subClassOf dpvs:Deidentification,
        dpvs:TechnicalMeasure ;
    skos:altLabel "Anonymisation" ;
    skos:definition """Anonymisation is the process by which data is irreversibly altered in
such a way that a data subject can no longer be identified directly or
indirectly, either by the entity holding the data alone or in
collaboration with other entities and information sources""" ;
    skos:exactMatch dpv:Anonymisation,
        dpv_owl:Anonymisation,
        dpvs:Anonymisation ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "technical-measures-classes" .

dpvs:Anonymise a owl:Class ;
    rdfs:label "Anonymise" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Transform ;
    skos:altLabel "Anonymise" ;
    skos:definition """to irreversibly alter personal data in such a way that an unique data
subject can no longer be identified directly or indirectly or in
combination with other data""" ;
    skos:exactMatch dpv:Anonymise,
        dpv_owl:Anonymise,
        dpvs:Anonymise ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch svpr:Anonymise ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:AnonymisedData a owl:Class ;
    rdfs:label "AnonymisedData" ;
    rdfs:subClassOf dpvs:NonPersonalData ;
    skos:altLabel "Anonymised Data" ;
    skos:definition """Personal Data that has been (fully and completely) anonymised so that it
is no longer considered Personal Data""" ;
    skos:exactMatch dpv:AnonymisedData,
        dpv_owl:AnonymisedData,
        dpvs:AnonymisedData ;
    skos:inScheme dpvs:core ;
    skos:note """It is advised to carefully consider indicating data is fully or
completely anonymised by determining whether the data by itself or in
combination with other data can identify a person. Failing this
condition, the data should be denoted as PseudonymisedData. To indicate
data is anonymised only for a specified entity (e.g. within an
organisation), the concept ContextuallyAnonymisedData (as subclass of
PseudonymisedData) should be used instead of AnonymisedData.""" ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:Applicant a owl:Class ;
    rdfs:label "Applicant" ;
    rdfs:subClassOf dpvs:HumanSubject ;
    skos:altLabel "Applicant" ;
    skos:definition "Humans that are applicants in some context" ;
    skos:exactMatch dpv:Applicant,
        dpv_owl:Applicant,
        dpvs:Applicant ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

dpvs:ApprovalProcedure a owl:Class ;
    rdfs:label "ApprovalProcedure" ;
    rdfs:subClassOf dpvs:GovernanceProcedures,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Approval Procedure" ;
    skos:definition """A procedure or process for determining and managing approvals for
activities as part of governance""" ;
    skos:exactMatch dpv:ApprovalProcedure,
        dpv_owl:ApprovalProcedure,
        dpvs:ApprovalProcedure ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:Assess a owl:Class ;
    rdfs:label "Assess" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Use ;
    skos:altLabel "Assess" ;
    skos:definition "to assess data for some criteria" ;
    skos:exactMatch dpv:Assess,
        dpv_owl:Assess,
        dpvs:Assess ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:AssetManagementProcedures a owl:Class ;
    rdfs:label "AssetManagementProcedures" ;
    rdfs:subClassOf dpvs:GovernanceProcedures,
        dpvs:OrganisationalMeasure ;
    skos:altLabel "Asset Management Procedures" ;
    skos:definition "Procedures related to management of assets" ;
    skos:exactMatch dpv:AssetManagementProcedures,
        dpv_owl:AssetManagementProcedures,
        dpvs:AssetManagementProcedures ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "organisational-measures-classes" .

dpvs:AssistiveAutomation a owl:Class ;
    rdfs:label "AssistiveAutomation" ;
    rdfs:subClassOf dpvs:AutomationLevel ;
    skos:altLabel "Assistive Automation" ;
    skos:definition """Level of automation corresponding to Level 1 in ISO/IEC 22989:2022 where
automation is limited to parts of the system or a specific part of the
system in a manner that does not change the control of the human in
using/driving the system""" ;
    skos:exactMatch dpv:AssistiveAutomation,
        dpv_owl:AssistiveAutomation,
        dpvs:AssistiveAutomation ;
    skos:inScheme dpvs:core ;
    skos:note """Human Involvement is implied here, specifically the ability to make
decisions regarding operations, but also possibly for intervention,
oversight, and verification""" ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:AsylumSeeker a owl:Class ;
    rdfs:label "AsylumSeeker" ;
    rdfs:subClassOf dpvs:HumanSubject,
        dpvs:VulnerableHuman ;
    skos:altLabel "Asylum Seeker" ;
    skos:definition "Humans that are asylum seekers" ;
    skos:exactMatch dpv:AsylumSeeker,
        dpv_owl:AsylumSeeker,
        dpvs:AsylumSeeker ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "entities-datasubject-classes" .

