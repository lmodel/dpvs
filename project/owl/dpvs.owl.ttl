dpvs:PublicSpace a owl:Class ;
    rdfs:label "PublicSpace" ;
    rdfs:subClassOf dpvs:DpvLocation ;
    skos:altLabel "Public Space" ;
    skos:definition "Any space that is accessible to the public or is owned by the public" ;
    skos:exactMatch dpv:PublicSpace,
        dpv_owl:PublicSpace,
        dpvs:PublicSpace ;
    skos:inScheme dpvs:core ;
    skos:note """Public space is distinct from places under (public) government ownership
as such places can exclude public from accessing the place e.g.
government military installations or reserved land""" ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:RecruitmentInterviewManagement a owl:Class ;
    rdfs:label "RecruitmentInterviewManagement" ;
