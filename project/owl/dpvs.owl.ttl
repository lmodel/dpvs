    skos:altLabel "Protection of National Security" ;
    skos:definition "Purposes associated with the protection of national security" ;
    skos:exactMatch dpv:ProtectionOfNationalSecurity,
        dpv_owl:ProtectionOfNationalSecurity,
        dpvs:ProtectionOfNationalSecurity ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "DGA 1.5" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:ProtectionOfPublicSecurity a owl:Class ;
    rdfs:label "ProtectionOfPublicSecurity" ;
    rdfs:subClassOf dpvs:PublicBenefit,
        dpvs:Purpose ;
    skos:altLabel "Protection of Public Security" ;
    skos:definition "Purposes associated with the protection of public security" ;
    skos:exactMatch dpv:ProtectionOfPublicSecurity,
