    dpvs:skos_in_scheme "personal-data-properties" .

dpvs:has_unstructured_data a owl:DatatypeProperty ;
    rdfs:label "has_unstructured_data" ;
    rdfs:subPropertyOf dpvs:has_data ;
    skos:altLabel "has unstructured data" ;
