    rdfs:label "ProvideEventRecommendations" ;
    rdfs:subClassOf dpvs:ProvidePersonalisedRecommendations,
        dpvs:Purpose ;
    skos:altLabel "Provide Event Recommendations" ;
    skos:definition """Purposes associated with creating and providing personalised
recommendations for events""" ;
    skos:exactMatch dpv:ProvideEventRecommendations,
        dpv_owl:ProvideEventRecommendations,
        dpvs:ProvideEventRecommendations ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:ProvideOfficialStatistics a owl:Class ;
    rdfs:label "ProvideOfficialStatistics" ;
    rdfs:subClassOf dpvs:PublicBenefit,
        dpvs:Purpose ;
    skos:altLabel "Provide Official Statistics" ;
    skos:definition """Purposes associated with facilitating the development, production and
dissemination of reliable official statistics""" ;
    skos:exactMatch dpv:ProvideOfficialStatistics,
        dpv_owl:ProvideOfficialStatistics,
        dpvs:ProvideOfficialStatistics ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "DGA 2.16" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:ProvideProductRecommendations a owl:Class ;
    rdfs:label "ProvideProductRecommendations" ;
    rdfs:subClassOf dpvs:ProvidePersonalisedRecommendations,
        dpvs:Purpose ;
    skos:altLabel "Provide Product Recommendations" ;
    skos:definition """Purposes associated with creating and providing product recommendations
e.g. suggest similar products""" ;
    skos:exactMatch dpv:ProvideProductRecommendations,
        dpv_owl:ProvideProductRecommendations,
        dpvs:ProvideProductRecommendations ;
    skos:inScheme dpvs:core ;
    skos:relatedMatch svpu:Marketing ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:ProvidedPersonalData a owl:Class ;
    rdfs:label "ProvidedPersonalData" ;
    rdfs:subClassOf dpvs:CollectedPersonalData,
        dpvs:ProvidedData ;
    skos:altLabel "Provided Personal Data" ;
    skos:definition """Personal Data that has been provided by an entity such as the Data
Subject""" ;
    skos:exactMatch dpv:ProvidedPersonalData,
        dpv_owl:ProvidedPersonalData,
        dpvs:ProvidedPersonalData ;
    skos:inScheme dpvs:core ;
    skos:note """Provided personal data involves one entity (e.g. data subject)
explicitly providing the data, which the other entity (e.g. data
controller) then collects""" ;
    dpvs:skos_in_scheme "personal-data-classes" .

dpvs:ProviderStandardFormContract a owl:Class ;
    rdfs:label "ProviderStandardFormContract" ;
    rdfs:subClassOf dpvs:LegalBasis,
        dpvs:StandardFormContract ;
    skos:altLabel "Provider Standard Form Contract" ;
    skos:definition """A contract where the terms and conditions are determined by parties in
the role of a 'provider', and the other parties have negligible or no
ability to negotiate the terms and conditions""" ;
    skos:exactMatch dpv:ProviderStandardFormContract,
        dpv_owl:ProviderStandardFormContract,
        dpvs:ProviderStandardFormContract ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "contract-types-classes" .

dpvs:Pseudonymise a owl:Class ;
    rdfs:label "Pseudonymise" ;
    rdfs:subClassOf dpvs:Processing,
        dpvs:Transform ;
    skos:altLabel "Pseudonymise" ;
    skos:definition "to replace personal identifiable information by artificial identifiers" ;
    skos:exactMatch dpv:Pseudonymise,
        dpv_owl:Pseudonymise,
        dpvs:Pseudonymise ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "processing-classes" .

dpvs:PublicDataSource a owl:Class ;
    rdfs:label "PublicDataSource" ;
    rdfs:subClassOf dpvs:DataSource ;
    skos:altLabel "Public Data Source" ;
    skos:definition "A source of data that is publicly accessible or available" ;
    skos:exactMatch dpv:PublicDataSource,
        dpv_owl:PublicDataSource,
        dpvs:PublicDataSource ;
    skos:inScheme dpvs:core ;
    skos:note """The term 'Public' is used here in a broad sense. Actual consideration of
what is 'Public Data' can vary based on several contextual or
jurisdictional factors such as definition of open, methods of access,
permissions and licenses.""" ;
    dpvs:skos_in_scheme "processing-context-classes" .

dpvs:PublicInterest a owl:Class ;
    rdfs:label "PublicInterest" ;
    rdfs:subClassOf dpvs:LegalBasis ;
    skos:altLabel "Public Interest" ;
    skos:definition """Activities are necessary or beneficial for interest of the public or
society at large""" ;
    skos:exactMatch dpv:PublicInterest,
        dpv_owl:PublicInterest,
        dpvs:PublicInterest ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-classes" .

dpvs:PublicInterestCompleted a owl:Class ;
    rdfs:label "PublicInterestCompleted" ;
    rdfs:subClassOf dpvs:PublicInterestStatus ;
    skos:altLabel "Public Interest Completed" ;
    skos:definition "Status where the public interest activity has been completed" ;
    skos:exactMatch dpv:PublicInterestCompleted,
        dpv_owl:PublicInterestCompleted,
        dpvs:PublicInterestCompleted ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-status-classes" .

dpvs:PublicInterestObjected a owl:Class ;
    rdfs:label "PublicInterestObjected" ;
    rdfs:subClassOf dpvs:PublicInterestStatus ;
    skos:altLabel "Public Interest Objected" ;
    skos:definition """Status where the public interest activity was objected to by the Data
Subject or another relevant entity""" ;
    skos:exactMatch dpv:PublicInterestObjected,
        dpv_owl:PublicInterestObjected,
        dpvs:PublicInterestObjected ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-status-classes" .

dpvs:PublicInterestOngoing a owl:Class ;
    rdfs:label "PublicInterestOngoing" ;
    rdfs:subClassOf dpvs:PublicInterestStatus ;
    skos:altLabel "Public Interest Ongoing" ;
    skos:definition "Status where the public interest activity is ongoing" ;
    skos:exactMatch dpv:PublicInterestOngoing,
        dpv_owl:PublicInterestOngoing,
        dpvs:PublicInterestOngoing ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-status-classes" .

dpvs:PublicInterestPending a owl:Class ;
    rdfs:label "PublicInterestPending" ;
    rdfs:subClassOf dpvs:PublicInterestStatus ;
    skos:altLabel "Public Interest Pending" ;
    skos:definition "Status where the public interest activity has not started" ;
    skos:exactMatch dpv:PublicInterestPending,
        dpv_owl:PublicInterestPending,
        dpvs:PublicInterestPending ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "legal-basis-status-classes" .

dpvs:PublicLocation a owl:Class ;
    rdfs:label "PublicLocation" ;
    rdfs:subClassOf dpvs:DpvLocation,
        dpvs:LocalLocation ;
    skos:altLabel "Public Location (deprecated)" ;
    skos:definition "Location that is or can be accessed by the public" ;
    skos:exactMatch dpv:PublicLocation,
        dpv_owl:PublicLocation,
        dpvs:PublicLocation ;
    skos:inScheme dpvs:core ;
    skos:note """This concept will be deprecated in a future DPV release, it is suggested
to use the better defined and legally aligned dpv:PublicSpace instead""" ;
    dpvs:skos_in_scheme "jurisdiction-classes" .

dpvs:PublicPolicyMaking a owl:Class ;
    rdfs:label "PublicPolicyMaking" ;
    rdfs:subClassOf dpvs:PublicBenefit,
        dpvs:Purpose ;
    skos:altLabel "Public Policy Making" ;
    skos:definition """Purposes associated with public policy making, such as the development
of new laws""" ;
    skos:exactMatch dpv:PublicPolicyMaking,
        dpv_owl:PublicPolicyMaking,
        dpvs:PublicPolicyMaking ;
    skos:inScheme dpvs:core ;
    dpvs:dct_source "DGA 2.16" ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PublicRelations a owl:Class ;
    rdfs:label "PublicRelations" ;
    rdfs:subClassOf dpvs:Marketing,
        dpvs:Purpose ;
    skos:altLabel "Public Relations" ;
    skos:definition """Purposes associated with managing and conducting public relations
processes, including creating goodwill for the organisation""" ;
    skos:exactMatch dpv:PublicRelations,
        dpv_owl:PublicRelations,
        dpvs:PublicRelations ;
    skos:inScheme dpvs:core ;
    dpvs:skos_in_scheme "purposes-classes" .

dpvs:PublicSectorBody a owl:Class ;
    rdfs:label "PublicSectorBody" ;
